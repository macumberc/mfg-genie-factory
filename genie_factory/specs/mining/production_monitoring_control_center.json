{
  "company_name": "MineOps Central",
  "industry": "Mining",
  "use_case": "Mining production monitoring and processing control center",
  "space_title": "MineOps Central - Production Monitoring Control Center 📊",
  "space_description": "Mining production analytics for MineOps Central. Ask about throughput rates, recovery yields, equipment utilization, and bottleneck analysis across 20 processing units.",
  "schema_basename": "mining_production_monitor",
  "tables": [
    {
      "table_name": "processing_units",
      "description": "Daily processing unit records with throughput, recovery rates, and energy consumption.",
      "columns": [
        {
          "name": "record_id",
          "sql_type": "STRING",
          "comment": "Record ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('PD-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.unit_id) + 10000 AS STRING), 6, '0'))"
        },
        {
          "name": "record_date",
          "sql_type": "DATE",
          "comment": "Record date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "unit_id",
          "sql_type": "STRING",
          "comment": "Unit ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "unit_name",
          "sql_type": "STRING",
          "comment": "Unit name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "unit_type",
          "sql_type": "STRING",
          "comment": "Unit type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "processing_stage",
          "sql_type": "STRING",
          "comment": "Processing stage",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "throughput_tph",
          "sql_type": "DOUBLE",
          "comment": "Throughput tons per hour",
          "is_dimension": false,
          "generation_expr": "ROUND(100.0 + ({qty_noise} * 900.0), 1)"
        },
        {
          "name": "recovery_pct",
          "sql_type": "DOUBLE",
          "comment": "Material recovery 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(70.0 + ({qty_noise} * 25.0), 2)"
        },
        {
          "name": "energy_kwh_per_ton",
          "sql_type": "DOUBLE",
          "comment": "Energy consumption kWh/ton",
          "is_dimension": false,
          "generation_expr": "ROUND(5.0 + ({qty_noise} * 25.0), 2)"
        },
        {
          "name": "unit_status",
          "sql_type": "STRING",
          "comment": "Status: Running, Idle, Maintenance, Fault",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.05 THEN 'Fault' WHEN {status_noise} < 0.12 THEN 'Maintenance' WHEN {status_noise} < 0.20 THEN 'Idle' ELSE 'Running' END"
        }
      ],
