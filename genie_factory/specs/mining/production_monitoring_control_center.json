  "genie_instructions": "You are a mining analytics assistant for MineOps Central. Answer questions about mining production monitoring and processing control center using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (unit_id, unit_name), query the base tables directly.\n- When joining tables, use the shared keys: unit_id (shared across processing_units, production_readings, throughput_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in running count?",
    "How has unique total units changed over time?",
    "What is the monthly trend in highest throughput tph?",
    "How has avg throughput tph changed over time?",
    "What is the monthly trend in bottleneck count?",
    "How has unique units changed over time?",
    "What is the monthly trend in highest planned throughput tpd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest throughput tph?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', record_date) AS record_date_month, MEASURE(max_throughput_tph) AS max_throughput_tph",
        "FROM {fqn}.production_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date_month"
      ],
      "usage_guidance": "Monthly trend of peak throughput tph; matches phrases like 'highest throughput over time' or 'maximum tph by month' using max_throughput_tph from production_kpi_monthly."
    },
    {
      "question": "How has avg throughput tph changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(avg_throughput_tph) AS avg_throughput_tph",
        "FROM {fqn}.production_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Monthly trend of average throughput tph; matches phrases like 'how has average tph changed' or 'avg throughput over time' using avg_throughput_tph from production_kpi_monthly."
    },
    {
      "question": "What is the monthly trend in highest planned throughput tpd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(max_planned_throughput_tpd) AS max_planned_throughput_tpd",
        "FROM {fqn}.throughput_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ],
      "usage_guidance": "Monthly trend of peak planned throughput tpd; matches phrases like 'highest planned tonnage per day over time' using max_planned_throughput_tpd from throughput_kpi_monthly."
    },
    {
      "question": "How has bottleneck count changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(bottleneck_count) AS bottleneck_count",
        "FROM {fqn}.throughput_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly trend of bottleneck occurrences; matches phrases like 'how often are bottlenecks occurring' or 'bottleneck count over time' using bottleneck_count from throughput_kpi_monthly."
    },
    {
      "question": "How does total throughput tons per hour break down by unit id for 'Fault' records?",
      "sql_lines": [
        "SELECT unit_id, COUNT(*) AS record_count, SUM(throughput_tph) AS total_throughput_tph",
        "FROM {fqn}.processing_units",
        "WHERE unit_status = 'Fault' GROUP BY unit_id ORDER BY total_throughput_tph DESC"
      ],
      "usage_guidance": "Filtered aggregate of total throughput tph broken down by unit_id where unit_status is 'Fault'; matches phrases like 'faulty units throughput' or 'which units have faults'."
    },
    {
      "question": "What is the trend of total average particle size mm over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(particle_size_mm) AS total_particle_size_mm",
        "FROM {fqn}.production_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of total particle size mm across production readings; matches phrases like 'particle size trend over time' or 'how has particle size changed' from production_readings."
    },
    {
      "question": "How has the average equipment utilization 0-100 changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(utilization_pct) AS avg_utilization_pct",
        "FROM {fqn}.throughput_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of average equipment utilization percentage; matches phrases like 'how has utilization changed' or 'equipment utilization over time' using utilization_pct from throughput_snapshots."
    }
  ],
