  "metric_views": [
    {
      "view_name": "production_kpi_monthly",
      "source_table": "processing_units",
      "dimensions": [
        {
          "name": "record_date",
          "expr": "record_date"
        },
        {
          "name": "unit_type",
          "expr": "unit_type"
        },
        {
          "name": "processing_stage",
          "expr": "processing_stage"
        },
        {
          "name": "unit_status",
          "expr": "unit_status"
        }
      ],
      "measures": [
        {
          "name": "avg_throughput_tph",
          "expr": "AVG(throughput_tph)",
          "comment": "Avg throughput tph"
        },
        {
          "name": "avg_recovery_pct",
          "expr": "AVG(recovery_pct)",
          "comment": "Avg recovery rate"
        },
        {
          "name": "avg_energy_per_ton",
          "expr": "AVG(energy_kwh_per_ton)",
          "comment": "Avg energy kWh/ton"
        },
        {
          "name": "running_count",
          "expr": "COUNT(DISTINCT CASE WHEN unit_status = 'Running' THEN unit_id END)",
          "comment": "Running units"
        },
        {
          "name": "total_unit_count",
          "expr": "COUNT(DISTINCT unit_id)",
          "comment": "Total units"
        },
        {
          "name": "max_throughput_tph",
          "expr": "MAX(throughput_tph)",
          "comment": "Maximum throughput tph"
        }
      ]
    },
    {
      "view_name": "throughput_kpi_monthly",
      "source_table": "throughput_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "unit_type",
          "expr": "unit_type"
        },
        {
          "name": "processing_stage",
          "expr": "processing_stage"
        },
        {
          "name": "bottleneck_flag",
          "expr": "bottleneck_flag"
        }
      ],
      "measures": [
        {
          "name": "total_planned_tpd",
          "expr": "SUM(planned_throughput_tpd)",
          "comment": "Total planned TPD"
        },
        {
          "name": "total_actual_tpd",
          "expr": "SUM(actual_throughput_tpd)",
          "comment": "Total actual TPD"
        },
        {
          "name": "avg_utilization",
          "expr": "AVG(utilization_pct)",
          "comment": "Avg utilization pct"
        },
        {
          "name": "total_downtime",
          "expr": "SUM(downtime_hours)",
          "comment": "Total downtime hours"
        },
        {
          "name": "bottleneck_count",
          "expr": "COUNT(DISTINCT CASE WHEN bottleneck_flag = 'Yes' THEN snapshot_id END)",
          "comment": "Bottleneck count"
        },
        {
          "name": "unique_unit_count",
          "expr": "COUNT(DISTINCT unit_id)",
          "comment": "Number of distinct units"
