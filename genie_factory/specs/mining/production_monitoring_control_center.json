    {
      "table_name": "throughput_snapshots",
      "description": "Weekly production targets and bottleneck analysis with planned vs actual throughput.",
      "columns": [
        {
          "name": "snapshot_id",
          "sql_type": "STRING",
          "comment": "Snapshot ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('TS-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.unit_id) AS STRING), 7, '0'))"
        },
        {
          "name": "snapshot_date",
          "sql_type": "DATE",
          "comment": "Snapshot date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "unit_id",
          "sql_type": "STRING",
          "comment": "Unit ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "unit_type",
          "sql_type": "STRING",
          "comment": "Unit type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "processing_stage",
          "sql_type": "STRING",
          "comment": "Stage",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "planned_throughput_tpd",
          "sql_type": "DOUBLE",
          "comment": "Planned throughput tons/day",
          "is_dimension": false,
          "generation_expr": "ROUND(2000.0 + ({qty_noise} * 18000.0), 0)"
        },
        {
          "name": "actual_throughput_tpd",
          "sql_type": "DOUBLE",
          "comment": "Actual throughput tons/day",
          "is_dimension": false,
          "generation_expr": "ROUND((2000.0 + ({qty_noise} * 18000.0)) * (0.75 + {status_noise} * 0.35), 0)"
        },
        {
          "name": "utilization_pct",
          "sql_type": "DOUBLE",
          "comment": "Equipment utilization 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(55.0 + ({qty_noise} * 40.0), 2)"
        },
        {
          "name": "downtime_hours",
          "sql_type": "DOUBLE",
          "comment": "Unplanned downtime hours",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 24.0, 1)"
        },
        {
          "name": "bottleneck_flag",
          "sql_type": "STRING",
          "comment": "Bottleneck: Yes, No",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'Yes' ELSE 'No' END"
        }
      ],
