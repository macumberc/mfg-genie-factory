    {
      "table_name": "failure_events",
      "description": "Monthly failure event records and RUL forecasts per vehicle.",
      "columns": [
        {
          "name": "event_id",
          "sql_type": "STRING",
          "comment": "Event ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('FE-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.vehicle_id) AS STRING), 7, '0'))"
        },
        {
          "name": "event_month",
          "sql_type": "DATE",
          "comment": "Event month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "vehicle_id",
          "sql_type": "STRING",
          "comment": "Vehicle ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "vehicle_model",
          "sql_type": "STRING",
          "comment": "Model",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "pit",
          "sql_type": "STRING",
          "comment": "Pit",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "failure_type",
          "sql_type": "STRING",
          "comment": "Type: Engine, Transmission, Tires, Hydraulic, Electrical, Structural",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.22 THEN 'Engine' WHEN {status_noise} < 0.40 THEN 'Tires' WHEN {status_noise} < 0.55 THEN 'Transmission' WHEN {status_noise} < 0.70 THEN 'Hydraulic' WHEN {status_noise} < 0.85 THEN 'Electrical' ELSE 'Structural' END"
        },
        {
          "name": "downtime_hours",
          "sql_type": "DOUBLE",
          "comment": "Downtime hours",
          "is_dimension": false,
          "generation_expr": "ROUND(4.0 + ({qty_noise} * 196.0), 1)"
        },
        {
          "name": "repair_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Repair cost USD",
          "is_dimension": false,
          "generation_expr": "ROUND(2000.0 + ({qty_noise} * 148000.0), 2)"
        },
        {
          "name": "rul_days",
          "sql_type": "INT",
          "comment": "Remaining useful life days",
          "is_dimension": false,
          "generation_expr": "CAST(20 + FLOOR({qty_noise} * 340) AS INT)"
        },
        {
          "name": "failure_probability_pct",
          "sql_type": "DOUBLE",
          "comment": "30-day failure probability",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 45.0, 2)"
        }
      ],
