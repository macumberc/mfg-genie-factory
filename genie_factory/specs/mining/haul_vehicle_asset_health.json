      "table_name": "sensor_readings",
      "description": "Vehicle sensor readings with engine temp, tire pressure, hydraulics, and health scores.",
      "columns": [
        {
          "name": "reading_id",
          "sql_type": "STRING",
          "comment": "Reading ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('VS-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.vehicle_id) AS STRING), 7, '0'))"
        },
        {
          "name": "reading_date",
          "sql_type": "DATE",
          "comment": "Reading date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "vehicle_id",
          "sql_type": "STRING",
          "comment": "Vehicle ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "vehicle_model",
          "sql_type": "STRING",
          "comment": "Model",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "pit",
          "sql_type": "STRING",
          "comment": "Pit",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "engine_temp_celsius",
          "sql_type": "DOUBLE",
          "comment": "Engine temperature C",
          "is_dimension": false,
          "generation_expr": "ROUND(70.0 + ({qty_noise} * 40.0), 1)"
        },
        {
          "name": "tire_pressure_psi",
          "sql_type": "DOUBLE",
          "comment": "Tire pressure PSI",
          "is_dimension": false,
          "generation_expr": "ROUND(80.0 + ({qty_noise} * 40.0), 1)"
        },
        {
          "name": "hydraulic_pressure_bar",
          "sql_type": "DOUBLE",
          "comment": "Hydraulic pressure bar",
          "is_dimension": false,
          "generation_expr": "ROUND(200.0 + ({qty_noise} * 100.0), 1)"
        },
        {
          "name": "health_score",
          "sql_type": "DOUBLE",
          "comment": "ML health score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(40.0 + ({qty_noise} * 60.0), 1)"
        },
        {
          "name": "alert_level",
          "sql_type": "STRING",
          "comment": "Alert: Normal, Caution, Warning, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.03 THEN 'Critical' WHEN {status_noise} < 0.10 THEN 'Warning' WHEN {status_noise} < 0.22 THEN 'Caution' ELSE 'Normal' END"
        }
      ],
