  "metric_views": [
    {
      "view_name": "health_monthly",
      "source_table": "sensor_readings",
      "dimensions": [
        {
          "name": "reading_date",
          "expr": "reading_date"
        },
        {
          "name": "vehicle_model",
          "expr": "vehicle_model"
        },
        {
          "name": "pit",
          "expr": "pit"
        },
        {
          "name": "alert_level",
          "expr": "alert_level"
        }
      ],
      "measures": [
        {
          "name": "avg_health_score",
          "expr": "AVG(health_score)",
          "comment": "Average health score"
        },
        {
          "name": "avg_engine_temp",
          "expr": "AVG(engine_temp_celsius)",
          "comment": "Avg engine temp"
        },
        {
          "name": "vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Monitored vehicles"
        },
        {
          "name": "critical_count",
          "expr": "COUNT(DISTINCT CASE WHEN alert_level = 'Critical' THEN vehicle_id END)",
          "comment": "Critical alert count"
        },
        {
          "name": "reading_count",
          "expr": "COUNT(DISTINCT reading_id)",
          "comment": "Total readings"
        },
        {
          "name": "total_tire_pressure_psi",
          "expr": "SUM(tire_pressure_psi)",
          "comment": "Total tire pressure psi"
        },
        {
          "name": "total_hydraulic_pressure_bar",
          "expr": "SUM(hydraulic_pressure_bar)",
          "comment": "Total hydraulic pressure bar"
        },
        {
          "name": "max_engine_temp_celsius",
          "expr": "MAX(engine_temp_celsius)",
          "comment": "Maximum engine temp celsius"
        }
      ]
    },
    {
      "view_name": "failure_monthly",
      "source_table": "failure_events",
      "dimensions": [
        {
          "name": "event_month",
          "expr": "event_month"
        },
        {
          "name": "vehicle_model",
          "expr": "vehicle_model"
        },
        {
          "name": "pit",
          "expr": "pit"
        },
        {
          "name": "failure_type",
          "expr": "failure_type"
        }
      ],
      "measures": [
        {
          "name": "total_downtime",
          "expr": "SUM(downtime_hours)",
          "comment": "Total downtime hours"
        },
        {
          "name": "total_repair_cost",
          "expr": "SUM(repair_cost_usd)",
          "comment": "Total repair cost"
        },
        {
          "name": "avg_rul",
          "expr": "AVG(rul_days)",
          "comment": "Average RUL days"
        },
        {
          "name": "failure_count",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Failure event count"
        },
        {
          "name": "high_risk_count",
          "expr": "COUNT(DISTINCT CASE WHEN failure_probability_pct > 25 THEN event_id END)",
          "comment": "High risk count"
        },
        {
          "name": "unique_vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Number of distinct vehicles"
        },
        {
          "name": "max_downtime_hours",
