        {
          "name": "peak_demand_mw",
          "sql_type": "DOUBLE",
          "comment": "Daily peak demand in MW",
          "is_dimension": false,
          "generation_expr": "ROUND(100.0 + ({qty_noise} * 900.0) + (CASE WHEN MONTH(d.dt) IN (7,8) THEN 150.0 WHEN MONTH(d.dt) IN (1,2) THEN 100.0 ELSE 0.0 END), 2)"
        },
        {
          "name": "avg_demand_mw",
          "sql_type": "DOUBLE",
          "comment": "Average demand in MW for the day",
          "is_dimension": false,
          "generation_expr": "ROUND(80.0 + ({qty_noise} * 620.0) + (CASE WHEN MONTH(d.dt) IN (7,8) THEN 80.0 ELSE 0.0 END), 2)"
        },
        {
          "name": "avg_temp_fahrenheit",
          "sql_type": "DOUBLE",
          "comment": "Average daily temperature in Fahrenheit",
          "is_dimension": false,
          "generation_expr": "ROUND(30.0 + ({qty_noise} * 70.0) + (CASE WHEN MONTH(d.dt) IN (6,7,8) THEN 20.0 WHEN MONTH(d.dt) IN (12,1,2) THEN -15.0 ELSE 0.0 END), 1)"
        },
        {
          "name": "day_type",
          "sql_type": "STRING",
          "comment": "Day type: Weekday, Weekend, Holiday",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.05 THEN 'Holiday' WHEN {status_noise} < 0.33 THEN 'Weekend' ELSE 'Weekday' END",
          "entity_values": [
            "Holiday",
            "Weekend",
            "Weekday"
          ]
