  "genie_instructions": "You are an electric utility analytics assistant for LoadCast Energy. Answer questions about electric load demand forecasting and capacity planning using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (territory_id, territory_name), query the base tables directly.\n- When joining tables, use the shared keys: territory_id (shared across demand_forecasts, demand_kpi_monthly, demand_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique readings?",
    "How has unique territorys changed over time?",
    "What is the monthly trend in highest peak demand mw?",
    "How has highest avg demand mw changed over time?",
    "What is the monthly trend in unique forecasts?",
    "How has unique territorys changed over time?",
    "What is the monthly trend in highest forecasted peak mw?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest peak demand mw?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', reading_date) AS reading_date_month, MEASURE(max_peak_demand_mw) AS max_peak_demand_mw",
        "FROM {fqn}.demand_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date_month"
      ],
      "usage_guidance": "Route trend-over-time questions about highest or maximum peak demand MW across all territories using the demand_readings_metrics metric view."
    },
    {
      "question": "How has highest avg demand mw changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_avg_demand_mw) AS max_avg_demand_mw",
        "FROM {fqn}.demand_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about highest or maximum average demand MW across all territories using the demand_readings_metrics metric view."
    },
    {
      "question": "How has unique forecasts changed over time?",
      "sql_lines": [
        "SELECT forecast_month, MEASURE(forecast_count) AS forecast_count",
        "FROM {fqn}.demand_forecast_metrics",
        "GROUP BY ALL",
        "ORDER BY forecast_month"
      ],
      "usage_guidance": "Route trend-over-time questions about forecast count or number of unique forecasts issued monthly using the demand_forecast_metrics metric view."
    },
    {
      "question": "What is the trend of total daily peak demand in mw over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(peak_demand_mw) AS total_peak_demand_mw",
        "FROM {fqn}.demand_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about total daily peak demand MW summed across territories from raw demand_readings transaction data."
    },
    {
      "question": "What is the trend of total forecasted peak demand in mw over time?",
      "sql_lines": [
        "SELECT forecast_month, SUM(forecasted_peak_mw) AS total_forecasted_peak_mw",
        "FROM {fqn}.demand_forecasts",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ],
      "usage_guidance": "Route trend-over-time questions about total monthly forecasted peak demand MW summed across territories from raw demand_forecasts transaction data."
    },
    {
      "question": "How has the average load factor as percentage (avg demand / peak demand * 100) changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(load_factor_pct) AS avg_load_factor_pct",
        "FROM {fqn}.demand_kpi_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ],
      "usage_guidance": "Route trend-over-time questions about load factor percentage (avg-to-peak demand ratio) averaged monthly from demand_kpi_monthly KPI data."
    },
    {
      "question": "How has total avg temp fahrenheit changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_avg_temp_fahrenheit) AS total_avg_temp_fahrenheit",
        "FROM {fqn}.demand_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about cumulative or total average temperature in Fahrenheit across territories using the demand_readings_metrics metric view."
    }
  ],
