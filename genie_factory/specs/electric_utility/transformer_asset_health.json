  "genie_instructions": "You are an electric utility analytics assistant for GridGuard Utilities. Answer questions about transformer asset health monitoring and failure prediction using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (transformer_id, transformer_name), query the base tables directly.\n- When joining tables, use the shared keys: transformer_id (shared across failure_events, health_monthly, sensor_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in critical alert count?",
    "How has unique readings changed over time?",
    "What is the monthly trend in unique transformers?",
    "How has highest dissolved gas ppm changed over time?",
    "What is the monthly trend in total failure events count?",
    "How has unique total events changed over time?",
    "What is the monthly trend in unique transformers?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique transformers?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', reading_date) AS reading_date_month, MEASURE(unique_transformer_count) AS unique_transformer_count",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date_month"
      ],
      "usage_guidance": "Monthly trend of unique transformer count across the fleet; matches questions about transformer population changes or fleet size over time using reading_date."
    },
    {
      "question": "How has highest dissolved gas ppm changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_dissolved_gas_ppm) AS max_dissolved_gas_ppm",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of peak dissolved gas PPM; matches questions about worst-case gas levels or DGA deterioration trends across all substations over time."
    },
    {
      "question": "How has total vibration mm s changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_vibration_mm_s) AS total_vibration_mm_s",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Cumulative vibration intensity trend over time; matches questions about overall mechanical stress, vibration buildup, or fleet-wide vibration patterns by reading_date."
    },
    {
      "question": "How does the number of unique readings vary by substation?",
      "sql_lines": [
        "SELECT substation, MEASURE(reading_count) AS reading_count",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_count DESC"
      ],
      "usage_guidance": "Bar/rank breakdown of sensor reading volume by substation; matches questions comparing data coverage, monitoring density, or activity levels across substations."
    },
    {
      "question": "What is the trend of total top oil temperature in celsius over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(oil_temp_celsius) AS total_oil_temp_celsius",
        "FROM {fqn}.sensor_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Summed oil temperature trend over time from raw sensor_readings; matches questions about thermal load buildup or total oil temperature exposure across the fleet by date."
    },
    {
      "question": "What is the trend of total duration of outage in hours over time?",
      "sql_lines": [
        "SELECT event_date, SUM(outage_hours) AS total_outage_hours",
        "FROM {fqn}.failure_events",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Cumulative outage duration trend over time from failure_events; matches questions about total downtime, outage hours accumulation, or service interruption patterns by event date."
    },
    {
      "question": "How has the average average health index for the month (0-100) changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(avg_health_index) AS avg_avg_health_index",
        "FROM {fqn}.health_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ],
      "usage_guidance": "Rolling average of monthly health index scores over time from health_monthly; matches questions about fleet health trajectory, degradation trends, or average asset condition by report month."
    }
  ],
