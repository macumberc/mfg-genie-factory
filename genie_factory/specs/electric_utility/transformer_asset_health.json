        {
          "name": "dissolved_gas_ppm",
          "sql_type": "DOUBLE",
          "comment": "Total dissolved gas in oil (ppm)",
          "is_dimension": false,
          "generation_expr": "ROUND(10.0 + ({qty_noise} * 490.0), 2)"
        },
        {
          "name": "load_pct",
          "sql_type": "DOUBLE",
          "comment": "Transformer load as percentage of rated capacity",
          "is_dimension": false,
          "generation_expr": "ROUND(25.0 + ({qty_noise} * 70.0) + (CASE WHEN MONTH(d.dt) IN (7,8) THEN 10.0 WHEN MONTH(d.dt) IN (1,2) THEN 5.0 ELSE 0.0 END), 2)"
        },
        {
          "name": "vibration_mm_s",
          "sql_type": "DOUBLE",
          "comment": "Vibration reading in mm/s",
          "is_dimension": false,
          "generation_expr": "ROUND(0.5 + ({qty_noise} * 9.5), 2)"
        },
        {
          "name": "health_index",
          "sql_type": "DOUBLE",
          "comment": "Computed health index 0-100 (higher is healthier)",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(10.0, 100.0 - ({qty_noise} * 50.0) - (CASE WHEN {status_noise} < 0.05 THEN 30.0 ELSE 0.0 END)), 2)"
        },
        {
          "name": "alert_level",
          "sql_type": "STRING",
          "comment": "Alert level: Normal, Watch, Warning, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.60 THEN 'Normal' WHEN {status_noise} < 0.80 THEN 'Watch' WHEN {status_noise} < 0.93 THEN 'Warning' ELSE 'Critical' END",
          "entity_values": [
            "Normal",
            "Watch",
            "Warning",
            "Critical"
          ]
        }
