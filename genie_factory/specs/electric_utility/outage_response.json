    {
      "table_name": "outage_kpi_monthly",
      "description": "Monthly outage performance KPIs including SAIDI, SAIFI, CAIDI, and restoration efficiency metrics.",
      "columns": [
        {
          "name": "record_id",
          "sql_type": "STRING",
          "comment": "Unique monthly KPI record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('OK-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.feeder_id) AS STRING), 7, '0'))"
        },
        {
          "name": "report_month",
          "sql_type": "DATE",
          "comment": "First day of the report month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "feeder_id",
          "sql_type": "STRING",
          "comment": "Distribution feeder identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "district",
          "sql_type": "STRING",
          "comment": "Service district",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "feeder_type",
          "sql_type": "STRING",
          "comment": "Feeder type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "saidi_minutes",
          "sql_type": "DOUBLE",
          "comment": "SAIDI - System Average Interruption Duration in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND(3.0 + ({qty_noise} * 57.0), 2)"
        },
        {
          "name": "saifi_events",
          "sql_type": "DOUBLE",
          "comment": "SAIFI - System Average Interruption Frequency",
          "is_dimension": false,
          "generation_expr": "ROUND(0.05 + ({qty_noise} * 1.45), 3)"
        },
        {
          "name": "caidi_minutes",
          "sql_type": "DOUBLE",
          "comment": "CAIDI - Customer Average Interruption Duration in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND(30.0 + ({qty_noise} * 170.0), 2)"
        },
        {
          "name": "restoration_rate_pct",
          "sql_type": "DOUBLE",
          "comment": "Percentage of outages restored within SLA target",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(99.5, 70.0 + ({qty_noise} * 29.0)), 2)"
        },
        {
          "name": "total_outage_events",
          "sql_type": "INT",
          "comment": "Total outage events in the month",
          "is_dimension": false,
          "generation_expr": "CAST(2 + FLOOR({qty_noise} * 28) AS INT)"
        }
      ],
