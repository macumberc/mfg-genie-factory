    {
      "table_name": "crew_dispatch_snapshots",
      "description": "Daily snapshot of crew dispatch activity including response time, travel time, crew utilization, and restoration metrics.",
      "columns": [
        {
          "name": "dispatch_id",
          "sql_type": "STRING",
          "comment": "Unique dispatch record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('CD-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.feeder_id) AS STRING), 7, '0'))"
        },
        {
          "name": "dispatch_date",
          "sql_type": "DATE",
          "comment": "Date of crew dispatch",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "feeder_id",
          "sql_type": "STRING",
          "comment": "Distribution feeder identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "district",
          "sql_type": "STRING",
          "comment": "Service district",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "feeder_type",
          "sql_type": "STRING",
          "comment": "Feeder type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "crew_type",
          "sql_type": "STRING",
          "comment": "Crew type: Line, Underground, Tree, Substation, Contractor",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Line' WHEN {status_noise} < 0.50 THEN 'Underground' WHEN {status_noise} < 0.65 THEN 'Tree' WHEN {status_noise} < 0.80 THEN 'Substation' ELSE 'Contractor' END"
        },
        {
          "name": "response_time_minutes",
          "sql_type": "DOUBLE",
          "comment": "Time from report to crew dispatch in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND(5.0 + ({qty_noise} * 115.0), 1)"
        },
        {
          "name": "travel_time_minutes",
          "sql_type": "DOUBLE",
          "comment": "Crew travel time to site in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND(10.0 + ({qty_noise} * 50.0), 1)"
        },
        {
          "name": "repair_time_minutes",
          "sql_type": "DOUBLE",
          "comment": "On-site repair time in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND(20.0 + ({qty_noise} * 280.0), 1)"
        },
        {
          "name": "crew_utilization_pct",
          "sql_type": "DOUBLE",
          "comment": "Crew utilization percentage for the day",
          "is_dimension": false,
          "generation_expr": "ROUND(40.0 + ({qty_noise} * 55.0), 2)"
        },
        {
          "name": "jobs_completed",
          "sql_type": "INT",
          "comment": "Number of restoration jobs completed in the day",
          "is_dimension": false,
          "generation_expr": "CAST(1 + FLOOR({qty_noise} * 7) AS INT)"
        }
      ],
      "seasonal_patterns": {
