{
  "company_name": "RestorePower Systems",
  "industry": "Electric Utility",
  "use_case": "Outage response management and crew dispatch optimization",
  "space_title": "RestorePower Systems - Outage Response & Crew Dispatch 🔌",
  "space_description": "Outage response analytics for RestorePower Systems. Ask about outage events, crew dispatch efficiency, restoration times, SAIDI/SAIFI metrics, and customer impact across 20 distribution feeders.",
  "schema_basename": "utility_outage_response",
  "tables": [
    {
      "table_name": "outage_events",
      "description": "Individual outage event records with cause, duration, customer impact, and priority classification.",
      "columns": [
        {
          "name": "outage_id",
          "sql_type": "STRING",
          "comment": "Unique outage event identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('OUT-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.feeder_id) + 10000 AS STRING), 7, '0'))"
        },
        {
          "name": "outage_date",
          "sql_type": "DATE",
          "comment": "Date outage was reported",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "feeder_id",
          "sql_type": "STRING",
          "comment": "Distribution feeder identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "feeder_name",
          "sql_type": "STRING",
          "comment": "Distribution feeder name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "district",
          "sql_type": "STRING",
          "comment": "Service district: Metro, North, South, East, West",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "feeder_type",
          "sql_type": "STRING",
          "comment": "Feeder type: Overhead, Underground, Mixed",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "cause",
          "sql_type": "STRING",
          "comment": "Outage cause: Storm, Equipment Failure, Tree Contact, Animal Contact, Vehicle Accident, Overload, Planned, Unknown",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'Storm' WHEN {status_noise} < 0.42 THEN 'Equipment Failure' WHEN {status_noise} < 0.55 THEN 'Tree Contact' WHEN {status_noise} < 0.65 THEN 'Animal Contact' WHEN {status_noise} < 0.73 THEN 'Vehicle Accident' WHEN {status_noise} < 0.82 THEN 'Overload' WHEN {status_noise} < 0.92 THEN 'Planned' ELSE 'Unknown' END"
        },
        {
          "name": "customers_affected",
          "sql_type": "INT",
          "comment": "Number of customers without power",
          "is_dimension": false,
          "generation_expr": "CAST(10 + FLOOR({qty_noise} * 9990) AS INT)"
        },
        {
          "name": "outage_duration_minutes",
          "sql_type": "DOUBLE",
          "comment": "Total outage duration in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND(15.0 + ({qty_noise} * 1425.0), 1)"
        },
        {
          "name": "priority",
          "sql_type": "STRING",
          "comment": "Priority: P1-Critical, P2-High, P3-Medium, P4-Low",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.10 THEN 'P1-Critical' WHEN {status_noise} < 0.35 THEN 'P2-High' WHEN {status_noise} < 0.70 THEN 'P3-Medium' ELSE 'P4-Low' END"
        },
        {
          "name": "customer_minutes_interrupted",
          "sql_type": "BIGINT",
          "comment": "Customer-minutes interrupted (customers x minutes)",
          "is_dimension": false,
          "generation_expr": "CAST((10 + FLOOR({qty_noise} * 9990)) * (15.0 + ({status_noise} * 500.0)) AS BIGINT)"
        }
      ],
      "seasonal_patterns": {
        "Overhead": {
          "6,7,8": 0.065,
          "12,1,2": 0.055
        },
        "Mixed": {
          "6,7,8": 0.05
        },
        "Underground": {
          "3,4": 0.04
