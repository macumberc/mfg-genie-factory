  "metric_views": [
    {
      "view_name": "outage_events_metrics",
      "source_table": "outage_events",
      "dimensions": [
        {
          "name": "outage_date",
          "expr": "outage_date"
        },
        {
          "name": "district",
          "expr": "district"
        },
        {
          "name": "feeder_type",
          "expr": "feeder_type"
        },
        {
          "name": "cause",
          "expr": "cause"
        },
        {
          "name": "priority",
          "expr": "priority"
        }
      ],
      "measures": [
        {
          "name": "total_outage_count",
          "expr": "COUNT(DISTINCT outage_id)",
          "comment": "Total number of outage events"
        },
        {
          "name": "total_customers_affected",
          "expr": "SUM(customers_affected)",
          "comment": "Total customers affected by outages"
        },
        {
          "name": "avg_outage_duration_min",
          "expr": "AVG(outage_duration_minutes)",
          "comment": "Average outage duration in minutes"
        },
        {
          "name": "total_customer_minutes",
          "expr": "SUM(customer_minutes_interrupted)",
          "comment": "Total customer-minutes interrupted"
        },
        {
          "name": "storm_outage_count",
          "expr": "COUNT(DISTINCT CASE WHEN cause = 'Storm' THEN outage_id END)",
          "comment": "Number of storm-caused outages"
        },
        {
          "name": "unique_feeder_count",
          "expr": "COUNT(DISTINCT feeder_id)",
          "comment": "Number of distinct feeders"
        },
        {
          "name": "max_customers_affected",
          "expr": "MAX(customers_affected)",
          "comment": "Maximum customers affected"
        }
      ]
    },
    {
      "view_name": "crew_dispatch_metrics",
      "source_table": "crew_dispatch_snapshots",
      "dimensions": [
        {
          "name": "dispatch_date",
          "expr": "dispatch_date"
        },
        {
          "name": "district",
          "expr": "district"
        },
        {
          "name": "crew_type",
          "expr": "crew_type"
        }
      ],
      "measures": [
        {
          "name": "avg_response_time_min",
          "expr": "AVG(response_time_minutes)",
          "comment": "Average response time in minutes"
        },
        {
          "name": "avg_travel_time_min",
          "expr": "AVG(travel_time_minutes)",
          "comment": "Average travel time to site in minutes"
        },
        {
          "name": "avg_repair_time_min",
          "expr": "AVG(repair_time_minutes)",
          "comment": "Average on-site repair time in minutes"
        },
        {
          "name": "avg_crew_utilization",
          "expr": "AVG(crew_utilization_pct)",
          "comment": "Average crew utilization percentage"
        },
        {
          "name": "total_jobs_completed",
          "expr": "SUM(jobs_completed)",
          "comment": "Total restoration jobs completed"
        },
        {
          "name": "unique_feeder_count",
          "expr": "COUNT(DISTINCT feeder_id)",
          "comment": "Number of distinct feeders"
        },
        {
          "name": "max_response_time_minutes",
          "expr": "MAX(response_time_minutes)",
          "comment": "Maximum response time minutes"
        }
      ]
