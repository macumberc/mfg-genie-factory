        "sql": "generation_readings.fuel_type IN ('Solar', 'Wind')",
        "display_name": "renewable generation",
        "synonyms": [
          "renewables",
          "clean energy"
        ],
        "instruction": "Use when filtering for renewable fuel sources only."
      },
      {
        "sql": "load_snapshots.congestion_index > 7",
        "display_name": "severe congestion",
        "synonyms": [
          "high congestion",
          "congested zones"
        ],
        "instruction": "Use when identifying zones with severe congestion."
      },
      {
        "sql": "generation_readings.fuel_type IN ('Natural Gas', 'Coal')",
        "display_name": "fossil fuel generation",
        "synonyms": [
          "thermal generation",
          "carbon-emitting sources"
        ],
        "instruction": "Use when analyzing fossil fuel or high-carbon generation."
      }
    ],
    "expressions": [
      {
        "alias": "generation_month",
        "sql": "DATE_TRUNC('month', generation_readings.reading_date)",
        "display_name": "generation month",
        "synonyms": [
          "month of generation",
          "monthly"
        ]
      },
      {
        "alias": "net_interchange_mw",
        "sql": "load_snapshots.import_mw - load_snapshots.export_mw",
        "display_name": "net interchange MW",
        "synonyms": [
          "net import",
          "net flow"
        ]
      },
      {
        "alias": "frequency_deviation",
        "sql": "ABS(load_snapshots.avg_frequency_hz - 60.0)",
        "display_name": "frequency deviation from 60 Hz",
        "synonyms": [
          "frequency error",
          "Hz deviation"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_generation_mw",
        "sql": "SUM(generation_readings.generation_mw)",
        "display_name": "total generation MW",
        "synonyms": [
          "total output",
          "generation capacity"
        ]
      },
      {
        "alias": "total_curtailment_mw",
        "sql": "SUM(generation_readings.curtailment_mw)",
        "display_name": "total curtailment MW",
        "synonyms": [
          "wasted renewable",
          "curtailed energy"
        ]
      },
      {
        "alias": "avg_carbon_intensity",
        "sql": "AVG(generation_readings.carbon_intensity_kg_mwh)",
        "display_name": "average carbon intensity",
        "synonyms": [
          "emissions rate",
          "carbon rate"
        ]
      },
      {
        "alias": "avg_peak_demand",
        "sql": "AVG(load_snapshots.peak_demand_mw)",
        "display_name": "average peak demand MW",
        "synonyms": [
          "peak load",
          "max demand"
        ]
      }
    ]
  },
  "benchmarks": [
    {
      "question": "What is the monthly trend in unique readings?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(reading_count) AS reading_count",
        "FROM {fqn}.generation_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has unique zones changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(unique_zone_count) AS unique_zone_count",
        "FROM {fqn}.generation_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest peak demand mw?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(max_peak_demand_mw) AS max_peak_demand_mw",
        "FROM {fqn}.load_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has total power imported in mw changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_import_mw) AS total_import_mw",
        "FROM {fqn}.load_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What are the top grid zone identifier by total curtailed generation in mw (renewable only)?",
      "sql_lines": [
        "SELECT zone_id, SUM(curtailment_mw) AS total_curtailment_mw",
        "FROM {fqn}.generation_readings",
        "GROUP BY zone_id ORDER BY total_curtailment_mw DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average congestion severity index 0-10 by grid zone name?",
      "sql_lines": [
        "SELECT zone_name, AVG(congestion_index) AS avg_congestion_index",
        "FROM {fqn}.load_snapshots",
        "GROUP BY zone_name ORDER BY avg_congestion_index DESC"
      ]
    },
    {
      "question": "How many records are there per first day of the report month?",
      "sql_lines": [
        "SELECT report_month, COUNT(*) AS record_count",
        "FROM {fqn}.grid_kpi_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ]
    }
  ]
}
