{
  "company_name": "PowerGrid Analytics",
  "industry": "Electric Utility",
  "use_case": "Grid management, energy mix optimization, and renewable integration",
  "space_title": "PowerGrid Analytics - Grid Management & Energy Mix ⚡",
  "space_description": "Grid management analytics for PowerGrid Analytics. Ask about generation mix, renewable integration, grid frequency, load balancing, and congestion across 20 grid zones and 6 generation fuel types.",
  "schema_basename": "utility_grid_management",
  "tables": [
    {
      "table_name": "generation_readings",
      "description": "Hourly generation readings by fuel source and grid zone including MW output, capacity factor, and curtailment.",
      "columns": [
        {
          "name": "reading_id",
          "sql_type": "STRING",
          "comment": "Unique generation reading identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('GR-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.zone_id) + 10000 AS STRING), 7, '0'))"
        },
        {
          "name": "reading_date",
          "sql_type": "DATE",
          "comment": "Date of generation reading",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "zone_id",
          "sql_type": "STRING",
          "comment": "Grid zone identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "zone_name",
          "sql_type": "STRING",
          "comment": "Grid zone descriptive name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "region",
          "sql_type": "STRING",
          "comment": "Geographic region: North, South, East, West, Central",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "fuel_type",
          "sql_type": "STRING",
          "comment": "Generation fuel: Solar, Wind, Natural Gas, Nuclear, Hydro, Coal",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.22 THEN 'Solar' WHEN {status_noise} < 0.42 THEN 'Wind' WHEN {status_noise} < 0.62 THEN 'Natural Gas' WHEN {status_noise} < 0.75 THEN 'Nuclear' WHEN {status_noise} < 0.88 THEN 'Hydro' ELSE 'Coal' END"
        },
        {
          "name": "generation_mw",
          "sql_type": "DOUBLE",
          "comment": "Generation output in megawatts",
          "is_dimension": false,
          "generation_expr": "ROUND(50.0 + ({qty_noise} * 950.0), 2)"
        },
        {
          "name": "capacity_factor_pct",
          "sql_type": "DOUBLE",
          "comment": "Capacity factor as percentage 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(15.0 + ({qty_noise} * 80.0), 2)"
        },
        {
          "name": "curtailment_mw",
          "sql_type": "DOUBLE",
          "comment": "Curtailed generation in MW (renewable only)",
          "is_dimension": false,
          "generation_expr": "ROUND(CASE WHEN {status_noise} < 0.42 THEN {qty_noise} * 120.0 ELSE 0.0 END, 2)"
        },
        {
          "name": "carbon_intensity_kg_mwh",
          "sql_type": "DOUBLE",
          "comment": "Carbon intensity in kg CO2 per MWh",
          "is_dimension": false,
          "generation_expr": "ROUND(CASE WHEN {status_noise} < 0.42 THEN 0.0 WHEN {status_noise} < 0.62 THEN 400.0 + ({qty_noise} * 100.0) WHEN {status_noise} < 0.75 THEN 12.0 WHEN {status_noise} < 0.88 THEN 24.0 ELSE 900.0 + ({qty_noise} * 100.0) END, 2)"
        }
      ],
