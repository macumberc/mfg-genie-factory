  "metric_views": [
    {
      "view_name": "generation_metrics",
      "source_table": "generation_readings",
      "dimensions": [
        {
          "name": "reading_date",
          "expr": "reading_date"
        },
        {
          "name": "region",
          "expr": "region"
        },
        {
          "name": "fuel_type",
          "expr": "fuel_type"
        }
      ],
      "measures": [
        {
          "name": "total_generation_mw",
          "expr": "SUM(generation_mw)",
          "comment": "Total generation output in MW"
        },
        {
          "name": "avg_capacity_factor",
          "expr": "AVG(capacity_factor_pct)",
          "comment": "Average capacity factor percentage"
        },
        {
          "name": "total_curtailment_mw",
          "expr": "SUM(curtailment_mw)",
          "comment": "Total renewable curtailment in MW"
        },
        {
          "name": "avg_carbon_intensity",
          "expr": "AVG(carbon_intensity_kg_mwh)",
          "comment": "Average carbon intensity kg CO2/MWh"
        },
        {
          "name": "reading_count",
          "expr": "COUNT(DISTINCT reading_id)",
          "comment": "Total number of generation readings"
        },
        {
          "name": "unique_zone_count",
          "expr": "COUNT(DISTINCT zone_id)",
          "comment": "Number of distinct zones"
        },
        {
          "name": "max_generation_mw",
          "expr": "MAX(generation_mw)",
          "comment": "Maximum generation mw"
        }
      ]
    },
    {
      "view_name": "load_metrics",
      "source_table": "load_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "region",
          "expr": "region"
        },
        {
          "name": "zone_id",
          "expr": "zone_id"
        }
      ],
      "measures": [
        {
          "name": "avg_peak_demand_mw",
          "expr": "AVG(peak_demand_mw)",
          "comment": "Average peak demand in MW"
        },
        {
          "name": "avg_congestion_index",
          "expr": "AVG(congestion_index)",
          "comment": "Average congestion severity index"
        },
        {
          "name": "total_import_mw",
          "expr": "SUM(import_mw)",
          "comment": "Total power imported in MW"
        },
        {
          "name": "total_export_mw",
          "expr": "SUM(export_mw)",
          "comment": "Total power exported in MW"
        },
        {
          "name": "avg_renewable_pct",
          "expr": "AVG(renewable_pct)",
          "comment": "Average renewable share percentage"
        },
        {
          "name": "total_avg_frequency_hz",
          "expr": "SUM(avg_frequency_hz)",
          "comment": "Total avg frequency hz"
        },
        {
          "name": "max_peak_demand_mw",
          "expr": "MAX(peak_demand_mw)",
          "comment": "Maximum peak demand mw"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The generation_metrics view (source: generation_readings) has dimensions: reading_date, region, fuel_type. Measures: total_generation_mw, avg_capacity_factor, total_curtailment_mw, avg_carbon_intensity, reading_count. The load_metrics view (source: load_snapshots) has dimensions: snapshot_date, region, zone_id. Measures: avg_peak_demand_mw, avg_congestion_index, total_import_mw, total_export_mw, avg_renewable_pct. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. zone_name).",
  "sample_questions": [
    "What is the monthly trend in unique readings?",
    "How has unique zones changed over time?",
    "What is the monthly trend in highest generation mw?",
    "How has total generation output in mw changed over time?",
    "What is the monthly trend in highest peak demand mw?",
    "How has total power imported in mw changed over time?",
    "What is the monthly trend in total power exported in mw?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest generation mw?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_generation_mw) AS max_generation_mw",
        "FROM {fqn}.generation_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has total generation output in mw changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_generation_mw) AS total_generation_mw",
        "FROM {fqn}.generation_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the monthly trend in total power exported in mw?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_export_mw) AS total_export_mw",
        "FROM {fqn}.load_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the monthly trend in average renewable share percentage?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(avg_renewable_pct) AS avg_renewable_pct",
        "FROM {fqn}.load_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the trend of total curtailed generation in mw (renewable only) over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(curtailment_mw) AS total_curtailment_mw",
        "FROM {fqn}.generation_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the trend of total peak demand in mw for the day over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(peak_demand_mw) AS total_peak_demand_mw",
        "FROM {fqn}.load_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has the average renewable energy share of total generation changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(renewable_share_pct) AS avg_renewable_share_pct",
        "FROM {fqn}.grid_kpi_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ]
    }
  ],
