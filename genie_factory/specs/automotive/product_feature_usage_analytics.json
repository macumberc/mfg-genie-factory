        },
        {
          "name": "adoption_error_pct",
          "sql_type": "DOUBLE",
          "comment": "Absolute adoption forecast error in pct points",
          "is_dimension": false,
          "generation_expr": "ROUND(ABS((55.0 + ({qty_noise} - 0.5) * 50.0) - (55.0 + ({qty_noise} - 0.5) * 55.0 + ({status_noise} - 0.5) * 10.0)), 1)"
        },
        {
          "name": "model_version",
          "sql_type": "STRING",
          "comment": "Adoption prediction model version",
