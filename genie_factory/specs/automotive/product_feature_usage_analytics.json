          "comment": "Name of the in-vehicle feature used",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.12 THEN 'Adaptive Cruise Control' WHEN {status_noise} < 0.22 THEN 'Lane Keep Assist' WHEN {status_noise} < 0.30 THEN 'Auto Park' WHEN {status_noise} < 0.40 THEN 'Voice Assistant' WHEN {status_noise} < 0.50 THEN 'Remote Start' WHEN {status_noise} < 0.58 THEN 'Heads-Up Display' WHEN {status_noise} < 0.66 THEN 'Surround View Camera' WHEN {status_noise} < 0.74 THEN 'Wireless CarPlay' WHEN {status_noise} < 0.82 THEN 'Over-the-Air Update' WHEN {status_noise} < 0.90 THEN 'Driver Drowsiness Alert' ELSE 'Traffic Sign Recognition' END",
          "entity_values": [
            "Adaptive Cruise Control",
            "Lane Keep Assist",
            "Auto Park",
            "Voice Assistant",
            "Remote Start",
            "Heads-Up Display",
            "Surround View Camera",
            "Wireless CarPlay",
            "Over-the-Air Update",
            "Driver Drowsiness Alert",
            "Traffic Sign Recognition"
          ]
        },
        {
          "name": "feature_category",
          "sql_type": "STRING",
          "comment": "Category of the feature",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'ADAS' WHEN {status_noise} < 0.55 THEN 'Infotainment' WHEN {status_noise} < 0.75 THEN 'Convenience' ELSE 'Safety' END",
          "entity_values": [
            "ADAS",
            "Infotainment",
            "Convenience",
            "Safety"
          ]
        },
        {
          "name": "session_duration_sec",
          "sql_type": "INT",
          "comment": "Feature session duration in seconds",
          "is_dimension": false,
          "generation_expr": "CAST(10 + FLOOR({qty_noise} * 3590) AS INT)"
        },
        {
          "name": "interaction_count",
          "sql_type": "INT",
          "comment": "Number of user interactions during the session",
          "is_dimension": false,
          "generation_expr": "CAST(1 + FLOOR({qty_noise} * 24) AS INT)"
        },
        {
          "name": "activation_status",
          "sql_type": "STRING",
          "comment": "Whether the feature activated successfully",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.82 THEN 'Success' WHEN {status_noise} < 0.94 THEN 'Partial' ELSE 'Failed' END",
          "entity_values": [
            "Success",
            "Partial",
            "Failed"
          ]
        }
