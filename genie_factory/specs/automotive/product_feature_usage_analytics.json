  "metric_views": [
    {
      "view_name": "feature_events_metrics",
      "source_table": "feature_events",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "model",
          "expr": "model"
        },
        {
          "name": "feature_tier",
          "expr": "feature_tier"
        },
        {
          "name": "feature_category",
          "expr": "feature_category"
        },
        {
          "name": "activation_status",
          "expr": "activation_status"
        }
      ],
      "measures": [
        {
          "name": "total_feature_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total feature activation events"
        },
        {
          "name": "avg_session_duration_sec",
          "expr": "AVG(session_duration_sec)",
          "comment": "Average feature session duration in seconds"
        },
        {
          "name": "total_interactions",
          "expr": "SUM(interaction_count)",
          "comment": "Total user interactions across sessions"
        },
        {
          "name": "failed_activation_count",
          "expr": "COUNT(DISTINCT CASE WHEN activation_status = 'Failed' THEN event_id END)",
          "comment": "Feature activations that failed"
        },
        {
          "name": "avg_interaction_count",
          "expr": "AVG(interaction_count)",
          "comment": "Average interactions per session"
        },
        {
          "name": "unique_vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Number of distinct vehicles"
        },
        {
          "name": "max_session_duration_sec",
          "expr": "MAX(session_duration_sec)",
          "comment": "Maximum session duration sec"
        }
      ]
    },
    {
      "view_name": "user_engagement_metrics",
      "source_table": "user_engagement_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "model",
          "expr": "model"
        },
        {
          "name": "feature_tier",
          "expr": "feature_tier"
        },
        {
          "name": "engagement_tier",
          "expr": "engagement_tier"
        },
        {
          "name": "churn_risk_flag",
          "expr": "churn_risk_flag"
        }
      ],
      "measures": [
        {
          "name": "avg_engagement_score",
          "expr": "AVG(engagement_score)",
          "comment": "Average engagement score"
        },
        {
          "name": "total_sessions",
          "expr": "SUM(total_sessions)",
          "comment": "Total feature sessions across vehicles"
        },
        {
          "name": "avg_features_used",
          "expr": "AVG(features_used_count)",
          "comment": "Average distinct features used per week"
        },
        {
          "name": "high_churn_risk_count",
          "expr": "COUNT(DISTINCT CASE WHEN churn_risk_flag = 'High' THEN snapshot_id END)",
          "comment": "Snapshots flagged as high churn risk"
        },
        {
          "name": "power_user_count",
          "expr": "COUNT(DISTINCT CASE WHEN engagement_tier = 'Power User' THEN snapshot_id END)",
          "comment": "Snapshots classified as power users"
        },
        {
          "name": "unique_vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Number of distinct vehicles"
        },
        {
          "name": "max_features_used_count",
          "expr": "MAX(features_used_count)",
          "comment": "Maximum features used count"
        },
        {
          "name": "total_avg_session_duration_sec",
          "expr": "SUM(avg_session_duration_sec)",
          "comment": "Total avg session duration sec"
        }
      ]
    }
  ],
  "genie_instructions": "You are an automotive analytics assistant for AutoMetrics Corp. Answer questions about in-vehicle feature adoption tracking and customer usage pattern analytics using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (vehicle_id, make, model_year), query the base tables directly.\n- When joining tables, use the shared keys: vehicle_id (shared across feature_adoption_monthly, feature_events, user_engagement_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in failed activation count?",
    "How has unique total feature eventss changed over time?",
    "What is the monthly trend in unique vehicles?",
    "How has highest session duration sec changed over time?",
    "What is the monthly trend in high churn risk count?",
    "How has power user count changed over time?",
    "What is the monthly trend in unique vehicles?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique vehicles?",
      "sql_lines": [
        "SELECT event_date, MEASURE(unique_vehicle_count) AS unique_vehicle_count",
        "FROM {fqn}.feature_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How has highest session duration sec changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(max_session_duration_sec) AS max_session_duration_sec",
        "FROM {fqn}.feature_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How has average interactions per session changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(avg_interaction_count) AS avg_interaction_count",
        "FROM {fqn}.feature_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How does failed activation count vary across models?",
      "sql_lines": [
        "SELECT model, MEASURE(failed_activation_count) AS failed_activation_count",
        "FROM {fqn}.feature_events_metrics",
        "GROUP BY ALL",
        "ORDER BY failed_activation_count DESC"
      ]
    },
    {
      "question": "How does total number of user interactions during the session break down by unique vehicle for 'Success' records?",
      "sql_lines": [
        "SELECT vehicle_id, COUNT(*) AS record_count, SUM(interaction_count) AS total_interaction_count",
        "FROM {fqn}.feature_events",
        "WHERE activation_status = 'Success' GROUP BY vehicle_id ORDER BY total_interaction_count DESC"
      ]
    },
    {
      "question": "What is the trend of total number of distinct features used during the week over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(features_used_count) AS total_features_used_count",
        "FROM {fqn}.user_engagement_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has the average predicted feature adoption rate 0-100 changed over time?",
      "sql_lines": [
        "SELECT forecast_month, AVG(forecasted_adoption_pct) AS avg_forecasted_adoption_pct",
        "FROM {fqn}.feature_adoption_monthly",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "feature_events.activation_status = 'Failed'",
        "display_name": "failed activations",
        "synonyms": [
          "activation failures",
          "failed features",
          "broken activations"
        ],
        "instruction": "Use when analyzing feature activation failures and reliability issues."
      },
      {
        "sql": "user_engagement_snapshots.churn_risk_flag = 'High'",
        "display_name": "high churn risk",
        "synonyms": [
          "at-risk subscribers",
          "likely churners",
          "high attrition risk"
        ],
        "instruction": "Use when filtering for vehicles whose owners are at high risk of subscription cancellation."
      },
      {
        "sql": "feature_events.event_date >= ADD_MONTHS(CURRENT_DATE(), -90)",
        "display_name": "last 90 days",
        "synonyms": [
          "recent events",
          "past 3 months",
          "trailing quarter"
        ],
        "instruction": "Use to restrict feature event analysis to the most recent 90-day window."
      }
    ],
    "expressions": [
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', feature_events.event_date)",
        "display_name": "event month",
        "synonyms": [
          "month of event",
          "feature event month"
        ]
      },
      {
        "alias": "adoption_gap_pct",
        "sql": "feature_adoption_monthly.forecasted_adoption_pct - feature_adoption_monthly.actual_adoption_pct",
        "display_name": "adoption forecast gap",
        "synonyms": [
          "forecast vs actual adoption",
          "adoption prediction error"
        ]
      },
      {
        "alias": "session_duration_minutes",
        "sql": "feature_events.session_duration_sec / 60.0",
        "display_name": "session duration in minutes",
        "synonyms": [
          "session minutes",
          "usage time in minutes"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_feature_events",
        "sql": "COUNT(DISTINCT feature_events.event_id)",
        "display_name": "total feature events",
        "synonyms": [
          "event count",
          "feature activations",
          "usage events"
        ]
      },
      {
        "alias": "avg_engagement_score",
        "sql": "AVG(user_engagement_snapshots.engagement_score)",
        "display_name": "average engagement score",
        "synonyms": [
          "mean engagement",
          "engagement rating",
          "user engagement"
        ]
      },
      {
        "alias": "total_interactions",
        "sql": "SUM(feature_events.interaction_count)",
        "display_name": "total interactions",
        "synonyms": [
          "interaction volume",
          "user interactions",
          "touch count"
        ]
      },
      {
        "alias": "failed_activation_rate",
        "sql": "COUNT(DISTINCT CASE WHEN feature_events.activation_status = 'Failed' THEN feature_events.event_id END)",
        "display_name": "failed activation count",
        "synonyms": [
          "failure count",
          "failed activations",
          "activation errors"
        ]
      }
    ]
  },
