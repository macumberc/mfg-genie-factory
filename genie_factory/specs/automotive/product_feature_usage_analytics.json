    {
      "question": "What are the top unique vehicle by total number of user interactions during the session?",
      "sql_lines": [
        "SELECT vehicle_id, SUM(interaction_count) AS total_interaction_count",
        "FROM {fqn}.feature_events",
        "GROUP BY vehicle_id ORDER BY total_interaction_count DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average average session duration in seconds for the week by vehicle model name?",
      "sql_lines": [
        "SELECT model, AVG(avg_session_duration_sec) AS avg_avg_session_duration_sec",
        "FROM {fqn}.user_engagement_snapshots",
        "GROUP BY model ORDER BY avg_avg_session_duration_sec DESC"
      ]
    },
    {
      "question": "How many records are there per month the adoption forecast covers?",
      "sql_lines": [
        "SELECT forecast_month, COUNT(*) AS record_count",
        "FROM {fqn}.feature_adoption_monthly",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ]
