        {
          "name": "engagement_score",
          "sql_type": "DOUBLE",
          "comment": "Composite engagement score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(10.0, 55.0 + ({qty_noise} - 0.5) * 60.0)), 1)"
        },
        {
          "name": "engagement_tier",
          "sql_type": "STRING",
          "comment": "Engagement classification",
          "is_dimension": false,
          "generation_expr": "CASE WHEN (55.0 + ({qty_noise} - 0.5) * 60.0) >= 80.0 THEN 'Power User' WHEN (55.0 + ({qty_noise} - 0.5) * 60.0) >= 50.0 THEN 'Active' WHEN (55.0 + ({qty_noise} - 0.5) * 60.0) >= 30.0 THEN 'Casual' ELSE 'Dormant' END",
          "entity_values": [
            "Power User",
            "Active",
            "Casual",
            "Dormant"
          ]
        },
        {
          "name": "churn_risk_flag",
          "sql_type": "STRING",
          "comment": "Whether the vehicle owner is at churn risk for subscription renewal",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'High' WHEN {status_noise} < 0.35 THEN 'Medium' ELSE 'Low' END",
          "entity_values": [
            "High",
            "Medium",
            "Low"
          ]
        }
