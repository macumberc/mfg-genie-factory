      "question": "How has power user count changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(power_user_count) AS power_user_count",
        "FROM {fqn}.user_engagement_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
