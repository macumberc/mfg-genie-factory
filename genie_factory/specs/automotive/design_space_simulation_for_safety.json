  "metric_views": [
    {
      "view_name": "simulation_runs_metrics",
      "source_table": "simulation_runs",
      "dimensions": [
        {
          "name": "run_date",
          "expr": "run_date"
        },
        {
          "name": "model_name",
          "expr": "model_name"
        },
        {
          "name": "body_type",
          "expr": "body_type"
        },
        {
          "name": "crash_test_type",
          "expr": "crash_test_type"
        },
        {
          "name": "safety_rating",
          "expr": "safety_rating"
        }
      ],
      "measures": [
        {
          "name": "total_simulation_runs",
          "expr": "COUNT(DISTINCT run_id)",
          "comment": "Total crash simulation runs executed"
        },
        {
          "name": "avg_injury_risk_score",
          "expr": "AVG(injury_risk_score)",
          "comment": "Average injury risk probability"
        },
        {
          "name": "avg_peak_deceleration",
          "expr": "AVG(peak_deceleration_g)",
          "comment": "Average peak deceleration in g-force"
        },
        {
          "name": "fail_count",
          "expr": "COUNT(DISTINCT CASE WHEN pass_fail = 'Fail' THEN run_id END)",
          "comment": "Simulation runs that failed regulatory thresholds"
        },
        {
          "name": "five_star_count",
          "expr": "COUNT(DISTINCT CASE WHEN safety_rating = '5-Star' THEN run_id END)",
          "comment": "Simulation runs achieving 5-star rating"
        },
        {
          "name": "total_impact_speed_kmh",
          "expr": "SUM(impact_speed_kmh)",
          "comment": "Total impact speed kmh"
        },
        {
          "name": "total_cabin_intrusion_mm",
          "expr": "SUM(cabin_intrusion_mm)",
          "comment": "Total cabin intrusion mm"
        },
        {
          "name": "unique_config_count",
          "expr": "COUNT(DISTINCT config_id)",
          "comment": "Number of distinct configs"
        },
        {
          "name": "max_impact_speed_kmh",
          "expr": "MAX(impact_speed_kmh)",
          "comment": "Maximum impact speed kmh"
        }
      ]
    },
    {
      "view_name": "parameter_snapshots_metrics",
      "source_table": "parameter_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "model_name",
          "expr": "model_name"
        },
        {
          "name": "body_type",
          "expr": "body_type"
        },
        {
          "name": "material_type",
          "expr": "material_type"
        },
        {
          "name": "exploration_status",
          "expr": "exploration_status"
        }
      ],
      "measures": [
        {
          "name": "avg_composite_safety_score",
          "expr": "AVG(composite_safety_score)",
          "comment": "Average composite safety score"
        },
        {
          "name": "avg_structural_thickness",
          "expr": "AVG(structural_thickness_mm)",
          "comment": "Average structural panel thickness in mm"
        },
        {
          "name": "avg_vehicle_weight",
          "expr": "AVG(weight_kg)",
          "comment": "Average vehicle weight in kg"
        },
        {
          "name": "converged_count",
          "expr": "COUNT(DISTINCT CASE WHEN exploration_status = 'Converged' THEN snapshot_id END)",
          "comment": "Parameter snapshots that have converged"
        },
        {
          "name": "total_snapshots",
          "expr": "COUNT(DISTINCT snapshot_id)",
          "comment": "Total parameter exploration snapshots"
        },
        {
          "name": "unique_config_count",
          "expr": "COUNT(DISTINCT config_id)",
          "comment": "Number of distinct configs"
        },
        {
          "name": "max_structural_thickness_mm",
          "expr": "MAX(structural_thickness_mm)",
          "comment": "Maximum structural thickness mm"
        },
        {
          "name": "total_airbag_count",
          "expr": "SUM(airbag_count)",
          "comment": "Total airbag count"
        }
      ]
    }
