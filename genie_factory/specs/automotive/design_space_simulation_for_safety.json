          "is_dimension": false,
          "generation_expr": "CONCAT('PS-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.config_id) + 5000 AS STRING), 7, '0'))"
        },
        {
          "name": "snapshot_date",
          "sql_type": "DATE",
          "comment": "Week-ending date of the parameter snapshot",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('week', d.dt)"
        },
        {
