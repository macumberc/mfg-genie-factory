  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The simulation_runs_metrics view (source: simulation_runs) has dimensions: run_date, model_name, body_type, crash_test_type, safety_rating. Measures: total_simulation_runs, avg_injury_risk_score, avg_peak_deceleration, fail_count, five_star_count. The parameter_snapshots_metrics view (source: parameter_snapshots) has dimensions: snapshot_date, model_name, body_type, material_type, exploration_status. Measures: avg_composite_safety_score, avg_structural_thickness, avg_vehicle_weight, converged_count, total_snapshots. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. config_id, safety_package).",
  "sample_questions": [
    "What is the monthly trend in fail count?",
    "How has five star count changed over time?",
    "What is the monthly trend in unique total simulation runss?",
    "How has unique configs changed over time?",
    "What is the monthly trend in converged count?",
    "How has unique total snapshotss changed over time?",
    "What is the monthly trend in unique configs?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total simulation runss?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_simulation_runs) AS total_simulation_runs",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "How has unique configs changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(unique_config_count) AS unique_config_count",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "What is the monthly trend in unique configs?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(unique_config_count) AS unique_config_count",
        "FROM {fqn}.parameter_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the trend of total impact speed in km/h over time?",
      "sql_lines": [
        "SELECT run_date, SUM(impact_speed_kmh) AS total_impact_speed_kmh",
        "FROM {fqn}.simulation_runs",
        "GROUP BY run_date ORDER BY run_date"
      ]
    },
    {
      "question": "What is the trend of total average structural panel thickness in mm over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(structural_thickness_mm) AS total_structural_thickness_mm",
        "FROM {fqn}.parameter_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has the average predicted composite safety score 0-100 changed over time?",
      "sql_lines": [
        "SELECT summary_month, AVG(forecasted_safety_score) AS avg_forecasted_safety_score",
        "FROM {fqn}.simulation_summary_monthly",
        "GROUP BY summary_month ORDER BY summary_month"
      ]
    },
    {
      "question": "How has total cabin intrusion mm changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_cabin_intrusion_mm) AS total_cabin_intrusion_mm",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "simulation_runs.pass_fail = 'Fail'",
        "display_name": "failed simulations",
        "synonyms": [
          "failed tests",
          "failed crash tests",
          "non-passing runs"
        ],
        "instruction": "Use when analyzing simulation runs that did not meet regulatory safety thresholds."
      },
      {
        "sql": "parameter_snapshots.exploration_status = 'Converged'",
        "display_name": "converged designs",
        "synonyms": [
          "finalized designs",
          "stable parameters",
          "optimized configurations"
        ],
        "instruction": "Use when filtering for design parameter sets that have converged to an optimal state."
      },
      {
        "sql": "simulation_runs.run_date >= ADD_MONTHS(CURRENT_DATE(), -90)",
        "display_name": "last 90 days",
        "synonyms": [
          "recent simulations",
          "past 3 months",
          "trailing quarter"
        ],
        "instruction": "Use to restrict simulation analysis to the most recent 90-day window."
      }
    ],
    "expressions": [
      {
        "alias": "run_month",
        "sql": "DATE_TRUNC('month', simulation_runs.run_date)",
        "display_name": "simulation month",
        "synonyms": [
          "month of simulation",
          "run month"
        ]
      },
      {
        "alias": "safety_forecast_gap",
        "sql": "simulation_summary_monthly.forecasted_safety_score - simulation_summary_monthly.actual_safety_score",
        "display_name": "safety forecast gap",
        "synonyms": [
          "forecast vs actual safety",
          "prediction error"
        ]
      },
      {
        "alias": "weight_to_safety_ratio",
        "sql": "parameter_snapshots.weight_kg / NULLIF(parameter_snapshots.composite_safety_score, 0)",
        "display_name": "weight to safety ratio",
        "synonyms": [
          "mass efficiency",
          "weight per safety point"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_simulation_runs",
        "sql": "COUNT(DISTINCT simulation_runs.run_id)",
        "display_name": "total simulation runs",
        "synonyms": [
          "run count",
          "simulation count",
          "test count"
        ]
      },
