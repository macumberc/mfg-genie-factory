{
  "company_name": "SafeDesign Automotive",
  "industry": "Automotive",
  "use_case": "Design space exploration and simulation for vehicle safety optimization",
  "space_title": "SafeDesign - Safety Simulation Analytics 🧪",
  "space_description": "Safety simulation and design space analytics for SafeDesign Automotive. Ask questions about crash simulation runs, parameter exploration states, simulation KPIs, and safety score trends across 20 vehicle configurations and 5 crash test types.",
  "schema_basename": "safety_simulation",
  "tables": [
    {
      "table_name": "simulation_runs",
      "description": "Daily crash simulation runs capturing impact forces, deformation measurements, injury risk scores, and pass/fail outcomes for various crash test configurations.",
      "columns": [
        {
          "name": "run_id",
          "sql_type": "STRING",
          "comment": "Unique simulation run identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('SIM-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.config_id) + 10000 AS STRING), 7, '0'))"
        },
        {
          "name": "run_date",
          "sql_type": "DATE",
          "comment": "Date the simulation was executed",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "config_id",
          "sql_type": "STRING",
          "comment": "Vehicle configuration identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "model_name",
          "sql_type": "STRING",
          "comment": "Vehicle model being simulated",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "body_type",
          "sql_type": "STRING",
          "comment": "Vehicle body type classification",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "crash_test_type",
          "sql_type": "STRING",
          "comment": "Type of crash test simulated",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "impact_speed_kmh",
          "sql_type": "DOUBLE",
          "comment": "Impact speed in km/h",
          "is_dimension": false,
          "generation_expr": "ROUND(30.0 + {qty_noise} * 90.0, 1)"
        },
        {
          "name": "peak_deceleration_g",
          "sql_type": "DOUBLE",
          "comment": "Peak deceleration in g-force",
          "is_dimension": false,
          "generation_expr": "ROUND(15.0 + {qty_noise} * 55.0, 2)"
        },
        {
          "name": "cabin_intrusion_mm",
          "sql_type": "DOUBLE",
          "comment": "Maximum cabin intrusion in millimeters",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.0, {qty_noise} * 120.0 - 10.0), 1)"
        },
        {
          "name": "injury_risk_score",
          "sql_type": "DOUBLE",
          "comment": "Computed injury risk probability 0-1",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(0.95, GREATEST(0.02, 0.25 + ({qty_noise} - 0.5) * 0.50)), 3)"
        },
        {
          "name": "safety_rating",
          "sql_type": "STRING",
          "comment": "Overall safety rating outcome",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN '5-Star' WHEN {status_noise} < 0.65 THEN '4-Star' WHEN {status_noise} < 0.85 THEN '3-Star' ELSE '2-Star' END"
        },
        {
          "name": "pass_fail",
          "sql_type": "STRING",
          "comment": "Whether the simulation passed regulatory thresholds",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.72 THEN 'Pass' WHEN {status_noise} < 0.90 THEN 'Marginal' ELSE 'Fail' END"
        }
      ],
      "seasonal_patterns": {
        "Sedan": {
          "1,2": 0.055,
          "9,10": 0.06
        },
