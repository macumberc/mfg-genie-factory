      "table_name": "parameter_snapshots",
      "description": "Weekly snapshots of design parameter exploration states, capturing material choices, structural thicknesses, airbag configurations, and resulting safety scores.",
      "columns": [
        {
          "name": "snapshot_id",
          "sql_type": "STRING",
