    {
      "table_name": "simulation_summary_monthly",
      "description": "Monthly simulation KPI summaries with forecasted vs actual safety scores, pass rates, and model accuracy tracking.",
      "columns": [
        {
          "name": "summary_id",
          "sql_type": "STRING",
          "comment": "Unique monthly summary record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('SSM-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.config_id) + 20000 AS STRING), 7, '0'))"
        },
        {
          "name": "summary_month",
          "sql_type": "DATE",
          "comment": "Month the summary covers",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "config_id",
          "sql_type": "STRING",
          "comment": "Vehicle configuration identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "model_name",
          "sql_type": "STRING",
          "comment": "Vehicle model name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "body_type",
          "sql_type": "STRING",
          "comment": "Vehicle body type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "forecasted_safety_score",
          "sql_type": "DOUBLE",
          "comment": "Predicted composite safety score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(98.0, GREATEST(45.0, 75.0 + ({qty_noise} - 0.5) * 35.0)), 1)"
        },
        {
          "name": "actual_safety_score",
          "sql_type": "DOUBLE",
          "comment": "Actual realized composite safety score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(99.0, GREATEST(40.0, 75.0 + ({qty_noise} - 0.5) * 40.0 + ({status_noise} - 0.5) * 8.0)), 1)"
        },
        {
          "name": "forecast_error_pct",
          "sql_type": "DOUBLE",
          "comment": "Absolute safety score forecast error in pct points",
          "is_dimension": false,
          "generation_expr": "ROUND(ABS((75.0 + ({qty_noise} - 0.5) * 35.0) - (75.0 + ({qty_noise} - 0.5) * 40.0 + ({status_noise} - 0.5) * 8.0)), 1)"
        },
        {
          "name": "simulation_model_version",
          "sql_type": "STRING",
          "comment": "Safety simulation model version",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'FEA-v4.0' WHEN {status_noise} < 0.60 THEN 'FEA-v4.1' ELSE 'FEA-v4.2' END"
        },
        {
          "name": "regulatory_compliance",
          "sql_type": "STRING",
          "comment": "Regulatory compliance status for the month",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.65 THEN 'Compliant' WHEN {status_noise} < 0.88 THEN 'Under Review' ELSE 'Non-Compliant' END"
        }
      ],
      "seasonal_patterns": {
