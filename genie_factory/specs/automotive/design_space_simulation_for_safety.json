          "comment": "Safety equipment package level",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "material_type",
          "sql_type": "STRING",
          "comment": "Primary structural material used",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'High-Strength Steel' WHEN {status_noise} < 0.50 THEN 'Aluminum Alloy' WHEN {status_noise} < 0.70 THEN 'Carbon Fiber Composite' WHEN {status_noise} < 0.85 THEN 'Boron Steel' ELSE 'Magnesium Alloy' END"
        },
        {
          "name": "structural_thickness_mm",
          "sql_type": "DOUBLE",
          "comment": "Average structural panel thickness in mm",
          "is_dimension": false,
          "generation_expr": "ROUND(1.2 + {qty_noise} * 3.8, 2)"
        },
        {
          "name": "airbag_count",
          "sql_type": "INT",
          "comment": "Number of airbags in configuration",
          "is_dimension": false,
          "generation_expr": "CAST(CASE WHEN {status_noise} < 0.20 THEN 6 WHEN {status_noise} < 0.50 THEN 8 WHEN {status_noise} < 0.80 THEN 10 ELSE 12 END AS INT)"
        },
        {
          "name": "weight_kg",
          "sql_type": "DOUBLE",
          "comment": "Total vehicle weight in kilograms",
          "is_dimension": false,
          "generation_expr": "ROUND(1200.0 + {qty_noise} * 1300.0, 1)"
        },
        {
          "name": "composite_safety_score",
          "sql_type": "DOUBLE",
          "comment": "Composite safety score 0-100 from parameter combination",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(99.0, GREATEST(40.0, 72.0 + ({qty_noise} - 0.5) * 40.0)), 1)"
        },
        {
          "name": "exploration_status",
          "sql_type": "STRING",
          "comment": "Design exploration convergence status",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Converged' WHEN {status_noise} < 0.65 THEN 'Exploring' ELSE 'Divergent' END"
        }
      ],
