  "metric_views": [
    {
      "view_name": "vehicle_telemetry_metrics",
      "source_table": "vehicle_telemetry",
      "dimensions": [
        {
          "name": "reading_date",
          "expr": "reading_date"
        },
        {
          "name": "model",
          "expr": "model"
        },
        {
          "name": "vehicle_class",
          "expr": "vehicle_class"
        },
        {
          "name": "connectivity_tier",
          "expr": "connectivity_tier"
        },
        {
          "name": "alert_severity",
          "expr": "alert_severity"
        }
      ],
      "measures": [
        {
          "name": "total_readings",
          "expr": "COUNT(DISTINCT reading_id)",
          "comment": "Total telemetry readings collected"
        },
        {
          "name": "avg_health_score",
          "expr": "AVG(health_score)",
          "comment": "Average vehicle health score"
        },
        {
          "name": "avg_engine_temp",
          "expr": "AVG(engine_temp_celsius)",
          "comment": "Average engine coolant temperature"
        },
        {
          "name": "critical_alert_count",
          "expr": "COUNT(DISTINCT CASE WHEN alert_severity = 'Critical' THEN reading_id END)",
          "comment": "Readings with critical severity alerts"
        },
        {
          "name": "avg_dtc_count",
          "expr": "AVG(dtc_count)",
          "comment": "Average diagnostic trouble codes per reading"
        },
        {
          "name": "total_battery_voltage",
          "expr": "SUM(battery_voltage)",
          "comment": "Total battery voltage"
        },
        {
          "name": "total_tire_pressure_psi",
          "expr": "SUM(tire_pressure_psi)",
          "comment": "Total tire pressure psi"
        },
        {
          "name": "unique_vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Number of distinct vehicles"
        },
        {
          "name": "max_engine_temp_celsius",
          "expr": "MAX(engine_temp_celsius)",
          "comment": "Maximum engine temp celsius"
        }
      ]
    },
    {
      "view_name": "maintenance_records_metrics",
      "source_table": "maintenance_records",
      "dimensions": [
        {
          "name": "service_date",
          "expr": "service_date"
        },
        {
          "name": "model",
          "expr": "model"
        },
        {
          "name": "vehicle_class",
          "expr": "vehicle_class"
        },
        {
          "name": "service_type",
          "expr": "service_type"
        },
        {
          "name": "service_region",
          "expr": "service_region"
        }
      ],
      "measures": [
        {
          "name": "total_service_records",
          "expr": "COUNT(DISTINCT record_id)",
          "comment": "Total service records"
        },
        {
          "name": "total_repair_cost",
          "expr": "SUM(repair_cost_usd)",
          "comment": "Total repair cost in USD"
        },
        {
          "name": "avg_labor_hours",
          "expr": "AVG(labor_hours)",
          "comment": "Average labor hours per service"
        },
        {
          "name": "warranty_covered_count",
          "expr": "COUNT(DISTINCT CASE WHEN warranty_covered = 'Yes' THEN record_id END)",
          "comment": "Services fully covered by warranty"
        },
        {
          "name": "avg_customer_satisfaction",
          "expr": "AVG(customer_satisfaction)",
          "comment": "Average post-service satisfaction score"
        },
        {
          "name": "unique_vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Number of distinct vehicles"
        },
        {
          "name": "max_parts_replaced_count",
          "expr": "MAX(parts_replaced_count)",
          "comment": "Maximum parts replaced count"
        },
        {
          "name": "total_parts_replaced_count",
