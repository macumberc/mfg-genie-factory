          "name": "parts_replaced_count",
          "sql_type": "INT",
          "comment": "Number of parts replaced during service",
          "is_dimension": false,
          "generation_expr": "CAST(CASE WHEN {status_noise} < 0.30 THEN FLOOR({qty_noise} * 3) WHEN {status_noise} < 0.70 THEN 1 + FLOOR({qty_noise} * 4) ELSE 2 + FLOOR({qty_noise} * 6) END AS INT)"
        },
