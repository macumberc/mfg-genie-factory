          "comment": "Type of service performed",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Routine Maintenance' WHEN {status_noise} < 0.50 THEN 'Recall Repair' WHEN {status_noise} < 0.70 THEN 'Warranty Repair' WHEN {status_noise} < 0.85 THEN 'Diagnostic' ELSE 'Emergency Repair' END",
