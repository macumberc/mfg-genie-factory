  "genie_instructions": "You are an automotive analytics assistant for DriveWell Automotive. Answer questions about connected vehicle health monitoring and predictive maintenance reporting using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (vehicle_id), query the base tables directly.\n- When joining tables, use the shared keys: vehicle_id (shared across maintenance_records, vehicle_health_monthly, vehicle_telemetry).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in critical alert count?",
    "How has unique total readingss changed over time?",
    "What is the monthly trend in unique vehicles?",
    "How has highest engine temp celsius changed over time?",
    "What is the monthly trend in warranty covered count?",
    "How has unique total service recordss changed over time?",
    "What is the monthly trend in unique vehicles?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique vehicles?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', reading_date) AS reading_date_month, MEASURE(unique_vehicle_count) AS unique_vehicle_count",
        "FROM {fqn}.vehicle_telemetry_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date_month"
      ],
      "usage_guidance": "Monthly trend of unique connected vehicles tracked across the DriveWell fleet, using reading_date and unique_vehicle_count from telemetry metrics."
    },
    {
      "question": "How has highest engine temp celsius changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_engine_temp_celsius) AS max_engine_temp_celsius",
        "FROM {fqn}.vehicle_telemetry_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of peak engine temperature recorded across the fleet, referencing max_engine_temp_celsius from vehicle telemetry metrics."
    },
    {
      "question": "How has total tire pressure psi changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_tire_pressure_psi) AS total_tire_pressure_psi",
        "FROM {fqn}.vehicle_telemetry_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of aggregated tire pressure PSI across all vehicles, using total_tire_pressure_psi from vehicle telemetry metrics."
    },
    {
      "question": "Which models have the highest total battery voltage?",
      "sql_lines": [
        "SELECT model, MEASURE(total_battery_voltage) AS total_battery_voltage",
        "FROM {fqn}.vehicle_telemetry_metrics",
        "GROUP BY ALL",
        "ORDER BY total_battery_voltage DESC"
      ],
      "usage_guidance": "Top-N ranking of vehicle models by cumulative battery voltage, grouping total_battery_voltage by model from telemetry metrics."
    },
    {
      "question": "What is the trend of total engine coolant temperature in celsius over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(engine_temp_celsius) AS total_engine_temp_celsius",
        "FROM {fqn}.vehicle_telemetry",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of summed engine coolant temperature in Celsius, querying raw engine_temp_celsius directly from vehicle_telemetry table."
    },
    {
      "question": "What is the trend of total number of parts replaced during service over time?",
      "sql_lines": [
        "SELECT service_date, SUM(parts_replaced_count) AS total_parts_replaced_count",
        "FROM {fqn}.maintenance_records",
        "GROUP BY service_date ORDER BY service_date"
      ],
      "usage_guidance": "Time-series trend of total parts replaced during maintenance services, querying parts_replaced_count directly from maintenance_records table."
    },
    {
      "question": "How has the average model-predicted health score 0-100 changed over time?",
      "sql_lines": [
        "SELECT forecast_month, AVG(forecasted_health_score) AS avg_forecasted_health_score",
        "FROM {fqn}.vehicle_health_monthly",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ],
      "usage_guidance": "Time-series trend of average AI-forecasted vehicle health scores 0–100, using forecasted_health_score from vehicle_health_monthly predictive model."
    }
  ],
  "sql_snippets": {
