        {
          "name": "engine_temp_celsius",
          "sql_type": "DOUBLE",
          "comment": "Engine coolant temperature in Celsius",
          "is_dimension": false,
          "generation_expr": "ROUND(75.0 + {qty_noise} * 35.0 + CASE WHEN MONTH(d.dt) IN (6,7,8) THEN 8.0 ELSE 0.0 END, 1)"
        },
        {
          "name": "battery_voltage",
          "sql_type": "DOUBLE",
          "comment": "Battery voltage reading in volts",
          "is_dimension": false,
          "generation_expr": "ROUND(11.5 + {qty_noise} * 2.5, 2)"
        },
        {
          "name": "tire_pressure_psi",
          "sql_type": "DOUBLE",
          "comment": "Average tire pressure in PSI",
          "is_dimension": false,
          "generation_expr": "ROUND(28.0 + {qty_noise} * 10.0 - CASE WHEN MONTH(d.dt) IN (12,1,2) THEN 3.0 ELSE 0.0 END, 1)"
        },
        {
          "name": "dtc_count",
          "sql_type": "INT",
          "comment": "Number of active diagnostic trouble codes",
          "is_dimension": false,
          "generation_expr": "CAST(CASE WHEN {status_noise} < 0.60 THEN 0 WHEN {status_noise} < 0.82 THEN 1 WHEN {status_noise} < 0.93 THEN 2 ELSE FLOOR({qty_noise} * 5) + 3 END AS INT)"
        },
        {
          "name": "health_score",
          "sql_type": "DOUBLE",
          "comment": "Overall vehicle health score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(35.0, 82.0 + ({qty_noise} - 0.5) * 30.0)), 1)"
        },
        {
          "name": "alert_severity",
          "sql_type": "STRING",
          "comment": "Alert severity level for the reading",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'None' WHEN {status_noise} < 0.78 THEN 'Low' WHEN {status_noise} < 0.92 THEN 'Medium' ELSE 'Critical' END",
          "entity_values": [
            "None",
            "Low",
            "Medium",
            "Critical"
          ]
        }
      ],
