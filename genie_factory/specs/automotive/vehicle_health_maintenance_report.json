          "is_dimension": false,
          "generation_expr": "ROUND(0.5 + {qty_noise} * 7.5, 1)"
        },
        {
          "name": "repair_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Total repair cost in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(50.0 + {qty_noise} * 2450.0, 2)"
        },
        {
          "name": "warranty_covered",
          "sql_type": "STRING",
          "comment": "Whether repair was covered by warranty",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.45 THEN 'Yes' WHEN {status_noise} < 0.80 THEN 'No' ELSE 'Partial' END",
          "entity_values": [
            "Yes",
            "No",
            "Partial"
          ]
        },
        {
          "name": "service_region",
          "sql_type": "STRING",
          "comment": "Service center region",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Northeast' WHEN {status_noise} < 0.30 THEN 'Southeast' WHEN {status_noise} < 0.45 THEN 'Midwest' WHEN {status_noise} < 0.60 THEN 'Southwest' WHEN {status_noise} < 0.75 THEN 'West Coast' WHEN {status_noise} < 0.88 THEN 'Mountain' ELSE 'Pacific NW' END",
          "entity_values": [
            "Northeast",
            "Southeast",
            "Midwest",
            "Southwest",
            "West Coast",
            "Mountain",
            "Pacific NW"
          ]
        },
        {
          "name": "customer_satisfaction",
          "sql_type": "DOUBLE",
          "comment": "Post-service customer satisfaction score 1-5",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(5.0, GREATEST(1.0, 3.5 + ({qty_noise} - 0.5) * 3.0)), 1)"
        }
      ],
