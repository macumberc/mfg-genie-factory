  "genie_instructions": "You are a railroad analytics assistant for RailRoute Logistics. Answer questions about railroad route planning and corridor capacity optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (corridor_id, corridor_name), query the base tables directly.\n- When joining tables, use the shared keys: corridor_id (shared across corridor_snapshots, rail_corridors, train_movements).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique corridors?",
    "How has highest trains count changed over time?",
    "What is the monthly trend in total gtm millions?",
    "How has total train movements changed over time?",
    "What is the monthly trend in high risk count?",
    "How has unique plans changed over time?",
    "What is the monthly trend in unique corridors?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total gtm millions?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', movement_date) AS movement_date_month, MEASURE(total_gross_ton_miles) AS total_gross_ton_miles",
        "FROM {fqn}.route_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY movement_date_month"
      ],
      "usage_guidance": "Monthly trend aggregate of gross ton miles (GTM) volume; matches phrases like 'GTM over time' or 'freight tonnage trend' using route_kpi_monthly total_gross_ton_miles."
    },
    {
      "question": "How has total train movements changed over time?",
      "sql_lines": [
        "SELECT movement_date, MEASURE(total_trains) AS total_trains",
        "FROM {fqn}.route_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY movement_date"
      ],
      "usage_guidance": "Monthly trend of total train movement counts; matches 'train volume over time' or 'how many trains ran each month' using route_kpi_monthly total_trains."
    },
    {
      "question": "How does the number of unique plans vary by corridor type?",
      "sql_lines": [
        "SELECT corridor_type, MEASURE(plan_count) AS plan_count",
        "FROM {fqn}.capacity_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY plan_count DESC"
      ],
      "usage_guidance": "Category breakdown of planning record counts by corridor type; matches 'plans per corridor type' or 'which corridor type has most plans' using capacity_kpi_monthly plan_count."
    },
    {
      "question": "What is the trend of total number of trains on corridor over time?",
      "sql_lines": [
        "SELECT movement_date, SUM(trains_count) AS total_trains_count",
        "FROM {fqn}.rail_corridors",
        "GROUP BY movement_date ORDER BY movement_date"
      ],
      "usage_guidance": "Time-series trend of raw train counts on corridors; matches 'trains on corridor over time' or 'corridor traffic trend' directly from rail_corridors trains_count."
    },
    {
      "question": "What is the trend of total total congestion delay hours over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(congestion_hours) AS total_congestion_hours",
        "FROM {fqn}.train_movements",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of total congestion delay hours; matches 'congestion over time' or 'how have delays changed' using train_movements congestion_hours by snapshot_date."
    },
    {
      "question": "How many distinct unique planning record are there per region?",
      "sql_lines": [
        "SELECT region, COUNT(DISTINCT plan_id) AS distinct_count",
        "FROM {fqn}.corridor_snapshots",
        "GROUP BY region ORDER BY distinct_count DESC"
      ],
      "usage_guidance": "Distinct planning record count grouped by region; matches 'planning records per region' or 'how many plans exist in each region' using corridor_snapshots plan_id."
    },
    {
      "question": "How has average terminal dwell hours changed over time?",
      "sql_lines": [
        "SELECT movement_date, MEASURE(avg_dwell_hours) AS avg_dwell_hours",
        "FROM {fqn}.route_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY movement_date"
      ],
      "usage_guidance": "Monthly trend of average terminal dwell hours; matches 'dwell time over time' or 'how long trains sit at terminals each month' using route_kpi_monthly avg_dwell_hours."
    }
  ],
