          "name": "total_carloads",
          "expr": "SUM(carloads)",
          "comment": "Total carloads shipped"
        },
        {
          "name": "total_revenue",
          "expr": "SUM(revenue_usd)",
          "comment": "Total freight revenue"
        },
        {
          "name": "avg_transit_days",
          "expr": "AVG(transit_days)",
          "comment": "Average transit time days"
        },
