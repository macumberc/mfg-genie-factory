    {
      "table_name": "demand_forecasts",
      "description": "Monthly freight demand forecasts vs actuals by lane and commodity.",
      "columns": [
        {
          "name": "forecast_id",
          "sql_type": "STRING",
          "comment": "Forecast ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('FF-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.lane_id) AS STRING), 7, '0'))"
        },
        {
          "name": "forecast_month",
          "sql_type": "DATE",
          "comment": "Forecast month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "lane_id",
          "sql_type": "STRING",
          "comment": "Lane identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "commodity",
          "sql_type": "STRING",
          "comment": "Commodity",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "origin_region",
          "sql_type": "STRING",
          "comment": "Origin",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "forecasted_carloads",
          "sql_type": "INT",
          "comment": "Forecasted carloads",
          "is_dimension": false,
          "generation_expr": "CAST(100 + FLOOR({qty_noise} * 1900) AS INT)"
        },
        {
          "name": "actual_carloads",
          "sql_type": "INT",
          "comment": "Actual carloads",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(0, (100 + FLOOR({qty_noise} * 1900)) * (0.80 + {status_noise} * 0.40)) AS INT)"
        },
        {
          "name": "forecast_error_pct",
          "sql_type": "DOUBLE",
          "comment": "Absolute forecast error pct",
          "is_dimension": false,
          "generation_expr": "ROUND(ABS(({qty_noise} * 0.40) - 0.10) * 100.0, 2)"
        },
        {
          "name": "forecasted_revenue_usd",
          "sql_type": "DOUBLE",
          "comment": "Forecasted revenue USD",
          "is_dimension": false,
          "generation_expr": "ROUND(50000.0 + ({qty_noise} * 450000.0), 2)"
        },
        {
          "name": "model_version",
          "sql_type": "STRING",
          "comment": "Forecast model version",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'v1.0' WHEN {status_noise} < 0.65 THEN 'v1.1' ELSE 'v1.2' END"
        }
      ],
