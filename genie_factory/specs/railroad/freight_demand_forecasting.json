          "sql_type": "DOUBLE",
          "comment": "Average rate per car USD",
          "is_dimension": false,
          "generation_expr": "ROUND(1500.0 + ({qty_noise} * 3500.0), 2)"
        },
        {
          "name": "utilization_pct",
          "sql_type": "DOUBLE",
          "comment": "Capacity utilization 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(40.0 + ({qty_noise} * 55.0), 2)"
        },
        {
          "name": "demand_trend",
          "sql_type": "STRING",
          "comment": "Trend: Growing, Stable, Declining, Volatile",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Declining' WHEN {status_noise} < 0.30 THEN 'Volatile' WHEN {status_noise} < 0.60 THEN 'Stable' ELSE 'Growing' END"
        }
