      "table_name": "shipping_lanes",
      "description": "Daily freight shipment records per lane with carloads, revenue, and transit times.",
      "columns": [
        {
          "name": "shipment_id",
          "sql_type": "STRING",
          "comment": "Unique shipment ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('FS-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.lane_id) + 10000 AS STRING), 6, '0'))"
        },
        {
          "name": "shipment_date",
          "sql_type": "DATE",
          "comment": "Date of shipment",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "lane_id",
          "sql_type": "STRING",
          "comment": "Freight lane identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "lane_name",
          "sql_type": "STRING",
          "comment": "Lane name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "commodity",
          "sql_type": "STRING",
          "comment": "Commodity type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "origin_region",
          "sql_type": "STRING",
          "comment": "Origin region",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "carloads",
          "sql_type": "INT",
          "comment": "Number of carloads",
          "is_dimension": false,
          "generation_expr": "CAST(5 + FLOOR({qty_noise} * 95) AS INT)"
        },
        {
          "name": "revenue_usd",
          "sql_type": "DOUBLE",
          "comment": "Freight revenue USD",
          "is_dimension": false,
          "generation_expr": "ROUND(5000.0 + ({qty_noise} * 95000.0), 2)"
        },
        {
          "name": "transit_days",
          "sql_type": "DOUBLE",
          "comment": "Transit time in days",
          "is_dimension": false,
          "generation_expr": "ROUND(2.0 + ({qty_noise} * 8.0), 1)"
        },
        {
          "name": "shipment_status",
          "sql_type": "STRING",
          "comment": "Status: Delivered, In Transit, Delayed, Cancelled",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.02 THEN 'Cancelled' WHEN {status_noise} < 0.10 THEN 'Delayed' WHEN {status_noise} < 0.25 THEN 'In Transit' ELSE 'Delivered' END"
        }
      ],
      "seasonal_patterns": {
