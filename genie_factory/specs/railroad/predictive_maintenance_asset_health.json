    {
      "table_name": "maintenance_events",
      "description": "Monthly fleet health forecasts with failure probability, RUL estimates, and maintenance budget.",
      "columns": [
        {
          "name": "forecast_id",
          "sql_type": "STRING",
          "comment": "Health forecast ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('HF-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.asset_id) AS STRING), 7, '0'))"
        },
        {
          "name": "forecast_month",
          "sql_type": "DATE",
          "comment": "Forecast month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "asset_id",
          "sql_type": "STRING",
          "comment": "Asset ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "asset_type",
          "sql_type": "STRING",
          "comment": "Asset type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "fleet",
          "sql_type": "STRING",
          "comment": "Fleet",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "failure_probability_pct",
          "sql_type": "DOUBLE",
          "comment": "30-day failure probability 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 40.0, 2)"
        },
        {
          "name": "remaining_useful_life_days",
          "sql_type": "INT",
          "comment": "Estimated RUL in days",
          "is_dimension": false,
          "generation_expr": "CAST(30 + FLOOR({qty_noise} * 330) AS INT)"
        },
        {
          "name": "maintenance_budget_usd",
          "sql_type": "DOUBLE",
          "comment": "Monthly maintenance budget USD",
          "is_dimension": false,
          "generation_expr": "ROUND(5000.0 + ({qty_noise} * 45000.0), 2)"
        },
        {
          "name": "actual_maintenance_usd",
          "sql_type": "DOUBLE",
          "comment": "Actual maintenance spend USD",
          "is_dimension": false,
          "generation_expr": "ROUND(3000.0 + ({qty_noise} * 47000.0), 2)"
        },
        {
          "name": "risk_level",
          "sql_type": "STRING",
          "comment": "Risk: Low, Medium, High, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.05 THEN 'Critical' WHEN {status_noise} < 0.18 THEN 'High' WHEN {status_noise} < 0.45 THEN 'Medium' ELSE 'Low' END"
        }
      ],
