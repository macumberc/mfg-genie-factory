          "offline hours"
        ]
      },
      {
        "alias": "total_maint_spend",
        "sql": "SUM(sensor_readings.parts_cost_usd + sensor_readings.labor_cost_usd)",
        "display_name": "total maintenance spend",
        "synonyms": [
          "repair spend",
          "total repair cost",
          "maintenance outlay"
        ]
      },
      {
        "alias": "avg_rul",
