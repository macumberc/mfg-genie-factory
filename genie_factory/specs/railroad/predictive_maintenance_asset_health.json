    {
      "table_name": "sensor_readings",
      "description": "Weekly maintenance event records with work orders, parts, and downtime.",
      "columns": [
        {
          "name": "event_id",
          "sql_type": "STRING",
          "comment": "Maintenance event ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('ME-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.asset_id) AS STRING), 7, '0'))"
        },
        {
          "name": "event_date",
          "sql_type": "DATE",
          "comment": "Event date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "asset_id",
          "sql_type": "STRING",
          "comment": "Asset ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "asset_type",
          "sql_type": "STRING",
          "comment": "Asset type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "fleet",
          "sql_type": "STRING",
          "comment": "Fleet",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "event_type",
          "sql_type": "STRING",
          "comment": "Type: Preventive, Corrective, Emergency, Inspection",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'Preventive' WHEN {status_noise} < 0.60 THEN 'Corrective' WHEN {status_noise} < 0.80 THEN 'Inspection' ELSE 'Emergency' END"
        },
        {
          "name": "downtime_hours",
          "sql_type": "DOUBLE",
          "comment": "Asset downtime hours",
          "is_dimension": false,
          "generation_expr": "ROUND(2.0 + ({qty_noise} * 118.0), 1)"
        },
        {
          "name": "parts_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Parts cost USD",
          "is_dimension": false,
          "generation_expr": "ROUND(100.0 + ({qty_noise} * 49900.0), 2)"
        },
        {
          "name": "labor_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Labor cost USD",
          "is_dimension": false,
          "generation_expr": "ROUND(200.0 + ({qty_noise} * 19800.0), 2)"
        },
        {
          "name": "failure_component",
          "sql_type": "STRING",
          "comment": "Component: Engine, Brakes, Wheels, Bearings, Couplers, Electronics",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'Engine' WHEN {status_noise} < 0.38 THEN 'Brakes' WHEN {status_noise} < 0.55 THEN 'Wheels' WHEN {status_noise} < 0.70 THEN 'Bearings' WHEN {status_noise} < 0.85 THEN 'Couplers' ELSE 'Electronics' END"
        }
      ],
