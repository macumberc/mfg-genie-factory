  "benchmarks": [
    {
      "question": "What is the monthly trend in low health count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', reading_date) AS reading_date_month, MEASURE(low_health_count) AS low_health_count",
        "FROM {fqn}.health_monthly",
        "GROUP BY ALL",
        "ORDER BY reading_date_month"
      ]
    },
    {
      "question": "How has unique assets changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(asset_count) AS asset_count",
        "FROM {fqn}.health_monthly",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the monthly trend in emergency count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(emergency_count) AS emergency_count",
        "FROM {fqn}.maintenance_cost_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ]
    },
    {
      "question": "How has unique events changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(event_count) AS event_count",
        "FROM {fqn}.maintenance_cost_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "What are the top 10 rolling stock asset id by total bearing temperature celsius?",
      "sql_lines": [
        "SELECT asset_id, SUM(bearing_temp_celsius) AS total_bearing_temp_celsius",
        "FROM {fqn}.rolling_stock",
        "GROUP BY asset_id ORDER BY total_bearing_temp_celsius DESC LIMIT 10"
      ]
    },
    {
      "question": "How many records are there per event date?",
      "sql_lines": [
        "SELECT event_date, COUNT(*) AS record_count",
        "FROM {fqn}.sensor_readings",
        "GROUP BY event_date ORDER BY event_date"
      ]
    },
    {
      "question": "How many records are there per forecast month?",
      "sql_lines": [
        "SELECT forecast_month, COUNT(*) AS record_count",
        "FROM {fqn}.maintenance_events",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ]
    }
