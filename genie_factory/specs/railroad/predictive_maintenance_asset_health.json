          "name": "reading_id",
          "sql_type": "STRING",
          "comment": "Unique sensor reading ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('SN-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.asset_id) + 10000 AS STRING), 6, '0'))"
        },
        {
          "name": "reading_date",
          "sql_type": "DATE",
          "comment": "Date of reading",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "asset_id",
          "sql_type": "STRING",
          "comment": "Rolling stock asset ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "asset_name",
          "sql_type": "STRING",
          "comment": "Asset name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "asset_type",
          "sql_type": "STRING",
          "comment": "Type: Locomotive, Hopper, Intermodal, Tank, Gondola, Flatcar",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "fleet",
          "sql_type": "STRING",
          "comment": "Fleet assignment",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "vibration_g",
          "sql_type": "DOUBLE",
          "comment": "Vibration level in g-force",
          "is_dimension": false,
          "generation_expr": "ROUND(0.1 + ({qty_noise} * 4.9), 2)"
        },
        {
          "name": "bearing_temp_celsius",
          "sql_type": "DOUBLE",
          "comment": "Bearing temperature Celsius",
          "is_dimension": false,
          "generation_expr": "ROUND(30.0 + ({qty_noise} * 80.0), 1)"
        },
        {
          "name": "oil_pressure_psi",
          "sql_type": "DOUBLE",
          "comment": "Oil pressure in PSI",
          "is_dimension": false,
          "generation_expr": "ROUND(20.0 + ({qty_noise} * 60.0), 1)"
        },
        {
          "name": "health_score",
          "sql_type": "DOUBLE",
          "comment": "ML-predicted health score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(40.0 + ({qty_noise} * 60.0), 1)"
