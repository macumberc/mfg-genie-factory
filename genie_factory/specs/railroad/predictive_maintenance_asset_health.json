  "metric_views": [
    {
      "view_name": "health_monthly",
      "source_table": "rolling_stock",
      "dimensions": [
        {
          "name": "reading_date",
          "expr": "reading_date"
        },
        {
          "name": "asset_type",
          "expr": "asset_type"
        },
        {
          "name": "fleet",
          "expr": "fleet"
        }
      ],
      "measures": [
        {
          "name": "avg_health_score",
          "expr": "AVG(health_score)",
          "comment": "Average ML health score"
        },
        {
          "name": "avg_vibration",
          "expr": "AVG(vibration_g)",
          "comment": "Average vibration g-force"
        },
        {
          "name": "avg_bearing_temp",
          "expr": "AVG(bearing_temp_celsius)",
          "comment": "Average bearing temperature"
        },
        {
          "name": "asset_count",
          "expr": "COUNT(DISTINCT asset_id)",
          "comment": "Number of assets monitored"
        },
        {
          "name": "low_health_count",
          "expr": "COUNT(DISTINCT CASE WHEN health_score < 60 THEN asset_id END)",
          "comment": "Assets with health score below 60"
        },
        {
          "name": "total_oil_pressure_psi",
          "expr": "SUM(oil_pressure_psi)",
          "comment": "Total oil pressure psi"
        },
        {
          "name": "max_vibration_g",
          "expr": "MAX(vibration_g)",
          "comment": "Maximum vibration g"
        }
      ]
    },
    {
      "view_name": "maintenance_cost_monthly",
      "source_table": "sensor_readings",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "asset_type",
          "expr": "asset_type"
        },
        {
          "name": "event_type",
          "expr": "event_type"
        },
        {
          "name": "failure_component",
          "expr": "failure_component"
        }
      ],
      "measures": [
        {
          "name": "total_parts_cost",
          "expr": "SUM(parts_cost_usd)",
          "comment": "Total parts cost USD"
        },
        {
          "name": "total_labor_cost",
          "expr": "SUM(labor_cost_usd)",
          "comment": "Total labor cost USD"
        },
        {
          "name": "total_downtime_hours",
          "expr": "SUM(downtime_hours)",
          "comment": "Total downtime hours"
        },
        {
          "name": "event_count",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total maintenance events"
        },
        {
          "name": "emergency_count",
          "expr": "COUNT(DISTINCT CASE WHEN event_type = 'Emergency' THEN event_id END)",
          "comment": "Emergency event count"
        },
        {
          "name": "unique_asset_count",
          "expr": "COUNT(DISTINCT asset_id)",
          "comment": "Number of distinct assets"
        },
        {
          "name": "max_downtime_hours",
          "expr": "MAX(downtime_hours)",
          "comment": "Maximum downtime hours"
        }
      ]
    }
  ],
  "genie_instructions": "You are a railroad analytics assistant for TrackGuard Systems. Answer questions about predictive maintenance and asset health monitoring for rolling stock using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (asset_id, asset_name), query the base tables directly.\n- When joining tables, use the shared keys: asset_id (shared across maintenance_events, rolling_stock, sensor_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in low health count?",
    "How has unique assets changed over time?",
    "What is the monthly trend in highest vibration g?",
    "How has total oil pressure psi changed over time?",
    "What is the monthly trend in emergency count?",
    "How has unique events changed over time?",
    "What is the monthly trend in unique assets?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest vibration g?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', reading_date) AS reading_date_month, MEASURE(max_vibration_g) AS max_vibration_g",
        "FROM {fqn}.health_monthly",
        "GROUP BY ALL",
        "ORDER BY reading_date_month"
      ],
      "usage_guidance": "Monthly trend of peak vibration levels across rolling stock; matches phrases like 'highest vibration over time' using max_vibration_g from health_monthly."
    },
    {
      "question": "How has total oil pressure psi changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_oil_pressure_psi) AS total_oil_pressure_psi",
        "FROM {fqn}.health_monthly",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series aggregate of oil pressure across the fleet; matches 'oil pressure trend' or 'how has oil pressure changed' using total_oil_pressure_psi from health_monthly."
    },
    {
      "question": "What is the monthly trend in unique assets?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(unique_asset_count) AS unique_asset_count",
        "FROM {fqn}.maintenance_cost_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Monthly trend of distinct assets appearing in maintenance events; matches 'unique assets over time' or 'how many assets had events each month' from maintenance_cost_monthly."
    },
    {
      "question": "How does the number of unique events vary by asset type?",
      "sql_lines": [
        "SELECT asset_type, MEASURE(event_count) AS event_count",
        "FROM {fqn}.maintenance_cost_monthly",
        "GROUP BY ALL",
        "ORDER BY event_count DESC"
      ],
      "usage_guidance": "Category breakdown of maintenance event counts by asset type; matches 'which asset type has most events' or 'event frequency by asset type' ranked descending."
    },
    {
      "question": "What is the trend of total bearing temperature celsius over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(bearing_temp_celsius) AS total_bearing_temp_celsius",
        "FROM {fqn}.rolling_stock",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series sum of bearing temperature across all rolling stock readings; matches 'bearing temp trend' or 'how hot are bearings over time' from rolling_stock table."
    },
    {
      "question": "What is the trend of total asset downtime hours over time?",
      "sql_lines": [
        "SELECT event_date, SUM(downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.sensor_readings",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Daily or monthly trend of cumulative downtime hours from sensor-triggered maintenance; matches 'asset downtime over time' or 'how much downtime occurred each period' from sensor_readings."
    },
    {
      "question": "How has the average 30-day failure probability 0-100 changed over time?",
      "sql_lines": [
        "SELECT forecast_month, AVG(failure_probability_pct) AS avg_failure_probability_pct",
        "FROM {fqn}.maintenance_events",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ],
      "usage_guidance": "Monthly trend of average failure probability forecasts; matches 'failure risk over time' or 'how has predicted failure chance changed' using failure_probability_pct from maintenance_events."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "rolling_stock.health_score < 60",
        "display_name": "low health assets",
        "synonyms": [
          "unhealthy",
          "at risk",
          "at-risk units"
        ],
        "instruction": "Filter to assets with health below 60."
