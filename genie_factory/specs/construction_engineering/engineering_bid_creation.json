  "genie_instructions": "You are a construction & engineering analytics assistant for BuildBid Engineering. Answer questions about engineering bid creation and cost estimation analytics using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (project_id, project_name), query the base tables directly.\n- When joining tables, use the shared keys: project_id (shared across bid_submissions, cost_estimate_snapshots, projects).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in won count?",
    "How has unique bids changed over time?",
    "What is the monthly trend in unique projects?",
    "How has highest estimated cost changed over time?",
    "What is the monthly trend in unique projects?",
    "How has highest bids submitted changed over time?",
    "What is the monthly trend in total bids submitted?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique projects?",
      "sql_lines": [
        "SELECT bid_date, MEASURE(unique_project_count) AS unique_project_count",
        "FROM {fqn}.bid_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY bid_date"
      ],
      "usage_guidance": "Monthly trend of unique projects tracked in bid_kpi_monthly; matches questions about project count volume or portfolio breadth over time."
    },
    {
      "question": "How has highest estimated cost changed over time?",
      "sql_lines": [
        "SELECT bid_date, MEASURE(max_estimated_cost) AS max_estimated_cost",
        "FROM {fqn}.bid_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY bid_date"
      ],
      "usage_guidance": "Time-series trend of the single highest estimated project cost; matches questions about peak or maximum cost estimates changing across bid periods."
    },
    {
      "question": "How has avg competitors per bid changed over time?",
      "sql_lines": [
        "SELECT perf_month, MEASURE(avg_competitors) AS avg_competitors",
        "FROM {fqn}.pipeline_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY perf_month"
      ],
      "usage_guidance": "Monthly trend of average competitor count per bid from pipeline_kpi_monthly; matches questions about competitive intensity or market crowding over time."
    },
    {
      "question": "What is the trend of total estimated project cost usd over time?",
      "sql_lines": [
        "SELECT bid_date, SUM(estimated_cost_usd) AS total_estimated_cost_usd",
        "FROM {fqn}.projects",
        "GROUP BY bid_date ORDER BY bid_date"
      ],
      "usage_guidance": "Time-series aggregate of total estimated project cost in USD directly from the projects table; matches questions about overall cost estimation volume trends by bid date."
    },
    {
      "question": "What is the trend of total labor cost usd over time?",
      "sql_lines": [
        "SELECT estimate_date, SUM(labor_cost_usd) AS total_labor_cost_usd",
        "FROM {fqn}.bid_submissions",
        "GROUP BY estimate_date ORDER BY estimate_date"
      ],
      "usage_guidance": "Time-series aggregate of total labor cost in USD from bid_submissions; matches questions about workforce cost trends or labor spend patterns across estimate dates."
    },
    {
      "question": "How has the average cost estimate accuracy 0-100 changed over time?",
      "sql_lines": [
        "SELECT perf_month, AVG(estimate_accuracy_pct) AS avg_estimate_accuracy_pct",
        "FROM {fqn}.cost_estimate_snapshots",
        "GROUP BY perf_month ORDER BY perf_month"
      ],
      "usage_guidance": "Monthly trend of average cost estimate accuracy percentage from cost_estimate_snapshots; matches questions about estimating precision, forecast quality, or accuracy improvement over time."
    },
    {
      "question": "How has won count changed over time?",
      "sql_lines": [
        "SELECT bid_date, MEASURE(won_count) AS won_count",
        "FROM {fqn}.bid_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY bid_date"
      ],
      "usage_guidance": "Monthly trend of won bid count from bid_kpi_monthly; matches questions about bid win volume, award frequency, or sales success rate over time."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "projects.bid_result = 'Won'",
