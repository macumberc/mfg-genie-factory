    "expressions": [
      {
        "alias": "bid_month",
        "sql": "DATE_TRUNC('month', projects.bid_date)",
        "display_name": "bid month",
        "synonyms": [
          "monthly",
          "tender month",
          "submission month"
        ]
      },
      {
        "alias": "bid_margin",
        "sql": "(projects.bid_amount_usd - projects.estimated_cost_usd) / NULLIF(projects.bid_amount_usd, 0) * 100",
        "display_name": "bid margin pct",
        "synonyms": [
          "markup",
          "markup pct",
          "profit margin"
        ]
      },
      {
        "alias": "total_direct_cost",
        "sql": "bid_submissions.labor_cost_usd + bid_submissions.material_cost_usd + bid_submissions.equipment_cost_usd + bid_submissions.subcontractor_cost_usd",
        "display_name": "total direct cost",
        "synonyms": [
          "project cost",
          "hard costs",
          "direct spend"
        ]
      }
    ],
    "measures": [
