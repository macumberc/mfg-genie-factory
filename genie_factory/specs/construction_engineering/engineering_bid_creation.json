          "quoted revenue"
        ]
      },
      {
        "alias": "avg_accuracy",
        "sql": "AVG(cost_estimate_snapshots.estimate_accuracy_pct)",
        "display_name": "avg estimate accuracy",
        "synonyms": [
          "accuracy",
          "estimate precision",
          "forecast accuracy"
        ]
      },
      {
        "alias": "total_pipeline",
        "sql": "SUM(cost_estimate_snapshots.pipeline_value_usd)",
