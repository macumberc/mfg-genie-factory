  "genie_instructions": "You are a construction & engineering analytics assistant for SiteTrack Construction. Answer questions about construction project monitoring and completion tracking using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (project_id, project_name), query the base tables directly.\n- When joining tables, use the shared keys: project_id (shared across milestone_snapshots, progress_events, projects).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique projects?",
    "How has highest work hours changed over time?",
    "What is the monthly trend in total work hours?",
    "How has total daily cost changed over time?",
    "What is the monthly trend in high risk count?",
    "How has unique projects changed over time?",
    "What is the monthly trend in highest budget at completion?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total work hours?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(total_work_hours) AS total_work_hours",
        "FROM {fqn}.project_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Monthly trend over time for total work hours logged across construction projects, matching phrases like 'work hours over time' or 'labor hours trend by month'."
    },
    {
      "question": "How has total daily cost changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_daily_cost) AS total_daily_cost",
        "FROM {fqn}.project_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Monthly trend over time for total daily cost spend, matching phrases like 'daily cost over time' or 'how has project spending changed month by month'."
    },
    {
      "question": "What is the monthly trend in highest budget at completion?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', forecast_month) AS forecast_month_month, MEASURE(max_budget_at_completion) AS max_budget_at_completion",
        "FROM {fqn}.completion_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY forecast_month_month"
      ],
      "usage_guidance": "Monthly trend over time for the highest single-project budget at completion, matching phrases like 'largest budget forecast trend' or 'max budget at completion over time'."
    },
    {
      "question": "Rank project types by avg schedule variance days",
      "sql_lines": [
        "SELECT project_type, MEASURE(avg_schedule_variance) AS avg_schedule_variance",
        "FROM {fqn}.completion_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY avg_schedule_variance DESC"
      ],
      "usage_guidance": "Top-N ranking of project types by average schedule variance days, matching phrases like 'which project type is most behind schedule' or 'schedule variance by project type'."
    },
    {
      "question": "What is the trend of total work hours logged over time?",
      "sql_lines": [
        "SELECT event_date, SUM(work_hours) AS total_work_hours",
        "FROM {fqn}.projects",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Date-level trend of raw work hours from the projects table, matching phrases like 'daily work hours logged' or 'work hours per event date' using granular project-level data."
    },
    {
      "question": "What is the trend of total milestones completed to date over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(milestones_completed) AS total_milestones_completed",
        "FROM {fqn}.progress_events",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Date-level trend of cumulative milestones completed from progress snapshots, matching phrases like 'milestone completion over time' or 'how many milestones completed per snapshot date'."
    },
    {
      "question": "How many distinct forecast id are there per region?",
      "sql_lines": [
        "SELECT region, COUNT(DISTINCT forecast_id) AS distinct_count",
        "FROM {fqn}.milestone_snapshots",
        "GROUP BY region ORDER BY distinct_count DESC"
      ],
      "usage_guidance": "Count of distinct forecast records per region from milestone snapshots, matching phrases like 'how many forecasts per region' or 'forecast coverage by region'."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "progress_events.project_health = 'Red'",
