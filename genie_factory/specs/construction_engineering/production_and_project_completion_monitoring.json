        "synonyms": [
          "value earned",
          "value delivered",
          "work accomplished"
        ]
      },
      {
        "alias": "total_incidents",
        "sql": "SUM(projects.safety_incidents)",
        "display_name": "total safety incidents",
        "synonyms": [
          "incidents",
          "accident count",
          "safety events"
        ]
      },
      {
        "alias": "avg_spi",
        "sql": "AVG(progress_events.schedule_performance_index)",
