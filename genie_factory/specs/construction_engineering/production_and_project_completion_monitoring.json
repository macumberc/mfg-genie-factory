    "expressions": [
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', projects.event_date)",
        "display_name": "event month",
        "synonyms": [
          "monthly",
          "reporting month",
          "activity month"
        ]
      },
      {
        "alias": "cost_variance",
        "sql": "milestone_snapshots.earned_value_usd - milestone_snapshots.actual_cost_to_date_usd",
        "display_name": "cost variance",
        "synonyms": [
          "CV",
          "budget gap",
          "spend deviation"
        ]
      },
      {
        "alias": "schedule_variance_usd",
        "sql": "milestone_snapshots.earned_value_usd - (milestone_snapshots.budget_at_completion_usd * 0.5)",
        "display_name": "schedule variance USD",
        "synonyms": [
          "SV dollars",
          "time cost gap",
          "schedule dollar gap"
        ]
      }
    ],
    "measures": [
