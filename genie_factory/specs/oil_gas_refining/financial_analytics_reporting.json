  "genie_instructions": "You are an oil & gas refining analytics assistant for RefineLedger Corp. Answer questions about financial analytics and reporting for oil & gas refining operations using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (cost_center_name), query the base tables directly.\n- When joining tables, use the shared keys: cost_center_id (shared across budget_snapshots, financial_kpi_monthly, financial_transactions).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique total transactionss?",
    "How has highest amount changed over time?",
    "What is the monthly trend in total transaction amount usd?",
    "How has total budgeted amount usd changed over time?",
    "What is the monthly trend in highest planned revenue?",
    "How has total actual revenue usd changed over time?",
    "What is the monthly trend in total planned revenue usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total transaction amount usd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', transaction_date) AS transaction_date_month, MEASURE(total_amount_usd) AS total_amount_usd",
        "FROM {fqn}.financial_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date_month"
      ],
      "usage_guidance": "Monthly trend analysis of actual transaction spend in USD across all cost centers, divisions, or regions using the financial_transactions_metrics metric view."
    },
    {
      "question": "How has total budgeted amount usd changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(total_budget_usd) AS total_budget_usd",
        "FROM {fqn}.financial_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series trend of total budgeted amounts in USD over transaction dates, useful for budget tracking and spend planning questions."
    },
    {
      "question": "What is the monthly trend in total planned revenue usd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_month) AS snapshot_month_month, MEASURE(total_planned_revenue) AS total_planned_revenue",
        "FROM {fqn}.budget_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_month_month"
      ],
      "usage_guidance": "Monthly trend of planned revenue in USD from budget snapshots, suited for forward-looking revenue planning and snapshot-based forecasting questions."
    },
    {
      "question": "What is the trend of total transaction amount usd over time?",
      "sql_lines": [
        "SELECT transaction_date, SUM(amount_usd) AS total_amount_usd",
        "FROM {fqn}.financial_transactions",
        "GROUP BY transaction_date ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series aggregation of actual transaction amounts in USD directly from the financial_transactions table, for raw spend trend analysis."
    },
    {
      "question": "What is the trend of total planned monthly revenue usd over time?",
      "sql_lines": [
        "SELECT snapshot_month, SUM(planned_revenue_usd) AS total_planned_revenue_usd",
        "FROM {fqn}.budget_snapshots",
        "GROUP BY snapshot_month ORDER BY snapshot_month"
      ],
      "usage_guidance": "Monthly planned revenue trend from the budget_snapshots table, for questions about forecasted or scheduled revenue over time."
    },
    {
      "question": "How has the average operating margin percentage changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(operating_margin_pct) AS avg_operating_margin_pct",
        "FROM {fqn}.financial_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Trend of average operating margin percentage over time from KPI data, for refining profitability and operational efficiency questions."
    },
    {
      "question": "How has unique total transactionss changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.financial_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Monthly trend of unique transaction counts over time, suited for transaction volume and activity frequency questions using the metric view."
    }
  ],
