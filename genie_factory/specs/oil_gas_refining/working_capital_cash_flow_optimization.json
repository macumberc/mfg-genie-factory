          "is_dimension": false,
          "generation_expr": "CONCAT('RCC-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.business_unit_id) + 100000 AS STRING), 8, '0'))"
        },
        {
          "name": "transaction_date",
          "sql_type": "DATE",
          "comment": "Transaction date",
