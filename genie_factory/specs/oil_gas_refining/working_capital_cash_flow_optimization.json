  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total transactionss?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', transaction_date) AS transaction_date_month, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.cash_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date_month"
      ],
      "usage_guidance": "Monthly trend of transaction count volume; matches phrases like 'how many cash transactions per month' using total_transactions measure from cash_transactions_metrics."
    },
    {
      "question": "How has highest amount changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(max_amount) AS max_amount",
        "FROM {fqn}.cash_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series trend of single largest transaction amount; matches 'peak transaction size over time' using max_amount measure from cash_transactions_metrics."
    },
    {
      "question": "What is the monthly trend in total ap usd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(total_payables_usd) AS total_payables_usd",
        "FROM {fqn}.working_capital_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ],
      "usage_guidance": "Monthly trend of total accounts payable balance; matches 'how are payables changing over time' using total_payables_usd from working_capital_snapshots_metrics."
    },
    {
      "question": "What is the trend of total cash flow amount usd (positive=inflow) over time?",
      "sql_lines": [
        "SELECT transaction_date, SUM(amount_usd) AS total_amount_usd",
        "FROM {fqn}.cash_transactions",
        "GROUP BY transaction_date ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series aggregate of net cash flow amounts (inflows positive, outflows negative); matches 'cash movement trend' using raw amount_usd from cash_transactions table."
    },
    {
      "question": "What is the trend of total ar balance usd over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(accounts_receivable_usd) AS total_accounts_receivable_usd",
        "FROM {fqn}.working_capital_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of total accounts receivable balance; matches 'AR balance over time' using accounts_receivable_usd directly from working_capital_snapshots table."
    },
    {
      "question": "How has the average current ratio changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(current_ratio) AS avg_current_ratio",
        "FROM {fqn}.cashflow_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly trend of average liquidity ratio; matches 'how is current ratio trending' using current_ratio from cashflow_monthly KPI table."
    },
    {
      "question": "How has unique total transactionss changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.cash_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Duplicate of index 0 — monthly transaction count trend; matches 'how has transaction volume evolved' using total_transactions measure from cash_transactions_metrics."
    }
  ],
