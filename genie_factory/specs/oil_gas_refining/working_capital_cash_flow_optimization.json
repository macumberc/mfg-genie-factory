  "metric_views": [
    {
      "view_name": "cash_transactions_metrics",
      "source_table": "cash_transactions",
      "dimensions": [
        {
          "name": "transaction_date",
          "expr": "transaction_date"
        },
        {
          "name": "business_unit_id",
          "expr": "business_unit_id"
        },
        {
          "name": "segment",
          "expr": "segment"
        },
        {
          "name": "region",
          "expr": "region"
        },
        {
          "name": "flow_type",
          "expr": "flow_type"
        }
      ],
      "measures": [
        {
          "name": "total_inflows_usd",
          "expr": "SUM(CASE WHEN amount_usd > 0 THEN amount_usd ELSE 0 END)",
          "comment": "Total inflows USD"
        },
        {
          "name": "total_outflows_usd",
          "expr": "SUM(CASE WHEN amount_usd < 0 THEN ABS(amount_usd) ELSE 0 END)",
          "comment": "Total outflows USD"
        },
        {
          "name": "net_cash_flow_usd",
          "expr": "SUM(amount_usd)",
          "comment": "Net cash flow USD"
        },
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT transaction_id)",
          "comment": "Total transactions"
        },
        {
          "name": "max_amount",
          "expr": "MAX(amount_usd)",
          "comment": "Maximum amount usd"
        },
        {
          "name": "total_days_outstanding",
          "expr": "SUM(days_outstanding)",
          "comment": "Total days outstanding"
        }
      ]
    },
    {
      "view_name": "working_capital_snapshots_metrics",
      "source_table": "working_capital_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "business_unit_id",
          "expr": "business_unit_id"
        },
        {
          "name": "segment",
          "expr": "segment"
        },
        {
          "name": "region",
          "expr": "region"
        }
      ],
      "measures": [
        {
          "name": "total_receivables_usd",
          "expr": "SUM(accounts_receivable_usd)",
          "comment": "Total AR USD"
        },
        {
          "name": "total_payables_usd",
          "expr": "SUM(accounts_payable_usd)",
          "comment": "Total AP USD"
        },
        {
          "name": "total_cash_balance_usd",
          "expr": "SUM(cash_balance_usd)",
          "comment": "Total cash USD"
        },
        {
          "name": "avg_dso_days",
          "expr": "AVG(dso_days)",
          "comment": "Average DSO"
        },
        {
          "name": "total_inventory",
          "expr": "SUM(inventory_usd)",
          "comment": "Total inventory usd"
        },
        {
          "name": "total_dpo_days",
          "expr": "SUM(dpo_days)",
          "comment": "Total dpo days"
        },
        {
          "name": "max_accounts_receivable",
          "expr": "MAX(accounts_receivable_usd)",
          "comment": "Maximum accounts receivable usd"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The cash_transactions_metrics view (source: cash_transactions) has dimensions: transaction_date, business_unit_id, segment, region, flow_type. Measures: total_inflows_usd, total_outflows_usd, net_cash_flow_usd, total_transactions. The working_capital_snapshots_metrics view (source: working_capital_snapshots) has dimensions: snapshot_date, business_unit_id, segment, region. Measures: total_receivables_usd, total_payables_usd, total_cash_balance_usd, avg_dso_days. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. business_unit_name).",
  "sample_questions": [
    "What is the monthly trend in total inflows usd count?",
    "How has total outflows usd count changed over time?",
    "What is the monthly trend in unique total transactionss?",
    "How has highest amount changed over time?",
    "What is the monthly trend in highest accounts receivable?",
    "How has total ar usd changed over time?",
    "What is the monthly trend in total ap usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total transactionss?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.cash_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ]
    },
    {
      "question": "How has highest amount changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(max_amount) AS max_amount",
        "FROM {fqn}.cash_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ]
    },
    {
      "question": "What is the monthly trend in total ap usd?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_payables_usd) AS total_payables_usd",
        "FROM {fqn}.working_capital_snapshots_metrics",
        "GROUP BY ALL",
