          "comment": "Region",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "flow_type",
          "sql_type": "STRING",
          "comment": "Flow: Collection, Disbursement, Intercompany, Tax Payment, Dividend",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'Collection' WHEN {status_noise} < 0.65 THEN 'Disbursement' WHEN {status_noise} < 0.80 THEN 'Intercompany' WHEN {status_noise} < 0.92 THEN 'Tax Payment' ELSE 'Dividend' END"
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Cash flow amount USD (positive=inflow)",
          "is_dimension": false,
          "generation_expr": "ROUND(CASE WHEN {status_noise} < 0.35 THEN {qty_noise} * 6000000.0 ELSE -{qty_noise} * 4500000.0 END, 2)"
        },
        {
          "name": "counterparty",
          "sql_type": "STRING",
          "comment": "Counterparty type",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Customer' WHEN {status_noise} < 0.55 THEN 'Supplier' WHEN {status_noise} < 0.72 THEN 'Government' WHEN {status_noise} < 0.88 THEN 'Internal' ELSE 'Shareholder' END"
        },
        {
          "name": "days_outstanding",
          "sql_type": "INT",
          "comment": "Days since invoice",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(0, FLOOR({qty_noise} * 120)) AS INT)"
        }
