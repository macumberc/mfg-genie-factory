          "sql_type": "DOUBLE",
          "comment": "Feed API gravity",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(15.0, 25.0 + {qty_noise} * 20.0), 1)"
        },
        {
          "name": "status",
          "sql_type": "STRING",
          "comment": "Status: Running, Reduced Rate, Shutdown, Startup",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.75 THEN 'Running' WHEN {status_noise} < 0.85 THEN 'Reduced Rate' WHEN {status_noise} < 0.94 THEN 'Shutdown' ELSE 'Startup' END",
          "entity_values": [
            "Running",
            "Reduced Rate",
            "Shutdown",
            "Startup"
          ]
        }
