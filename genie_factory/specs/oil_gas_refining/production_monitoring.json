        {
          "name": "utilization_pct",
          "sql_type": "DOUBLE",
          "comment": "Unit utilization percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(50.0, 82.0 + ({qty_noise} - 0.5) * 30.0)), 1)"
