        {
          "name": "yield_pct",
          "sql_type": "DOUBLE",
          "comment": "Product yield percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(99.0, GREATEST(50.0, 80.0 + ({qty_noise} - 0.5) * 30.0)), 1)"
