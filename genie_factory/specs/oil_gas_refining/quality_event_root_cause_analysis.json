          "sql_type": "STRING",
          "comment": "Unique quality event identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('QE-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.unit_id) + 100000 AS STRING), 8, '0'))"
        },
        {
          "name": "event_date",
          "sql_type": "DATE",
