        {
          "name": "product_grade",
          "sql_type": "STRING",
          "comment": "Product grade: Premium Gasoline, Regular Gasoline, Diesel, Jet Fuel, Fuel Oil, Naphtha",
          "is_dimension": true,
          "generation_expr": "",
          "entity_values": [
            "Naphtha",
            "Diesel",
            "Fuel Oil",
            "Regular Gasoline",
            "Premium Gasoline",
            "Jet Fuel"
          ],
          "synonyms": [
            "fuel type",
            "product type"
          ]
        },
        {
          "name": "deviation_type",
          "sql_type": "STRING",
          "comment": "Type: Off-Spec, Process Upset, Contamination, Yield Loss, Temperature Excursion",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Off-Spec' WHEN {status_noise} < 0.50 THEN 'Process Upset' WHEN {status_noise} < 0.65 THEN 'Contamination' WHEN {status_noise} < 0.82 THEN 'Yield Loss' ELSE 'Temperature Excursion' END",
          "entity_values": [
            "Off-Spec",
            "Process Upset",
            "Contamination",
            "Yield Loss",
            "Temperature Excursion"
          ]
        },
        {
          "name": "root_cause",
          "sql_type": "STRING",
          "comment": "Root cause category",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.14 THEN 'Catalyst Degradation' WHEN {status_noise} < 0.28 THEN 'Feedstock Variation' WHEN {status_noise} < 0.42 THEN 'Equipment Malfunction' WHEN {status_noise} < 0.56 THEN 'Operator Error' WHEN {status_noise} < 0.68 THEN 'Process Control Drift' WHEN {status_noise} < 0.80 THEN 'Fouling Accumulation' WHEN {status_noise} < 0.90 THEN 'Corrosion Product' ELSE 'Unknown' END",
          "entity_values": [
            "Catalyst Degradation",
            "Feedstock Variation",
            "Equipment Malfunction",
            "Operator Error",
            "Process Control Drift",
            "Fouling Accumulation",
            "Corrosion Product",
            "Unknown"
          ]
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Severity: Minor, Moderate, Major, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN 'Minor' WHEN {status_noise} < 0.70 THEN 'Moderate' WHEN {status_noise} < 0.90 THEN 'Major' ELSE 'Critical' END",
          "entity_values": [
            "Minor",
            "Moderate",
            "Major",
            "Critical"
          ]
        },
        {
          "name": "off_spec_volume_bbl",
          "sql_type": "DOUBLE",
          "comment": "Off-spec product volume in barrels",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.0, {qty_noise} * 5000.0), 0)"
        },
        {
          "name": "financial_impact_usd",
          "sql_type": "DOUBLE",
          "comment": "Financial impact in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(500.0, {qty_noise} * 250000.0), 2)"
        },
        {
          "name": "resolution_hours",
          "sql_type": "DOUBLE",
          "comment": "Time to resolution in hours",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.5, 1.0 + {qty_noise} * 48.0), 1)"
        }
      ],
