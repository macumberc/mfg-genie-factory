  "company_name": "RefineGuard Systems",
  "industry": "Oil & Gas Refining",
  "use_case": "Predictive maintenance and asset health monitoring for refinery equipment",
  "space_title": "RefineGuard Systems - Predictive Maintenance & Asset Health 🔧",
  "space_description": "Asset health analytics for RefineGuard Systems. Ask questions about refinery equipment health, sensor readings, maintenance events, and failure predictions across 20 critical refinery assets including pumps, compressors, heat exchangers, and reactors.",
  "schema_basename": "og_refining_pred_maint",
  "tables": [
    {
      "table_name": "sensor_readings",
      "description": "Real-time sensor telemetry from refinery equipment including temperature, pressure, vibration, and flow measurements.",
      "columns": [
        {
          "name": "reading_id",
          "sql_type": "STRING",
          "comment": "Unique sensor reading identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('SR-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.equipment_id) + 100000 AS STRING), 8, '0'))"
        },
        {
          "name": "reading_timestamp",
          "sql_type": "DATE",
          "comment": "Date of the sensor reading",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "equipment_id",
          "sql_type": "STRING",
          "comment": "Refinery equipment identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "equipment_name",
          "sql_type": "STRING",
          "comment": "Equipment name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "equipment_type",
          "sql_type": "STRING",
          "comment": "Equipment type: Pump, Compressor, Heat Exchanger, Reactor, Column, Furnace",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "process_unit",
          "sql_type": "STRING",
          "comment": "Refinery process unit name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "sensor_type",
          "sql_type": "STRING",
          "comment": "Sensor measurement type",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.10 THEN 'Vibration' WHEN {status_noise} < 0.20 THEN 'Temperature' WHEN {status_noise} < 0.30 THEN 'Pressure' WHEN {status_noise} < 0.40 THEN 'Flow Rate' WHEN {status_noise} < 0.50 THEN 'Motor Current' WHEN {status_noise} < 0.58 THEN 'Bearing Temp' WHEN {status_noise} < 0.66 THEN 'Corrosion Rate' WHEN {status_noise} < 0.74 THEN 'Thickness' WHEN {status_noise} < 0.82 THEN 'Acoustic Emission' WHEN {status_noise} < 0.90 THEN 'RPM' ELSE 'Differential Pressure' END"
        },
        {
          "name": "sensor_value",
          "sql_type": "DOUBLE",
          "comment": "Raw sensor measurement value",
          "is_dimension": false,
          "generation_expr": "ROUND(20.0 + {qty_noise} * 480.0, 2)"
        },
        {
          "name": "health_score",
          "sql_type": "DOUBLE",
          "comment": "AI-computed equipment health score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(0.0, 70.0 + ({qty_noise} - 0.5) * 60.0)), 1)"
        },
        {
          "name": "alert_level",
          "sql_type": "STRING",
          "comment": "Alert level: Normal, Advisory, Warning, Alarm, Trip",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'Normal' WHEN {status_noise} < 0.75 THEN 'Advisory' WHEN {status_noise} < 0.88 THEN 'Warning' WHEN {status_noise} < 0.96 THEN 'Alarm' ELSE 'Trip' END"
        },
        {
          "name": "predicted_rul_days",
          "sql_type": "INT",
          "comment": "Predicted remaining useful life in days",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(1, 10 + FLOOR({qty_noise} * 300)) AS INT)"
        }
      ],
      "seasonal_patterns": {
        "Crude Distillation": {
          "3,4,9,10": 0.05
        },
        "Catalytic Cracking": {
          "6,7,8": 0.06
