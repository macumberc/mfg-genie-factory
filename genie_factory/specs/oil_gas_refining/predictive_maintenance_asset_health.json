    {
      "table_name": "equipment_health_monthly",
      "description": "Monthly aggregated equipment health KPIs including MTBF, MTTR, availability, and failure prediction accuracy.",
      "columns": [
        {
          "name": "snapshot_id",
          "sql_type": "STRING",
          "comment": "Unique monthly snapshot identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('EH-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.equipment_id) + 30000 AS STRING), 6, '0'))"
        },
        {
          "name": "snapshot_month",
          "sql_type": "DATE",
          "comment": "First day of the snapshot month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "equipment_id",
          "sql_type": "STRING",
          "comment": "Equipment identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "equipment_type",
