      "table_name": "maintenance_events",
      "description": "Maintenance work orders for refinery equipment including planned turnarounds, predictive actions, and corrective repairs.",
      "columns": [
        {
          "name": "event_id",
          "sql_type": "STRING",
          "comment": "Unique maintenance event identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('ME-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.equipment_id) + 50000 AS STRING), 7, '0'))"
        },
        {
          "name": "event_date",
          "sql_type": "DATE",
          "comment": "Date of the maintenance event",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "equipment_id",
          "sql_type": "STRING",
          "comment": "Equipment identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "equipment_name",
          "sql_type": "STRING",
