          "expr": "alert_level"
        }
      ],
      "measures": [
        {
          "name": "avg_health_score",
          "expr": "AVG(health_score)",
          "comment": "Average equipment health score"
        },
        {
          "name": "total_readings",
          "expr": "COUNT(DISTINCT reading_id)",
          "comment": "Total sensor readings"
        },
        {
          "name": "alarm_trip_count",
          "expr": "COUNT(DISTINCT CASE WHEN alert_level IN ('Alarm', 'Trip') THEN reading_id END)",
          "comment": "Count of alarm and trip events"
        },
        {
          "name": "min_rul_days",
          "expr": "MIN(predicted_rul_days)",
          "comment": "Minimum predicted remaining useful life"
        },
