          "comment": "Equipment type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "process_unit",
          "sql_type": "STRING",
          "comment": "Refinery process unit",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "event_type",
          "sql_type": "STRING",
          "comment": "Type: Planned PM, Predictive, Corrective, Turnaround, Inspection, Emergency",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.28 THEN 'Planned PM' WHEN {status_noise} < 0.48 THEN 'Predictive' WHEN {status_noise} < 0.65 THEN 'Corrective' WHEN {status_noise} < 0.78 THEN 'Turnaround' WHEN {status_noise} < 0.90 THEN 'Inspection' ELSE 'Emergency' END"
        },
        {
          "name": "failure_mode",
          "sql_type": "STRING",
          "comment": "Root cause failure mode",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.10 THEN 'Fouling' WHEN {status_noise} < 0.20 THEN 'Corrosion' WHEN {status_noise} < 0.30 THEN 'Erosion' WHEN {status_noise} < 0.40 THEN 'Catalyst Deactivation' WHEN {status_noise} < 0.50 THEN 'Seal Failure' WHEN {status_noise} < 0.58 THEN 'Bearing Wear' WHEN {status_noise} < 0.66 THEN 'Tube Leak' WHEN {status_noise} < 0.74 THEN 'Coking' WHEN {status_noise} < 0.82 THEN 'Vibration Fatigue' WHEN {status_noise} < 0.90 THEN 'Tray Damage' ELSE 'Refractory Failure' END"
        },
        {
          "name": "was_predicted",
          "sql_type": "BOOLEAN",
          "comment": "Whether the failure was predicted by the ML model",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.42 THEN TRUE ELSE FALSE END"
        },
        {
          "name": "downtime_hours",
          "sql_type": "DOUBLE",
          "comment": "Equipment downtime in hours",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.5, 2.0 + {qty_noise} * 96.0), 1)"
        },
        {
          "name": "throughput_loss_bbl",
          "sql_type": "DOUBLE",
          "comment": "Refinery throughput loss in barrels",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.0, {qty_noise} * 12000.0), 0)"
        },
        {
          "name": "repair_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Total repair cost in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(3000 + {qty_noise} * 350000, 2)"
        }
      ],
