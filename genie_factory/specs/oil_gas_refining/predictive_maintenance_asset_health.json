  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The sensor_readings_metrics view (source: sensor_readings) has dimensions: reading_timestamp, equipment_id, equipment_type, process_unit, alert_level. Measures: avg_health_score, total_readings, alarm_trip_count, min_rul_days. The maintenance_events_metrics view (source: maintenance_events) has dimensions: event_date, equipment_id, equipment_type, process_unit, event_type, failure_mode, was_predicted. Measures: total_events, total_downtime_hours, total_throughput_loss_bbl, total_repair_cost_usd, avg_repair_cost_usd. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. equipment_name).",
  "sample_questions": [
    "What is the alarm trip count by reading timestamp?",
    "Which reading timestamps have the most unique total readingss?",
    "What is the highest sensor value for each reading timestamp?",
    "Rank reading timestamps by total sensor value",
    "What is the monthly trend in unique total eventss?",
    "How has highest downtime hours changed over time?",
    "What is the monthly trend in total equipment downtime?"
  ],
  "example_sqls": [
    {
      "question": "What is the highest sensor value for each reading timestamp?",
      "sql_lines": [
        "SELECT reading_timestamp, MEASURE(max_sensor_value) AS max_sensor_value",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY max_sensor_value DESC"
      ]
    },
    {
      "question": "Rank reading timestamps by total sensor value",
      "sql_lines": [
        "SELECT reading_timestamp, MEASURE(total_sensor_value) AS total_sensor_value",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY total_sensor_value DESC"
      ]
    },
    {
      "question": "What is the monthly trend in total equipment downtime?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.maintenance_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "What is the trend of total raw sensor measurement value over time?",
      "sql_lines": [
        "SELECT reading_timestamp, SUM(sensor_value) AS total_sensor_value",
        "FROM {fqn}.sensor_readings",
        "GROUP BY reading_timestamp ORDER BY reading_timestamp"
      ]
    },
    {
      "question": "What is the trend of total equipment downtime in hours over time?",
      "sql_lines": [
        "SELECT event_date, SUM(downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.maintenance_events",
        "GROUP BY event_date ORDER BY event_date"
      ]
    },
    {
      "question": "How has the average average health score for the month changed over time?",
      "sql_lines": [
        "SELECT snapshot_month, AVG(avg_health_score) AS avg_avg_health_score",
        "FROM {fqn}.equipment_health_monthly",
        "GROUP BY snapshot_month ORDER BY snapshot_month"
      ]
