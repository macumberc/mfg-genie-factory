          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "process_unit",
          "sql_type": "STRING",
          "comment": "Refinery process unit",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "avg_health_score",
          "sql_type": "DOUBLE",
          "comment": "Average health score for the month",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(30.0, 72.0 + ({qty_noise} - 0.5) * 44.0)), 1)"
        },
        {
          "name": "mtbf_days",
          "sql_type": "DOUBLE",
          "comment": "Mean time between failures in days",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(5.0, 25.0 + {qty_noise} * 120.0), 1)"
        },
        {
          "name": "mttr_hours",
          "sql_type": "DOUBLE",
          "comment": "Mean time to repair in hours",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(1.0, 3.0 + {qty_noise} * 45.0), 1)"
        },
        {
          "name": "availability_pct",
          "sql_type": "DOUBLE",
          "comment": "Equipment availability percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(82.0, 94.0 + ({qty_noise} - 0.5) * 12.0)), 2)"
        },
        {
          "name": "prediction_accuracy_pct",
          "sql_type": "DOUBLE",
          "comment": "ML prediction accuracy percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(99.0, GREATEST(50.0, 75.0 + ({qty_noise} - 0.5) * 30.0)), 1)"
        }
      ],
