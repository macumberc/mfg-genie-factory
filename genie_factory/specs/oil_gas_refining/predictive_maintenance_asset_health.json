  "metric_views": [
    {
      "view_name": "sensor_readings_metrics",
      "source_table": "sensor_readings",
      "dimensions": [
        {
          "name": "reading_timestamp",
          "expr": "reading_timestamp"
        },
        {
          "name": "equipment_id",
          "expr": "equipment_id"
        },
        {
          "name": "equipment_type",
