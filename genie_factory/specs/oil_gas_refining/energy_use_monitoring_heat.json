  "genie_instructions": "You are an oil & gas refining analytics assistant for HeatTrack Refining. Answer questions about energy use monitoring and heat exchange optimization for refinery operations using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (exchanger_name), query the base tables directly.\n- When joining tables, use the shared keys: exchanger_id (shared across energy_kpi_monthly, energy_readings, thermal_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in highest energy consumption mmbtu?",
    "How has total energy consumption mmbtu changed over time?",
    "What is the monthly trend in total inlet temp f?",
    "How has total outlet temp f changed over time?",
    "What is the monthly trend in highest clean ua btu hr f?",
    "How has total co2 emissions in metric tons changed over time?",
    "What is the monthly trend in average heat transfer effectiveness?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total inlet temp f?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_inlet_temp_f) AS total_inlet_temp_f",
        "FROM {fqn}.energy_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Monthly trend of total inlet temperature across all heat exchangers; matches questions about inlet temp patterns or feed temperature over time."
    },
    {
      "question": "How has total outlet temp f changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_outlet_temp_f) AS total_outlet_temp_f",
        "FROM {fqn}.energy_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of total outlet temperature across exchangers; matches questions about outlet temp changes or product temperature history."
    },
    {
      "question": "What is the monthly trend in average heat transfer effectiveness?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(avg_effectiveness_pct) AS avg_effectiveness_pct",
        "FROM {fqn}.thermal_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly trend of average heat transfer effectiveness percentage; matches questions about exchanger effectiveness or thermal performance over time."
    },
    {
      "question": "What is the trend of total energy consumption in mmbtu over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(energy_consumption_mmbtu) AS total_energy_consumption_mmbtu",
        "FROM {fqn}.energy_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series aggregate of total energy consumption in MMBtu; matches questions about refinery-wide energy usage trends or consumption history."
    },
    {
      "question": "What is the trend of total clean ua value btu/hr/f over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(clean_ua_btu_hr_f) AS total_clean_ua_btu_hr_f",
        "FROM {fqn}.thermal_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of total clean UA heat transfer coefficient; matches questions about baseline heat transfer capacity or clean UA values over time."
    },
    {
      "question": "How has the average solomon energy efficiency index (lower=better) changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(energy_efficiency_index) AS avg_energy_efficiency_index",
        "FROM {fqn}.energy_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly trend of average Solomon Energy Efficiency Index; matches questions about refinery energy benchmarking, EEI performance, or efficiency index changes over time."
    },
    {
      "question": "How has total inlet temp f changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_inlet_temp_f) AS total_inlet_temp_f",
        "FROM {fqn}.energy_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of total inlet temperature using metric view; matches questions about feed temperature history or inlet temp fluctuations across the refinery."
    }
  ],
