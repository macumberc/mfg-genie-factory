          "sql_type": "STRING",
          "comment": "Line",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "microbe_count_cfu",
          "sql_type": "INT",
          "comment": "Microbial count CFU/g",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 1000) AS INT)"
        },
        {
          "name": "ph_level",
          "sql_type": "DOUBLE",
          "comment": "pH level",
          "is_dimension": false,
          "generation_expr": "ROUND(3.5 + ({qty_noise} * 4.0), 2)"
        },
        {
          "name": "temperature_compliance",
          "sql_type": "STRING",
          "comment": "Temp compliance: Pass, Marginal, Fail",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.03 THEN 'Fail' WHEN {status_noise} < 0.12 THEN 'Marginal' ELSE 'Pass' END"
        },
        {
          "name": "overall_score",
          "sql_type": "DOUBLE",
          "comment": "Overall quality score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(65.0 + ({qty_noise} * 35.0), 1)"
        },
        {
          "name": "disposition",
          "sql_type": "STRING",
          "comment": "Disposition: Released, Hold, Rework, Rejected",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.03 THEN 'Rejected' WHEN {status_noise} < 0.10 THEN 'Rework' WHEN {status_noise} < 0.20 THEN 'Hold' ELSE 'Released' END"
        }
      ],
