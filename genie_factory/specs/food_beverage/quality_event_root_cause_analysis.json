    {
      "question": "What are the top 10 product id by total units affected?",
      "sql_lines": [
        "SELECT product_id, SUM(units_affected) AS total_units_affected",
        "FROM {fqn}.product_lines",
        "GROUP BY product_id ORDER BY total_units_affected DESC LIMIT 10"
      ]
