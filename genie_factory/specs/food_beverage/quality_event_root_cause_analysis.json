  "genie_instructions": "You are a food & beverage analytics assistant for FreshGuard Foods. Answer questions about quality event tracking and root cause analysis for food production using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (product_id, product_name), query the base tables directly.\n- When joining tables, use the shared keys: product_id (shared across inspection_records, product_lines, quality_events).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in critical events count?",
    "How has unique total eventss changed over time?",
    "What is the monthly trend in unique products?",
    "How has highest units affected changed over time?",
    "What is the monthly trend in nc count?",
    "How has unique products changed over time?",
    "What is the monthly trend in highest events count?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique products?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(unique_product_count) AS unique_product_count",
        "FROM {fqn}.quality_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Monthly trend of distinct products with quality events; matches phrases like 'unique product count over time' using quality_kpi_monthly.unique_product_count."
    },
    {
      "question": "How has highest units affected changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(max_units_affected) AS max_units_affected",
        "FROM {fqn}.quality_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Time-series of peak units affected per period; matches 'worst single batch impact over time' using quality_kpi_monthly.max_units_affected."
    },
    {
      "question": "What is the monthly trend in highest events count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', kpi_month) AS kpi_month_month, MEASURE(max_events_count) AS max_events_count",
        "FROM {fqn}.inspection_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY kpi_month_month"
      ],
      "usage_guidance": "Monthly trend of highest single-line event counts; matches 'peak inspection events per month' using inspection_kpi_monthly.max_events_count."
    },
    {
      "question": "How has nc count changed over time?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(nc_count) AS nc_count",
        "FROM {fqn}.inspection_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ],
      "usage_guidance": "Time-series of non-conformance counts; matches 'how are NC rates trending' using inspection_kpi_monthly.nc_count."
    },
    {
      "question": "What is the trend of total units affected over time?",
      "sql_lines": [
        "SELECT event_date, SUM(units_affected) AS total_units_affected",
        "FROM {fqn}.product_lines",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Date-level trend of total production units affected by quality events; matches 'units impacted over time' from product_lines.units_affected."
    },
    {
      "question": "What is the trend of total microbial count cfu/g over time?",
      "sql_lines": [
        "SELECT inspection_date, SUM(microbe_count_cfu) AS total_microbe_count_cfu",
        "FROM {fqn}.quality_events",
        "GROUP BY inspection_date ORDER BY inspection_date"
      ],
      "usage_guidance": "Daily trend of cumulative microbial load across inspections; matches 'microbial count CFU trend' from quality_events.microbe_count_cfu."
    },
    {
      "question": "How has the average regulatory audit score 0-100 changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(audit_score) AS avg_audit_score",
        "FROM {fqn}.inspection_records",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly trend of average regulatory audit scores; matches 'how are audit scores changing' from inspection_records.audit_score."
    }
  ],
  "sql_snippets": {
