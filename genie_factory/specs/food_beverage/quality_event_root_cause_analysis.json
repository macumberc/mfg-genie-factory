    {
      "question": "What is the average overall quality score 0-100 by category?",
      "sql_lines": [
        "SELECT product_category, AVG(overall_score) AS avg_overall_score",
        "FROM {fqn}.quality_events",
        "GROUP BY product_category ORDER BY avg_overall_score DESC"
      ]
