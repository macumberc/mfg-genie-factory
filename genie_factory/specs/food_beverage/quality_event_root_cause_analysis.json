  "metric_views": [
    {
      "view_name": "quality_kpi_monthly",
      "source_table": "product_lines",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "severity",
          "expr": "severity"
        },
        {
          "name": "root_cause",
          "expr": "root_cause"
        }
      ],
      "measures": [
        {
          "name": "total_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total quality events"
        },
        {
          "name": "total_units_affected",
          "expr": "SUM(units_affected)",
          "comment": "Total units affected"
        },
        {
          "name": "total_cost_impact",
          "expr": "SUM(cost_impact_usd)",
          "comment": "Total cost impact USD"
        },
        {
          "name": "critical_events",
          "expr": "COUNT(DISTINCT CASE WHEN severity = 'Critical' THEN event_id END)",
          "comment": "Critical event count"
        },
        {
          "name": "avg_cost_per_event",
          "expr": "AVG(cost_impact_usd)",
          "comment": "Avg cost per event"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_units_affected",
          "expr": "MAX(units_affected)",
          "comment": "Maximum units affected"
        }
      ]
    },
    {
      "view_name": "inspection_kpi_monthly",
      "source_table": "inspection_records",
      "dimensions": [
        {
          "name": "kpi_month",
          "expr": "kpi_month"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "production_line",
          "expr": "production_line"
        },
        {
          "name": "compliance_status",
          "expr": "compliance_status"
        }
      ],
      "measures": [
        {
          "name": "total_events_count",
          "expr": "SUM(events_count)",
          "comment": "Total monthly events"
        },
        {
          "name": "total_capa_open",
          "expr": "SUM(capa_open)",
          "comment": "Total open CAPAs"
        },
        {
          "name": "total_capa_closed",
          "expr": "SUM(capa_closed)",
          "comment": "Total closed CAPAs"
        },
        {
