    {
      "table_name": "inspection_records",
      "description": "Monthly quality KPI summaries with CAPA tracking and regulatory audit results.",
      "columns": [
        {
          "name": "kpi_id",
          "sql_type": "STRING",
          "comment": "KPI record ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('QK-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.product_id) AS STRING), 7, '0'))"
        },
        {
          "name": "kpi_month",
          "sql_type": "DATE",
          "comment": "KPI month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "product_id",
          "sql_type": "STRING",
          "comment": "Product ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_category",
          "sql_type": "STRING",
          "comment": "Category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "production_line",
          "sql_type": "STRING",
          "comment": "Line",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "events_count",
          "sql_type": "INT",
          "comment": "Quality events in month",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 20) AS INT)"
        },
        {
          "name": "capa_open",
          "sql_type": "INT",
          "comment": "Open CAPAs",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 10) AS INT)"
        },
        {
          "name": "capa_closed",
          "sql_type": "INT",
          "comment": "Closed CAPAs",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 15) AS INT)"
        },
        {
          "name": "audit_score",
          "sql_type": "DOUBLE",
          "comment": "Regulatory audit score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(70.0 + ({qty_noise} * 30.0), 1)"
        },
        {
          "name": "compliance_status",
          "sql_type": "STRING",
          "comment": "Status: Compliant, Observation, Non-Conformance",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.05 THEN 'Non-Conformance' WHEN {status_noise} < 0.20 THEN 'Observation' ELSE 'Compliant' END"
        }
      ],
