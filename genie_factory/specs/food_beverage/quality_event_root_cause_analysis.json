{
  "company_name": "FreshGuard Foods",
  "industry": "Food & Beverage",
  "use_case": "Quality event tracking and root cause analysis for food production",
  "space_title": "FreshGuard Foods - Quality Event Root Cause Analysis 🔍",
  "space_description": "Food quality analytics for FreshGuard Foods. Ask about quality events, root causes, corrective actions, and trend analysis across 20 food product lines.",
  "schema_basename": "fb_quality_rca",
  "tables": [
    {
      "table_name": "product_lines",
      "description": "Daily quality event records per product line with severity, root cause, and disposition.",
      "columns": [
        {
          "name": "event_id",
          "sql_type": "STRING",
          "comment": "Quality event ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('QE-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.product_id) + 10000 AS STRING), 6, '0'))"
        },
        {
          "name": "event_date",
          "sql_type": "DATE",
          "comment": "Event date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "product_id",
          "sql_type": "STRING",
          "comment": "Product ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_name",
          "sql_type": "STRING",
          "comment": "Product name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_category",
          "sql_type": "STRING",
          "comment": "Category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "production_line",
          "sql_type": "STRING",
          "comment": "Production line",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Severity: Minor, Major, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.05 THEN 'Critical' WHEN {status_noise} < 0.25 THEN 'Major' ELSE 'Minor' END"
        },
        {
          "name": "root_cause",
          "sql_type": "STRING",
          "comment": "Cause: Equipment, Ingredient, Process, Contamination, Packaging, Handling",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.22 THEN 'Equipment' WHEN {status_noise} < 0.40 THEN 'Process' WHEN {status_noise} < 0.55 THEN 'Ingredient' WHEN {status_noise} < 0.70 THEN 'Contamination' WHEN {status_noise} < 0.85 THEN 'Packaging' ELSE 'Handling' END"
        },
        {
          "name": "units_affected",
          "sql_type": "INT",
          "comment": "Units affected",
          "is_dimension": false,
          "generation_expr": "CAST(10 + FLOOR({qty_noise} * 4990) AS INT)"
        },
        {
          "name": "cost_impact_usd",
          "sql_type": "DOUBLE",
          "comment": "Cost impact USD",
          "is_dimension": false,
          "generation_expr": "ROUND(100.0 + ({qty_noise} * 49900.0), 2)"
        }
      ],
      "seasonal_patterns": {
