          "comment": "Inspection ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('QI-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.product_id) AS STRING), 7, '0'))"
        },
        {
          "name": "inspection_date",
          "sql_type": "DATE",
          "comment": "Inspection date",
          "is_dimension": false,
          "generation_expr": "d.dt"
