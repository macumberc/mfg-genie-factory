        "synonyms": [
          "failure rate"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_lots",
        "sql": "COUNT(DISTINCT products.lot_number)",
        "display_name": "total lots",
        "synonyms": [
          "batches"
        ]
      },
      {
        "alias": "avg_trace_success",
        "sql": "AVG(chain_of_custody_snapshots.trace_success_rate_pct)",
        "display_name": "avg trace success",
        "synonyms": [
          "traceability rate"
        ]
      },
      {
        "alias": "avg_recall_time",
        "sql": "AVG(lot_tracking_events.recall_readiness_hours)",
        "display_name": "avg recall time",
        "synonyms": [
          "mock recall time"
        ]
      },
      {
        "alias": "avg_fda",
        "sql": "AVG(chain_of_custody_snapshots.fda_compliance_pct)",
        "display_name": "avg FDA compliance",
        "synonyms": [
          "FSMA score"
        ]
      }
    ]
  },
