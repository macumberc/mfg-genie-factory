  "genie_instructions": "You are a food & beverage analytics assistant for TraceFood Systems. Answer questions about food product traceability and recall management using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (product_id, product_name, production_line), query the base tables directly.\n- When joining tables, use the shared keys: product_id (shared across chain_of_custody_snapshots, lot_tracking_events, products).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in full trace count?",
    "How has gap count changed over time?",
    "What is the monthly trend in unique total lotss?",
    "How has unique events changed over time?",
    "What is the monthly trend in fail sim count?",
    "How has unique products changed over time?",
    "What is the monthly trend in highest lots traced?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total lotss?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_lots) AS total_lots",
        "FROM {fqn}.traceability_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How has unique events changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(event_count) AS event_count",
        "FROM {fqn}.traceability_monthly",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest lots traced?",
      "sql_lines": [
        "SELECT perf_month, MEASURE(max_lots_traced) AS max_lots_traced",
        "FROM {fqn}.recall_readiness_monthly",
        "GROUP BY ALL",
        "ORDER BY perf_month"
      ]
    },
    {
      "question": "Rank product categories by avg fda compliance",
      "sql_lines": [
        "SELECT product_category, MEASURE(avg_fda_compliance) AS avg_fda_compliance",
        "FROM {fqn}.recall_readiness_monthly",
        "GROUP BY ALL",
        "ORDER BY avg_fda_compliance DESC"
      ]
    },
    {
      "question": "How does total units in lot break down by product id for 'Gap' records?",
      "sql_lines": [
        "SELECT product_id, COUNT(*) AS record_count, SUM(units_in_lot) AS total_units_in_lot",
        "FROM {fqn}.products",
        "WHERE traceability_status = 'Gap' GROUP BY product_id ORDER BY total_units_in_lot DESC"
      ]
    },
    {
      "question": "What is the trend of total recorded temperature f over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(temp_recorded_f) AS total_temp_recorded_f",
        "FROM {fqn}.lot_tracking_events",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has the average trace success rate 0-100 changed over time?",
      "sql_lines": [
        "SELECT perf_month, AVG(trace_success_rate_pct) AS avg_trace_success_rate_pct",
        "FROM {fqn}.chain_of_custody_snapshots",
        "GROUP BY perf_month ORDER BY perf_month"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "products.traceability_status = 'Gap'",
        "display_name": "traceability gaps",
        "synonyms": [
          "missing trace"
        ],
        "instruction": "Filter gaps."
      },
      {
        "sql": "lot_tracking_events.temp_compliant = 'No'",
        "display_name": "temp violations",
        "synonyms": [
          "cold chain break"
        ],
        "instruction": "Filter temp non-compliant."
      },
      {
        "sql": "chain_of_custody_snapshots.recall_sim_result = 'Fail'",
        "display_name": "failed recalls",
        "synonyms": [
          "recall failure"
        ],
        "instruction": "Filter failed recall sims."
      }
    ],
    "expressions": [
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', products.event_date)",
        "display_name": "event month",
        "synonyms": [
          "monthly"
        ]
      },
      {
        "alias": "temp_deviation",
        "sql": "ABS(lot_tracking_events.temp_recorded_f - 38.0)",
        "display_name": "temp deviation from target",
        "synonyms": [
          "temp variance"
        ]
      },
      {
        "alias": "trace_gap_rate",
        "sql": "100.0 - chain_of_custody_snapshots.trace_success_rate_pct",
