      "table_name": "perishable_products",
      "description": "Daily inventory movements for perishable products with lot dates and temperature zones.",
      "columns": [
        {
          "name": "movement_id",
          "sql_type": "STRING",
          "comment": "Movement ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('FM-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.product_id) + 10000 AS STRING), 6, '0'))"
        },
        {
          "name": "movement_date",
          "sql_type": "DATE",
          "comment": "Movement date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "product_id",
          "sql_type": "STRING",
          "comment": "Product ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_name",
          "sql_type": "STRING",
          "comment": "Product name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_category",
          "sql_type": "STRING",
          "comment": "Category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "production_line",
          "sql_type": "STRING",
          "comment": "Line",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "quantity_units",
          "sql_type": "INT",
          "comment": "Units moved",
          "is_dimension": false,
          "generation_expr": "CAST(20 + FLOOR({qty_noise} * 480) AS INT)"
        },
        {
          "name": "days_to_expiry",
          "sql_type": "INT",
          "comment": "Days until expiration",
          "is_dimension": false,
          "generation_expr": "CAST(1 + FLOOR({qty_noise} * 29) AS INT)"
        },
        {
          "name": "movement_type",
          "sql_type": "STRING",
          "comment": "Type: Received, Shipped, Spoiled, Donated, Transferred",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'Received' WHEN {status_noise} < 0.70 THEN 'Shipped' WHEN {status_noise} < 0.82 THEN 'Spoiled' WHEN {status_noise} < 0.92 THEN 'Donated' ELSE 'Transferred' END"
        },
        {
          "name": "temperature_zone",
          "sql_type": "STRING",
          "comment": "Zone: Frozen, Refrigerated, Ambient",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Frozen' WHEN {status_noise} < 0.75 THEN 'Refrigerated' ELSE 'Ambient' END"
        }
      ],
