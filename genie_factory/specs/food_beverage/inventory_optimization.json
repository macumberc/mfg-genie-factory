  "metric_views": [
    {
      "view_name": "inventory_kpi_monthly",
      "source_table": "inventory_transactions",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "production_line",
          "expr": "production_line"
        }
      ],
      "measures": [
        {
          "name": "avg_on_hand",
          "expr": "AVG(on_hand_units)",
          "comment": "Avg units on hand"
        },
        {
          "name": "avg_spoilage_rate",
          "expr": "AVG(spoilage_rate_pct)",
          "comment": "Avg spoilage rate"
        },
        {
          "name": "avg_fill_rate",
          "expr": "AVG(fill_rate_pct)",
          "comment": "Avg fill rate"
        },
        {
          "name": "avg_freshness",
          "expr": "AVG(freshness_score)",
          "comment": "Avg freshness score"
        },
        {
          "name": "total_near_expiry",
          "expr": "SUM(near_expiry_units)",
          "comment": "Total near-expiry units"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_on_hand_units",
          "expr": "MAX(on_hand_units)",
          "comment": "Maximum on hand units"
        }
      ]
    },
    {
      "view_name": "waste_kpi_monthly",
      "source_table": "shelf_life_snapshots",
      "dimensions": [
        {
          "name": "perf_month",
          "expr": "perf_month"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "optimization_action",
          "expr": "optimization_action"
        }
      ],
      "measures": [
        {
          "name": "total_spoiled",
          "expr": "SUM(total_spoiled_units)",
          "comment": "Total units spoiled"
        },
        {
          "name": "total_spoilage_cost",
          "expr": "SUM(spoilage_cost_usd)",
          "comment": "Total spoilage cost USD"
        },
        {
          "name": "avg_turnover",
          "expr": "AVG(turnover_ratio)",
          "comment": "Avg turnover ratio"
        },
        {
          "name": "avg_shelf_remaining",
          "expr": "AVG(avg_shelf_remaining_days)",
          "comment": "Avg shelf life remaining days"
        },
        {
          "name": "item_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Items tracked"
        },
        {
          "name": "max_total_spoiled_units",
          "expr": "MAX(total_spoiled_units)",
          "comment": "Maximum total spoiled units"
        }
      ]
