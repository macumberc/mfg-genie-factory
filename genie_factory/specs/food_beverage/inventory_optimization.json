    {
      "table_name": "shelf_life_snapshots",
      "description": "Monthly inventory optimization metrics with waste reduction and cost analysis.",
      "columns": [
        {
          "name": "perf_id",
          "sql_type": "STRING",
          "comment": "Performance ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('FP-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.product_id) AS STRING), 7, '0'))"
        },
        {
          "name": "perf_month",
          "sql_type": "DATE",
          "comment": "Performance month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "product_id",
          "sql_type": "STRING",
          "comment": "Product ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_category",
          "sql_type": "STRING",
          "comment": "Category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "production_line",
          "sql_type": "STRING",
          "comment": "Line",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "total_spoiled_units",
          "sql_type": "INT",
          "comment": "Total units spoiled",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 500) AS INT)"
        },
        {
          "name": "spoilage_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Spoilage cost USD",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 5000.0, 2)"
        },
        {
          "name": "turnover_ratio",
          "sql_type": "DOUBLE",
          "comment": "Inventory turnover ratio",
          "is_dimension": false,
          "generation_expr": "ROUND(4.0 + ({qty_noise} * 16.0), 2)"
        },
        {
          "name": "avg_shelf_remaining_days",
          "sql_type": "DOUBLE",
          "comment": "Avg remaining shelf life days",
          "is_dimension": false,
          "generation_expr": "ROUND(2.0 + ({qty_noise} * 18.0), 1)"
        },
        {
          "name": "optimization_action",
          "sql_type": "STRING",
          "comment": "Action: Markdown, Donate, Reorder, No Action",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.12 THEN 'Markdown' WHEN {status_noise} < 0.22 THEN 'Donate' WHEN {status_noise} < 0.38 THEN 'Reorder' ELSE 'No Action' END"
        }
      ],
