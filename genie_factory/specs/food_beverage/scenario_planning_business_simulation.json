  "example_sqls": [
    {
      "question": "What is the monthly trend in unique categorys?",
      "sql_lines": [
        "SELECT run_date, MEASURE(unique_category_count) AS unique_category_count",
        "FROM {fqn}.scenario_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "How has highest simulated revenue changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(max_simulated_revenue) AS max_simulated_revenue",
        "FROM {fqn}.scenario_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest expected revenue?",
      "sql_lines": [
        "SELECT outcome_month, MEASURE(max_expected_revenue) AS max_expected_revenue",
        "FROM {fqn}.portfolio_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY outcome_month"
      ]
    },
    {
      "question": "How has invest count changed over time?",
      "sql_lines": [
        "SELECT outcome_month, MEASURE(invest_count) AS invest_count",
        "FROM {fqn}.portfolio_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY outcome_month"
      ]
    },
    {
      "question": "What is the trend of total simulated revenue usd over time?",
      "sql_lines": [
        "SELECT run_date, SUM(simulated_revenue_usd) AS total_simulated_revenue_usd",
        "FROM {fqn}.product_categories",
        "GROUP BY run_date ORDER BY run_date"
      ]
    },
    {
      "question": "What is the trend of total price elasticity of demand over time?",
      "sql_lines": [
