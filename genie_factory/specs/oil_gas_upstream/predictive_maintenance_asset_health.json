  "metric_views": [
    {
      "view_name": "sensor_readings_metrics",
      "source_table": "sensor_readings",
      "dimensions": [
        {
          "name": "reading_date",
          "expr": "reading_date"
        },
        {
          "name": "equipment_id",
          "expr": "equipment_id"
        },
        {
          "name": "equipment_type",
          "expr": "equipment_type"
        },
        {
          "name": "field_name",
          "expr": "field_name"
        },
        {
          "name": "alert_level",
          "expr": "alert_level"
        }
      ],
      "measures": [
        {
          "name": "avg_health_score",
          "expr": "AVG(health_score)",
          "comment": "Avg health score"
        },
        {
          "name": "min_rul_days",
          "expr": "MIN(predicted_rul_days)",
          "comment": "Min predicted RUL"
        },
        {
          "name": "alarm_trip_count",
          "expr": "COUNT(DISTINCT CASE WHEN alert_level IN ('Alarm', 'Trip') THEN reading_id END)",
          "comment": "Alarm/trip count"
        },
        {
          "name": "total_readings",
          "expr": "COUNT(DISTINCT reading_id)",
          "comment": "Total readings"
        },
        {
          "name": "total_sensor_value",
          "expr": "SUM(sensor_value)",
          "comment": "Total sensor value"
        },
        {
          "name": "max_sensor_value",
          "expr": "MAX(sensor_value)",
          "comment": "Maximum sensor value"
        }
      ]
    },
    {
      "view_name": "maintenance_events_metrics",
      "source_table": "maintenance_events",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "equipment_id",
          "expr": "equipment_id"
        },
        {
          "name": "equipment_type",
          "expr": "equipment_type"
        },
        {
          "name": "field_name",
          "expr": "field_name"
        },
        {
          "name": "event_type",
          "expr": "event_type"
        },
        {
          "name": "was_predicted",
          "expr": "was_predicted"
        }
      ],
      "measures": [
        {
          "name": "total_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total events"
        },
        {
          "name": "total_downtime_hours",
          "expr": "SUM(downtime_hours)",
          "comment": "Total downtime hours"
        },
        {
          "name": "total_repair_cost_usd",
          "expr": "SUM(repair_cost_usd)",
          "comment": "Total repair cost"
        },
        {
          "name": "total_production_loss_bbl",
          "expr": "SUM(production_loss_bbl)",
          "comment": "Total production loss BBL"
        },
        {
          "name": "max_downtime_hours",
          "expr": "MAX(downtime_hours)",
          "comment": "Maximum downtime hours"
        }
      ]
