{
  "company_name": "WellGuard Upstream",
  "industry": "Oil & Gas Upstream",
  "use_case": "Predictive maintenance for drilling and production equipment",
  "space_title": "WellGuard Upstream - Predictive Maintenance & Asset Health 🔧",
  "space_description": "Asset health analytics for WellGuard Upstream. Ask questions about drilling and production equipment health, sensor readings, maintenance events, and failure predictions across 20 assets in onshore fields.",
  "schema_basename": "og_upstream_pred_maint",
  "tables": [
    {
      "table_name": "sensor_readings",
      "description": "Sensor telemetry from drilling and production equipment.",
      "columns": [
        {
          "name": "reading_id",
          "sql_type": "STRING",
          "comment": "Reading ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('SR-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.equipment_id) + 100000 AS STRING), 8, '0'))"
        },
        {
          "name": "reading_date",
          "sql_type": "DATE",
          "comment": "Reading date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "equipment_id",
          "sql_type": "STRING",
          "comment": "Equipment ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "equipment_name",
          "sql_type": "STRING",
          "comment": "Equipment name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "equipment_type",
          "sql_type": "STRING",
          "comment": "Equipment type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "field_name",
          "sql_type": "STRING",
          "comment": "Field name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "sensor_type",
          "sql_type": "STRING",
          "comment": "Sensor type",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.12 THEN 'Vibration' WHEN {status_noise} < 0.24 THEN 'Temperature' WHEN {status_noise} < 0.36 THEN 'Pressure' WHEN {status_noise} < 0.48 THEN 'RPM' WHEN {status_noise} < 0.60 THEN 'Torque' WHEN {status_noise} < 0.72 THEN 'Motor Current' WHEN {status_noise} < 0.84 THEN 'Flow Rate' ELSE 'Acoustic' END"
        },
        {
          "name": "sensor_value",
          "sql_type": "DOUBLE",
          "comment": "Sensor value",
          "is_dimension": false,
          "generation_expr": "ROUND(30.0 + {qty_noise} * 470.0, 2)"
        },
        {
          "name": "health_score",
          "sql_type": "DOUBLE",
          "comment": "Health score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(0.0, 70.0 + ({qty_noise} - 0.5) * 60.0)), 1)"
        },
        {
          "name": "alert_level",
          "sql_type": "STRING",
          "comment": "Alert: Normal, Advisory, Warning, Alarm, Trip",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'Normal' WHEN {status_noise} < 0.75 THEN 'Advisory' WHEN {status_noise} < 0.88 THEN 'Warning' WHEN {status_noise} < 0.96 THEN 'Alarm' ELSE 'Trip' END"
        },
        {
          "name": "predicted_rul_days",
          "sql_type": "INT",
          "comment": "Predicted RUL days",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(1, 10 + FLOOR({qty_noise} * 300)) AS INT)"
        }
      ],
      "seasonal_patterns": {
        "Permian Basin": {
          "3,4,5,9,10": 0.05
        }
      },
