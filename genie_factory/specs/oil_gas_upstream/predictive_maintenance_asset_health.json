  "metric_views": [
    {
      "view_name": "sensor_readings_metrics",
      "source_table": "sensor_readings",
      "dimensions": [
        {
          "name": "reading_date",
          "expr": "reading_date"
        },
        {
          "name": "equipment_id",
          "expr": "equipment_id"
        },
        {
          "name": "equipment_type",
          "expr": "equipment_type"
        },
        {
          "name": "field_name",
