          "name": "event_id",
          "sql_type": "STRING",
          "comment": "Event ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('ME-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.equipment_id) + 50000 AS STRING), 7, '0'))"
        },
        {
          "name": "event_date",
          "sql_type": "DATE",
          "comment": "Event date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "equipment_id",
          "sql_type": "STRING",
          "comment": "Equipment ID",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "equipment_name",
