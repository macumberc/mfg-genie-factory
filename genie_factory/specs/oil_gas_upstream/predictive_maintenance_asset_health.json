        {
          "name": "field_name",
          "sql_type": "STRING",
          "comment": "Field name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "event_type",
          "sql_type": "STRING",
          "comment": "Type: Planned PM, Predictive, Corrective, Emergency, Rig Move, Overhaul",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.28 THEN 'Planned PM' WHEN {status_noise} < 0.50 THEN 'Predictive' WHEN {status_noise} < 0.68 THEN 'Corrective' WHEN {status_noise} < 0.80 THEN 'Emergency' WHEN {status_noise} < 0.90 THEN 'Rig Move' ELSE 'Overhaul' END"
        },
        {
          "name": "was_predicted",
          "sql_type": "BOOLEAN",
          "comment": "ML predicted",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN TRUE ELSE FALSE END"
        },
        {
          "name": "downtime_hours",
          "sql_type": "DOUBLE",
          "comment": "Downtime hours",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.5, 2.0 + {qty_noise} * 72.0), 1)"
        },
        {
          "name": "production_loss_bbl",
          "sql_type": "DOUBLE",
          "comment": "Production loss BBL",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.0, {qty_noise} * 5000.0), 0)"
        },
        {
          "name": "repair_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Repair cost USD",
          "is_dimension": false,
          "generation_expr": "ROUND(2000 + {qty_noise} * 300000, 2)"
        }
