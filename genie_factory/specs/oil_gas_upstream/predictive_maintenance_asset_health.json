  "genie_instructions": "You are an oil & gas upstream analytics assistant for WellGuard Upstream. Answer questions about predictive maintenance for drilling and production equipment using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (equipment_name), query the base tables directly.\n- When joining tables, use the shared keys: equipment_id (shared across equipment_health_monthly, maintenance_events, sensor_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in alarm trip count?",
    "How has unique total readingss changed over time?",
    "What is the monthly trend in highest sensor value?",
    "How has total sensor value changed over time?",
    "What is the monthly trend in unique total eventss?",
    "How has highest downtime hours changed over time?",
    "What is the monthly trend in total downtime hours?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest sensor value?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_sensor_value) AS max_sensor_value",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Monthly trend of peak sensor readings; matches questions about highest or maximum sensor values spiking over time using the sensor_readings_metrics metric view."
    },
    {
      "question": "How has total sensor value changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_sensor_value) AS total_sensor_value",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Cumulative sensor activity trend over time; matches questions about total or aggregate sensor output volume changing across reading dates via metric view."
    },
    {
      "question": "What is the monthly trend in total downtime hours?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.maintenance_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Monthly downtime hours trend; matches questions about equipment outage duration patterns over time using the maintenance_events_metrics metric view."
    },
    {
      "question": "What is the trend of total sensor value over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(sensor_value) AS total_sensor_value",
        "FROM {fqn}.sensor_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of summed sensor values; matches questions about total sensor output over time querying the raw sensor_readings table directly."
    },
    {
      "question": "What is the trend of total downtime hours over time?",
      "sql_lines": [
        "SELECT event_date, SUM(downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.maintenance_events",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Time-series trend of total downtime hours; matches questions about cumulative equipment downtime over time querying the raw maintenance_events table directly."
    },
    {
      "question": "How has the average avg health score changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(avg_health_score) AS avg_avg_health_score",
        "FROM {fqn}.equipment_health_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly average health score trend across all equipment; matches questions about fleet-wide health degradation or improvement over time from equipment_health_monthly."
    },
    {
      "question": "How does alarm trip count vary across equipment ids?",
      "sql_lines": [
        "SELECT equipment_id, MEASURE(alarm_trip_count) AS alarm_trip_count",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY alarm_trip_count DESC"
      ],
      "usage_guidance": "Ranked breakdown of alarm trip counts by equipment ID; matches questions identifying which specific pieces of equipment trigger the most alarms."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "alert_level IN ('Alarm', 'Trip')",
        "display_name": "critical alerts",
        "synonyms": [
          "alarms",
          "high priority alarms",
          "trip alarms"
        ],
        "instruction": "Critical alerts."
      },
      {
        "sql": "event_type = 'Emergency'",
        "display_name": "emergency events",
        "synonyms": [
          "unplanned",
          "unplanned failures",
          "urgent breakdowns"
        ],
        "instruction": "Emergency maintenance."
      },
      {
        "sql": "predicted_rul_days < 30",
        "display_name": "near failure",
        "synonyms": [
          "low RUL",
          "imminent breakdown",
          "end of life"
        ],
        "instruction": "Near-failure assets."
      }
    ],
    "expressions": [
      {
        "alias": "cost_per_hr",
        "sql": "ROUND(maintenance_events.repair_cost_usd / NULLIF(maintenance_events.downtime_hours, 0), 2)",
        "display_name": "cost per downtime hr",
        "synonyms": [
          "hourly cost",
          "hourly repair rate",
          "downtime cost rate"
        ]
      },
      {
        "alias": "prediction_rate",
        "sql": "ROUND(100.0 * COUNT(DISTINCT CASE WHEN maintenance_events.was_predicted = TRUE THEN maintenance_events.event_id END) / NULLIF(COUNT(DISTINCT maintenance_events.event_id), 0), 2)",
        "display_name": "prediction rate",
        "synonyms": [
          "ML accuracy",
          "forecast accuracy",
          "predicted failure rate"
        ]
      },
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', maintenance_events.event_date)",
        "display_name": "month",
        "synonyms": [
          "period",
          "failure month",
          "incident month"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_cost",
        "sql": "SUM(maintenance_events.repair_cost_usd)",
        "display_name": "total repair cost",
        "synonyms": [
          "cost",
          "repair spend",
          "maintenance spend"
        ]
      },
      {
        "alias": "total_downtime",
        "sql": "SUM(maintenance_events.downtime_hours)",
        "display_name": "total downtime",
        "synonyms": [
          "downtime",
          "offline hours",
          "lost hours"
        ]
      },
      {
        "alias": "avg_health",
        "sql": "AVG(sensor_readings.health_score)",
        "display_name": "avg health",
        "synonyms": [
          "health",
          "mean health",
          "average condition"
        ]
      },
      {
        "alias": "total_loss",
        "sql": "SUM(maintenance_events.production_loss_bbl)",
        "display_name": "production loss",
        "synonyms": [
          "lost barrels",
          "deferred production",
          "output loss"
        ]
      }
    ]
  },
