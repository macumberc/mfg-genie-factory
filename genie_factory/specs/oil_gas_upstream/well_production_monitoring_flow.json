  "genie_instructions": "You are an oil & gas upstream analytics assistant for WellFlow Monitoring. Answer questions about well production monitoring and flow optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (well_name), query the base tables directly.\n- When joining tables, use the shared keys: well_id (shared across production_kpi_monthly, production_readings, well_status_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in highest oil bpd?",
    "How has total casing pressure psi changed over time?",
    "What is the monthly trend in avg oil bpd?",
    "How has avg gas mcfpd changed over time?",
    "What is the monthly trend in highest cumulative oil bbl?",
    "How has total cumulative oil bbl changed over time?",
    "What is the monthly trend in total gor scf bbl?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in avg oil bpd?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_oil_bpd) AS avg_oil_bpd",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about daily oil production rate (bpd) using the production_readings_metrics metric view."
    },
    {
      "question": "How has avg gas mcfpd changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_gas_mcfpd) AS avg_gas_mcfpd",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about daily gas production volume (mcfpd) using the production_readings_metrics metric view."
    },
    {
      "question": "What is the monthly trend in total gor scf bbl?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_gor_scf_bbl) AS total_gor_scf_bbl",
        "FROM {fqn}.well_status_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Route trend-over-time questions about gas-oil ratio (GOR in scf/bbl) using the well_status_snapshots_metrics metric view."
    },
    {
      "question": "How does total oil bpd break down by well id for 'Flowing' records?",
      "sql_lines": [
        "SELECT well_id, COUNT(*) AS record_count, SUM(oil_bpd) AS total_oil_bpd",
        "FROM {fqn}.production_readings",
        "WHERE well_status = 'Flowing' GROUP BY well_id ORDER BY total_oil_bpd DESC"
      ],
      "usage_guidance": "Route filtered breakdown questions about oil production by well when user specifies 'Flowing' well status from raw production_readings."
    },
    {
      "question": "What is the trend of total cumulative oil bbl over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(cumulative_oil_bbl) AS total_cumulative_oil_bbl",
        "FROM {fqn}.well_status_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Route cumulative oil volume trend questions over time aggregated from raw well_status_snapshots table."
    },
    {
      "question": "How many distinct kpi id are there per pad name?",
      "sql_lines": [
        "SELECT pad_name, COUNT(DISTINCT kpi_id) AS distinct_count",
        "FROM {fqn}.production_kpi_monthly",
        "GROUP BY pad_name ORDER BY distinct_count DESC"
      ],
      "usage_guidance": "Route questions counting distinct KPI records grouped by pad name from the production_kpi_monthly table."
    },
    {
      "question": "How has avg tubing pressure changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_tubing_pressure) AS avg_tubing_pressure",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about wellbore tubing pressure (psi) using the production_readings_metrics metric view."
    }
  ],
