    "expressions": [
      {
        "alias": "gor",
        "sql": "ROUND(production_readings.gas_mcfpd / NULLIF(production_readings.oil_bpd, 0), 0)",
        "display_name": "GOR",
        "synonyms": [
          "gas-oil ratio"
        ]
      },
      {
        "alias": "water_cut",
        "sql": "ROUND(100.0 * production_readings.water_bpd / NULLIF(production_readings.oil_bpd + production_readings.water_bpd, 0), 1)",
        "display_name": "water cut",
        "synonyms": [
          "BSW"
        ]
      },
      {
        "alias": "reading_month",
        "sql": "DATE_TRUNC('month', production_readings.reading_date)",
        "display_name": "month",
        "synonyms": [
          "period"
        ]
      }
    ],
