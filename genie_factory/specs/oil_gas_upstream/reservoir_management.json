  "genie_instructions": "You are an oil & gas upstream analytics assistant for ReservoirSight Analytics. Answer questions about reservoir management and production optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (reservoir_name), query the base tables directly.\n- When joining tables, use the shared keys: reservoir_id (shared across production_readings, reservoir_kpi_monthly, reservoir_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in highest oil bpd?",
    "How has total bottomhole temp f changed over time?",
    "What is the monthly trend in avg oil bpd?",
    "How has avg gas mcfpd changed over time?",
    "What is the monthly trend in highest cumulative oil bbl?",
    "How has total cumulative oil changed over time?",
    "What is the monthly trend in total estimated eur bbl?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in avg oil bpd?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_oil_bpd) AS avg_oil_bpd",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has avg gas mcfpd changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_gas_mcfpd) AS avg_gas_mcfpd",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the monthly trend in total estimated eur bbl?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_estimated_eur_bbl) AS total_estimated_eur_bbl",
        "FROM {fqn}.reservoir_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the trend of total oil bpd over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(oil_bpd) AS total_oil_bpd",
        "FROM {fqn}.production_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the trend of total cumulative oil bbl over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(cumulative_oil_bbl) AS total_cumulative_oil_bbl",
        "FROM {fqn}.reservoir_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How many distinct kpi id are there per basin?",
      "sql_lines": [
        "SELECT basin, COUNT(DISTINCT kpi_id) AS distinct_count",
        "FROM {fqn}.reservoir_kpi_monthly",
        "GROUP BY basin ORDER BY distinct_count DESC"
      ]
    },
    {
      "question": "How has avg reservoir pressure changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_reservoir_pressure) AS avg_reservoir_pressure",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "water_cut_pct > 50",
