        {
          "name": "sensor_type",
          "sql_type": "STRING",
          "comment": "Type of sensor measurement",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.07 THEN 'Vibration X-Axis' WHEN {status_noise} < 0.14 THEN 'Vibration Y-Axis' WHEN {status_noise} < 0.21 THEN 'Bearing Temperature' WHEN {status_noise} < 0.28 THEN 'Inlet Pressure' WHEN {status_noise} < 0.35 THEN 'Outlet Pressure' WHEN {status_noise} < 0.42 THEN 'Flow Rate' WHEN {status_noise} < 0.49 THEN 'Oil Temperature' WHEN {status_noise} < 0.56 THEN 'Acoustic Emission' WHEN {status_noise} < 0.63 THEN 'Corrosion Rate' WHEN {status_noise} < 0.70 THEN 'RPM' WHEN {status_noise} < 0.77 THEN 'Torque' WHEN {status_noise} < 0.84 THEN 'Discharge Pressure' WHEN {status_noise} < 0.90 THEN 'Seal Leakage' WHEN {status_noise} < 0.95 THEN 'Motor Current' ELSE 'Humidity' END",
          "entity_values": [
            "Vibration X-Axis",
            "Vibration Y-Axis",
            "Bearing Temperature",
            "Inlet Pressure",
            "Outlet Pressure",
            "Flow Rate",
            "Oil Temperature",
            "Acoustic Emission",
            "Corrosion Rate",
            "RPM",
            "Torque",
            "Discharge Pressure",
            "Seal Leakage",
            "Motor Current",
            "Humidity"
          ]
        },
        {
          "name": "sensor_value",
          "sql_type": "DOUBLE",
          "comment": "Raw sensor measurement value",
          "is_dimension": false,
          "generation_expr": "ROUND(50.0 + {qty_noise} * 450.0, 2)"
        },
        {
          "name": "health_score",
          "sql_type": "DOUBLE",
          "comment": "AI-computed asset health score 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(0.0, 72.0 + ({qty_noise} - 0.5) * 56.0)), 1)"
        },
        {
          "name": "alert_level",
          "sql_type": "STRING",
          "comment": "Alert level: Normal, Advisory, Warning, Alarm, Trip",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'Normal' WHEN {status_noise} < 0.75 THEN 'Advisory' WHEN {status_noise} < 0.88 THEN 'Warning' WHEN {status_noise} < 0.96 THEN 'Alarm' ELSE 'Trip' END",
          "entity_values": [
            "Normal",
            "Advisory",
            "Warning",
            "Alarm",
            "Trip"
          ]
        },
        {
          "name": "predicted_rul_days",
          "sql_type": "INT",
          "comment": "Predicted remaining useful life in days",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(1, 10 + FLOOR({qty_noise} * 350)) AS INT)"
        }
