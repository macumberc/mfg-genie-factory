  "genie_instructions": "You are an oil & gas integrated analytics assistant for DeepHorizon Energy. Answer questions about predictive maintenance and asset health monitoring for offshore and onshore production equipment using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (asset_name), query the base tables directly.\n- When joining tables, use the shared keys: asset_id (shared across health_metrics_monthly, maintenance_events, sensor_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the alarm trip count by reading timestamp?",
    "Which reading timestamps have the most unique total readings?",
    "What is the highest sensor value for each reading timestamp?",
    "Rank reading timestamps by average asset health score",
    "What is the monthly trend in predicted event count?",
    "How has unique total eventss changed over time?",
    "What is the monthly trend in highest downtime hours?"
  ],
  "example_sqls": [
    {
      "question": "What is the highest sensor value for each reading timestamp?",
      "sql_lines": [
        "SELECT reading_timestamp, MEASURE(max_sensor_value) AS max_sensor_value",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY max_sensor_value DESC"
      ],
      "usage_guidance": "Peak sensor value ranked by timestamp; matches questions about highest recorded readings or sensor spikes across all assets."
    },
    {
      "question": "Rank reading timestamps by average asset health score",
      "sql_lines": [
        "SELECT reading_timestamp, MEASURE(avg_health_score) AS avg_health_score",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY avg_health_score DESC"
      ],
      "usage_guidance": "Timestamps ranked by average health score; matches questions about which dates showed best or worst overall asset health."
    },
    {
      "question": "What is the monthly trend in highest downtime hours?",
      "sql_lines": [
        "SELECT event_date, MEASURE(max_downtime_hours) AS max_downtime_hours",
        "FROM {fqn}.maintenance_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Monthly trend of worst single downtime event; matches questions about how maximum equipment outage duration has changed over time."
    },
    {
      "question": "What is the trend of total raw sensor measurement value over time?",
      "sql_lines": [
        "SELECT reading_timestamp, SUM(sensor_value) AS total_sensor_value",
        "FROM {fqn}.sensor_readings",
        "GROUP BY reading_timestamp ORDER BY reading_timestamp"
      ],
      "usage_guidance": "Raw sensor value summed over time; matches questions about total sensor measurement volume or cumulative signal trends across the fleet."
    },
    {
      "question": "What is the trend of total equipment downtime in hours over time?",
      "sql_lines": [
        "SELECT event_date, SUM(downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.maintenance_events",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Total equipment downtime hours trended by event date; matches questions about how overall production outage hours have evolved over time."
    },
    {
      "question": "How has the average average health score for the month 0-100 changed over time?",
      "sql_lines": [
        "SELECT snapshot_month, AVG(avg_health_score) AS avg_avg_health_score",
        "FROM {fqn}.health_metrics_monthly",
        "GROUP BY snapshot_month ORDER BY snapshot_month"
      ],
      "usage_guidance": "Monthly average health score trend from health_metrics_monthly; matches questions about fleet-wide health score trajectory or month-over-month condition changes."
    },
    {
      "question": "Which asset ids have the highest lowest predicted rul days?",
      "sql_lines": [
        "SELECT asset_id, MEASURE(min_predicted_rul_days) AS min_predicted_rul_days",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY min_predicted_rul_days DESC"
      ],
      "usage_guidance": "Assets ranked by shortest remaining useful life; matches questions about which assets are closest to predicted failure or need urgent maintenance."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "alert_level IN ('Alarm', 'Trip')",
        "display_name": "critical alerts",
        "synonyms": [
          "alarm or trip",
          "critical events",
          "high severity"
        ],
        "instruction": "Use to filter sensor readings to only critical alert conditions."
      },
      {
        "sql": "predicted_rul_days < 30",
        "display_name": "end of life assets",
        "synonyms": [
          "low RUL",
          "near failure",
          "critical assets"
        ],
        "instruction": "Use to identify assets with less than 30 days predicted remaining useful life."
      },
      {
        "sql": "event_type = 'Emergency'",
        "display_name": "emergency maintenance",
        "synonyms": [
          "unplanned",
          "emergency repairs",
          "reactive"
        ],
        "instruction": "Use to filter to emergency maintenance events only."
      }
    ],
    "expressions": [
      {
        "alias": "prediction_accuracy_pct",
        "sql": "ROUND(100.0 * COUNT(DISTINCT CASE WHEN maintenance_events.was_predicted = TRUE THEN maintenance_events.event_id END) / NULLIF(COUNT(DISTINCT maintenance_events.event_id), 0), 2)",
        "display_name": "prediction accuracy",
        "synonyms": [
          "ML accuracy",
          "predicted percentage",
          "forecast hit rate"
        ]
      },
      {
        "alias": "cost_per_barrel_lost",
        "sql": "ROUND(maintenance_events.repair_cost_usd / NULLIF(maintenance_events.production_loss_bbl, 0), 2)",
        "display_name": "cost per barrel lost",
        "synonyms": [
          "repair efficiency",
          "cost per bbl",
          "repair cost ratio"
        ]
      },
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', maintenance_events.event_date)",
        "display_name": "event month",
        "synonyms": [
          "month",
          "maintenance month",
          "failure month"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_repair_cost_usd",
        "sql": "SUM(maintenance_events.repair_cost_usd)",
        "display_name": "total repair cost",
        "synonyms": [
          "maintenance cost",
          "repair spend",
          "maintenance spend"
        ]
      },
      {
        "alias": "total_production_loss_bbl",
        "sql": "SUM(maintenance_events.production_loss_bbl)",
        "display_name": "total production loss",
        "synonyms": [
          "lost barrels",
          "production impact",
          "output loss"
        ]
      },
      {
        "alias": "total_downtime_hours",
        "sql": "SUM(maintenance_events.downtime_hours)",
        "display_name": "total downtime",
        "synonyms": [
          "downtime",
          "hours offline",
          "offline hours"
        ]
      },
      {
        "alias": "avg_health_score",
        "sql": "AVG(sensor_readings.health_score)",
        "display_name": "average health score",
        "synonyms": [
          "health",
          "equipment health",
          "mean health"
        ]
      }
    ]
  },
  "benchmarks": [
    {
      "question": "What is the alarm trip count by reading timestamp?",
      "sql_lines": [
        "SELECT reading_timestamp, MEASURE(alarm_trip_count) AS alarm_trip_count",
        "FROM {fqn}.sensor_readings_metrics",
