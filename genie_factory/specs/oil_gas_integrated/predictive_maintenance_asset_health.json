    {
      "question": "What are the top equipment asset by total raw sensor measurement value?",
      "sql_lines": [
        "SELECT asset_id, SUM(sensor_value) AS total_sensor_value",
        "FROM {fqn}.sensor_readings",
        "GROUP BY asset_id ORDER BY total_sensor_value DESC LIMIT 10"
      ]
    },
    {
      "question": "How many records are there per date of the maintenance event?",
      "sql_lines": [
        "SELECT event_date, COUNT(*) AS record_count",
        "FROM {fqn}.maintenance_events",
        "GROUP BY event_date ORDER BY event_date"
      ]
    },
    {
      "question": "How many records are there per first day of the snapshot month?",
      "sql_lines": [
        "SELECT snapshot_month, COUNT(*) AS record_count",
        "FROM {fqn}.health_metrics_monthly",
        "GROUP BY snapshot_month ORDER BY snapshot_month"
      ]
    }
