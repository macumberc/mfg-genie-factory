{
  "company_name": "CapVenture Energy",
  "industry": "Oil & Gas Integrated",
  "use_case": "Capital investment simulation and portfolio optimization for exploration and development projects",
  "space_title": "CapVenture Energy - Capital Investment Simulation 💰",
  "space_description": "Capital investment analytics for CapVenture Energy. Ask questions about project economics, investment returns, portfolio allocation, and risk-adjusted outcomes across 20 exploration and development projects spanning deepwater, onshore, and LNG.",
  "schema_basename": "og_integrated_capinvest",
  "tables": [
    {
      "table_name": "investment_transactions",
      "description": "Capital investment transactions including expenditures, commitments, and drawdowns across projects.",
      "columns": [
        {
          "name": "transaction_id",
          "sql_type": "STRING",
          "comment": "Unique investment transaction identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('IT-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.project_id) + 100000 AS STRING), 8, '0'))"
        },
        {
          "name": "transaction_date",
          "sql_type": "DATE",
          "comment": "Date of the investment transaction",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "project_id",
          "sql_type": "STRING",
          "comment": "Project identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "project_name",
          "sql_type": "STRING",
          "comment": "Project name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "project_type",
          "sql_type": "STRING",
          "comment": "Project type: Deepwater, Onshore Conventional, Shale, LNG, Infrastructure",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "basin_region",
          "sql_type": "STRING",
          "comment": "Basin or geographic region",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "spend_category",
          "sql_type": "STRING",
          "comment": "Category: Drilling, Facilities, Subsea, Seismic, Engineering, Procurement",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'Drilling' WHEN {status_noise} < 0.42 THEN 'Facilities' WHEN {status_noise} < 0.55 THEN 'Subsea' WHEN {status_noise} < 0.68 THEN 'Seismic' WHEN {status_noise} < 0.82 THEN 'Engineering' ELSE 'Procurement' END"
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Transaction amount in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(50000.0, {qty_noise} * 15000000.0), 2)"
        },
        {
          "name": "budget_amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Budgeted amount for this category in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(60000.0, {qty_noise} * 16000000.0), 2)"
        },
        {
          "name": "phase",
          "sql_type": "STRING",
          "comment": "Project phase: Exploration, Appraisal, Development, Production, Abandonment",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Exploration' WHEN {status_noise} < 0.30 THEN 'Appraisal' WHEN {status_noise} < 0.65 THEN 'Development' WHEN {status_noise} < 0.90 THEN 'Production' ELSE 'Abandonment' END"
        },
        {
          "name": "approval_status",
          "sql_type": "STRING",
          "comment": "Status: Approved, Pending, On Hold, Cancelled",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.65 THEN 'Approved' WHEN {status_noise} < 0.80 THEN 'Pending' WHEN {status_noise} < 0.92 THEN 'On Hold' ELSE 'Cancelled' END"
        }
      ],
      "seasonal_patterns": {
        "Deepwater": {
          "3,4,5,9,10": 0.05
        },
        "LNG": {
          "6,7,8": 0.04
        }
      },
