    {
      "table_name": "project_snapshots",
      "description": "Periodic project health snapshots including NPV, IRR, schedule adherence, and risk ratings.",
      "columns": [
        {
          "name": "snapshot_id",
          "sql_type": "STRING",
          "comment": "Unique project snapshot identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('PS-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.project_id) + 50000 AS STRING), 7, '0'))"
        },
        {
          "name": "snapshot_date",
          "sql_type": "DATE",
          "comment": "Date of the project snapshot",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "project_id",
          "sql_type": "STRING",
          "comment": "Project identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "project_name",
          "sql_type": "STRING",
          "comment": "Project name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "project_type",
          "sql_type": "STRING",
          "comment": "Project type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "basin_region",
          "sql_type": "STRING",
          "comment": "Basin or geographic region",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "npv_mm",
          "sql_type": "DOUBLE",
          "comment": "Net present value in millions USD",
          "is_dimension": false,
          "generation_expr": "ROUND(-200.0 + {qty_noise} * 3200.0, 1)"
        },
        {
          "name": "irr_pct",
          "sql_type": "DOUBLE",
          "comment": "Internal rate of return percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(-5.0, 2.0 + {qty_noise} * 28.0), 2)"
        },
        {
          "name": "schedule_adherence_pct",
          "sql_type": "DOUBLE",
          "comment": "Schedule adherence percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(110.0, GREATEST(60.0, 90.0 + ({qty_noise} - 0.5) * 30.0)), 1)"
        },
        {
          "name": "cost_variance_pct",
          "sql_type": "DOUBLE",
          "comment": "Cost variance from budget percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(-15.0 + {qty_noise} * 30.0, 2)"
        },
        {
          "name": "risk_rating",
          "sql_type": "STRING",
          "comment": "Risk: Low, Medium, High, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'Low' WHEN {status_noise} < 0.65 THEN 'Medium' WHEN {status_noise} < 0.88 THEN 'High' ELSE 'Critical' END"
        }
      ],
