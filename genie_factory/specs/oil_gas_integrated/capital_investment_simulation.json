  "metric_views": [
    {
      "view_name": "investment_transactions_metrics",
      "source_table": "investment_transactions",
      "dimensions": [
        {
          "name": "transaction_date",
          "expr": "transaction_date"
        },
        {
          "name": "project_id",
          "expr": "project_id"
        },
        {
          "name": "project_type",
          "expr": "project_type"
        },
        {
          "name": "basin_region",
          "expr": "basin_region"
        },
        {
          "name": "spend_category",
          "expr": "spend_category"
        },
        {
          "name": "phase",
          "expr": "phase"
        },
        {
          "name": "approval_status",
          "expr": "approval_status"
        }
      ],
      "measures": [
        {
          "name": "total_spend_usd",
          "expr": "SUM(amount_usd)",
          "comment": "Total investment spend in USD"
        },
        {
          "name": "total_budget_usd",
          "expr": "SUM(budget_amount_usd)",
          "comment": "Total budgeted amount in USD"
        },
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT transaction_id)",
          "comment": "Total investment transactions"
        },
        {
          "name": "avg_transaction_usd",
          "expr": "AVG(amount_usd)",
          "comment": "Average transaction size in USD"
        },
        {
          "name": "max_amount",
          "expr": "MAX(amount_usd)",
          "comment": "Maximum amount usd"
        }
      ]
    },
    {
      "view_name": "project_snapshots_metrics",
      "source_table": "project_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "project_id",
          "expr": "project_id"
        },
        {
          "name": "project_type",
          "expr": "project_type"
        },
        {
          "name": "basin_region",
          "expr": "basin_region"
        },
        {
          "name": "risk_rating",
          "expr": "risk_rating"
        }
      ],
      "measures": [
        {
          "name": "avg_npv_mm",
          "expr": "AVG(npv_mm)",
          "comment": "Average NPV in millions USD"
        },
        {
          "name": "avg_irr_pct",
          "expr": "AVG(irr_pct)",
          "comment": "Average IRR percentage"
        },
        {
          "name": "avg_schedule_adherence",
          "expr": "AVG(schedule_adherence_pct)",
          "comment": "Average schedule adherence percentage"
        },
        {
          "name": "avg_cost_variance_pct",
          "expr": "AVG(cost_variance_pct)",
          "comment": "Average cost variance from budget"
        },
        {
          "name": "max_npv_mm",
          "expr": "MAX(npv_mm)",
          "comment": "Maximum npv mm"
        }
      ]
