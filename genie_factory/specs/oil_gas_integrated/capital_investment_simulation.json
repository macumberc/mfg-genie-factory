          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "basin_region",
          "sql_type": "STRING",
          "comment": "Basin or geographic region",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "monthly_spend_usd",
          "sql_type": "DOUBLE",
          "comment": "Monthly capital spend in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(100000.0, {qty_noise} * 25000000.0), 2)"
        },
        {
          "name": "cumulative_spend_usd",
          "sql_type": "DOUBLE",
          "comment": "Cumulative capital spend in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(500000.0, {qty_noise} * 150000000.0), 2)"
        },
        {
          "name": "budget_remaining_pct",
          "sql_type": "DOUBLE",
          "comment": "Budget remaining percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(0.0, 60.0 + ({qty_noise} - 0.5) * 80.0)), 1)"
        },
        {
          "name": "portfolio_roic_pct",
          "sql_type": "DOUBLE",
          "comment": "Return on invested capital percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(-5.0, 3.0 + {qty_noise} * 17.0), 2)"
        }
      ],
