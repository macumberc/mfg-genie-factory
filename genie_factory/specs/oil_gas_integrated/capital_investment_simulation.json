      "table_name": "investment_kpi_monthly",
      "description": "Monthly investment portfolio KPIs including total spend, budget variance, and portfolio-level return metrics.",
      "columns": [
        {
          "name": "kpi_id",
          "sql_type": "STRING",
          "comment": "Unique KPI record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('IK-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.project_id) + 30000 AS STRING), 6, '0'))"
        },
        {
          "name": "kpi_month",
          "sql_type": "DATE",
          "comment": "First day of the KPI month",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', d.dt)"
        },
        {
          "name": "project_id",
          "sql_type": "STRING",
          "comment": "Project identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "project_type",
          "sql_type": "STRING",
