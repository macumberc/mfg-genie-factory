  "metric_views": [
    {
      "view_name": "simulation_runs_metrics",
      "source_table": "simulation_runs",
      "dimensions": [
        {
          "name": "run_date",
          "expr": "run_date"
        },
        {
          "name": "scenario_id",
          "expr": "scenario_id"
        },
        {
          "name": "scenario_category",
          "expr": "scenario_category"
        }
      ],
      "measures": [
        {
          "name": "avg_npv_mm",
          "expr": "AVG(npv_mm)",
          "comment": "Average NPV in millions USD"
        },
        {
          "name": "avg_irr_pct",
          "expr": "AVG(irr_pct)",
          "comment": "Average internal rate of return"
        },
        {
          "name": "total_capex_mm",
          "expr": "SUM(capex_allocation_mm)",
          "comment": "Total capital expenditure allocation in millions"
        },
        {
          "name": "total_runs",
          "expr": "COUNT(DISTINCT run_id)",
          "comment": "Total simulation runs"
        },
        {
          "name": "avg_oil_price",
          "expr": "AVG(oil_price_assumption)",
          "comment": "Average assumed oil price"
        },
        {
          "name": "total_production_growth_percent",
          "expr": "SUM(production_growth_pct)",
          "comment": "Total production growth pct"
        },
        {
          "name": "total_probability_weight",
          "expr": "SUM(probability_weight)",
          "comment": "Total probability weight"
        },
        {
          "name": "max_oil_price_assumption",
          "expr": "MAX(oil_price_assumption)",
          "comment": "Maximum oil price assumption"
        }
      ]
    },
    {
      "view_name": "outcome_snapshots_metrics",
      "source_table": "outcome_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "scenario_id",
          "expr": "scenario_id"
        },
        {
          "name": "scenario_category",
          "expr": "scenario_category"
        },
        {
          "name": "confidence_level",
          "expr": "confidence_level"
        }
      ],
      "measures": [
        {
          "name": "avg_projected_revenue_mm",
          "expr": "AVG(projected_revenue_mm)",
          "comment": "Average projected revenue in millions USD"
        },
        {
          "name": "avg_projected_ebitda_mm",
          "expr": "AVG(projected_ebitda_mm)",
          "comment": "Average projected EBITDA in millions USD"
        },
        {
          "name": "avg_breakeven_price",
          "expr": "AVG(breakeven_price_usd)",
          "comment": "Average breakeven oil price USD"
        },
        {
          "name": "avg_co2_intensity",
          "expr": "AVG(co2_intensity_kg_boe)",
          "comment": "Average CO2 intensity kg per BOE"
        },
        {
          "name": "avg_production_mboed",
          "expr": "AVG(projected_production_mboed)",
          "comment": "Average projected production in MBOE/d"
        },
        {
          "name": "max_projected_revenue_mm",
          "expr": "MAX(projected_revenue_mm)",
          "comment": "Maximum projected revenue mm"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The simulation_runs_metrics view (source: simulation_runs) has dimensions: run_date, scenario_id, scenario_category. Measures: avg_npv_mm, avg_irr_pct, total_capex_mm, total_runs, avg_oil_price. The outcome_snapshots_metrics view (source: outcome_snapshots) has dimensions: snapshot_date, scenario_id, scenario_category, confidence_level. Measures: avg_projected_revenue_mm, avg_projected_ebitda_mm, avg_breakeven_price, avg_co2_intensity, avg_production_mboed. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. scenario_name).",
  "sample_questions": [
    "What is the monthly trend in unique total runss?",
    "How has highest oil price assumption changed over time?",
    "What is the monthly trend in total capital expenditure allocation in millions?",
    "How has total production growth pct changed over time?",
    "What is the monthly trend in highest projected revenue mm?",
    "How has average projected revenue in millions usd changed over time?",
    "What is the monthly trend in average projected ebitda in millions usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total capital expenditure allocation in millions?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_capex_mm) AS total_capex_mm",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "How has total production growth pct changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_production_growth_percent) AS total_production_growth_percent",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "What is the monthly trend in average projected ebitda in millions usd?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(avg_projected_ebitda_mm) AS avg_projected_ebitda_mm",
        "FROM {fqn}.outcome_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the monthly trend in average co2 intensity kg per boe?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(avg_co2_intensity) AS avg_co2_intensity",
        "FROM {fqn}.outcome_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the trend of total assumed wti oil price usd per barrel over time?",
      "sql_lines": [
