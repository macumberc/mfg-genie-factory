{
  "company_name": "StratOil Dynamics",
  "industry": "Oil & Gas Integrated",
  "use_case": "Scenario planning and business simulation for strategic decision-making",
  "space_title": "StratOil Dynamics - Scenario Planning & Business Simulation 🎯",
  "space_description": "Scenario planning analytics for StratOil Dynamics. Ask questions about simulation outcomes, scenario comparisons, sensitivity analysis, and strategic KPIs across 20 business scenarios covering oil price, production, and capital allocation strategies.",
  "schema_basename": "og_integrated_scenario",
  "tables": [
    {
      "table_name": "simulation_runs",
      "description": "Individual simulation run results with input parameters and output metrics for each scenario.",
      "columns": [
        {
          "name": "run_id",
          "sql_type": "STRING",
          "comment": "Unique simulation run identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('SIM-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.scenario_id) + 100000 AS STRING), 8, '0'))"
        },
        {
          "name": "run_date",
          "sql_type": "DATE",
          "comment": "Date of the simulation run",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "scenario_id",
          "sql_type": "STRING",
          "comment": "Scenario identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "scenario_name",
          "sql_type": "STRING",
          "comment": "Scenario descriptive name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "scenario_category",
          "sql_type": "STRING",
          "comment": "Category: Price Stress, Production Upside, Capital Realloc, Transition, Baseline",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "oil_price_assumption",
          "sql_type": "DOUBLE",
          "comment": "Assumed WTI oil price USD per barrel",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(30.0, 45.0 + {qty_noise} * 80.0), 2)"
        },
        {
          "name": "production_growth_pct",
          "sql_type": "DOUBLE",
          "comment": "Assumed annual production growth rate",
          "is_dimension": false,
          "generation_expr": "ROUND(-5.0 + {qty_noise} * 15.0, 2)"
        },
        {
          "name": "capex_allocation_mm",
          "sql_type": "DOUBLE",
          "comment": "Capital expenditure allocation in millions USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(100.0, 500.0 + {qty_noise} * 4500.0), 1)"
        },
        {
          "name": "npv_mm",
          "sql_type": "DOUBLE",
          "comment": "Net present value in millions USD",
          "is_dimension": false,
          "generation_expr": "ROUND(-500.0 + {qty_noise} * 5500.0, 1)"
        },
        {
          "name": "irr_pct",
          "sql_type": "DOUBLE",
          "comment": "Internal rate of return percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(-10.0, -5.0 + {qty_noise} * 35.0), 2)"
        },
        {
          "name": "probability_weight",
          "sql_type": "DOUBLE",
          "comment": "Probability weight for this scenario 0-1",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.02, {qty_noise} * 0.30), 3)"
        }
