  "genie_instructions": "You are an oil & gas integrated analytics assistant for PetroLedger Corp. Answer questions about financial analytics and reporting for integrated oil and gas operations using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (cost_center_name), query the base tables directly.\n- When joining tables, use the shared keys: cost_center_id (shared across budget_snapshots, financial_kpi_monthly, financial_transactions).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique total transactionss?",
    "How has highest amount changed over time?",
    "What is the monthly trend in total transaction amount in usd?",
    "How has total budgeted amount in usd changed over time?",
    "What is the monthly trend in highest planned revenue?",
    "How has total actual revenue in usd changed over time?",
    "What is the monthly trend in total planned revenue in usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total transaction amount in usd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', transaction_date) AS transaction_date_month, MEASURE(total_amount_usd) AS total_amount_usd",
        "FROM {fqn}.financial_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date_month"
      ],
      "usage_guidance": "Route trend-over-time questions about actual transaction spend or total amount USD using the financial_transactions_metrics metric view."
    },
    {
      "question": "How has total budgeted amount in usd changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(total_budget_usd) AS total_budget_usd",
        "FROM {fqn}.financial_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Route time-series questions about budgeted spend, planned transaction amounts, or budget tracking across transaction dates."
    },
    {
      "question": "What is the monthly trend in total planned revenue in usd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_month) AS snapshot_month_month, MEASURE(total_planned_revenue) AS total_planned_revenue",
        "FROM {fqn}.budget_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_month_month"
      ],
      "usage_guidance": "Route monthly trend questions about planned revenue using the budget_snapshots_metrics metric view with snapshot_month as the time axis."
    },
    {
      "question": "What is the trend of total transaction amount in usd over time?",
      "sql_lines": [
        "SELECT transaction_date, SUM(amount_usd) AS total_amount_usd",
        "FROM {fqn}.financial_transactions",
        "GROUP BY transaction_date ORDER BY transaction_date"
      ],
      "usage_guidance": "Route trend-over-time questions about actual transaction spend when querying the raw financial_transactions table directly rather than the metric view."
    },
    {
      "question": "What is the trend of total planned monthly revenue in usd over time?",
      "sql_lines": [
        "SELECT snapshot_month, SUM(planned_revenue_usd) AS total_planned_revenue_usd",
        "FROM {fqn}.budget_snapshots",
        "GROUP BY snapshot_month ORDER BY snapshot_month"
      ],
      "usage_guidance": "Route time-series questions about planned monthly revenue when querying the raw budget_snapshots table for upstream revenue planning trends."
    },
    {
      "question": "How has the average operating margin percentage changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(operating_margin_pct) AS avg_operating_margin_pct",
        "FROM {fqn}.financial_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Route trend questions about operating margin percentage, profitability efficiency, or how margins have shifted month-over-month across KPI periods."
    },
    {
      "question": "How has unique total transactionss changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.financial_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Route trend-over-time questions about transaction volume, transaction counts, or how the number of financial transactions has changed over time."
    }
  ],
