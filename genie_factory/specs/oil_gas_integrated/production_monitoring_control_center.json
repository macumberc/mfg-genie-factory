    "expressions": [
      {
        "alias": "water_cut_pct",
        "sql": "ROUND(100.0 * production_readings.water_bbl / NULLIF(production_readings.oil_bbl + production_readings.water_bbl, 0), 2)",
        "display_name": "water cut percent",
        "synonyms": [
          "water cut",
          "BSW",
          "bsw percent"
        ]
      },
      {
        "alias": "boe_total",
        "sql": "production_readings.oil_bbl + (production_readings.gas_mcf / 6.0)",
        "display_name": "barrels of oil equivalent",
        "synonyms": [
          "BOE",
          "total equivalent",
          "equivalent barrels"
        ]
      },
      {
        "alias": "reading_month",
        "sql": "DATE_TRUNC('month', production_readings.reading_date)",
        "display_name": "production month",
        "synonyms": [
          "month",
          "period",
          "monthly period"
        ]
      }
    ],
    "measures": [
