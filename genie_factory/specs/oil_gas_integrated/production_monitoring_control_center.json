  "genie_instructions": "You are an oil & gas integrated analytics assistant for PetroPulse Integrated. Answer questions about real-time production monitoring and control center for wells and platforms using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (well_name), query the base tables directly.\n- When joining tables, use the shared keys: well_id (shared across production_events, production_kpi_monthly, production_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.\n- Treat the `status` field as authoritative for lifecycle state.",
  "sample_questions": [
    "What is the monthly trend in highest oil bbl?",
    "How has total oil production in barrels changed over time?",
    "What is the monthly trend in total gas production in mcf?",
    "How has total water production in barrels changed over time?",
    "What is the monthly trend in unique total eventss?",
    "How has highest duration hours changed over time?",
    "What is the monthly trend in total deferred oil production in barrels?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total gas production in mcf?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', reading_date) AS reading_date_month, MEASURE(total_gas_mcf) AS total_gas_mcf",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date_month"
      ],
      "usage_guidance": "Route trend-over-time questions about gas output volume in MCF using the production_readings_metrics metric view."
    },
    {
      "question": "How has total water production in barrels changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_water_bbl) AS total_water_bbl",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route time-series questions about water production volumes in barrels using the production_readings_metrics metric view."
    },
    {
      "question": "What is the monthly trend in total deferred oil production in barrels?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(total_deferred_oil_bbl) AS total_deferred_oil_bbl",
        "FROM {fqn}.production_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Route trend-over-time questions about deferred gas or oil losses in barrels using the production_events_metrics metric view."
    },
    {
      "question": "How does total daily oil production in barrels break down by well for 'Flowing' records?",
      "sql_lines": [
        "SELECT well_id, COUNT(*) AS record_count, SUM(oil_bbl) AS total_oil_bbl",
        "FROM {fqn}.production_readings",
        "WHERE status = 'Flowing' GROUP BY well_id ORDER BY total_oil_bbl DESC"
      ],
      "usage_guidance": "Route per-well breakdown or top-N oil production questions filtered to 'Flowing' well status from raw production_readings."
    },
    {
      "question": "What is the trend of total oil production deferred in barrels over time?",
      "sql_lines": [
        "SELECT event_date, SUM(deferred_oil_bbl) AS total_deferred_oil_bbl",
        "FROM {fqn}.production_events",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Route time-series questions about cumulative deferred oil barrels lost to production events from the production_events table."
    },
    {
      "question": "How has the average water cut percentage changed over time?",
      "sql_lines": [
        "SELECT snapshot_month, AVG(water_cut_pct) AS avg_water_cut_pct",
        "FROM {fqn}.production_kpi_monthly",
        "GROUP BY snapshot_month ORDER BY snapshot_month"
      ],
      "usage_guidance": "Route trend questions about water cut percentage over monthly KPI snapshots using production_kpi_monthly."
    },
    {
      "question": "How has average wellhead pressure in psi changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_wellhead_pressure_psi) AS avg_wellhead_pressure_psi",
        "FROM {fqn}.production_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about wellhead pressure in PSI using the production_readings_metrics metric view."
    }
  ],
  "sql_snippets": {
    "filters": [
