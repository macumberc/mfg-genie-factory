    {
      "question": "What are the top 10 well by total daily oil production in barrels?",
      "sql_lines": [
        "SELECT well_id, SUM(oil_bbl) AS total_oil_bbl",
        "FROM {fqn}.production_readings",
        "GROUP BY well_id ORDER BY total_oil_bbl DESC LIMIT 10"
      ]
