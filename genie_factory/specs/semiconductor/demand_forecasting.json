    {
      "question": "What is the monthly trend in backlogged order count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', order_date) AS order_date_month, MEASURE(backlogged_order_count) AS backlogged_order_count",
        "FROM {fqn}.customer_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date_month"
      ]
    },
    {
      "question": "How has unique total orderss changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(total_orders) AS total_orders",
        "FROM {fqn}.customer_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ]
    },
    {
      "question": "What is the monthly trend in unique total forecast recordss?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', forecast_date) AS forecast_date_month, MEASURE(total_forecast_records) AS total_forecast_records",
        "FROM {fqn}.forecast_accuracy_metrics",
        "GROUP BY ALL",
        "ORDER BY forecast_date_month"
      ]
    },
    {
      "question": "How has unique skus changed over time?",
      "sql_lines": [
        "SELECT forecast_date, MEASURE(unique_sku_count) AS unique_sku_count",
        "FROM {fqn}.forecast_accuracy_metrics",
        "GROUP BY ALL",
        "ORDER BY forecast_date"
      ]
    },
    {
      "question": "What are the top 10 product sku by total number of units ordered?",
      "sql_lines": [
        "SELECT sku_id, SUM(order_quantity) AS total_order_quantity",
        "FROM {fqn}.customer_orders",
        "GROUP BY sku_id ORDER BY total_order_quantity DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average forecast accuracy as percentage by human-readable product sku name?",
      "sql_lines": [
        "SELECT sku_name, AVG(forecast_accuracy_pct) AS avg_forecast_accuracy_pct",
        "FROM {fqn}.demand_forecasts",
        "GROUP BY sku_name ORDER BY avg_forecast_accuracy_pct DESC"
      ]
    },
    {
      "question": "How many records are there per month of inventory position?",
      "sql_lines": [
        "SELECT position_month, COUNT(*) AS record_count",
        "FROM {fqn}.inventory_positions",
        "GROUP BY position_month ORDER BY position_month"
      ]
    }
