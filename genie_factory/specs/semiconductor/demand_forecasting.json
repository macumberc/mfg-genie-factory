  "metric_views": [
    {
      "view_name": "customer_order_metrics",
      "source_table": "customer_orders",
      "dimensions": [
        {
          "name": "order_date",
          "expr": "order_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "customer_segment",
          "expr": "customer_segment"
        },
        {
          "name": "fulfillment_status",
          "expr": "fulfillment_status"
        },
        {
          "name": "region",
          "expr": "region"
        }
      ],
      "measures": [
        {
          "name": "total_orders",
          "expr": "COUNT(DISTINCT order_id)",
          "comment": "Total customer orders"
        },
        {
          "name": "total_order_revenue_usd",
          "expr": "SUM(order_revenue_usd)",
          "comment": "Total order revenue in USD"
        },
        {
          "name": "total_units_ordered",
          "expr": "SUM(order_quantity)",
          "comment": "Total units ordered"
        },
        {
          "name": "avg_lead_time_days",
          "expr": "AVG(lead_time_days)",
          "comment": "Average quoted lead time in days"
        },
        {
          "name": "backlogged_order_count",
          "expr": "COUNT(DISTINCT CASE WHEN fulfillment_status = 'Backlogged' THEN order_id END)",
          "comment": "Orders in backlog"
        },
        {
          "name": "total_unit_price",
          "expr": "SUM(unit_price_usd)",
          "comment": "Total unit price usd"
        },
        {
          "name": "unique_sku_count",
          "expr": "COUNT(DISTINCT sku_id)",
          "comment": "Number of distinct skus"
        },
        {
          "name": "max_order_quantity",
          "expr": "MAX(order_quantity)",
          "comment": "Maximum order quantity"
        }
      ]
    },
    {
      "view_name": "forecast_accuracy_metrics",
      "source_table": "demand_forecasts",
      "dimensions": [
        {
          "name": "forecast_date",
          "expr": "forecast_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "forecast_bias",
          "expr": "forecast_bias"
        },
        {
          "name": "model_type",
          "expr": "model_type"
        }
      ],
      "measures": [
        {
          "name": "avg_forecast_accuracy_pct",
          "expr": "AVG(forecast_accuracy_pct)",
          "comment": "Average forecast accuracy percentage"
        },
        {
          "name": "total_forecasted_units",
          "expr": "SUM(forecasted_units)",
          "comment": "Total units forecasted"
        },
        {
          "name": "total_actual_units",
          "expr": "SUM(actual_units)",
          "comment": "Total actual units ordered"
        },
        {
          "name": "total_forecast_records",
          "expr": "COUNT(DISTINCT forecast_id)",
          "comment": "Total forecast records"
        },
        {
          "name": "unique_sku_count",
          "expr": "COUNT(DISTINCT sku_id)",
          "comment": "Number of distinct skus"
        },
        {
          "name": "max_forecasted_units",
          "expr": "MAX(forecasted_units)",
          "comment": "Maximum forecasted units"
        }
      ]
    }
  ],
  "genie_instructions": "You are a semiconductor analytics assistant for ChipFlow Supply. Answer questions about semiconductor demand forecasting and order backlog management using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (sku_id, sku_name), query the base tables directly.\n- When joining tables, use the shared keys: sku_id (shared across customer_orders, demand_forecasts, inventory_positions).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in backlogged order count?",
    "How has unique total orderss changed over time?",
    "What is the monthly trend in unique skus?",
    "How has highest order quantity changed over time?",
    "What is the monthly trend in unique total forecast recordss?",
    "How has unique skus changed over time?",
    "What is the monthly trend in highest forecasted units?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique skus?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', order_date) AS order_date_month, MEASURE(unique_sku_count) AS unique_sku_count",
        "FROM {fqn}.customer_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date_month"
      ],
      "usage_guidance": "Monthly trend of distinct SKU variety in the order book; user asks about SKU diversity or product breadth over time using order_date."
    },
    {
      "question": "How has highest order quantity changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(max_order_quantity) AS max_order_quantity",
        "FROM {fqn}.customer_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Time-series of peak single-order quantity; user asks how largest or highest order volumes have shifted across order dates."
    },
    {
      "question": "What is the monthly trend in highest forecasted units?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', forecast_date) AS forecast_date_month, MEASURE(max_forecasted_units) AS max_forecasted_units",
        "FROM {fqn}.forecast_accuracy_metrics",
        "GROUP BY ALL",
        "ORDER BY forecast_date_month"
      ],
      "usage_guidance": "Monthly trend of peak forecasted demand volume; user asks how maximum predicted units or top forecast figures changed over forecast periods."
    },
    {
      "question": "How does total number of units ordered break down by product sku for 'Shipped' records?",
      "sql_lines": [
        "SELECT sku_id, COUNT(*) AS record_count, SUM(order_quantity) AS total_order_quantity",
        "FROM {fqn}.customer_orders",
        "WHERE fulfillment_status = 'Shipped' GROUP BY sku_id ORDER BY total_order_quantity DESC"
      ],
      "usage_guidance": "Per-SKU breakdown of units ordered filtered to Shipped status; user asks which SKUs drove fulfilled demand or shipped order quantities."
    },
    {
      "question": "What is the trend of total predicted demand in units over time?",
      "sql_lines": [
        "SELECT forecast_date, SUM(forecasted_units) AS total_forecasted_units",
        "FROM {fqn}.demand_forecasts",
        "GROUP BY forecast_date ORDER BY forecast_date"
      ],
      "usage_guidance": "Aggregate predicted demand trend over forecast dates; user asks about total forecasted units, future demand outlook, or demand planning trends."
    },
    {
      "question": "How many distinct unique inventory position record are there per product category grouping?",
      "sql_lines": [
        "SELECT product_category, COUNT(DISTINCT position_id) AS distinct_count",
        "FROM {fqn}.inventory_positions",
        "GROUP BY product_category ORDER BY distinct_count DESC"
      ],
      "usage_guidance": "Count of distinct inventory position records grouped by product category; user asks about inventory record coverage or category-level position distribution."
    },
    {
      "question": "How has total unit price usd changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(total_unit_price) AS total_unit_price",
        "FROM {fqn}.customer_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Time-series of cumulative unit price totals across order dates; user asks how aggregate pricing or total unit price revenue trended over time."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "customer_orders.fulfillment_status = 'Backlogged'",
        "display_name": "backlogged orders",
        "synonyms": [
          "backlog",
          "unfulfilled orders",
          "stuck orders"
        ],
        "instruction": "Use when analyzing orders that cannot be fulfilled from current stock."
      },
      {
        "sql": "inventory_positions.inventory_health = 'Critical'",
        "display_name": "critical inventory",
        "synonyms": [
          "low stock",
          "stockout risk",
          "under 2 weeks supply"
        ],
        "instruction": "Use when identifying SKUs at risk of stockout."
      },
      {
        "sql": "customer_orders.order_date >= ADD_MONTHS(CURRENT_DATE(), -3)",
        "display_name": "last 3 months",
        "synonyms": [
          "recent orders",
          "past quarter",
          "trailing 90 days"
        ],
        "instruction": "Use to restrict analysis to the most recent quarter."
      }
    ],
    "expressions": [
      {
        "alias": "order_month",
        "sql": "DATE_TRUNC('month', customer_orders.order_date)",
        "display_name": "order month",
        "synonyms": [
          "month of order",
          "order period",
          "booking month"
        ]
      },
      {
        "alias": "forecast_gap_units",
        "sql": "demand_forecasts.forecasted_units - demand_forecasts.actual_units",
        "display_name": "forecast gap",
        "synonyms": [
          "demand gap",
          "forecast vs actual delta",
          "forecast miss"
        ]
      },
      {
        "alias": "committed_pct",
        "sql": "inventory_positions.committed_units * 100.0 / NULLIF(inventory_positions.on_hand_units, 0)",
        "display_name": "committed percentage",
        "synonyms": [
          "allocation rate",
          "pct committed",
          "reserved percentage"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_revenue",
        "sql": "SUM(customer_orders.order_revenue_usd)",
        "display_name": "total order revenue",
        "synonyms": [
          "revenue",
          "order value",
          "total sales"
        ]
      },
      {
        "alias": "total_units",
        "sql": "SUM(customer_orders.order_quantity)",
        "display_name": "total units ordered",
        "synonyms": [
          "order volume",
          "unit count",
          "units booked"
        ]
      },
      {
        "alias": "avg_forecast_accuracy",
        "sql": "AVG(demand_forecasts.forecast_accuracy_pct)",
        "display_name": "average forecast accuracy",
        "synonyms": [
          "mean accuracy",
          "forecast precision",
          "forecast hit rate"
        ]
      },
      {
        "alias": "avg_weeks_of_supply",
        "sql": "AVG(inventory_positions.weeks_of_supply)",
        "display_name": "average weeks of supply",
        "synonyms": [
          "mean WOS",
          "inventory coverage",
          "inventory runway"
        ]
      }
    ]
  },
