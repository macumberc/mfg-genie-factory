          "name": "thickness_nm",
          "sql_type": "DOUBLE",
          "comment": "Film thickness measurement in nanometers",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(1.0, 50.0 + ({qty_noise} - 0.5) * 40.0), 2)"
        },
        {
          "name": "cd_nm",
          "sql_type": "DOUBLE",
          "comment": "Critical dimension measurement in nanometers",
          "is_dimension": false,
