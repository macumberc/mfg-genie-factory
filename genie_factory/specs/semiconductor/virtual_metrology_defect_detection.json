          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'MET-ASML-01' WHEN {status_noise} < 0.40 THEN 'MET-KLA-02' WHEN {status_noise} < 0.55 THEN 'MET-AMAT-03' WHEN {status_noise} < 0.70 THEN 'MET-HITC-04' WHEN {status_noise} < 0.85 THEN 'MET-NOVA-05' ELSE 'MET-ONTO-06' END",
