  "metric_views": [
    {
      "view_name": "wafer_measurement_metrics",
      "source_table": "wafer_measurements",
      "dimensions": [
        {
          "name": "measurement_date",
          "expr": "measurement_date"
        },
        {
          "name": "process_step",
          "expr": "process_step"
        },
        {
          "name": "tool_id",
          "expr": "tool_id"
        },
        {
          "name": "measurement_status",
          "expr": "measurement_status"
        }
      ],
      "measures": [
        {
          "name": "total_measurements",
          "expr": "COUNT(DISTINCT measurement_id)",
          "comment": "Total wafer measurements taken"
        },
        {
          "name": "avg_thickness_nm",
          "expr": "AVG(thickness_nm)",
          "comment": "Average film thickness in nanometers"
        },
        {
          "name": "avg_cd_nm",
          "expr": "AVG(cd_nm)",
          "comment": "Average critical dimension in nanometers"
        },
        {
          "name": "avg_overlay_nm",
          "expr": "AVG(overlay_nm)",
          "comment": "Average overlay alignment error"
        },
        {
          "name": "out_of_spec_count",
          "expr": "COUNT(DISTINCT CASE WHEN measurement_status = 'Out of Spec' THEN measurement_id END)",
          "comment": "Measurements flagged Out of Spec"
        },
        {
          "name": "unique_recipe_count",
          "expr": "COUNT(DISTINCT recipe_id)",
          "comment": "Number of distinct recipes"
        },
        {
          "name": "max_thickness_nm",
          "expr": "MAX(thickness_nm)",
          "comment": "Maximum thickness nm"
        }
      ]
    },
    {
      "view_name": "defect_detection_metrics",
      "source_table": "defect_detections",
      "dimensions": [
        {
          "name": "detection_month",
          "expr": "detection_month"
        },
        {
          "name": "process_step",
          "expr": "process_step"
        },
        {
          "name": "defect_type",
          "expr": "defect_type"
        }
      ],
      "measures": [
        {
          "name": "avg_defect_density",
          "expr": "AVG(defect_density_per_cm2)",
          "comment": "Average defect density per cm2"
        },
        {
          "name": "avg_kill_ratio_pct",
          "expr": "AVG(kill_ratio_pct)",
          "comment": "Average kill ratio percentage"
        },
        {
          "name": "total_wafers_inspected",
          "expr": "SUM(wafers_inspected)",
          "comment": "Total wafers inspected"
        },
        {
          "name": "total_defects_found",
          "expr": "SUM(total_defects_found)",
          "comment": "Total defects found"
        },
        {
          "name": "unique_recipe_count",
          "expr": "COUNT(DISTINCT recipe_id)",
          "comment": "Number of distinct recipes"
        },
        {
          "name": "max_defect_density_per_cm2",
          "expr": "MAX(defect_density_per_cm2)",
          "comment": "Maximum defect density per cm2"
        }
      ]
    }
  ],
  "genie_instructions": "You are a semiconductor analytics assistant for FabSight Analytics. Answer questions about virtual metrology and inline defect detection for wafer fabrication using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (recipe_id, recipe_name), query the base tables directly.\n- When joining tables, use the shared keys: recipe_id (shared across defect_detections, metrology_predictions, wafer_measurements).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in out of spec count?",
    "How has unique total measurementss changed over time?",
    "What is the monthly trend in unique recipes?",
    "How has highest thickness nm changed over time?",
    "What is the monthly trend in unique recipes?",
    "How has highest defect density per cm2 changed over time?",
    "What is the monthly trend in total wafers inspected?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique recipes?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', measurement_date) AS measurement_date_month, MEASURE(unique_recipe_count) AS unique_recipe_count",
        "FROM {fqn}.wafer_measurement_metrics",
        "GROUP BY ALL",
        "ORDER BY measurement_date_month"
      ],
      "usage_guidance": "Monthly trend of unique recipe count across wafer measurement dates; matches questions about recipe diversity or variety over time."
    },
    {
      "question": "How has highest thickness nm changed over time?",
      "sql_lines": [
        "SELECT measurement_date, MEASURE(max_thickness_nm) AS max_thickness_nm",
        "FROM {fqn}.wafer_measurement_metrics",
        "GROUP BY ALL",
        "ORDER BY measurement_date"
      ],
      "usage_guidance": "Time-series trend of peak or maximum thickness in nanometers; matches questions about highest or worst-case film thickness evolution."
    },
    {
      "question": "How has total defects found changed over time?",
      "sql_lines": [
        "SELECT detection_month, MEASURE(total_defects_found) AS total_defects_found",
        "FROM {fqn}.defect_detection_metrics",
        "GROUP BY ALL",
        "ORDER BY detection_month"
      ],
      "usage_guidance": "Monthly trend of cumulative defects found during wafer inspection; matches questions about defect volume or inspection totals over time."
    },
    {
      "question": "How does total film thickness measurement in nanometers break down by process recipe for 'In Spec' records?",
      "sql_lines": [
        "SELECT recipe_id, COUNT(*) AS record_count, SUM(thickness_nm) AS total_thickness_nm",
        "FROM {fqn}.wafer_measurements",
        "WHERE measurement_status = 'In Spec' GROUP BY recipe_id ORDER BY total_thickness_nm DESC"
      ],
      "usage_guidance": "Filtered aggregate of total film thickness broken down by recipe_id, restricted to 'In Spec' measurement_status; matches recipe-level thickness rollups for conforming wafers."
    },
    {
      "question": "What is the trend of total model-predicted film thickness in nm over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(predicted_thickness_nm) AS total_predicted_thickness_nm",
        "FROM {fqn}.metrology_predictions",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of summed virtual-metrology predicted thickness in nanometers from metrology_predictions; matches questions about model forecast thickness totals over snapshot dates."
    },
    {
      "question": "How has the average estimated percentage of defects that are yield-killing changed over time?",
      "sql_lines": [
        "SELECT detection_month, AVG(kill_ratio_pct) AS avg_kill_ratio_pct",
        "FROM {fqn}.defect_detections",
        "GROUP BY detection_month ORDER BY detection_month"
      ],
      "usage_guidance": "Time-series trend of average yield-killing kill_ratio_pct from defect_detections; matches questions about how lethal or yield-impacting defects have changed over detection months."
    },
    {
      "question": "How has out of spec count changed over time?",
      "sql_lines": [
        "SELECT measurement_date, MEASURE(out_of_spec_count) AS out_of_spec_count",
        "FROM {fqn}.wafer_measurement_metrics",
        "GROUP BY ALL",
        "ORDER BY measurement_date"
      ],
      "usage_guidance": "Time-series trend of out-of-spec wafer measurement count; matches questions about spec violations, non-conformance frequency, or quality excursions over measurement dates."
    }
  ],
