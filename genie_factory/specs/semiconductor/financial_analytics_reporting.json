  "use_case": "Semiconductor financial analytics, margin analysis, and cost reporting",
  "space_title": "SemiLedger - Financial Analytics & Reporting 💰",
  "space_description": "Financial analytics and reporting for SemiLedger Analytics. Analyze financial transactions, budget snapshots, and monthly KPIs across 20 cost centers to track margins, control costs, and improve financial planning accuracy.",
  "schema_basename": "semiconductor_financial",
  "tables": [
    {
      "table_name": "financial_transactions",
      "description": "Daily financial transaction records capturing revenue, COGS, operating expenses, and capital expenditures across cost centers.",
      "columns": [
        {
          "name": "transaction_id",
          "sql_type": "STRING",
          "comment": "Unique financial transaction identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('FT-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "transaction_date",
          "sql_type": "DATE",
          "comment": "Date the transaction was recorded",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "cost_center_id",
          "sql_type": "STRING",
          "comment": "Cost center identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "cost_center_name",
          "sql_type": "STRING",
          "comment": "Human-readable cost center name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "department",
          "sql_type": "STRING",
          "comment": "Department grouping",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "gl_category",
          "sql_type": "STRING",
          "comment": "General ledger category",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Revenue' WHEN {status_noise} < 0.50 THEN 'COGS' WHEN {status_noise} < 0.70 THEN 'OpEx' WHEN {status_noise} < 0.85 THEN 'CapEx' ELSE 'Other' END"
        },
        {
          "name": "gl_account",
          "sql_type": "STRING",
          "comment": "Specific GL account",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.12 THEN 'Product Revenue' WHEN {status_noise} < 0.22 THEN 'License Revenue' WHEN {status_noise} < 0.30 THEN 'Service Revenue' WHEN {status_noise} < 0.38 THEN 'Wafer Cost' WHEN {status_noise} < 0.44 THEN 'Packaging Cost' WHEN {status_noise} < 0.50 THEN 'Test Cost' WHEN {status_noise} < 0.56 THEN 'R&D Salaries' WHEN {status_noise} < 0.62 THEN 'R&D Equipment' WHEN {status_noise} < 0.68 THEN 'SG&A' WHEN {status_noise} < 0.73 THEN 'Marketing' WHEN {status_noise} < 0.78 THEN 'Fab Equipment' WHEN {status_noise} < 0.83 THEN 'IT Infrastructure' WHEN {status_noise} < 0.88 THEN 'Facilities' WHEN {status_noise} < 0.93 THEN 'Depreciation' ELSE 'Other Expense' END"
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Transaction amount in USD (positive = credit/revenue, negative = debit/expense)",
          "is_dimension": false,
          "generation_expr": "ROUND(CASE WHEN {status_noise} < 0.30 THEN 1000.0 + {qty_noise} * 99000.0 ELSE -500.0 - {qty_noise} * 49500.0 END, 2)"
        },
        {
          "name": "currency_code",
          "sql_type": "STRING",
          "comment": "Original transaction currency",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.50 THEN 'USD' WHEN {status_noise} < 0.70 THEN 'EUR' WHEN {status_noise} < 0.85 THEN 'TWD' ELSE 'JPY' END"
        },
        {
          "name": "fiscal_quarter",
          "sql_type": "STRING",
          "comment": "Fiscal quarter label",
          "is_dimension": false,
          "generation_expr": "CONCAT('FY', CAST(YEAR(dt) AS STRING), '-Q', CAST(QUARTER(dt) AS STRING))"
        }
      ],
      "seasonal_patterns": {
        "Fab Operations": {
