    {
      "table_name": "budget_snapshots",
      "description": "Weekly budget vs actual snapshots per cost center tracking planned spend, actual spend, and variance analysis.",
      "columns": [
        {
          "name": "snapshot_id",
          "sql_type": "STRING",
          "comment": "Unique budget snapshot identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('BS-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "snapshot_date",
          "sql_type": "DATE",
          "comment": "Week-ending date of budget snapshot",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('week', dt)"
        },
        {
          "name": "cost_center_id",
          "sql_type": "STRING",
          "comment": "Cost center identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "cost_center_name",
          "sql_type": "STRING",
          "comment": "Human-readable cost center name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "department",
          "sql_type": "STRING",
          "comment": "Department grouping",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "budgeted_amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Planned budget amount in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(5000.0 + {qty_noise} * 95000.0, 2)"
        },
        {
          "name": "actual_amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Actual spend in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(4000.0 + {qty_noise} * 96000.0 + ({status_noise} - 0.5) * 15000.0, 2)"
        },
        {
          "name": "variance_usd",
          "sql_type": "DOUBLE",
          "comment": "Budget variance in USD (positive = under budget)",
          "is_dimension": false,
          "generation_expr": "ROUND((5000.0 + {qty_noise} * 95000.0) - (4000.0 + {qty_noise} * 96000.0 + ({status_noise} - 0.5) * 15000.0), 2)"
        },
        {
          "name": "variance_pct",
          "sql_type": "DOUBLE",
          "comment": "Budget variance as percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(({qty_noise} - 0.5) * 30.0 + ({status_noise} - 0.5) * 10.0, 1)"
        },
        {
          "name": "budget_status",
          "sql_type": "STRING",
          "comment": "Budget health status",
          "is_dimension": false,
          "generation_expr": "CASE WHEN ({qty_noise} - 0.5) * 30.0 > 5.0 THEN 'Under Budget' WHEN ({qty_noise} - 0.5) * 30.0 > -5.0 THEN 'On Track' WHEN ({qty_noise} - 0.5) * 30.0 > -15.0 THEN 'Over Budget' ELSE 'Critical Overrun' END"
        },
        {
          "name": "headcount",
          "sql_type": "INT",
          "comment": "Allocated headcount for the cost center",
          "is_dimension": false,
          "generation_expr": "CAST(5 + FLOOR({qty_noise} * 95) AS INT)"
        }
      ],
