  "metric_views": [
    {
      "view_name": "financial_transaction_metrics",
      "source_table": "financial_transactions",
      "dimensions": [
        {
          "name": "transaction_date",
          "expr": "transaction_date"
        },
        {
          "name": "department",
          "expr": "department"
        },
        {
          "name": "gl_category",
          "expr": "gl_category"
        },
        {
          "name": "fiscal_quarter",
          "expr": "fiscal_quarter"
        }
      ],
      "measures": [
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT transaction_id)",
          "comment": "Total financial transactions"
        },
        {
          "name": "total_revenue_usd",
          "expr": "SUM(CASE WHEN gl_category = 'Revenue' THEN amount_usd ELSE 0 END)",
          "comment": "Total revenue in USD"
        },
        {
          "name": "total_cogs_usd",
          "expr": "SUM(CASE WHEN gl_category = 'COGS' THEN amount_usd ELSE 0 END)",
          "comment": "Total COGS in USD (negative value)"
        },
        {
          "name": "total_opex_usd",
          "expr": "SUM(CASE WHEN gl_category = 'OpEx' THEN amount_usd ELSE 0 END)",
          "comment": "Total operating expenses in USD (negative value)"
        },
        {
          "name": "total_capex_usd",
          "expr": "SUM(CASE WHEN gl_category = 'CapEx' THEN amount_usd ELSE 0 END)",
          "comment": "Total capital expenditures in USD (negative value)"
        },
        {
          "name": "unique_cost_center_count",
          "expr": "COUNT(DISTINCT cost_center_id)",
          "comment": "Number of distinct cost centers"
        },
        {
          "name": "unique_currency_count",
          "expr": "COUNT(DISTINCT currency_code)",
          "comment": "Number of distinct currencys"
        },
        {
          "name": "max_amount",
          "expr": "MAX(amount_usd)",
          "comment": "Maximum amount usd"
        }
      ]
    },
    {
      "view_name": "budget_variance_metrics",
      "source_table": "budget_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "department",
          "expr": "department"
        },
        {
          "name": "budget_status",
          "expr": "budget_status"
        }
      ],
      "measures": [
        {
          "name": "total_budgeted_usd",
          "expr": "SUM(budgeted_amount_usd)",
          "comment": "Total budgeted amount in USD"
        },
        {
          "name": "total_actual_usd",
          "expr": "SUM(actual_amount_usd)",
          "comment": "Total actual spend in USD"
        },
        {
          "name": "total_variance_usd",
          "expr": "SUM(variance_usd)",
          "comment": "Total budget variance in USD"
        },
        {
          "name": "avg_variance_pct",
          "expr": "AVG(variance_pct)",
          "comment": "Average variance percentage"
        },
        {
          "name": "critical_overrun_count",
