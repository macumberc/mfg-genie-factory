    {
      "table_name": "financial_kpi_monthly",
      "description": "Monthly financial KPI summaries per department tracking gross margin, operating margin, R&D intensity, and cost per wafer.",
      "columns": [
        {
          "name": "kpi_id",
          "sql_type": "STRING",
          "comment": "Unique monthly KPI record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('FK-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "kpi_month",
          "sql_type": "DATE",
          "comment": "Month of KPI measurement",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', dt)"
        },
        {
          "name": "cost_center_id",
          "sql_type": "STRING",
          "comment": "Cost center identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "cost_center_name",
          "sql_type": "STRING",
          "comment": "Human-readable cost center name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "department",
          "sql_type": "STRING",
          "comment": "Department grouping",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "gross_margin_pct",
          "sql_type": "DOUBLE",
          "comment": "Gross margin percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(75.0, GREATEST(25.0, 52.0 + ({qty_noise} - 0.5) * 40.0)), 1)"
        },
        {
          "name": "operating_margin_pct",
          "sql_type": "DOUBLE",
          "comment": "Operating margin percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(45.0, GREATEST(5.0, 22.0 + ({qty_noise} - 0.5) * 30.0)), 1)"
        },
        {
          "name": "rd_intensity_pct",
          "sql_type": "DOUBLE",
          "comment": "R&D spend as percentage of revenue",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(35.0, GREATEST(8.0, 18.0 + ({qty_noise} - 0.5) * 20.0)), 1)"
        },
        {
          "name": "cost_per_wafer_usd",
          "sql_type": "DOUBLE",
          "comment": "Fully loaded cost per wafer in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(2000.0 + {qty_noise} * 13000.0, 2)"
        },
        {
          "name": "revenue_per_employee_usd",
          "sql_type": "DOUBLE",
          "comment": "Revenue per employee in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(50000.0 + {qty_noise} * 200000.0, 2)"
        }
