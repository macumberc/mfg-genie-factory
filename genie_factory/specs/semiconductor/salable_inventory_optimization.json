          "name": "transaction_type",
          "sql_type": "STRING",
          "comment": "Type of inventory transaction",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'Receipt' WHEN {status_noise} < 0.65 THEN 'Shipment' WHEN {status_noise} < 0.80 THEN 'Transfer' WHEN {status_noise} < 0.92 THEN 'Adjustment' ELSE 'Scrap' END",
