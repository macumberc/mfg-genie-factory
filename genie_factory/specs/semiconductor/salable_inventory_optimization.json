  "metric_views": [
    {
      "view_name": "inventory_transaction_metrics",
      "source_table": "inventory_transactions",
      "dimensions": [
        {
          "name": "transaction_date",
          "expr": "transaction_date"
        },
        {
          "name": "product_line",
          "expr": "product_line"
        },
        {
          "name": "transaction_type",
          "expr": "transaction_type"
        },
        {
          "name": "warehouse_location",
          "expr": "warehouse_location"
        },
        {
          "name": "stock_stage",
          "expr": "stock_stage"
        }
      ],
      "measures": [
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT transaction_id)",
          "comment": "Total inventory transactions"
        },
        {
          "name": "total_transaction_value_usd",
          "expr": "SUM(transaction_value_usd)",
          "comment": "Total transaction value in USD"
        },
        {
          "name": "total_units_moved",
          "expr": "SUM(quantity_units)",
          "comment": "Total units across all transactions"
        },
        {
          "name": "scrap_transaction_count",
          "expr": "COUNT(DISTINCT CASE WHEN transaction_type = 'Scrap' THEN transaction_id END)",
          "comment": "Scrap transactions"
        },
        {
          "name": "avg_unit_cost_usd",
          "expr": "AVG(unit_cost_usd)",
          "comment": "Average unit cost in USD"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_quantity_units",
          "expr": "MAX(quantity_units)",
          "comment": "Maximum quantity units"
        }
      ]
    },
    {
      "view_name": "inventory_snapshot_metrics",
      "source_table": "inventory_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "product_line",
          "expr": "product_line"
        },
        {
          "name": "warehouse_location",
          "expr": "warehouse_location"
        },
        {
          "name": "aging_bucket",
          "expr": "aging_bucket"
        }
      ],
      "measures": [
        {
          "name": "total_on_hand_units",
          "expr": "SUM(on_hand_units)",
          "comment": "Total units on hand"
        },
        {
          "name": "total_available_to_sell",
          "expr": "SUM(available_to_sell)",
          "comment": "Total units available for sale"
        },
        {
          "name": "total_inventory_value_usd",
          "expr": "SUM(inventory_value_usd)",
          "comment": "Total inventory value in USD"
        },
        {
          "name": "avg_committed_units",
          "expr": "AVG(committed_units)",
          "comment": "Average committed units per snapshot"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_on_hand_units",
          "expr": "MAX(on_hand_units)",
          "comment": "Maximum on hand units"
        }
      ]
    }
  ],
  "genie_instructions": "You are a semiconductor analytics assistant for WaferVault Systems. Answer questions about salable inventory optimization across wafer, die, and finished goods stock using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (product_id, product_name), query the base tables directly.\n- When joining tables, use the shared keys: product_id (shared across inventory_kpi_monthly, inventory_snapshots, inventory_transactions).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in scrap transaction count?",
    "How has unique total transactionss changed over time?",
    "What is the monthly trend in unique products?",
    "How has highest quantity units changed over time?",
    "What is the monthly trend in unique products?",
    "How has highest on hand units changed over time?",
    "What is the monthly trend in total units on hand?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique products?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(unique_product_count) AS unique_product_count",
        "FROM {fqn}.inventory_transaction_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Monthly trend of distinct SKUs or product variety across wafer, die, or finished goods transactions using unique_product_count."
    },
    {
      "question": "How has highest quantity units changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(max_quantity_units) AS max_quantity_units",
        "FROM {fqn}.inventory_transaction_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series trend of peak single-transaction quantity units, surfacing shipment or receipt spikes across stock stages."
    },
    {
      "question": "How has average unit cost in usd changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(avg_unit_cost_usd) AS avg_unit_cost_usd",
        "FROM {fqn}.inventory_transaction_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Trend over time of average unit cost in USD, useful for tracking wafer or die cost fluctuations across transaction dates."
    },
    {
      "question": "How does scrap transaction count vary across product lines?",
      "sql_lines": [
        "SELECT product_line, MEASURE(scrap_transaction_count) AS scrap_transaction_count",
        "FROM {fqn}.inventory_transaction_metrics",
        "GROUP BY ALL",
        "ORDER BY scrap_transaction_count DESC"
      ],
      "usage_guidance": "Cross-product-line comparison (top-N by category) of scrap transaction counts to identify yield loss or write-off hotspots."
    },
    {
      "question": "What is the trend of total transaction quantity in units over time?",
      "sql_lines": [
        "SELECT transaction_date, SUM(quantity_units) AS total_quantity_units",
        "FROM {fqn}.inventory_transactions",
        "GROUP BY transaction_date ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series aggregate of total physical units moved per transaction date, covering receipts, shipments, and adjustments in inventory_transactions."
    },
    {
      "question": "What is the trend of total total units on hand over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(on_hand_units) AS total_on_hand_units",
        "FROM {fqn}.inventory_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Trend over time of total on-hand unit inventory levels from snapshot data, tracking stock build or depletion across snapshot dates."
    },
    {
      "question": "How has the average order fill rate percentage changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(fill_rate_pct) AS avg_fill_rate_pct",
        "FROM {fqn}.inventory_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly trend of average order fill rate percentage from KPI data, measuring service-level performance across product lines over time."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "inventory_transactions.transaction_type = 'Scrap'",
        "display_name": "scrap transactions",
        "synonyms": [
          "scrapped inventory",
          "waste",
          "write-offs"
        ],
        "instruction": "Use when analyzing inventory losses due to scrap."
      },
      {
        "sql": "inventory_snapshots.aging_bucket = '180+ days'",
        "display_name": "aged inventory",
        "synonyms": [
          "old stock",
          "stale inventory",
          "obsolescence risk"
        ],
        "instruction": "Use when identifying inventory at risk of obsolescence."
      },
      {
        "sql": "inventory_kpi_monthly.fill_rate_pct < 90",
        "display_name": "low fill rate",
        "synonyms": [
          "poor fill rate",
          "service level miss",
          "poor fulfillment"
        ],
        "instruction": "Use when identifying products with service level issues."
      }
    ],
    "expressions": [
      {
        "alias": "transaction_month",
        "sql": "DATE_TRUNC('month', inventory_transactions.transaction_date)",
        "display_name": "transaction month",
        "synonyms": [
          "month of transaction",
          "inventory movement month",
          "move month"
        ]
      },
      {
        "alias": "eo_total_usd",
        "sql": "inventory_kpi_monthly.excess_exposure_usd + inventory_kpi_monthly.obsolete_exposure_usd",
        "display_name": "total E&O exposure",
        "synonyms": [
          "excess and obsolete total",
          "E&O value",
          "excess obsolete usd"
        ]
      },
      {
        "alias": "committed_pct",
        "sql": "inventory_snapshots.committed_units * 100.0 / NULLIF(inventory_snapshots.on_hand_units, 0)",
        "display_name": "committed percentage",
        "synonyms": [
          "allocation rate",
          "pct allocated",
          "reserved ratio"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_inventory_value",
        "sql": "SUM(inventory_snapshots.inventory_value_usd)",
        "display_name": "total inventory value",
        "synonyms": [
          "stock value",
          "inventory dollars",
          "on-hand dollars"
        ]
      },
      {
        "alias": "avg_turns",
        "sql": "AVG(inventory_kpi_monthly.inventory_turns)",
        "display_name": "average inventory turns",
        "synonyms": [
          "mean turns",
          "turn rate",
          "stock rotation"
        ]
      },
      {
        "alias": "total_units_moved",
        "sql": "SUM(inventory_transactions.quantity_units)",
        "display_name": "total units transacted",
        "synonyms": [
          "unit volume",
          "transaction quantity",
          "units transacted"
        ]
      },
      {
        "alias": "avg_fill_rate",
        "sql": "AVG(inventory_kpi_monthly.fill_rate_pct)",
        "display_name": "average fill rate",
        "synonyms": [
          "mean fill rate",
          "service level",
          "fulfillment rate"
        ]
      }
    ]
  },
