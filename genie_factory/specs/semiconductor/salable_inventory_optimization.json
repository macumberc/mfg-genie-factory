          "sql_type": "STRING",
          "comment": "Warehouse or storage location",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'WH-Taiwan' WHEN {status_noise} < 0.45 THEN 'WH-Chandler' WHEN {status_noise} < 0.65 THEN 'WH-Penang' WHEN {status_noise} < 0.82 THEN 'WH-Shanghai' ELSE 'WH-Munich' END",
          "entity_values": [
            "WH-Taiwan",
            "WH-Chandler",
            "WH-Penang",
            "WH-Shanghai",
            "WH-Munich"
          ]
        },
        {
          "name": "quantity_units",
          "sql_type": "INT",
          "comment": "Transaction quantity in units",
          "is_dimension": false,
          "generation_expr": "CAST(50 + FLOOR({qty_noise} * 4950) AS INT)"
        },
        {
          "name": "unit_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Unit cost in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(0.25 + {qty_noise} * 24.75, 2)"
        },
        {
          "name": "transaction_value_usd",
          "sql_type": "DOUBLE",
          "comment": "Total transaction value in USD",
          "is_dimension": false,
          "generation_expr": "ROUND((50 + FLOOR({qty_noise} * 4950)) * (0.25 + {qty_noise} * 24.75), 2)"
        },
