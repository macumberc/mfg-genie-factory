          "sql_type": "STRING",
          "comment": "Stage of inventory in the supply chain",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Wafer Bank' WHEN {status_noise} < 0.55 THEN 'Die Bank' WHEN {status_noise} < 0.80 THEN 'Finished Goods' ELSE 'WIP' END",
          "entity_values": [
