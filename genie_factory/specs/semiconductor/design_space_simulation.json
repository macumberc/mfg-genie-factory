        {
          "name": "dynamic_power_mw",
          "sql_type": "DOUBLE",
          "comment": "Estimated dynamic power in milliwatts",
          "is_dimension": false,
          "generation_expr": "ROUND(200.0 + {qty_noise} * 1800.0, 1)"
        },
        {
          "name": "leakage_power_mw",
          "sql_type": "DOUBLE",
          "comment": "Estimated leakage power in milliwatts",
          "is_dimension": false,
          "generation_expr": "ROUND(10.0 + {qty_noise} * 90.0, 2)"
        },
        {
          "name": "die_area_mm2",
          "sql_type": "DOUBLE",
          "comment": "Estimated die area in square millimeters",
          "is_dimension": false,
          "generation_expr": "ROUND(4.0 + {qty_noise} * 96.0, 2)"
        },
        {
          "name": "drc_violations",
          "sql_type": "INT",
          "comment": "Number of design rule check violations",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 50) AS INT)"
