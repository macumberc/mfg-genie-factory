          "comment": "Target process node in nanometers",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 3 WHEN {status_noise} < 0.50 THEN 5 WHEN {status_noise} < 0.75 THEN 7 ELSE 14 END"
        },
        {
          "name": "timing_slack_ns",
          "sql_type": "DOUBLE",
          "comment": "Worst negative slack in nanoseconds (positive = met timing)",
          "is_dimension": false,
          "generation_expr": "ROUND(-0.5 + {qty_noise} * 1.2, 3)"
