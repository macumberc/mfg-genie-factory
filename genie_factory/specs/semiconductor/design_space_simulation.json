  "benchmarks": [
    {
      "question": "What is the monthly trend in completed runs count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', run_date) AS run_date_month, MEASURE(completed_runs) AS completed_runs",
        "FROM {fqn}.simulation_run_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date_month"
      ]
    },
    {
      "question": "How has unique total simulation runss changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_simulation_runs) AS total_simulation_runs",
        "FROM {fqn}.simulation_run_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "What is the monthly trend in blocked design count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', result_month) AS result_month_month, MEASURE(blocked_design_count) AS blocked_design_count",
        "FROM {fqn}.optimization_result_metrics",
        "GROUP BY ALL",
        "ORDER BY result_month_month"
      ]
    },
    {
      "question": "How has unique total optimization recordss changed over time?",
      "sql_lines": [
        "SELECT result_month, MEASURE(total_optimization_records) AS total_optimization_records",
        "FROM {fqn}.optimization_result_metrics",
        "GROUP BY ALL",
        "ORDER BY result_month"
      ]
    },
    {
      "question": "What are the top 10 chip design by total target process node in nanometers?",
      "sql_lines": [
        "SELECT design_id, SUM(target_node_nm) AS total_target_node_nm",
        "FROM {fqn}.simulation_runs",
        "GROUP BY design_id ORDER BY total_target_node_nm DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average normalized performance score (0-100) by human-readable chip design name?",
      "sql_lines": [
        "SELECT design_name, AVG(performance_score) AS avg_performance_score",
        "FROM {fqn}.parameter_explorations",
        "GROUP BY design_name ORDER BY avg_performance_score DESC"
      ]
    },
    {
      "question": "How many records are there per month of the optimization result?",
      "sql_lines": [
        "SELECT result_month, COUNT(*) AS record_count",
        "FROM {fqn}.optimization_results",
        "GROUP BY result_month ORDER BY result_month"
      ]
    }
  ]
