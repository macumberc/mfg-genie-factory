        "synonyms": [
          "combined power",
          "dynamic plus leakage",
          "full power draw"
        ]
      },
      {
        "alias": "power_efficiency",
        "sql": "parameter_explorations.performance_score / NULLIF(parameter_explorations.total_power_mw, 0)",
        "display_name": "power efficiency",
        "synonyms": [
          "performance per watt",
          "perf/power ratio",
          "perf per watt"
        ]
      },
      {
        "alias": "run_month",
        "sql": "DATE_TRUNC('month', simulation_runs.run_date)",
        "display_name": "run month",
        "synonyms": [
          "simulation month",
          "month of run",
          "monthly bucket"
        ]
      }
    ],
    "measures": [
