  "metric_views": [
    {
      "view_name": "simulation_run_metrics",
      "source_table": "simulation_runs",
      "dimensions": [
        {
          "name": "run_date",
          "expr": "run_date"
        },
        {
          "name": "design_family",
          "expr": "design_family"
        },
        {
          "name": "run_status",
          "expr": "run_status"
        },
        {
          "name": "target_node_nm",
          "expr": "target_node_nm"
        }
      ],
      "measures": [
        {
          "name": "total_simulation_runs",
          "expr": "COUNT(DISTINCT run_id)",
          "comment": "Total simulation runs executed"
        },
        {
          "name": "completed_runs",
          "expr": "COUNT(DISTINCT CASE WHEN run_status = 'Completed' THEN run_id END)",
          "comment": "Successfully completed runs"
        },
        {
          "name": "avg_dynamic_power_mw",
          "expr": "AVG(dynamic_power_mw)",
          "comment": "Average dynamic power in milliwatts"
        },
        {
          "name": "avg_die_area_mm2",
          "expr": "AVG(die_area_mm2)",
          "comment": "Average die area in square millimeters"
        },
        {
          "name": "avg_drc_violations",
          "expr": "AVG(drc_violations)",
          "comment": "Average DRC violations per run"
        },
        {
          "name": "total_timing_slack_ns",
          "expr": "SUM(timing_slack_ns)",
          "comment": "Total timing slack ns"
        },
        {
          "name": "total_leakage_power_mw",
          "expr": "SUM(leakage_power_mw)",
          "comment": "Total leakage power mw"
        },
        {
          "name": "unique_design_count",
          "expr": "COUNT(DISTINCT design_id)",
          "comment": "Number of distinct designs"
        },
        {
          "name": "max_timing_slack_ns",
          "expr": "MAX(timing_slack_ns)",
          "comment": "Maximum timing slack ns"
        }
      ]
    },
    {
      "view_name": "optimization_result_metrics",
      "source_table": "optimization_results",
      "dimensions": [
        {
          "name": "result_month",
          "expr": "result_month"
        },
        {
          "name": "design_family",
          "expr": "design_family"
        },
        {
          "name": "design_closure_status",
          "expr": "design_closure_status"
        }
      ],
      "measures": [
        {
          "name": "avg_best_power_mw",
          "expr": "AVG(best_power_mw)",
          "comment": "Average best power found across designs"
        },
        {
          "name": "avg_best_performance",
          "expr": "AVG(best_performance_score)",
          "comment": "Average best performance score"
        },
        {
          "name": "avg_convergence_pct",
          "expr": "AVG(convergence_pct)",
          "comment": "Average optimization convergence"
        },
        {
          "name": "total_optimization_records",
          "expr": "COUNT(DISTINCT result_id)",
          "comment": "Total optimization result records"
        },
        {
          "name": "blocked_design_count",
          "expr": "COUNT(DISTINCT CASE WHEN design_closure_status = 'Blocked' THEN result_id END)",
          "comment": "Designs in Blocked status"
        },
        {
          "name": "total_best_area_mm2",
          "expr": "SUM(best_area_mm2)",
          "comment": "Total best area mm2"
        },
        {
          "name": "unique_design_count",
          "expr": "COUNT(DISTINCT design_id)",
          "comment": "Number of distinct designs"
        },
        {
          "name": "max_best_power_mw",
          "expr": "MAX(best_power_mw)",
          "comment": "Maximum best power mw"
        },
        {
          "name": "total_pareto_front_size",
          "expr": "SUM(pareto_front_size)",
          "comment": "Total pareto front size"
        }
      ]
    }
  ],
  "genie_instructions": "You are a semiconductor analytics assistant for SiliconPath Design. Answer questions about chip design space exploration and multi-objective optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (design_id, design_name), query the base tables directly.\n- When joining tables, use the shared keys: design_id (shared across optimization_results, parameter_explorations, simulation_runs).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in completed runs count?",
    "How has unique total simulation runss changed over time?",
    "What is the monthly trend in unique designs?",
    "How has highest timing slack ns changed over time?",
    "What is the monthly trend in blocked design count?",
    "How has unique total optimization recordss changed over time?",
    "What is the monthly trend in unique designs?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique designs?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', run_date) AS run_date_month, MEASURE(unique_design_count) AS unique_design_count",
        "FROM {fqn}.simulation_run_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date_month"
      ],
      "usage_guidance": "Monthly trend of unique design count across simulation runs, matching phrases like 'how many distinct designs were simulated each month'."
    },
    {
      "question": "How has highest timing slack ns changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(max_timing_slack_ns) AS max_timing_slack_ns",
        "FROM {fqn}.simulation_run_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Time-series trend of maximum timing slack in nanoseconds, matching phrases like 'best timing slack over time' or 'peak timing margin trend'."
    },
    {
      "question": "How has unique designs changed over time?",
      "sql_lines": [
        "SELECT result_month, MEASURE(unique_design_count) AS unique_design_count",
        "FROM {fqn}.optimization_result_metrics",
        "GROUP BY ALL",
        "ORDER BY result_month"
      ],
      "usage_guidance": "Monthly trend of unique design count from optimization results, matching phrases like 'how many designs were optimized each month' using optimization_result_metrics."
    },
    {
      "question": "How does total target process node in nanometers break down by chip design for 'Completed' records?",
      "sql_lines": [
        "SELECT design_id, COUNT(*) AS record_count, SUM(target_node_nm) AS total_target_node_nm",
        "FROM {fqn}.simulation_runs",
        "WHERE run_status = 'Completed' GROUP BY design_id ORDER BY total_target_node_nm DESC"
      ],
      "usage_guidance": "Filtered aggregate of total target process node (nm) broken down by design_id, restricted to run_status = 'Completed' simulation runs."
    },
    {
      "question": "What is the trend of total target clock frequency in ghz over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(clock_freq_ghz) AS total_clock_freq_ghz",
        "FROM {fqn}.parameter_explorations",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of total clock frequency (GHz) summed across parameter exploration snapshots, matching phrases like 'clock frequency trend over time'."
    },
    {
      "question": "How has the average best performance score achieved (0-100) changed over time?",
      "sql_lines": [
        "SELECT result_month, AVG(best_performance_score) AS avg_best_performance_score",
        "FROM {fqn}.optimization_results",
        "GROUP BY result_month ORDER BY result_month"
      ],
      "usage_guidance": "Monthly trend of average best performance score (0–100) from optimization results, matching phrases like 'how has optimization performance improved over time'."
    },
    {
      "question": "How has total leakage power mw changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_leakage_power_mw) AS total_leakage_power_mw",
        "FROM {fqn}.simulation_run_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Time-series trend of total leakage power (mW) across simulation runs, matching phrases like 'leakage power trend' or 'how leakage power changed over time'."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "simulation_runs.run_status = 'Completed'",
        "display_name": "completed simulations",
        "synonyms": [
          "successful runs",
          "passing simulations",
          "finished runs"
        ],
        "instruction": "Use when analyzing only successfully completed simulation runs."
      },
      {
        "sql": "parameter_explorations.pareto_optimal = 'Yes'",
        "display_name": "pareto optimal points",
        "synonyms": [
          "pareto front",
          "optimal tradeoffs",
          "non-dominated solutions"
        ],
        "instruction": "Use when filtering for Pareto-optimal design points only."
      },
      {
        "sql": "optimization_results.design_closure_status = 'Blocked'",
        "display_name": "blocked designs",
        "synonyms": [
          "stalled designs",
          "blocked closure",
          "stalled chips"
        ],
        "instruction": "Use when identifying designs that cannot proceed to tapeout."
      }
    ],
    "expressions": [
