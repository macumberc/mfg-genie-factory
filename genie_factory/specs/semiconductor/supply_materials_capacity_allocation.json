          "fab usage rate",
          "typical loading"
        ]
      },
      {
        "alias": "total_orders",
        "sql": "COUNT(DISTINCT material_orders.order_id)",
        "display_name": "total material orders",
        "synonyms": [
          "order count",
          "procurement orders",
          "purchase orders"
        ]
      },
      {
        "alias": "avg_plan_adherence",
        "sql": "AVG(allocation_monthly.plan_adherence_pct)",
        "display_name": "average plan adherence",
        "synonyms": [
          "mean adherence",
          "plan accuracy",
          "schedule compliance"
        ]
      }
    ]
