        "synonyms": [
          "procurement month",
          "material order month",
          "purchase month"
        ]
      },
      {
        "alias": "spare_capacity_pct",
        "sql": "100.0 - capacity_snapshots.utilization_pct",
        "display_name": "spare capacity",
        "synonyms": [
          "available capacity",
          "headroom",
          "idle capacity"
        ]
      },
      {
        "alias": "capacity_gap",
        "sql": "allocation_monthly.allocated_capacity_units - allocation_monthly.consumed_capacity_units",
        "display_name": "capacity gap",
        "synonyms": [
          "unused allocation",
          "capacity slack",
          "unmet capacity"
        ]
      }
    ],
    "measures": [
