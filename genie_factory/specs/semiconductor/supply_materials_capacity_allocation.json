    {
      "question": "How has rejected order count changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(rejected_order_count) AS rejected_order_count",
        "FROM {fqn}.material_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ]
    },
    {
      "question": "What is the monthly trend in critical bottleneck count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(critical_bottleneck_count) AS critical_bottleneck_count",
        "FROM {fqn}.capacity_utilization_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ]
    },
    {
      "question": "What is the monthly trend in highest utilization percent?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(max_utilization_percent) AS max_utilization_percent",
        "FROM {fqn}.capacity_utilization_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ]
    },
    {
      "question": "What are the top 10 material or component by total quantity ordered (units vary by material)?",
      "sql_lines": [
        "SELECT material_id, SUM(order_quantity) AS total_order_quantity",
        "FROM {fqn}.material_orders",
        "GROUP BY material_id ORDER BY total_order_quantity DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average fab line utilization percentage by human-readable material name?",
      "sql_lines": [
        "SELECT material_name, AVG(utilization_pct) AS avg_utilization_pct",
        "FROM {fqn}.capacity_snapshots",
        "GROUP BY material_name ORDER BY avg_utilization_pct DESC"
      ]
    },
    {
      "question": "How many records are there per month of allocation plan?",
      "sql_lines": [
        "SELECT allocation_month, COUNT(*) AS record_count",
        "FROM {fqn}.allocation_monthly",
        "GROUP BY allocation_month ORDER BY allocation_month"
      ]
    }
