  "metric_views": [
    {
      "view_name": "material_order_metrics",
      "source_table": "material_orders",
      "dimensions": [
        {
          "name": "order_date",
          "expr": "order_date"
        },
        {
          "name": "material_category",
          "expr": "material_category"
        },
        {
          "name": "supplier_name",
          "expr": "supplier_name"
        },
        {
          "name": "delivery_status",
          "expr": "delivery_status"
        },
        {
          "name": "quality_result",
          "expr": "quality_result"
        }
      ],
      "measures": [
        {
          "name": "total_material_orders",
          "expr": "COUNT(DISTINCT order_id)",
          "comment": "Total material orders placed"
        },
        {
          "name": "total_order_value_usd",
          "expr": "SUM(order_value_usd)",
          "comment": "Total procurement value in USD"
        },
        {
          "name": "avg_lead_time_days",
          "expr": "AVG(lead_time_days)",
          "comment": "Average supplier lead time in days"
        },
        {
          "name": "delayed_order_count",
          "expr": "COUNT(DISTINCT CASE WHEN delivery_status = 'Delayed' THEN order_id END)",
          "comment": "Delayed material orders"
        },
        {
          "name": "rejected_order_count",
          "expr": "COUNT(DISTINCT CASE WHEN quality_result = 'Reject' THEN order_id END)",
          "comment": "Orders rejected on quality inspection"
        },
        {
          "name": "unique_material_count",
          "expr": "COUNT(DISTINCT material_id)",
          "comment": "Number of distinct materials"
        },
        {
          "name": "max_order_quantity",
          "expr": "MAX(order_quantity)",
          "comment": "Maximum order quantity"
        },
        {
          "name": "total_order_quantity",
          "expr": "SUM(order_quantity)",
          "comment": "Total order quantity"
        }
      ]
    },
    {
      "view_name": "capacity_utilization_metrics",
      "source_table": "capacity_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "material_category",
          "expr": "material_category"
        },
        {
          "name": "fab_line",
          "expr": "fab_line"
        },
        {
          "name": "bottleneck_status",
          "expr": "bottleneck_status"
        }
      ],
      "measures": [
        {
          "name": "avg_utilization_pct",
          "expr": "AVG(utilization_pct)",
          "comment": "Average fab utilization percentage"
        },
        {
          "name": "total_available_starts",
          "expr": "SUM(available_wafer_starts)",
          "comment": "Total available wafer start slots"
        },
        {
          "name": "total_consumed_starts",
          "expr": "SUM(consumed_wafer_starts)",
          "comment": "Total consumed wafer start slots"
        },
        {
          "name": "critical_bottleneck_count",
          "expr": "COUNT(DISTINCT CASE WHEN bottleneck_status = 'Critical' THEN snapshot_id END)",
          "comment": "Snapshots with Critical bottleneck"
        },
        {
          "name": "unique_material_count",
          "expr": "COUNT(DISTINCT material_id)",
          "comment": "Number of distinct materials"
        },
        {
          "name": "max_utilization_percent",
          "expr": "MAX(utilization_pct)",
          "comment": "Maximum utilization pct"
        }
      ]
    }
  ],
  "genie_instructions": "You are a semiconductor analytics assistant for CapAlloc Semi. Answer questions about supply chain materials management and fab capacity allocation using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (material_id, material_name), query the base tables directly.\n- When joining tables, use the shared keys: material_id (shared across allocation_monthly, capacity_snapshots, material_orders).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in delayed order count?",
    "How has rejected order count changed over time?",
    "What is the monthly trend in unique total material orderss?",
    "How has unique materials changed over time?",
    "What is the monthly trend in critical bottleneck count?",
    "How has unique materials changed over time?",
    "What is the monthly trend in highest utilization percent?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total material orderss?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', order_date) AS order_date_month, MEASURE(total_material_orders) AS total_material_orders",
        "FROM {fqn}.material_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date_month"
      ],
      "usage_guidance": "Monthly trend of total material orders volume; matches phrases like 'order count over time' or 'how many orders per month' using order_date dimension."
    },
    {
      "question": "How has unique materials changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(unique_material_count) AS unique_material_count",
        "FROM {fqn}.material_order_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Time-series trend of distinct materials ordered; matches 'unique materials over time' or 'material variety by date' using unique_material_count across order_date."
    },
    {
      "question": "How does rejected order count vary across material categories?",
      "sql_lines": [
        "SELECT material_category, MEASURE(rejected_order_count) AS rejected_order_count",
        "FROM {fqn}.material_order_metrics",
        "GROUP BY ALL",
        "ORDER BY rejected_order_count DESC"
      ],
      "usage_guidance": "Category-level breakdown of rejected orders; matches 'which material categories have most rejections' ranked descending by rejected_order_count."
    },
    {
      "question": "What is the delayed order count by supplier name?",
      "sql_lines": [
        "SELECT supplier_name, MEASURE(delayed_order_count) AS delayed_order_count",
        "FROM {fqn}.material_order_metrics",
        "GROUP BY ALL",
        "ORDER BY delayed_order_count DESC"
      ],
      "usage_guidance": "Supplier-ranked delayed order count; matches 'which suppliers are causing delays' or 'late deliveries by vendor' ordered by delayed_order_count descending."
    },
    {
      "question": "How does total quantity ordered (units vary by material) break down by material or component for 'Delivered' records?",
      "sql_lines": [
        "SELECT material_id, COUNT(*) AS record_count, SUM(order_quantity) AS total_order_quantity",
        "FROM {fqn}.material_orders",
        "WHERE delivery_status = 'Delivered' GROUP BY material_id ORDER BY total_order_quantity DESC"
      ],
      "usage_guidance": "Filtered aggregate of total order quantity per material for Delivered status only; matches 'how much was delivered per component' with delivery_status = 'Delivered' filter."
    },
    {
      "question": "What is the trend of total available wafer start slots for the week over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(available_wafer_starts) AS total_available_wafer_starts",
        "FROM {fqn}.capacity_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Weekly or date-level trend of total available wafer start capacity; matches 'fab capacity availability over time' or 'wafer starts trend' from capacity_snapshots."
    },
    {
      "question": "How has the average percentage adherence to allocation plan changed over time?",
      "sql_lines": [
        "SELECT allocation_month, AVG(plan_adherence_pct) AS avg_plan_adherence_pct",
        "FROM {fqn}.allocation_monthly",
        "GROUP BY allocation_month ORDER BY allocation_month"
      ],
      "usage_guidance": "Monthly trend of average plan adherence percentage; matches 'how well are we following allocation plans' or 'plan adherence over time' from allocation_monthly."
    }
  ],
  "sql_snippets": {
    "filters": [
