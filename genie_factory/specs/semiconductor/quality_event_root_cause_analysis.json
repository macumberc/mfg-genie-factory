  "metric_views": [
    {
      "view_name": "quality_events_metrics",
      "source_table": "quality_events",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "product_family",
          "expr": "product_family"
        },
        {
          "name": "fab_location",
          "expr": "fab_location"
        },
        {
          "name": "root_cause_category",
          "expr": "root_cause_category"
        },
        {
          "name": "severity_level",
          "expr": "severity_level"
        }
      ],
      "measures": [
        {
          "name": "total_quality_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total number of quality events"
        },
        {
          "name": "critical_event_count",
          "expr": "COUNT(DISTINCT CASE WHEN severity_level = 'Critical' THEN event_id END)",
          "comment": "Events with Critical severity"
        },
        {
          "name": "closed_event_count",
          "expr": "COUNT(DISTINCT CASE WHEN status = 'Closed' THEN event_id END)",
          "comment": "Events in Closed status"
        },
        {
          "name": "total_wafers_affected",
          "expr": "SUM(affected_wafer_count)",
          "comment": "Total wafers impacted by quality events"
        },
        {
          "name": "open_event_count",
          "expr": "COUNT(DISTINCT CASE WHEN status = 'Open' THEN event_id END)",
          "comment": "Events currently Open"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_affected_wafer_count",
          "expr": "MAX(affected_wafer_count)",
          "comment": "Maximum affected wafer count"
        }
      ]
    },
    {
      "view_name": "lot_yield_metrics",
      "source_table": "manufacturing_lots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "product_family",
          "expr": "product_family"
        },
        {
          "name": "fab_location",
          "expr": "fab_location"
        },
        {
          "name": "lot_grade",
          "expr": "lot_grade"
        }
      ],
      "measures": [
        {
          "name": "avg_yield_pct",
          "expr": "AVG(yield_pct)",
          "comment": "Average lot yield percentage"
        },
        {
          "name": "total_good_die",
          "expr": "SUM(good_die_count)",
          "comment": "Total good die produced"
        },
        {
          "name": "avg_defect_density",
          "expr": "AVG(defect_density_per_cm2)",
          "comment": "Average defect density per cm2"
        },
        {
          "name": "total_lots",
          "expr": "COUNT(DISTINCT lot_id)",
          "comment": "Total manufacturing lots"
        },
        {
          "name": "grade_c_lot_count",
          "expr": "COUNT(DISTINCT CASE WHEN lot_grade = 'C' THEN lot_id END)",
          "comment": "Lots graded C (below threshold)"
        },
        {
          "name": "total_cycle_time_hours",
          "expr": "SUM(cycle_time_hours)",
          "comment": "Total cycle time hours"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_yield_percent",
          "expr": "MAX(yield_pct)",
          "comment": "Maximum yield pct"
        },
        {
          "name": "total_wafers_in_lot",
          "expr": "SUM(wafers_in_lot)",
          "comment": "Total wafers in lot"
        }
      ]
    }
  ],
  "genie_instructions": "You are a semiconductor analytics assistant for NanoVista Semiconductor. Answer questions about semiconductor quality event root cause analysis and yield improvement using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (product_id, product_name), query the base tables directly.\n- When joining tables, use the shared keys: product_id (shared across manufacturing_lots, quality_events, quality_kpi_monthly).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.\n- Treat the `status` field as authoritative for lifecycle state.",
  "sample_questions": [
    "What is the monthly trend in critical event count?",
    "How has closed event count changed over time?",
    "What is the monthly trend in open event count?",
    "How has unique total quality eventss changed over time?",
    "What is the monthly trend in grade c lot count?",
    "How has unique total lotss changed over time?",
    "What is the monthly trend in unique products?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in open event count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(open_event_count) AS open_event_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Route for time-series trend of open (unresolved) quality events count using the quality_events_metrics metric view."
    },
    {
      "question": "How has unique total quality eventss changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_quality_events) AS total_quality_events",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Route for time-series trend of total quality event volume across all products and fabs using quality_events_metrics."
    },
    {
      "question": "What is the monthly trend in unique products?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(unique_product_count) AS unique_product_count",
        "FROM {fqn}.lot_yield_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ],
      "usage_guidance": "Route for monthly trend of unique product count tracked in manufacturing lots using lot_yield_metrics snapshot dates."
    },
    {
      "question": "How does total number of wafers affected by the event break down by product for 'Closed' records?",
      "sql_lines": [
        "SELECT product_id, COUNT(*) AS record_count, SUM(affected_wafer_count) AS total_affected_wafer_count",
        "FROM {fqn}.quality_events",
        "WHERE status = 'Closed' GROUP BY product_id ORDER BY total_affected_wafer_count DESC"
      ],
      "usage_guidance": "Route for per-product breakdown of total wafers affected, filtered specifically to 'Closed' status quality events."
    },
    {
      "question": "What is the trend of total number of wafers in the lot over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(wafers_in_lot) AS total_wafers_in_lot",
        "FROM {fqn}.manufacturing_lots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Route for time-series trend of total wafer volume in manufacturing lots using manufacturing_lots wafers_in_lot aggregation."
    },
    {
      "question": "How has the average first pass yield percentage changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(first_pass_yield_pct) AS avg_first_pass_yield_pct",
        "FROM {fqn}.quality_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Route for monthly trend of first pass yield percentage from quality KPI data in quality_kpi_monthly."
    },
    {
      "question": "How has open event count changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(open_event_count) AS open_event_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Route for time-series trend of open quality event count when user asks how unresolved events change over time."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "quality_events.severity_level = 'Critical'",
        "display_name": "critical events",
        "synonyms": [
          "critical quality events",
          "severe events",
          "high severity"
        ],
        "instruction": "Use when analyzing only the most severe quality events."
      },
      {
        "sql": "manufacturing_lots.lot_grade = 'C'",
        "display_name": "low yield lots",
        "synonyms": [
          "grade C lots",
          "failing lots",
          "below threshold"
        ],
        "instruction": "Use when filtering for lots with yield below 75%."
      },
      {
        "sql": "quality_events.event_date >= ADD_MONTHS(CURRENT_DATE(), -90)",
        "display_name": "last 90 days",
        "synonyms": [
          "recent events",
          "past 3 months",
          "trailing quarter"
        ],
        "instruction": "Use to restrict quality event analysis to the most recent 90-day window."
      }
    ],
    "expressions": [
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', quality_events.event_date)",
        "display_name": "event month",
        "synonyms": [
          "month of event",
          "quality event month",
          "incident month"
        ]
      },
      {
        "alias": "yield_grade_flag",
        "sql": "CASE WHEN manufacturing_lots.yield_pct >= 90 THEN 'A' WHEN manufacturing_lots.yield_pct >= 75 THEN 'B' ELSE 'C' END",
        "display_name": "yield grade",
        "synonyms": [
          "lot grade",
          "yield bucket",
          "lot rating"
        ]
      },
      {
        "alias": "closure_rate",
        "sql": "CASE WHEN quality_events.status = 'Closed' THEN 1 ELSE 0 END",
        "display_name": "closure flag",
        "synonyms": [
          "resolved flag",
          "closed indicator",
          "fix status"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_events",
        "sql": "COUNT(DISTINCT quality_events.event_id)",
        "display_name": "total quality events",
        "synonyms": [
          "event count",
          "number of events",
          "quality event volume"
        ]
      },
      {
        "alias": "avg_lot_yield",
        "sql": "AVG(manufacturing_lots.yield_pct)",
        "display_name": "average lot yield",
        "synonyms": [
          "mean yield",
          "yield percentage",
          "lot yield rate"
        ]
      },
      {
        "alias": "total_wafers_affected",
        "sql": "SUM(quality_events.affected_wafer_count)",
        "display_name": "total wafers affected",
        "synonyms": [
          "impacted wafers",
          "affected wafer count",
          "wafer impact"
        ]
      },
      {
        "alias": "avg_dppm",
        "sql": "AVG(quality_kpi_monthly.dppm)",
        "display_name": "average DPPM",
        "synonyms": [
          "mean DPPM",
          "defective parts per million",
          "defect rate"
        ]
      }
    ]
  },
