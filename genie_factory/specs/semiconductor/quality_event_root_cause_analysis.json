          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'FAB-Taiwan' WHEN {status_noise} < 0.55 THEN 'FAB-Arizona' WHEN {status_noise} < 0.80 THEN 'FAB-Dresden' ELSE 'FAB-Singapore' END",
          "entity_values": [
            "FAB-Taiwan",
            "FAB-Arizona",
            "FAB-Dresden",
            "FAB-Singapore"
          ]
        },
        {
          "name": "event_type",
          "sql_type": "STRING",
          "comment": "Type of quality event",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.18 THEN 'Defect Excursion' WHEN {status_noise} < 0.34 THEN 'Process Deviation' WHEN {status_noise} < 0.48 THEN 'Equipment Alarm' WHEN {status_noise} < 0.60 THEN 'Yield Drop' WHEN {status_noise} < 0.72 THEN 'Customer Return' WHEN {status_noise} < 0.86 THEN 'Incoming Material Fail' ELSE 'Environmental Event' END",
          "entity_values": [
            "Defect Excursion",
            "Process Deviation",
            "Equipment Alarm",
            "Yield Drop",
            "Customer Return",
            "Incoming Material Fail",
            "Environmental Event"
          ]
        },
        {
          "name": "failure_mode",
          "sql_type": "STRING",
          "comment": "Specific failure mode observed",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.07 THEN 'Open Circuit' WHEN {status_noise} < 0.14 THEN 'Short Circuit' WHEN {status_noise} < 0.20 THEN 'Gate Oxide Breakdown' WHEN {status_noise} < 0.26 THEN 'Electromigration' WHEN {status_noise} < 0.32 THEN 'Hot Carrier Injection' WHEN {status_noise} < 0.38 THEN 'Latch-Up' WHEN {status_noise} < 0.44 THEN 'Metal Bridging' WHEN {status_noise} < 0.50 THEN 'Via Void' WHEN {status_noise} < 0.56 THEN 'Particle Contamination' WHEN {status_noise} < 0.62 THEN 'Pattern Collapse' WHEN {status_noise} < 0.68 THEN 'Delamination' WHEN {status_noise} < 0.74 THEN 'Crack Propagation' WHEN {status_noise} < 0.80 THEN 'Solder Joint Fatigue' WHEN {status_noise} < 0.86 THEN 'Wire Bond Lift' WHEN {status_noise} < 0.93 THEN 'ESD Damage' ELSE 'Corrosion' END",
          "entity_values": [
            "Open Circuit",
            "Short Circuit",
            "Gate Oxide Breakdown",
            "Electromigration",
            "Hot Carrier Injection",
            "Latch-Up",
            "Metal Bridging",
            "Via Void",
            "Particle Contamination",
            "Pattern Collapse",
            "Delamination",
            "Crack Propagation",
            "Solder Joint Fatigue",
            "Wire Bond Lift",
            "ESD Damage",
            "Corrosion"
          ]
        },
        {
          "name": "severity_level",
          "sql_type": "STRING",
          "comment": "Event severity classification",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.50 THEN 'Minor' WHEN {status_noise} < 0.74 THEN 'Major' WHEN {status_noise} < 0.95 THEN 'Observation' ELSE 'Critical' END",
          "entity_values": [
            "Minor",
            "Major",
            "Observation",
            "Critical"
          ]
        },
        {
          "name": "root_cause_category",
          "sql_type": "STRING",
          "comment": "Root cause classification",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.14 THEN 'Contamination' WHEN {status_noise} < 0.26 THEN 'Lithography' WHEN {status_noise} < 0.38 THEN 'Etch Variation' WHEN {status_noise} < 0.48 THEN 'CMP Defect' WHEN {status_noise} < 0.58 THEN 'Implant Drift' WHEN {status_noise} < 0.68 THEN 'Equipment Fault' WHEN {status_noise} < 0.78 THEN 'Material Defect' WHEN {status_noise} < 0.88 THEN 'Operator Error' ELSE 'Environmental' END",
          "entity_values": [
            "Contamination",
            "Lithography",
            "Etch Variation",
            "CMP Defect",
            "Implant Drift",
            "Equipment Fault",
            "Material Defect",
            "Operator Error",
            "Environmental"
          ]
        },
        {
          "name": "status",
          "sql_type": "STRING",
          "comment": "Current event status",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.51 THEN 'Closed' WHEN {status_noise} < 0.68 THEN 'Pending' WHEN {status_noise} < 0.85 THEN 'Open' ELSE 'In Progress' END",
          "entity_values": [
            "Closed",
            "Pending",
            "Open",
            "In Progress"
          ]
        },
        {
          "name": "affected_wafer_count",
          "sql_type": "INT",
          "comment": "Number of wafers affected by the event",
          "is_dimension": false,
          "generation_expr": "CAST(1 + FLOOR({qty_noise} * 24) AS INT)"
        }
