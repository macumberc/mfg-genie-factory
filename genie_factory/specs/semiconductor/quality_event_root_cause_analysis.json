        {
          "name": "lot_grade",
          "sql_type": "STRING",
          "comment": "Lot quality grade (A/B/C)",
          "is_dimension": false,
          "generation_expr": "CASE WHEN (82.0 + ({qty_noise} - 0.5) * 30.0) >= 90.0 THEN 'A' WHEN (82.0 + ({qty_noise} - 0.5) * 30.0) >= 75.0 THEN 'B' ELSE 'C' END",
          "entity_values": [
            "A",
            "B",
            "C"
          ]
        },
        {
          "name": "wafers_in_lot",
          "sql_type": "INT",
          "comment": "Number of wafers in the lot",
          "is_dimension": false,
          "generation_expr": "CAST(20 + FLOOR({qty_noise} * 6) AS INT)"
        },
        {
          "name": "good_die_count",
          "sql_type": "INT",
          "comment": "Number of good die produced from lot",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR((20 + FLOOR({qty_noise} * 6)) * 400 * (0.55 + {qty_noise} * 0.44)) AS INT)"
        },
        {
          "name": "defect_density_per_cm2",
          "sql_type": "DOUBLE",
          "comment": "Defects per square centimeter on wafer surface",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.01, 0.50 - ({qty_noise} * 0.40)), 4)"
        },
        {
          "name": "cycle_time_hours",
          "sql_type": "DOUBLE",
          "comment": "Total lot processing time in hours",
          "is_dimension": false,
          "generation_expr": "ROUND(120.0 + {qty_noise} * 360.0, 1)"
        }
