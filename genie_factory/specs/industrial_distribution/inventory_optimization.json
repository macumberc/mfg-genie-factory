  "metric_views": [
    {
      "view_name": "inventory_kpi_monthly",
      "source_table": "inventory_transactions",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "warehouse",
          "expr": "warehouse"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "stock_status",
          "expr": "stock_status"
        }
      ],
      "measures": [
        {
          "name": "avg_on_hand_qty",
          "expr": "AVG(on_hand_qty)",
          "comment": "Average units on hand"
        },
        {
          "name": "total_carrying_cost",
          "expr": "SUM(carrying_cost_usd)",
          "comment": "Total carrying cost USD"
        },
        {
          "name": "avg_days_of_supply",
          "expr": "AVG(days_of_supply)",
          "comment": "Average days of supply"
        },
        {
          "name": "stockout_count",
          "expr": "COUNT(DISTINCT CASE WHEN stock_status = 'Stockout' THEN snapshot_id END)",
          "comment": "Stockout snapshot count"
        },
        {
          "name": "total_snapshot_count",
          "expr": "COUNT(DISTINCT snapshot_id)",
          "comment": "Total snapshot count"
        },
        {
          "name": "unique_wp_count",
          "expr": "COUNT(DISTINCT wp_id)",
          "comment": "Number of distinct wps"
        },
        {
          "name": "max_on_hand_qty",
          "expr": "MAX(on_hand_qty)",
          "comment": "Maximum on hand qty"
        },
        {
          "name": "total_reorder_point",
          "expr": "SUM(reorder_point)",
          "comment": "Total reorder point"
        }
      ]
    },
    {
      "view_name": "inventory_perf_monthly",
      "source_table": "inventory_snapshots",
      "dimensions": [
        {
          "name": "perf_month",
          "expr": "perf_month"
        },
        {
          "name": "warehouse",
          "expr": "warehouse"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        }
      ],
      "measures": [
        {
          "name": "avg_turnover_ratio",
          "expr": "AVG(turnover_ratio)",
          "comment": "Average inventory turnover"
        },
        {
          "name": "total_stockout_days",
          "expr": "SUM(stockout_days)",
          "comment": "Total stockout days"
        },
        {
          "name": "avg_fill_rate",
          "expr": "AVG(fill_rate_pct)",
          "comment": "Average fill rate"
        },
        {
          "name": "total_monthly_carrying_cost",
          "expr": "SUM(total_carrying_cost_usd)",
          "comment": "Total monthly carrying cost"
        },
        {
          "name": "item_count",
          "expr": "COUNT(DISTINCT wp_id)",
          "comment": "Number of items tracked"
        },
        {
          "name": "max_turnover_ratio",
          "expr": "MAX(turnover_ratio)",
          "comment": "Maximum turnover ratio"
        }
      ]
    }
  ],
  "genie_instructions": "You are an industrial distribution analytics assistant for StockSmart Distribution. Answer questions about warehouse inventory optimization and stock level management using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (wp_id, product_name), query the base tables directly.\n- When joining tables, use the shared keys: wp_id (shared across inventory_snapshots, inventory_transactions, warehouse_products).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in stockout count?",
    "How has unique total snapshots changed over time?",
    "What is the monthly trend in unique wps?",
    "How has highest on hand qty changed over time?",
    "What is the monthly trend in unique items?",
    "How has highest turnover ratio changed over time?",
    "What is the monthly trend in total stockout days?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique wps?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(unique_wp_count) AS unique_wp_count",
        "FROM {fqn}.inventory_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ],
      "usage_guidance": "Monthly trend of unique warehouse-product count; matches phrases like 'how many distinct WPs tracked each month' using unique_wp_count from inventory_kpi_monthly."
    },
    {
      "question": "How has highest on hand qty changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(max_on_hand_qty) AS max_on_hand_qty",
        "FROM {fqn}.inventory_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of peak on-hand quantity; matches phrases like 'highest stock level over time' using max_on_hand_qty from inventory_kpi_monthly."
    },
    {
      "question": "What is the monthly trend in total stockout days?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', perf_month) AS perf_month_month, MEASURE(total_stockout_days) AS total_stockout_days",
        "FROM {fqn}.inventory_perf_monthly",
        "GROUP BY ALL",
        "ORDER BY perf_month_month"
      ],
      "usage_guidance": "Monthly trend of total stockout days across all warehouses; matches phrases like 'how often were we out of stock each month' using total_stockout_days from inventory_perf_monthly."
    },
    {
      "question": "How has total monthly carrying cost changed over time?",
      "sql_lines": [
        "SELECT perf_month, MEASURE(total_monthly_carrying_cost) AS total_monthly_carrying_cost",
        "FROM {fqn}.inventory_perf_monthly",
        "GROUP BY ALL",
        "ORDER BY perf_month"
      ],
      "usage_guidance": "Monthly trend of total inventory carrying cost; matches phrases like 'how has our holding cost changed over time' using total_monthly_carrying_cost from inventory_perf_monthly."
    },
    {
      "question": "What is the trend of total units moved (positive=receipt, negative=issue) over time?",
      "sql_lines": [
        "SELECT movement_date, SUM(quantity_moved) AS total_quantity_moved",
        "FROM {fqn}.warehouse_products",
        "GROUP BY movement_date ORDER BY movement_date"
      ],
      "usage_guidance": "Daily trend of net units moved (receipts vs. issues); matches phrases like 'inventory flow over time' using quantity_moved from warehouse_products movement transactions."
    },
    {
      "question": "What is the trend of total units on hand over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(on_hand_qty) AS total_on_hand_qty",
        "FROM {fqn}.inventory_transactions",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Daily trend of total on-hand units across all locations; matches phrases like 'total stock on hand over time' using on_hand_qty from inventory_transactions snapshots."
    },
    {
      "question": "How has the average inventory turnover ratio changed over time?",
      "sql_lines": [
        "SELECT perf_month, AVG(turnover_ratio) AS avg_turnover_ratio",
        "FROM {fqn}.inventory_snapshots",
        "GROUP BY perf_month ORDER BY perf_month"
      ],
      "usage_guidance": "Monthly trend of average inventory turnover ratio; matches phrases like 'how fast is inventory turning each month' using turnover_ratio from inventory_snapshots."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "inventory_transactions.stock_status = 'Stockout'",
        "display_name": "stockouts",
        "synonyms": [
          "out of stock",
          "zero inventory",
          "depleted stock"
        ],
        "instruction": "Filter to stockout items."
      },
      {
        "sql": "inventory_transactions.stock_status = 'Overstock'",
        "display_name": "overstocked",
        "synonyms": [
          "excess inventory",
          "surplus stock",
          "bloated stock"
        ],
        "instruction": "Filter to overstocked items."
      },
      {
        "sql": "warehouse_products.movement_type = 'Issue'",
        "display_name": "issues",
        "synonyms": [
          "outbound",
          "shipments",
          "disbursements"
        ],
        "instruction": "Filter to inventory issues."
      }
    ],
    "expressions": [
      {
        "alias": "movement_month",
        "sql": "DATE_TRUNC('month', warehouse_products.movement_date)",
        "display_name": "movement month",
        "synonyms": [
          "monthly",
          "activity month",
          "transaction month"
        ]
      },
      {
        "alias": "inventory_value",
        "sql": "inventory_transactions.on_hand_qty * warehouse_products.unit_cost_usd",
        "display_name": "inventory value USD",
        "synonyms": [
          "stock value",
          "on-hand worth",
          "holdings value"
        ]
      },
      {
        "alias": "below_reorder",
        "sql": "CASE WHEN inventory_transactions.on_hand_qty < inventory_transactions.reorder_point THEN 'Yes' ELSE 'No' END",
        "display_name": "below reorder point",
        "synonyms": [
          "needs reorder",
          "reorder flag",
          "low stock flag"
        ]
      }
    ],
    "measures": [
      {
        "alias": "avg_on_hand",
        "sql": "AVG(inventory_transactions.on_hand_qty)",
        "display_name": "average on-hand qty",
        "synonyms": [
          "stock level",
          "mean stock qty",
          "typical inventory"
        ]
      },
      {
        "alias": "total_carrying_cost",
        "sql": "SUM(inventory_transactions.carrying_cost_usd)",
        "display_name": "total carrying cost",
        "synonyms": [
          "holding cost",
          "storage expense",
          "inventory overhead"
        ]
      },
      {
        "alias": "avg_turnover",
        "sql": "AVG(inventory_snapshots.turnover_ratio)",
        "display_name": "average turnover",
        "synonyms": [
          "turns",
          "stock rotation",
          "inventory churn"
        ]
      },
      {
        "alias": "avg_fill_rate",
        "sql": "AVG(inventory_snapshots.fill_rate_pct)",
        "display_name": "average fill rate",
        "synonyms": [
          "service level",
          "order fulfillment rate",
          "demand satisfaction"
        ]
      }
    ]
  },
