    {
      "question": "How has highest turnover ratio changed over time?",
      "sql_lines": [
        "SELECT perf_month, MEASURE(max_turnover_ratio) AS max_turnover_ratio",
        "FROM {fqn}.inventory_perf_monthly",
        "GROUP BY ALL",
        "ORDER BY perf_month"
      ]
    },
    {
      "question": "What are the top 10 warehouse-product combo by total units moved (positive=receipt, negative=issue)?",
      "sql_lines": [
        "SELECT wp_id, SUM(quantity_moved) AS total_quantity_moved",
        "FROM {fqn}.warehouse_products",
        "GROUP BY wp_id ORDER BY total_quantity_moved DESC LIMIT 10"
      ]
    },
    {
      "question": "How many records are there per date of inventory snapshot?",
      "sql_lines": [
        "SELECT snapshot_date, COUNT(*) AS record_count",
        "FROM {fqn}.inventory_transactions",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How many records are there per performance month?",
      "sql_lines": [
        "SELECT perf_month, COUNT(*) AS record_count",
        "FROM {fqn}.inventory_snapshots",
        "GROUP BY perf_month ORDER BY perf_month"
      ]
    }
