    {
      "question": "What is the monthly trend in stockout count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(stockout_count) AS stockout_count",
        "FROM {fqn}.inventory_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ]
