    {
      "question": "How has unique total snapshots changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_snapshot_count) AS total_snapshot_count",
        "FROM {fqn}.inventory_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the monthly trend in unique items?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', perf_month) AS perf_month_month, MEASURE(item_count) AS item_count",
        "FROM {fqn}.inventory_perf_monthly",
        "GROUP BY ALL",
        "ORDER BY perf_month_month"
      ]
