  "genie_instructions": "You are an industrial distribution analytics assistant for DistroCapital Finance. Answer questions about working capital and cash flow optimization for industrial distribution using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (bu_id, bu_name), query the base tables directly.\n- When joining tables, use the shared keys: bu_id (shared across business_units, cash_transactions, working_capital_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique transactions?",
    "How has unique bus changed over time?",
    "What is the monthly trend in highest cash inflow?",
    "How has total cash inflow usd changed over time?",
    "What is the monthly trend in critical count?",
    "How has unique bus changed over time?",
    "What is the monthly trend in highest forecasted cash flow?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest cash inflow?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(max_cash_inflow) AS max_cash_inflow",
        "FROM {fqn}.cashflow_monthly",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ],
      "usage_guidance": "Monthly trend of peak/highest single cash inflow; user asks about maximum or top cash inflow performance over time using cashflow_monthly metric view."
    },
    {
      "question": "How has total cash inflow usd changed over time?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(total_cash_inflow) AS total_cash_inflow",
        "FROM {fqn}.cashflow_monthly",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ],
      "usage_guidance": "Monthly trend of aggregated total cash inflow dollars; user asks how overall cash receipts or inflows have grown or declined across all business units over time."
    },
    {
      "question": "How has critical count changed over time?",
      "sql_lines": [
        "SELECT forecast_month, MEASURE(critical_count) AS critical_count",
        "FROM {fqn}.working_capital_monthly",
        "GROUP BY ALL",
        "ORDER BY forecast_month"
      ],
      "usage_guidance": "Monthly trend of count of business units in critical liquidity status; user asks how many units are flagged critical or at-risk in working capital over time."
    },
    {
      "question": "What is the trend of total cash inflow in usd over time?",
      "sql_lines": [
        "SELECT txn_date, SUM(cash_inflow_usd) AS total_cash_inflow_usd",
        "FROM {fqn}.business_units",
        "GROUP BY txn_date ORDER BY txn_date"
      ],
      "usage_guidance": "Monthly trend of summed cash inflow from raw business_units table; user asks about cash inflow over time without needing metric view aggregation or payment_type breakdown."
    },
    {
      "question": "What is the trend of total total ar balance usd over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(ar_balance_usd) AS total_ar_balance_usd",
        "FROM {fqn}.cash_transactions",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly trend of total accounts receivable balance from cash_transactions snapshots; user asks how AR balances or outstanding receivables have changed over time."
    },
    {
      "question": "How has the average current ratio (assets/liabilities) changed over time?",
      "sql_lines": [
        "SELECT forecast_month, AVG(current_ratio) AS avg_current_ratio",
        "FROM {fqn}.working_capital_snapshots",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ],
      "usage_guidance": "Monthly trend of average current ratio from working_capital_snapshots; user asks about liquidity health, assets-to-liabilities ratio, or solvency trends over forecast periods."
    },
    {
      "question": "How has unique transactions changed over time?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(transaction_count) AS transaction_count",
        "FROM {fqn}.cashflow_monthly",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ],
      "usage_guidance": "Monthly trend of transaction volume count; user asks how transaction activity, deal frequency, or number of cash transactions has changed over time."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "working_capital_snapshots.liquidity_status = 'Critical'",
        "display_name": "critical liquidity",
        "synonyms": [
          "cash crisis",
          "liquidity alert",
          "distressed units"
        ],
        "instruction": "Filter to critical liquidity."
      },
      {
        "sql": "business_units.payment_type = 'Customer Payment'",
        "display_name": "customer payments",
        "synonyms": [
          "AR collections",
          "incoming receipts",
          "client remittances"
        ],
        "instruction": "Filter to customer payments."
      },
      {
        "sql": "cash_transactions.dso_days > 45",
        "display_name": "high DSO",
        "synonyms": [
          "slow collections",
          "overdue receivables",
          "extended payment terms"
        ],
        "instruction": "Filter to high DSO business units."
      }
    ],
    "expressions": [
      {
        "alias": "txn_month",
        "sql": "DATE_TRUNC('month', business_units.txn_date)",
        "display_name": "transaction month",
        "synonyms": [
          "monthly",
          "billing month",
          "activity month"
        ]
      },
      {
        "alias": "working_capital",
        "sql": "cash_transactions.ar_balance_usd + cash_transactions.inventory_investment_usd - cash_transactions.ap_balance_usd",
        "display_name": "net working capital USD",
        "synonyms": [
          "NWC",
          "net current assets",
          "liquidity buffer"
        ]
      },
      {
        "alias": "cf_variance",
        "sql": "working_capital_snapshots.actual_cash_flow_usd - working_capital_snapshots.forecasted_cash_flow_usd",
        "display_name": "cash flow variance",
        "synonyms": [
          "forecast miss",
          "budget deviation",
          "cash gap"
        ]
      }
    ],
    "measures": [
      {
        "alias": "net_cash_flow",
        "sql": "SUM(business_units.cash_inflow_usd) - SUM(business_units.cash_outflow_usd)",
        "display_name": "net cash flow",
        "synonyms": [
          "cash position",
          "cash surplus",
          "net liquidity"
        ]
      },
      {
        "alias": "total_ar",
        "sql": "SUM(cash_transactions.ar_balance_usd)",
        "display_name": "total AR balance",
        "synonyms": [
          "receivables",
          "receivables balance",
          "outstanding invoices"
        ]
      },
      {
        "alias": "avg_dso",
        "sql": "AVG(cash_transactions.dso_days)",
        "display_name": "average DSO",
        "synonyms": [
          "days sales outstanding",
          "collection days",
          "days to collect"
        ]
      },
      {
        "alias": "avg_ccc",
        "sql": "AVG(working_capital_snapshots.cash_conversion_cycle_days)",
        "display_name": "average CCC",
        "synonyms": [
          "cash conversion cycle",
          "cash cycle",
          "conversion cycle"
        ]
      }
    ]
  },
