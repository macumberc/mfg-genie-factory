    {
      "question": "What is the monthly trend in backordered count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', order_date) AS order_date_month, MEASURE(backordered_count) AS backordered_count",
        "FROM {fqn}.demand_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY order_date_month"
      ]
    },
    {
      "question": "How has unique total orders changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(total_order_count) AS total_order_count",
        "FROM {fqn}.demand_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ]
    },
    {
      "question": "What is the monthly trend in over forecast count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', forecast_month) AS forecast_month_month, MEASURE(over_forecast_count) AS over_forecast_count",
        "FROM {fqn}.forecast_accuracy_monthly",
        "GROUP BY ALL",
        "ORDER BY forecast_month_month"
      ]
    },
    {
      "question": "How has unique forecasts changed over time?",
      "sql_lines": [
        "SELECT forecast_month, MEASURE(forecast_count) AS forecast_count",
        "FROM {fqn}.forecast_accuracy_monthly",
        "GROUP BY ALL",
        "ORDER BY forecast_month"
      ]
    },
    {
      "question": "What are the top 10 product sku code by total units ordered?",
      "sql_lines": [
        "SELECT sku, SUM(order_quantity) AS total_order_quantity",
        "FROM {fqn}.product_skus",
        "GROUP BY sku ORDER BY total_order_quantity DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average order fill rate 0-100 by product category?",
      "sql_lines": [
        "SELECT product_category, AVG(fill_rate_pct) AS avg_fill_rate_pct",
        "FROM {fqn}.sales_orders",
        "GROUP BY product_category ORDER BY avg_fill_rate_pct DESC"
      ]
    },
    {
      "question": "How many records are there per forecast month (first day)?",
      "sql_lines": [
        "SELECT forecast_month, COUNT(*) AS record_count",
        "FROM {fqn}.demand_forecasts",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ]
    }
