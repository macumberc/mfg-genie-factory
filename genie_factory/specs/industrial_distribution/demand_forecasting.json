  "metric_views": [
    {
      "view_name": "demand_kpi_monthly",
      "source_table": "product_skus",
      "dimensions": [
        {
          "name": "order_date",
          "expr": "order_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "customer_segment",
          "expr": "customer_segment"
        },
        {
          "name": "order_status",
          "expr": "order_status"
        }
      ],
      "measures": [
        {
          "name": "total_order_revenue",
          "expr": "SUM(order_quantity * unit_price_usd)",
          "comment": "Total order revenue USD"
        },
        {
          "name": "total_order_quantity",
          "expr": "SUM(order_quantity)",
          "comment": "Total units ordered"
        },
        {
          "name": "total_order_count",
          "expr": "COUNT(DISTINCT order_id)",
          "comment": "Total orders placed"
        },
        {
          "name": "backordered_count",
          "expr": "COUNT(DISTINCT CASE WHEN order_status = 'Backordered' THEN order_id END)",
          "comment": "Backordered order count"
        },
        {
          "name": "avg_lead_time",
          "expr": "AVG(lead_time_days)",
          "comment": "Average lead time days"
        },
        {
          "name": "max_order_quantity",
          "expr": "MAX(order_quantity)",
          "comment": "Maximum order quantity"
        }
      ]
    },
    {
      "view_name": "forecast_accuracy_monthly",
      "source_table": "demand_forecasts",
      "dimensions": [
        {
          "name": "forecast_month",
          "expr": "forecast_month"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "model_version",
          "expr": "model_version"
        }
      ],
      "measures": [
        {
          "name": "total_forecasted_units",
          "expr": "SUM(forecasted_units)",
          "comment": "Total forecasted demand"
        },
        {
          "name": "total_actual_units",
          "expr": "SUM(actual_units)",
          "comment": "Total actual demand"
        },
        {
          "name": "avg_forecast_error",
          "expr": "AVG(forecast_error_pct)",
          "comment": "Average forecast error pct"
        },
        {
          "name": "forecast_count",
          "expr": "COUNT(DISTINCT forecast_id)",
          "comment": "Number of forecast records"
        },
        {
          "name": "over_forecast_count",
          "expr": "COUNT(DISTINCT CASE WHEN forecasted_units > actual_units THEN forecast_id END)",
          "comment": "Over-forecast count"
        },
        {
          "name": "max_forecasted_units",
          "expr": "MAX(forecasted_units)",
          "comment": "Maximum forecasted units"
        },
        {
          "name": "total_confidence_lower",
          "expr": "SUM(confidence_lower)",
          "comment": "Total confidence lower"
        },
        {
          "name": "total_confidence_upper",
          "expr": "SUM(confidence_upper)",
          "comment": "Total confidence upper"
        }
      ]
    }
  ],
  "genie_instructions": "You are an industrial distribution analytics assistant for DistroForecast Systems. Answer questions about industrial product demand forecasting and order backlog management using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (sku, product_name), query the base tables directly.\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in backordered count?",
    "How has unique total orders changed over time?",
    "What is the monthly trend in highest order quantity?",
    "How has total order revenue usd changed over time?",
    "What is the monthly trend in over forecast count?",
    "How has unique forecasts changed over time?",
    "What is the monthly trend in highest forecasted units?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest order quantity?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', order_date) AS order_date_month, MEASURE(max_order_quantity) AS max_order_quantity",
        "FROM {fqn}.demand_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY order_date_month"
      ],
      "usage_guidance": "Monthly trend of peak/highest order quantity over time; user mentions 'max order quantity', 'highest orders', or 'order volume spikes' across periods."
    },
    {
      "question": "How has total order revenue usd changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(total_order_revenue) AS total_order_revenue",
        "FROM {fqn}.demand_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Time-series trend of total order revenue; user asks how revenue or sales dollars have grown, declined, or changed month over month."
    },
    {
      "question": "What is the monthly trend in highest forecasted units?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', forecast_month) AS forecast_month_month, MEASURE(max_forecasted_units) AS max_forecasted_units",
        "FROM {fqn}.forecast_accuracy_monthly",
        "GROUP BY ALL",
        "ORDER BY forecast_month_month"
      ],
      "usage_guidance": "Monthly trend of peak forecasted units; user asks about 'highest forecast', 'max forecasted demand', or 'forecast volume spikes' over time."
    },
    {
      "question": "How has highest forecasted units changed over time?",
      "sql_lines": [
        "SELECT forecast_month, MEASURE(max_forecasted_units) AS max_forecasted_units",
        "FROM {fqn}.forecast_accuracy_monthly",
        "GROUP BY ALL",
        "ORDER BY forecast_month"
      ],
      "usage_guidance": "Time-series change in maximum forecasted units; user asks how top-end demand forecasts have evolved or shifted across forecast months."
    },
    {
      "question": "How does total units ordered break down by product sku code for 'Backordered' records?",
      "sql_lines": [
        "SELECT sku, COUNT(*) AS record_count, SUM(order_quantity) AS total_order_quantity",
        "FROM {fqn}.product_skus",
        "WHERE order_status = 'Backordered' GROUP BY sku ORDER BY total_order_quantity DESC"
      ],
      "usage_guidance": "Filtered aggregate of total order quantity broken down by SKU, specifically for Backordered order_status; user asks which SKUs have the most backordered units."
    },
    {
      "question": "What is the trend of total total open order value in usd over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(open_order_value_usd) AS total_open_order_value_usd",
        "FROM {fqn}.sales_orders",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Trend of total open order value in USD over snapshot dates; user asks about backlog value, open pipeline dollars, or unfulfilled order value over time."
    },
    {
      "question": "How has the average absolute forecast error percent changed over time?",
      "sql_lines": [
        "SELECT forecast_month, AVG(forecast_error_pct) AS avg_forecast_error_pct",
        "FROM {fqn}.demand_forecasts",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ],
      "usage_guidance": "Time-series trend of average forecast error percentage; user asks how forecast accuracy, forecast deviation, or MAPE has improved or worsened over forecast months."
    }
  ],
