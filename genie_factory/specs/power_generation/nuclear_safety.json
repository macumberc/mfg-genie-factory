  "genie_instructions": "You are a power generation analytics assistant for NucleoSafe Systems. Answer questions about nuclear reactor safety monitoring and compliance tracking using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (component_id, component_name), query the base tables directly.\n- When joining tables, use the shared keys: component_id (shared across inspection_snapshots, reactor_components, safety_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique readings?",
    "How has unique components changed over time?",
    "What is the monthly trend in highest neutron flux percent?",
    "How has total safety alarms triggered changed over time?",
    "What is the monthly trend in fail count?",
    "How has unique inspections changed over time?",
    "What is the monthly trend in unique components?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest neutron flux percent?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_neutron_flux_percent) AS max_neutron_flux_percent",
        "FROM {fqn}.safety_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has total safety alarms triggered changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_alarm_count) AS total_alarm_count",
        "FROM {fqn}.safety_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the monthly trend in unique components?",
      "sql_lines": [
        "SELECT inspection_date, MEASURE(unique_component_count) AS unique_component_count",
        "FROM {fqn}.inspection_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY inspection_date"
      ]
    },
    {
      "question": "How does fail count vary across component types?",
      "sql_lines": [
        "SELECT component_type, MEASURE(fail_count) AS fail_count",
        "FROM {fqn}.inspection_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY fail_count DESC"
      ]
    },
    {
      "question": "How does total component temperature in celsius break down by reactor component for 'Critical' records?",
      "sql_lines": [
        "SELECT component_id, COUNT(*) AS record_count, SUM(temperature_celsius) AS total_temperature_celsius",
        "FROM {fqn}.reactor_components",
        "WHERE health_status = 'Critical' GROUP BY component_id ORDER BY total_temperature_celsius DESC"
      ]
    },
    {
      "question": "What is the trend of total containment pressure in kilopascals over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(containment_pressure_kpa) AS total_containment_pressure_kpa",
        "FROM {fqn}.safety_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ]
    },
    {
      "question": "How has the average nrc compliance score 0-100 changed over time?",
      "sql_lines": [
        "SELECT inspection_date, AVG(compliance_score) AS avg_compliance_score",
        "FROM {fqn}.inspection_snapshots",
        "GROUP BY inspection_date ORDER BY inspection_date"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "reactor_components.health_status IN ('Warning', 'Critical')",
