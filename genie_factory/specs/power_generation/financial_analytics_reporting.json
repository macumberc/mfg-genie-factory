  "genie_instructions": "You are a power generation analytics assistant for PowerLedger Corp. Answer questions about power generation financial analytics and budget reporting using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (cost_center_id, cost_center_name, region), query the base tables directly.\n- When joining tables, use the shared keys: cost_center_id (shared across budget_snapshots, cost_centers, financial_transactions).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique cost centers?",
    "How has highest revenue changed over time?",
    "What is the monthly trend in total revenue in usd?",
    "How has total actual cost in usd changed over time?",
    "What is the monthly trend in unique cost centers?",
    "How has highest annual budget changed over time?",
    "What is the monthly trend in total annual budget usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total revenue in usd?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_revenue) AS total_revenue",
        "FROM {fqn}.financial_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Monthly revenue trend over time using the financial_kpi_monthly metric view; matches phrases like 'revenue over time' or 'monthly revenue performance'."
    },
    {
      "question": "How has total actual cost in usd changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_actual_cost) AS total_actual_cost",
        "FROM {fqn}.financial_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Month-over-month actual cost trend from financial_kpi_monthly; matches phrases like 'how costs changed' or 'actual spend over time' across all departments."
    },
    {
      "question": "What is the monthly trend in average operating margin pct?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(avg_operating_margin) AS avg_operating_margin",
        "FROM {fqn}.budget_status_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly operating margin trend from budget_status_monthly metric view; matches phrases like 'margin trend' or 'operating margin over time' at the snapshot level."
    },
    {
      "question": "Rank departments by total committed capex usd",
      "sql_lines": [
        "SELECT department, MEASURE(total_capex_committed) AS total_capex_committed",
        "FROM {fqn}.budget_status_monthly",
        "GROUP BY ALL",
        "ORDER BY total_capex_committed DESC"
      ],
      "usage_guidance": "Top-N department ranking by committed capital expenditure from budget_status_monthly; matches phrases like 'which departments have highest capex' or 'capex by department'."
    },
    {
      "question": "How does total transaction amount in usd break down by cost center for 'Pending' records?",
      "sql_lines": [
        "SELECT cost_center_id, COUNT(*) AS record_count, SUM(amount_usd) AS total_amount_usd",
        "FROM {fqn}.cost_centers",
        "WHERE approval_status = 'Pending' GROUP BY cost_center_id ORDER BY total_amount_usd DESC"
      ],
      "usage_guidance": "Filtered aggregate of transaction amounts by cost center where approval_status is Pending; matches phrases like 'pending transactions' or 'unapproved spend by cost center'."
    },
    {
      "question": "What is the trend of total revenue in usd (generation cost centers only) over time?",
      "sql_lines": [
        "SELECT record_date, SUM(revenue_usd) AS total_revenue_usd",
        "FROM {fqn}.financial_transactions",
        "GROUP BY record_date ORDER BY record_date"
      ],
      "usage_guidance": "Time-series revenue trend queried directly from financial_transactions table; matches phrases like 'generation revenue over time' or 'raw revenue trend by date'."
    },
    {
      "question": "How has the average operating margin percentage changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(operating_margin_pct) AS avg_operating_margin_pct",
        "FROM {fqn}.budget_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Historical average operating margin trend from budget_snapshots table; matches phrases like 'margin performance over time' or 'how operating margin changed by snapshot date'."
    }
  ],
