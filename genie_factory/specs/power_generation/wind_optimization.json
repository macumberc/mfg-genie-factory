          "name": "forecasted_generation_mwh",
          "sql_type": "DOUBLE",
          "comment": "Forecasted generation in MWh",
          "is_dimension": false,
          "generation_expr": "ROUND(100.0 + ({qty_noise} * 1900.0), 2)"
        },
        {
          "name": "actual_generation_mwh",
          "sql_type": "DOUBLE",
          "comment": "Actual generation in MWh",
          "is_dimension": false,
          "generation_expr": "ROUND((100.0 + ({qty_noise} * 1900.0)) * (0.80 + {status_noise} * 0.35), 2)"
        },
        {
          "name": "curtailment_mwh",
          "sql_type": "DOUBLE",
          "comment": "Energy curtailed in MWh",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 200.0, 2)"
        },
        {
          "name": "availability_pct",
          "sql_type": "DOUBLE",
          "comment": "Turbine availability percentage 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(85.0 + ({qty_noise} * 14.0), 2)"
        },
        {
          "name": "revenue_usd",
          "sql_type": "DOUBLE",
          "comment": "Revenue from energy sales in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(2000.0 + ({qty_noise} * 48000.0), 2)"
        },
        {
          "name": "ppa_price_mwh",
          "sql_type": "DOUBLE",
          "comment": "Power purchase agreement price per MWh",
          "is_dimension": false,
          "generation_expr": "ROUND(25.0 + ({qty_noise} * 35.0), 2)"
        }
