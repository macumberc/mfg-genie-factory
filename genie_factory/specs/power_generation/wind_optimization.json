    {
      "table_name": "wind_turbines",
      "description": "Daily wind turbine operational records with generation output, wind speed, and availability.",
      "columns": [
        {
          "name": "record_id",
          "sql_type": "STRING",
          "comment": "Unique turbine record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('WT-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.turbine_id) + 10000 AS STRING), 6, '0'))"
        },
        {
          "name": "record_date",
          "sql_type": "DATE",
          "comment": "Date of operational record",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "turbine_id",
          "sql_type": "STRING",
          "comment": "Wind turbine identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "turbine_name",
          "sql_type": "STRING",
          "comment": "Turbine name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "turbine_model",
          "sql_type": "STRING",
          "comment": "Turbine model: V150, SG-5.8, GE-3.6, Goldwind-6.7",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "wind_farm",
          "sql_type": "STRING",
          "comment": "Wind farm name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "generation_mwh",
          "sql_type": "DOUBLE",
          "comment": "Energy generated in MWh",
          "is_dimension": false,
          "generation_expr": "ROUND(20.0 + ({qty_noise} * 280.0), 2)"
        },
        {
          "name": "avg_wind_speed_ms",
          "sql_type": "DOUBLE",
          "comment": "Average wind speed in meters per second",
          "is_dimension": false,
          "generation_expr": "ROUND(3.0 + ({qty_noise} * 17.0), 1)"
        },
        {
          "name": "capacity_factor_pct",
          "sql_type": "DOUBLE",
          "comment": "Capacity factor 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(15.0 + ({qty_noise} * 55.0), 2)"
        },
        {
          "name": "turbine_status",
          "sql_type": "STRING",
          "comment": "Status: Generating, Idling, Curtailed, Maintenance, Fault",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.04 THEN 'Fault' WHEN {status_noise} < 0.10 THEN 'Maintenance' WHEN {status_noise} < 0.18 THEN 'Curtailed' WHEN {status_noise} < 0.25 THEN 'Idling' ELSE 'Generating' END"
        }
      ],
      "seasonal_patterns": {
        "V150": {
          "3,4,10,11": 0.06,
          "7,8": -0.03
        },
