          "name": "snapshot_id",
          "sql_type": "STRING",
          "comment": "Unique snapshot identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('WS-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.turbine_id) AS STRING), 7, '0'))"
        },
        {
          "name": "snapshot_date",
          "sql_type": "DATE",
          "comment": "Date of snapshot",
          "is_dimension": false,
          "generation_expr": "d.dt"
