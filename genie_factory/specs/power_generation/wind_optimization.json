{
  "company_name": "WindPeak Energy",
  "industry": "Power Generation",
  "use_case": "Wind farm performance optimization and turbine health monitoring",
  "space_title": "WindPeak Energy - Wind Farm Optimization 💨",
  "space_description": "Wind energy analytics for WindPeak Energy. Ask about turbine performance, wind resource availability, capacity factors, and maintenance events across 20 wind turbines.",
  "schema_basename": "wind_optimization",
