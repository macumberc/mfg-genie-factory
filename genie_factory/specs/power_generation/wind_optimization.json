  "metric_views": [
    {
      "view_name": "turbine_kpi_monthly",
      "source_table": "wind_turbines",
      "dimensions": [
        {
          "name": "record_date",
          "expr": "record_date"
        },
        {
          "name": "turbine_model",
          "expr": "turbine_model"
        },
        {
          "name": "wind_farm",
          "expr": "wind_farm"
        },
        {
          "name": "turbine_status",
          "expr": "turbine_status"
        }
      ],
      "measures": [
        {
          "name": "total_generation_mwh",
          "expr": "SUM(generation_mwh)",
          "comment": "Total wind generation MWh"
        },
        {
          "name": "avg_capacity_factor",
          "expr": "AVG(capacity_factor_pct)",
          "comment": "Average capacity factor"
        },
        {
          "name": "avg_wind_speed",
          "expr": "AVG(avg_wind_speed_ms)",
          "comment": "Average wind speed m/s"
        },
        {
          "name": "generating_count",
          "expr": "COUNT(DISTINCT CASE WHEN turbine_status = 'Generating' THEN turbine_id END)",
          "comment": "Generating turbine count"
        },
        {
          "name": "total_turbine_count",
          "expr": "COUNT(DISTINCT turbine_id)",
          "comment": "Total turbine count"
        },
        {
          "name": "max_generation_mwh",
          "expr": "MAX(generation_mwh)",
          "comment": "Maximum generation mwh"
        }
      ]
    },
    {
      "view_name": "wind_forecast_monthly",
      "source_table": "wind_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "wind_farm",
          "expr": "wind_farm"
        }
      ],
      "measures": [
        {
          "name": "total_forecasted_mwh",
          "expr": "SUM(forecasted_generation_mwh)",
          "comment": "Total forecasted generation MWh"
        },
        {
          "name": "total_actual_mwh",
          "expr": "SUM(actual_generation_mwh)",
          "comment": "Total actual generation MWh"
        },
        {
          "name": "total_curtailment_mwh",
          "expr": "SUM(curtailment_mwh)",
          "comment": "Total curtailed energy MWh"
        },
        {
          "name": "total_revenue",
          "expr": "SUM(revenue_usd)",
          "comment": "Total revenue USD"
        },
        {
          "name": "avg_availability",
          "expr": "AVG(availability_pct)",
          "comment": "Average turbine availability"
        },
        {
          "name": "total_ppa_price_mwh",
          "expr": "SUM(ppa_price_mwh)",
          "comment": "Total ppa price mwh"
        },
        {
          "name": "unique_turbine_count",
          "expr": "COUNT(DISTINCT turbine_id)",
          "comment": "Number of distinct turbines"
        },
        {
          "name": "max_forecasted_generation_mwh",
          "expr": "MAX(forecasted_generation_mwh)",
          "comment": "Maximum forecasted generation mwh"
        }
      ]
    }
  ],
  "genie_instructions": "You are a power generation analytics assistant for WindPeak Energy. Answer questions about wind farm performance optimization and turbine health monitoring using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (turbine_id, turbine_name), query the base tables directly.\n- When joining tables, use the shared keys: turbine_id (shared across performance_readings, wind_snapshots, wind_turbines).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in generating count?",
    "How has unique total turbines changed over time?",
    "What is the monthly trend in highest generation mwh?",
    "How has total wind generation mwh changed over time?",
    "What is the monthly trend in unique turbines?",
    "How has highest forecasted generation mwh changed over time?",
    "What is the monthly trend in total forecasted generation mwh?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest generation mwh?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', record_date) AS record_date_month, MEASURE(max_generation_mwh) AS max_generation_mwh",
        "FROM {fqn}.turbine_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date_month"
      ],
      "usage_guidance": "Monthly trend of peak/highest single-turbine generation MWh, using the turbine_kpi_monthly metric view max_generation_mwh measure."
    },
    {
      "question": "How has total wind generation mwh changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_generation_mwh) AS total_generation_mwh",
        "FROM {fqn}.turbine_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Monthly trend of fleet-wide total energy output in MWh, aggregated across all turbines via turbine_kpi_monthly total_generation_mwh measure."
    },
    {
      "question": "What is the monthly trend in total forecasted generation mwh?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(total_forecasted_mwh) AS total_forecasted_mwh",
        "FROM {fqn}.wind_forecast_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ],
      "usage_guidance": "Monthly trend of total forecasted wind generation MWh across farms, sourced from wind_forecast_monthly total_forecasted_mwh measure."
    },
    {
      "question": "How has total ppa price mwh changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_ppa_price_mwh) AS total_ppa_price_mwh",
        "FROM {fqn}.wind_forecast_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly trend of cumulative PPA price per MWh over time, tracked via wind_forecast_monthly total_ppa_price_mwh measure."
    },
    {
      "question": "How does total average wind speed in meters per second break down by wind turbine for 'Fault' records?",
      "sql_lines": [
        "SELECT turbine_id, COUNT(*) AS record_count, SUM(avg_wind_speed_ms) AS total_avg_wind_speed_ms",
        "FROM {fqn}.wind_turbines",
        "WHERE turbine_status = 'Fault' GROUP BY turbine_id ORDER BY total_avg_wind_speed_ms DESC"
      ],
      "usage_guidance": "Filtered aggregate breaking down wind speed by individual turbine for fault-status records only, using turbine_status = 'Fault' filter."
    },
    {
      "question": "What is the trend of total blade pitch angle in degrees over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(blade_pitch_deg) AS total_blade_pitch_deg",
        "FROM {fqn}.performance_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of total blade pitch angle in degrees across all turbines, aggregated daily from performance_readings."
    },
    {
      "question": "How has the average forecasted generation in mwh changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(forecasted_generation_mwh) AS avg_forecasted_generation_mwh",
        "FROM {fqn}.wind_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Daily trend of average forecasted generation MWh per turbine snapshot, calculated directly from wind_snapshots forecasted_generation_mwh column."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "wind_turbines.turbine_status = 'Generating'",
        "display_name": "generating turbines",
        "synonyms": [
          "active turbines",
          "producing turbines",
          "active units"
        ],
        "instruction": "Use when filtering to actively generating wind turbines."
      },
      {
        "sql": "wind_turbines.turbine_status IN ('Fault', 'Maintenance')",
        "display_name": "turbines down",
        "synonyms": [
          "offline turbines",
          "unavailable turbines",
          "offline units"
        ],
        "instruction": "Use when filtering to turbines in fault or maintenance."
      },
      {
        "sql": "performance_readings.power_curve_deviation_pct > 10",
        "display_name": "high deviation turbines",
        "synonyms": [
          "underperforming",
          "off curve",
          "underperforming units"
        ],
        "instruction": "Use when filtering to turbines deviating significantly from power curve."
      }
    ],
    "expressions": [
      {
        "alias": "gen_month",
        "sql": "DATE_TRUNC('month', wind_turbines.record_date)",
        "display_name": "generation month",
        "synonyms": [
          "monthly",
          "output month",
          "production month"
        ]
      },
      {
        "alias": "forecast_accuracy",
        "sql": "wind_snapshots.actual_generation_mwh / NULLIF(wind_snapshots.forecasted_generation_mwh, 0) * 100",
        "display_name": "forecast accuracy pct",
        "synonyms": [
          "prediction accuracy",
          "forecast hit rate",
          "forecast vs actual"
        ]
      },
      {
        "alias": "revenue_per_mwh",
        "sql": "wind_snapshots.revenue_usd / NULLIF(wind_snapshots.actual_generation_mwh, 0)",
        "display_name": "revenue per MWh",
        "synonyms": [
          "unit revenue",
          "realized price",
          "earnings per mwh"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_generation",
        "sql": "SUM(wind_turbines.generation_mwh)",
        "display_name": "total wind generation MWh",
        "synonyms": [
          "wind output",
          "energy produced",
          "total output"
        ]
      },
      {
        "alias": "avg_capacity_factor",
        "sql": "AVG(wind_turbines.capacity_factor_pct)",
        "display_name": "average capacity factor",
        "synonyms": [
          "CF",
          "capacity utilization",
          "utilization rate"
        ]
      },
      {
        "alias": "total_revenue",
        "sql": "SUM(wind_snapshots.revenue_usd)",
        "display_name": "total revenue",
        "synonyms": [
          "energy revenue",
          "sales",
          "total earnings"
        ]
      },
      {
        "alias": "total_curtailment",
        "sql": "SUM(wind_snapshots.curtailment_mwh)",
        "display_name": "total curtailment MWh",
        "synonyms": [
          "curtailed energy",
          "wasted wind",
          "lost generation"
        ]
      }
    ]
