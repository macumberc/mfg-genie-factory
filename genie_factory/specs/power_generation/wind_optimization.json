    {
      "question": "What is the monthly trend in generating count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', record_date) AS record_date_month, MEASURE(generating_count) AS generating_count",
        "FROM {fqn}.turbine_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date_month"
      ]
    },
    {
      "question": "How has unique total turbines changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_turbine_count) AS total_turbine_count",
        "FROM {fqn}.turbine_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ]
    },
    {
      "question": "What is the monthly trend in unique turbines?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(unique_turbine_count) AS unique_turbine_count",
        "FROM {fqn}.wind_forecast_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ]
    },
    {
      "question": "How has highest forecasted generation mwh changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(max_forecasted_generation_mwh) AS max_forecasted_generation_mwh",
        "FROM {fqn}.wind_forecast_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What are the top 10 wind turbine by total average wind speed in meters per second?",
      "sql_lines": [
        "SELECT turbine_id, SUM(avg_wind_speed_ms) AS total_avg_wind_speed_ms",
        "FROM {fqn}.wind_turbines",
        "GROUP BY turbine_id ORDER BY total_avg_wind_speed_ms DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average deviation from ideal power curve 0-100 by turbine model?",
      "sql_lines": [
        "SELECT turbine_model, AVG(power_curve_deviation_pct) AS avg_power_curve_deviation_pct",
        "FROM {fqn}.performance_readings",
        "GROUP BY turbine_model ORDER BY avg_power_curve_deviation_pct DESC"
      ]
    },
    {
      "question": "How many records are there per date of snapshot?",
      "sql_lines": [
        "SELECT snapshot_date, COUNT(*) AS record_count",
        "FROM {fqn}.wind_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    }
  ]
