        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How does total average wind speed in meters per second break down by wind turbine identifier for 'Fault' records?",
      "sql_lines": [
        "SELECT turbine_id, COUNT(*) AS record_count, SUM(avg_wind_speed_ms) AS total_avg_wind_speed_ms",
