  "metric_views": [
    {
      "view_name": "generation_kpi_monthly",
      "source_table": "turbine_units",
      "dimensions": [
        {
          "name": "record_date",
          "expr": "record_date"
        },
        {
          "name": "turbine_type",
          "expr": "turbine_type"
        },
        {
          "name": "dam_name",
          "expr": "dam_name"
        },
        {
          "name": "operating_status",
          "expr": "operating_status"
        }
      ],
      "measures": [
        {
          "name": "total_generation_mwh",
          "expr": "SUM(generation_mwh)",
          "comment": "Total hydro generation in MWh"
        },
        {
          "name": "avg_efficiency_pct",
          "expr": "AVG(efficiency_pct)",
          "comment": "Average turbine efficiency"
        },
        {
          "name": "avg_water_flow",
          "expr": "AVG(water_flow_m3s)",
          "comment": "Average water flow rate m3/s"
        },
        {
          "name": "generating_turbine_count",
          "expr": "COUNT(DISTINCT CASE WHEN operating_status = 'Generating' THEN turbine_id END)",
          "comment": "Number of generating turbines"
        },
        {
          "name": "total_turbine_count",
          "expr": "COUNT(DISTINCT turbine_id)",
          "comment": "Total turbine count"
        },
        {
          "name": "max_generation_mwh",
          "expr": "MAX(generation_mwh)",
          "comment": "Maximum generation mwh"
        }
      ]
    },
    {
      "view_name": "reservoir_kpi_monthly",
      "source_table": "reservoir_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "dam_name",
          "expr": "dam_name"
        },
        {
          "name": "drought_risk",
          "expr": "drought_risk"
        }
      ],
      "measures": [
        {
          "name": "avg_storage_pct",
          "expr": "AVG(storage_pct)",
          "comment": "Average reservoir storage percentage"
        },
        {
          "name": "total_spill_volume",
          "expr": "SUM(spill_volume_m3)",
          "comment": "Total water spilled in m3"
        },
        {
          "name": "avg_generation_potential",
          "expr": "AVG(generation_potential_mwh)",
          "comment": "Average generation potential MWh"
        },
        {
          "name": "avg_days_of_storage",
          "expr": "AVG(days_of_storage)",
          "comment": "Average days of storage remaining"
        },
        {
          "name": "high_drought_risk_count",
          "expr": "COUNT(DISTINCT CASE WHEN drought_risk IN ('High', 'Severe') THEN snapshot_id END)",
          "comment": "Snapshots with high/severe drought risk"
        },
        {
          "name": "total_water_level_m",
          "expr": "SUM(water_level_m)",
          "comment": "Total water level m"
        },
        {
          "name": "unique_turbine_count",
          "expr": "COUNT(DISTINCT turbine_id)",
          "comment": "Number of distinct turbines"
        },
        {
          "name": "max_water_level_m",
          "expr": "MAX(water_level_m)",
          "comment": "Maximum water level m"
        }
      ]
    }
  ],
  "genie_instructions": "You are a power generation analytics assistant for HydroFlow Energy. Answer questions about hydroelectric turbine optimization and reservoir management using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (turbine_id, turbine_name), query the base tables directly.\n- When joining tables, use the shared keys: turbine_id (shared across flow_readings, reservoir_snapshots, turbine_units).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in generating turbine count?",
    "How has unique total turbines changed over time?",
    "What is the monthly trend in highest generation mwh?",
    "How has total hydro generation in mwh changed over time?",
    "What is the monthly trend in high drought risk count?",
    "How has unique turbines changed over time?",
    "What is the monthly trend in highest water level m?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest generation mwh?",
      "sql_lines": [
        "SELECT record_date, MEASURE(max_generation_mwh) AS max_generation_mwh",
        "FROM {fqn}.generation_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ]
    },
    {
      "question": "How has total hydro generation in mwh changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_generation_mwh) AS total_generation_mwh",
        "FROM {fqn}.generation_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest water level m?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(max_water_level_m) AS max_water_level_m",
        "FROM {fqn}.reservoir_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has total water level m changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_water_level_m) AS total_water_level_m",
        "FROM {fqn}.reservoir_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How does total water flow rate in cubic meters per second break down by turbine unit for 'Maintenance' records?",
      "sql_lines": [
        "SELECT turbine_id, COUNT(*) AS record_count, SUM(water_flow_m3s) AS total_water_flow_m3s",
        "FROM {fqn}.turbine_units",
        "WHERE operating_status = 'Maintenance' GROUP BY turbine_id ORDER BY total_water_flow_m3s DESC"
      ]
    },
    {
      "question": "What is the trend of total water inflow rate in m3/s over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(inflow_m3s) AS total_inflow_m3s",
        "FROM {fqn}.flow_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ]
    },
    {
      "question": "How has the average reservoir storage as percentage of capacity changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(storage_pct) AS avg_storage_pct",
        "FROM {fqn}.reservoir_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "turbine_units.operating_status = 'Generating'",
        "display_name": "generating turbines",
        "synonyms": [
          "active turbines",
          "online turbines"
        ],
        "instruction": "Use when filtering to actively generating turbines."
      },
      {
        "sql": "reservoir_snapshots.drought_risk IN ('High', 'Severe')",
        "display_name": "high drought risk",
        "synonyms": [
          "drought warning",
          "water shortage"
        ],
        "instruction": "Use when filtering to reservoirs with elevated drought risk."
      },
      {
        "sql": "flow_readings.env_flow_compliance = 'Non-Compliant'",
        "display_name": "non-compliant flows",
        "synonyms": [
          "env flow violation"
        ],
        "instruction": "Use when filtering to environmental flow violations."
      }
    ],
    "expressions": [
      {
        "alias": "gen_month",
        "sql": "DATE_TRUNC('month', turbine_units.record_date)",
        "display_name": "generation month",
        "synonyms": [
          "monthly"
        ]
      },
      {
        "alias": "net_flow_m3s",
        "sql": "flow_readings.inflow_m3s - flow_readings.outflow_m3s",
        "display_name": "net water flow m3/s",
        "synonyms": [
          "flow balance",
          "net inflow"
        ]
      },
      {
        "alias": "generation_per_flow",
        "sql": "turbine_units.generation_mwh / NULLIF(turbine_units.water_flow_m3s, 0)",
        "display_name": "MWh per m3/s flow",
        "synonyms": [
          "water productivity",
          "flow efficiency"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_generation",
        "sql": "SUM(turbine_units.generation_mwh)",
        "display_name": "total generation MWh",
        "synonyms": [
          "hydro output",
          "energy generated"
        ]
      },
      {
        "alias": "avg_efficiency",
        "sql": "AVG(turbine_units.efficiency_pct)",
        "display_name": "average turbine efficiency",
        "synonyms": [
          "efficiency",
          "conversion rate"
        ]
      },
      {
        "alias": "avg_storage",
        "sql": "AVG(reservoir_snapshots.storage_pct)",
        "display_name": "average storage percent",
        "synonyms": [
          "reservoir level",
          "water storage"
        ]
      },
      {
        "alias": "total_spill",
        "sql": "SUM(reservoir_snapshots.spill_volume_m3)",
        "display_name": "total spill volume",
        "synonyms": [
          "water spilled",
          "spillway volume"
        ]
      }
    ]
  },
