  "genie_instructions": "You are a power generation analytics assistant for PowerMix Dynamics. Answer questions about grid management and energy mix optimization across diverse generation sources using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (plant_id, plant_name), query the base tables directly.\n- When joining tables, use the shared keys: plant_id (shared across dispatch_snapshots, generation_readings, generation_units).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in dispatched plant count?",
    "How has unique total plants changed over time?",
    "What is the monthly trend in highest generation mwh?",
    "How has total energy generated in mwh changed over time?",
    "What is the monthly trend in unique plants?",
    "How has highest planned mwh changed over time?",
    "What is the monthly trend in total planned generation mwh?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest generation mwh?",
      "sql_lines": [
        "SELECT record_date, MEASURE(max_generation_mwh) AS max_generation_mwh",
        "FROM {fqn}.generation_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Monthly trend of peak/highest generation MWh using the generation KPI metric view, matching phrases like 'highest output' or 'max generation over time'."
    },
    {
      "question": "How has total energy generated in mwh changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_generation_mwh) AS total_generation_mwh",
        "FROM {fqn}.generation_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Monthly trend of total cumulative energy generated in MWh from the generation KPI metric view, matching phrases like 'total energy output over time'."
    },
    {
      "question": "What is the monthly trend in total planned generation mwh?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_planned_mwh) AS total_planned_mwh",
        "FROM {fqn}.dispatch_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly trend of total planned generation MWh from the dispatch KPI metric view, matching phrases like 'planned output schedule' or 'generation planning trend'."
    },
    {
      "question": "How has total forecast accuracy pct changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_forecast_accuracy_percent) AS total_forecast_accuracy_percent",
        "FROM {fqn}.dispatch_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly trend of forecast accuracy percentage from the dispatch KPI metric view, matching phrases like 'how accurate are our dispatch forecasts over time'."
    },
    {
      "question": "How has the average energy generated in megawatt-hours changed over time?",
      "sql_lines": [
        "SELECT record_date, AVG(generation_mwh) AS avg_generation_mwh",
        "FROM {fqn}.generation_units",
        "GROUP BY record_date ORDER BY record_date"
      ],
      "usage_guidance": "Time-series trend of average per-plant generation MWh from raw generation_units records, matching phrases like 'average plant output' or 'mean generation per unit over time'."
    },
    {
      "question": "What is the trend of total instantaneous output in megawatts over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(output_mw) AS total_output_mw",
        "FROM {fqn}.generation_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of total instantaneous grid output in MW from generation_readings, matching phrases like 'real-time output' or 'live power production trend'."
    },
    {
      "question": "How has the average operating reserve margin percentage changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(reserve_margin_pct) AS avg_reserve_margin_pct",
        "FROM {fqn}.dispatch_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of average operating reserve margin percentage from raw dispatch_snapshots, matching phrases like 'grid reliability buffer' or 'reserve margin over time'."
    }
  ],
