        "FROM {fqn}.outage_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY outage_date"
      ]
    },
    {
      "question": "What is the monthly trend in running unit count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', record_date) AS record_date_month, MEASURE(running_unit_count) AS running_unit_count",
        "FROM {fqn}.unit_availability_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date_month"
      ]
    },
    {
      "question": "How has unique total units changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_unit_count) AS total_unit_count",
        "FROM {fqn}.unit_availability_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ]
    },
    {
      "question": "What are the top 10 generator unit by total hours of operation in the day?",
      "sql_lines": [
        "SELECT unit_id, SUM(runtime_hours) AS total_runtime_hours",
        "FROM {fqn}.generating_units",
        "GROUP BY unit_id ORDER BY total_runtime_hours DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average outage duration in hours by generator type?",
      "sql_lines": [
        "SELECT unit_type, AVG(duration_hours) AS avg_duration_hours",
        "FROM {fqn}.outage_events",
        "GROUP BY unit_type ORDER BY avg_duration_hours DESC"
      ]
