  "metric_views": [
    {
      "view_name": "outage_kpi_monthly",
      "source_table": "outage_events",
      "dimensions": [
        {
          "name": "outage_date",
          "expr": "outage_date"
        },
        {
          "name": "unit_type",
          "expr": "unit_type"
        },
        {
          "name": "outage_type",
          "expr": "outage_type"
        },
        {
          "name": "cause_code",
          "expr": "cause_code"
        }
      ],
      "measures": [
        {
          "name": "total_outage_events",
          "expr": "COUNT(DISTINCT outage_id)",
          "comment": "Total number of outage events"
        },
        {
          "name": "total_lost_generation_mwh",
          "expr": "SUM(lost_generation_mwh)",
          "comment": "Total lost generation in MWh"
        },
        {
          "name": "avg_outage_duration_hours",
          "expr": "AVG(duration_hours)",
          "comment": "Average outage duration in hours"
        },
        {
          "name": "total_repair_cost",
          "expr": "SUM(repair_cost_usd)",
          "comment": "Total repair cost in USD"
        },
        {
          "name": "forced_outage_count",
          "expr": "COUNT(DISTINCT CASE WHEN outage_type = 'Forced' THEN outage_id END)",
          "comment": "Number of forced outage events"
        },
        {
          "name": "unique_unit_count",
          "expr": "COUNT(DISTINCT unit_id)",
          "comment": "Number of distinct units"
        },
        {
          "name": "max_duration_hours",
          "expr": "MAX(duration_hours)",
          "comment": "Maximum duration hours"
        }
      ]
    },
    {
      "view_name": "unit_availability_monthly",
      "source_table": "generating_units",
      "dimensions": [
        {
          "name": "record_date",
          "expr": "record_date"
        },
        {
          "name": "unit_type",
          "expr": "unit_type"
        },
        {
          "name": "station",
          "expr": "station"
        },
        {
          "name": "operational_status",
          "expr": "operational_status"
        }
      ],
      "measures": [
        {
          "name": "avg_availability_pct",
          "expr": "AVG(availability_pct)",
          "comment": "Average unit availability percentage"
        },
        {
          "name": "total_output_mwh",
          "expr": "SUM(output_mwh)",
          "comment": "Total energy output in MWh"
        },
        {
          "name": "total_runtime_hours",
          "expr": "SUM(runtime_hours)",
          "comment": "Total runtime hours"
        },
        {
          "name": "running_unit_count",
          "expr": "COUNT(DISTINCT CASE WHEN operational_status = 'Running' THEN unit_id END)",
          "comment": "Number of running units"
        },
        {
          "name": "total_unit_count",
          "expr": "COUNT(DISTINCT unit_id)",
          "comment": "Total number of units"
        },
        {
          "name": "max_runtime_hours",
          "expr": "MAX(runtime_hours)",
          "comment": "Maximum runtime hours"
        }
      ]
    }
  ],
  "genie_instructions": "You are a power generation analytics assistant for RestorePower Gen. Answer questions about generator outage response and restoration tracking using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (unit_id, unit_name), query the base tables directly.\n- When joining tables, use the shared keys: unit_id (shared across generating_units, outage_events, repair_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in forced outage count?",
    "How has unique total outage eventss changed over time?",
    "What is the monthly trend in unique units?",
    "How has highest duration hours changed over time?",
    "What is the monthly trend in running unit count?",
    "How has unique total units changed over time?",
    "What is the monthly trend in highest runtime hours?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique units?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', outage_date) AS outage_date_month, MEASURE(unique_unit_count) AS unique_unit_count",
        "FROM {fqn}.outage_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY outage_date_month"
      ],
      "usage_guidance": "Monthly trend of distinct affected generators; matches phrases like 'how many unique units had outages each month' using outage_kpi_monthly.unique_unit_count."
    },
    {
      "question": "How has highest duration hours changed over time?",
      "sql_lines": [
        "SELECT outage_date, MEASURE(max_duration_hours) AS max_duration_hours",
        "FROM {fqn}.outage_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY outage_date"
      ],
      "usage_guidance": "Time-series of worst single outage duration per month; matches 'longest outage duration trend' using outage_kpi_monthly.max_duration_hours."
    },
    {
      "question": "What is the monthly trend in highest runtime hours?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', record_date) AS record_date_month, MEASURE(max_runtime_hours) AS max_runtime_hours",
        "FROM {fqn}.unit_availability_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date_month"
      ],
      "usage_guidance": "Monthly trend of peak generator runtime hours; matches 'highest runtime hours over time' using unit_availability_monthly.max_runtime_hours."
    },
    {
      "question": "How has running unit count changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(running_unit_count) AS running_unit_count",
        "FROM {fqn}.unit_availability_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Time-series count of actively running generators per month; matches 'how many units were running each month' using unit_availability_monthly.running_unit_count."
    },
    {
      "question": "How does total hours of operation in the day break down by generator unit for 'Forced Outage' records?",
      "sql_lines": [
        "SELECT unit_id, COUNT(*) AS record_count, SUM(runtime_hours) AS total_runtime_hours",
        "FROM {fqn}.generating_units",
        "WHERE operational_status = 'Forced Outage' GROUP BY unit_id ORDER BY total_runtime_hours DESC"
      ],
      "usage_guidance": "Per-unit aggregated runtime hours filtered to Forced Outage status; matches 'runtime breakdown by generator during forced outages' from generating_units."
    },
    {
      "question": "What is the trend of total repair and restoration cost in usd over time?",
      "sql_lines": [
        "SELECT outage_date, SUM(repair_cost_usd) AS total_repair_cost_usd",
        "FROM {fqn}.outage_events",
        "GROUP BY outage_date ORDER BY outage_date"
      ],
      "usage_guidance": "Time-series of total outage repair costs; matches 'repair cost trend over time' or 'restoration spending by date' from outage_events.repair_cost_usd."
    },
    {
      "question": "How has the average percentage of required parts available changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(parts_on_hand_pct) AS avg_parts_on_hand_pct",
        "FROM {fqn}.repair_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Trend of average parts inventory readiness over time; matches 'parts availability trend' or 'how well-stocked are repair crews' from repair_snapshots.parts_on_hand_pct."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "outage_events.outage_type = 'Forced'",
        "display_name": "forced outages",
        "synonyms": [
          "unplanned outages",
          "unexpected outages",
          "emergency outages"
        ],
        "instruction": "Use when analyzing forced/unplanned outage events."
      },
      {
        "sql": "generating_units.operational_status = 'Forced Outage'",
        "display_name": "units in forced outage",
        "synonyms": [
          "down units",
          "tripped units",
          "emergency down units"
        ],
        "instruction": "Use when filtering to units currently in forced outage."
      },
      {
        "sql": "repair_snapshots.repair_status NOT IN ('Restored')",
