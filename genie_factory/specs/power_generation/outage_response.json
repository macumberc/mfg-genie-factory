    {
      "question": "How many records are there per date of repair snapshot?",
      "sql_lines": [
        "SELECT snapshot_date, COUNT(*) AS record_count",
        "FROM {fqn}.repair_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
