        "alias": "outage_month",
        "sql": "DATE_TRUNC('month', outage_events.outage_date)",
        "display_name": "outage month",
        "synonyms": [
          "month of outage",
          "failure month",
          "incident month"
        ]
      },
      {
        "alias": "cost_per_hour",
        "sql": "outage_events.repair_cost_usd / NULLIF(outage_events.duration_hours, 0)",
