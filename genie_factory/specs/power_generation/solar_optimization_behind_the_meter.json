  "company_name": "SolarEdge Power",
  "industry": "Power Generation",
  "use_case": "Behind-the-meter solar and battery storage optimization",
  "space_title": "SolarEdge Power - Solar & Storage Optimization ☀️",
  "space_description": "Solar and battery storage analytics for SolarEdge Power. Ask about solar generation, battery state of charge, demand response events, and net metering across 20 solar+storage sites.",
  "schema_basename": "solar_behind_meter",
  "tables": [
    {
      "table_name": "solar_installations",
      "description": "Daily solar generation records per site with irradiance, panel output, and inverter performance.",
      "columns": [
        {
          "name": "record_id",
          "sql_type": "STRING",
          "comment": "Unique generation record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('SOL-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.site_id) + 10000 AS STRING), 6, '0'))"
        },
        {
          "name": "record_date",
          "sql_type": "DATE",
          "comment": "Date of generation record",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "site_id",
          "sql_type": "STRING",
          "comment": "Solar+storage site identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "site_name",
          "sql_type": "STRING",
          "comment": "Site name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "site_type",
          "sql_type": "STRING",
          "comment": "Site type: Commercial, Industrial, Municipal, Campus",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "region",
          "sql_type": "STRING",
          "comment": "Geographic region",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "solar_generation_kwh",
          "sql_type": "DOUBLE",
          "comment": "Solar energy generated in kWh",
          "is_dimension": false,
          "generation_expr": "ROUND(200.0 + ({qty_noise} * 4800.0) * (CASE WHEN MONTH(d.dt) IN (5,6,7,8) THEN 1.3 WHEN MONTH(d.dt) IN (11,12,1) THEN 0.6 ELSE 1.0 END), 2)"
        },
        {
          "name": "irradiance_kwh_m2",
          "sql_type": "DOUBLE",
          "comment": "Solar irradiance in kWh/m2",
          "is_dimension": false,
          "generation_expr": "ROUND(2.0 + ({qty_noise} * 6.0) * (CASE WHEN MONTH(d.dt) IN (5,6,7,8) THEN 1.3 WHEN MONTH(d.dt) IN (11,12,1) THEN 0.6 ELSE 1.0 END), 2)"
        },
        {
          "name": "panel_efficiency_pct",
          "sql_type": "DOUBLE",
          "comment": "Panel conversion efficiency 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(16.0 + ({qty_noise} * 8.0), 2)"
        },
        {
          "name": "inverter_status",
          "sql_type": "STRING",
          "comment": "Inverter status: Online, Degraded, Offline, Clipping",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.03 THEN 'Offline' WHEN {status_noise} < 0.08 THEN 'Degraded' WHEN {status_noise} < 0.15 THEN 'Clipping' ELSE 'Online' END"
        }
      ],
      "seasonal_patterns": {
        "Commercial": {
          "5,6,7,8": 0.08,
          "11,12,1": -0.04
        },
        "Industrial": {
          "5,6,7,8": 0.07,
          "11,12,1": -0.04
        },
        "Municipal": {
          "6,7,8": 0.07
        },
        "Campus": {
