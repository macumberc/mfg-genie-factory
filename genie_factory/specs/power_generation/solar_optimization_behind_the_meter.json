        "synonyms": [
          "monthly",
          "billing month",
          "production month"
        ]
      },
      {
        "alias": "self_consumption_ratio",
        "sql": "generation_readings.self_consumption_kwh / NULLIF(generation_readings.self_consumption_kwh + generation_readings.grid_export_kwh, 0)",
