    {
      "table_name": "battery_snapshots",
      "description": "Weekly battery storage snapshots with state of charge, cycle counts, and degradation tracking.",
      "columns": [
        {
          "name": "snapshot_id",
          "sql_type": "STRING",
          "comment": "Unique battery snapshot identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('BAT-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.site_id) AS STRING), 7, '0'))"
        },
        {
          "name": "snapshot_date",
          "sql_type": "DATE",
          "comment": "Date of battery snapshot",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "site_id",
          "sql_type": "STRING",
          "comment": "Site identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "site_type",
          "sql_type": "STRING",
          "comment": "Site type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "state_of_charge_pct",
          "sql_type": "DOUBLE",
          "comment": "Battery state of charge 0-100",
          "is_dimension": false,
          "generation_expr": "ROUND(10.0 + ({qty_noise} * 85.0), 1)"
        },
        {
          "name": "cycle_count",
          "sql_type": "INT",
          "comment": "Cumulative charge/discharge cycles",
          "is_dimension": false,
          "generation_expr": "CAST(50 + FLOOR({qty_noise} * 2950) AS INT)"
        },
        {
          "name": "health_pct",
          "sql_type": "DOUBLE",
          "comment": "Battery health as percentage of original capacity",
          "is_dimension": false,
          "generation_expr": "ROUND(80.0 + ({qty_noise} * 20.0), 1)"
        },
        {
          "name": "discharge_kwh",
          "sql_type": "DOUBLE",
          "comment": "Energy discharged during period in kWh",
          "is_dimension": false,
          "generation_expr": "ROUND(50.0 + ({qty_noise} * 1950.0), 2)"
        },
        {
          "name": "charge_kwh",
          "sql_type": "DOUBLE",
          "comment": "Energy charged during period in kWh",
          "is_dimension": false,
          "generation_expr": "ROUND(55.0 + ({qty_noise} * 2045.0), 2)"
        },
        {
          "name": "battery_status",
          "sql_type": "STRING",
          "comment": "Battery status: Charging, Discharging, Idle, Fault",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.03 THEN 'Fault' WHEN {status_noise} < 0.25 THEN 'Discharging' WHEN {status_noise} < 0.50 THEN 'Charging' ELSE 'Idle' END"
        }
      ],
      "seasonal_patterns": {
        "Commercial": {
          "6,7,8": 0.07
        },
        "Industrial": {
          "6,7,8": 0.06
        },
        "Municipal": {
          "7,8": 0.05
        },
        "Campus": {
          "9,10": 0.04
        }
      },
