  "metric_views": [
    {
      "view_name": "solar_kpi_monthly",
      "source_table": "solar_installations",
      "dimensions": [
        {
          "name": "record_date",
          "expr": "record_date"
        },
        {
          "name": "site_type",
          "expr": "site_type"
        },
        {
          "name": "region",
          "expr": "region"
        },
        {
          "name": "inverter_status",
          "expr": "inverter_status"
        }
      ],
      "measures": [
        {
          "name": "total_solar_generation_kwh",
          "expr": "SUM(solar_generation_kwh)",
          "comment": "Total solar generation in kWh"
        },
        {
          "name": "avg_panel_efficiency",
          "expr": "AVG(panel_efficiency_pct)",
          "comment": "Average panel efficiency percentage"
        },
        {
          "name": "avg_irradiance",
          "expr": "AVG(irradiance_kwh_m2)",
          "comment": "Average solar irradiance kWh/m2"
        },
        {
          "name": "online_site_count",
          "expr": "COUNT(DISTINCT CASE WHEN inverter_status = 'Online' THEN site_id END)",
          "comment": "Sites with online inverters"
        },
        {
          "name": "total_site_count",
          "expr": "COUNT(DISTINCT site_id)",
          "comment": "Total site count"
        },
        {
          "name": "max_solar_generation_kwh",
          "expr": "MAX(solar_generation_kwh)",
          "comment": "Maximum solar generation kwh"
        }
      ]
    },
    {
      "view_name": "battery_kpi_monthly",
      "source_table": "battery_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "site_type",
          "expr": "site_type"
        },
        {
          "name": "battery_status",
          "expr": "battery_status"
        }
      ],
      "measures": [
        {
          "name": "avg_state_of_charge",
          "expr": "AVG(state_of_charge_pct)",
          "comment": "Average battery state of charge"
        },
        {
          "name": "avg_battery_health",
          "expr": "AVG(health_pct)",
          "comment": "Average battery health percentage"
        },
        {
          "name": "total_discharge_kwh",
          "expr": "SUM(discharge_kwh)",
          "comment": "Total energy discharged kWh"
        },
        {
          "name": "total_charge_kwh",
          "expr": "SUM(charge_kwh)",
          "comment": "Total energy charged kWh"
        },
        {
          "name": "fault_count",
          "expr": "COUNT(DISTINCT CASE WHEN battery_status = 'Fault' THEN snapshot_id END)",
          "comment": "Battery fault count"
        },
        {
          "name": "unique_site_count",
          "expr": "COUNT(DISTINCT site_id)",
          "comment": "Number of distinct sites"
        },
        {
          "name": "max_state_of_charge_percent",
          "expr": "MAX(state_of_charge_pct)",
          "comment": "Maximum state of charge pct"
        },
        {
          "name": "total_cycle_count",
          "expr": "SUM(cycle_count)",
