          "name": "inverter_status",
          "sql_type": "STRING",
          "comment": "Inverter status: Online, Degraded, Offline, Clipping",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.03 THEN 'Offline' WHEN {status_noise} < 0.08 THEN 'Degraded' WHEN {status_noise} < 0.15 THEN 'Clipping' ELSE 'Online' END",
          "entity_values": [
