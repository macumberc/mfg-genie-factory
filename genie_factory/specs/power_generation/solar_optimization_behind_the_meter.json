  "genie_instructions": "You are a power generation analytics assistant for SolarEdge Power. Answer questions about behind-the-meter solar and battery storage optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (site_id, site_name), query the base tables directly.\n- When joining tables, use the shared keys: site_id (shared across battery_snapshots, generation_readings, solar_installations).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in online site count?",
    "How has unique total sites changed over time?",
    "What is the monthly trend in highest solar generation kwh?",
    "How has total solar generation in kwh changed over time?",
    "What is the monthly trend in fault count?",
    "How has unique sites changed over time?",
    "What is the monthly trend in highest state of charge percent?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest solar generation kwh?",
      "sql_lines": [
        "SELECT record_date, MEASURE(max_solar_generation_kwh) AS max_solar_generation_kwh",
        "FROM {fqn}.solar_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Monthly trend of peak/highest solar generation KWh, spotting record-output months across all sites using max_solar_generation_kwh."
    },
    {
      "question": "How has total solar generation in kwh changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(total_solar_generation_kwh) AS total_solar_generation_kwh",
        "FROM {fqn}.solar_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Time-series trend of aggregated solar energy produced in KWh fleet-wide, tracking total_solar_generation_kwh growth or decline by month."
    },
    {
      "question": "What is the monthly trend in highest state of charge percent?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(max_state_of_charge_percent) AS max_state_of_charge_percent",
        "FROM {fqn}.battery_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly trend of peak battery state-of-charge percent, identifying months where storage reached maximum charge levels across the fleet."
    },
    {
      "question": "How does total solar irradiance in kwh/m2 break down by solar+storage site for 'Offline' records?",
      "sql_lines": [
        "SELECT site_id, COUNT(*) AS record_count, SUM(irradiance_kwh_m2) AS total_irradiance_kwh_m2",
        "FROM {fqn}.solar_installations",
        "WHERE inverter_status = 'Offline' GROUP BY site_id ORDER BY total_irradiance_kwh_m2 DESC"
      ],
      "usage_guidance": "Filtered site-level breakdown of cumulative irradiance KWh/m2 for Solar+Storage sites where inverter_status is Offline, ranking underperforming sites."
    },
    {
      "question": "What is the trend of total energy exported to grid in kwh over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(grid_export_kwh) AS total_grid_export_kwh",
        "FROM {fqn}.generation_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Time-series trend of total energy exported to the grid in KWh, monitoring net-metering and grid-export volumes by reading date."
    },
    {
      "question": "How has the average battery state of charge 0-100 changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(state_of_charge_pct) AS avg_state_of_charge_pct",
        "FROM {fqn}.battery_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Daily or periodic trend of average battery state-of-charge percent (0–100), tracking fleet-wide storage health and charge levels over time."
    },
    {
      "question": "How has online site count changed over time?",
      "sql_lines": [
        "SELECT record_date, MEASURE(online_site_count) AS online_site_count",
        "FROM {fqn}.solar_kpi_monthly",
        "GROUP BY ALL",
        "ORDER BY record_date"
      ],
      "usage_guidance": "Monthly trend of how many inverter-online sites are active, monitoring fleet availability and operational site count over time."
    }
  ],
