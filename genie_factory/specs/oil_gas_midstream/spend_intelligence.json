          "name": "risk_tier",
          "sql_type": "STRING",
          "comment": "Risk: Low, Medium, High",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "document_type",
          "sql_type": "STRING",
          "comment": "Type: PO, Invoice, Change Order, Credit Memo",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'PO' WHEN {status_noise} < 0.70 THEN 'Invoice' WHEN {status_noise} < 0.88 THEN 'Change Order' ELSE 'Credit Memo' END"
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Transaction amount USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(500.0, {qty_noise} * 2000000.0), 2)"
        },
        {
          "name": "contract_compliance_pct",
          "sql_type": "DOUBLE",
          "comment": "Contract compliance pct",
          "is_dimension": false,
          "generation_expr": "ROUND(LEAST(100.0, GREATEST(60.0, 88.0 + ({qty_noise} - 0.5) * 20.0)), 1)"
