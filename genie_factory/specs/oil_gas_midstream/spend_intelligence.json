  "genie_instructions": "You are an oil & gas midstream analytics assistant for MidSpend Analytics. Answer questions about procurement spend intelligence and supplier management using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (supplier_name), query the base tables directly.\n- When joining tables, use the shared keys: supplier_id (shared across procurement_transactions, spend_kpi_monthly, supplier_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique total transactionss?",
    "How has highest amount changed over time?",
    "What is the monthly trend in total spend usd?",
    "How has avg contract compliance changed over time?",
    "What is the monthly trend in highest quality score?",
    "How has avg quality score changed over time?",
    "What is the monthly trend in avg on-time delivery?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total spend usd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', transaction_date) AS transaction_date_month, MEASURE(total_spend_usd) AS total_spend_usd",
        "FROM {fqn}.procurement_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date_month"
      ],
      "usage_guidance": "Monthly trend of total procurement spend in USD; matches phrases like 'spend over time' or 'how much are we spending each month' using transaction_date."
    },
    {
      "question": "How has avg contract compliance changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(avg_compliance_pct) AS avg_compliance_pct",
        "FROM {fqn}.procurement_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series trend of average contract compliance percentage; matches phrases like 'compliance rate over time' or 'are suppliers meeting contract terms' using avg_compliance_pct."
    },
    {
      "question": "What is the monthly trend in avg on-time delivery?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(avg_on_time_pct) AS avg_on_time_pct",
        "FROM {fqn}.supplier_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ],
      "usage_guidance": "Monthly trend of average supplier on-time delivery percentage; matches phrases like 'delivery performance over time' or 'are suppliers delivering on schedule' using snapshot_date."
    },
    {
      "question": "What is the trend of total transaction amount usd over time?",
      "sql_lines": [
        "SELECT transaction_date, SUM(amount_usd) AS total_amount_usd",
        "FROM {fqn}.procurement_transactions",
        "GROUP BY transaction_date ORDER BY transaction_date"
      ],
      "usage_guidance": "Time-series aggregate of raw transaction amounts from procurement_transactions table; matches phrases like 'total invoice value over time' or 'transaction dollar trend' using amount_usd."
    },
    {
      "question": "What is the trend of total avg lead time days over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(avg_lead_time_days) AS total_avg_lead_time_days",
        "FROM {fqn}.supplier_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of cumulative average supplier lead time days; matches phrases like 'how lead times are changing' or 'supplier fulfillment speed over time' using avg_lead_time_days."
    },
    {
      "question": "How has the average off-contract spend pct changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(maverick_spend_pct) AS avg_maverick_spend_pct",
        "FROM {fqn}.spend_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly trend of off-contract or maverick spend percentage; matches phrases like 'uncontrolled spend over time' or 'how much spend is outside contract' using maverick_spend_pct."
    },
    {
      "question": "How does the number of unique total transactionss vary by supplier id?",
      "sql_lines": [
        "SELECT supplier_id, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.procurement_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY total_transactions DESC"
      ],
      "usage_guidance": "Ranked breakdown of transaction volume by supplier; matches phrases like 'which suppliers have the most transactions' or 'busiest suppliers by deal count' using total_transactions descending."
    }
  ],
