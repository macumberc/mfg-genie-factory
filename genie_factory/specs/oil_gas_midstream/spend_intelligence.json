  "metric_views": [
    {
      "view_name": "procurement_transactions_metrics",
      "source_table": "procurement_transactions",
      "dimensions": [
        {
          "name": "transaction_date",
          "expr": "transaction_date"
        },
        {
          "name": "supplier_id",
          "expr": "supplier_id"
        },
        {
          "name": "spend_category",
          "expr": "spend_category"
        },
        {
          "name": "risk_tier",
          "expr": "risk_tier"
        },
        {
          "name": "document_type",
          "expr": "document_type"
        }
      ],
      "measures": [
        {
          "name": "total_spend_usd",
          "expr": "SUM(amount_usd)",
          "comment": "Total spend USD"
        },
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT transaction_id)",
          "comment": "Total transactions"
        },
        {
          "name": "avg_compliance_pct",
          "expr": "AVG(contract_compliance_pct)",
          "comment": "Avg contract compliance"
        },
        {
          "name": "avg_delivery_days",
          "expr": "AVG(delivery_days)",
          "comment": "Avg delivery lead time days"
        },
        {
          "name": "max_amount",
          "expr": "MAX(amount_usd)",
          "comment": "Maximum amount usd"
        }
      ]
    },
    {
      "view_name": "supplier_snapshots_metrics",
      "source_table": "supplier_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "supplier_id",
          "expr": "supplier_id"
        },
        {
          "name": "spend_category",
          "expr": "spend_category"
        },
        {
          "name": "risk_tier",
          "expr": "risk_tier"
        }
      ],
      "measures": [
        {
          "name": "avg_quality_score",
          "expr": "AVG(quality_score)",
          "comment": "Avg quality score"
        },
        {
          "name": "avg_on_time_pct",
          "expr": "AVG(on_time_delivery_pct)",
          "comment": "Avg on-time delivery"
        },
        {
          "name": "avg_defect_rate",
          "expr": "AVG(defect_rate_pct)",
          "comment": "Avg defect rate"
        },
        {
          "name": "avg_lead_time",
          "expr": "AVG(avg_lead_time_days)",
          "comment": "Avg lead time days"
        },
        {
          "name": "max_quality_score",
          "expr": "MAX(quality_score)",
          "comment": "Maximum quality score"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The procurement_transactions_metrics view (source: procurement_transactions) has dimensions: transaction_date, supplier_id, spend_category, risk_tier, document_type. Measures: total_spend_usd, total_transactions, avg_compliance_pct, avg_delivery_days. The supplier_snapshots_metrics view (source: supplier_snapshots) has dimensions: snapshot_date, supplier_id, spend_category, risk_tier. Measures: avg_quality_score, avg_on_time_pct, avg_defect_rate, avg_lead_time. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. supplier_name).",
  "sample_questions": [
    "What is the monthly trend in unique total transactionss?",
    "How has highest amount changed over time?",
    "What is the monthly trend in total spend usd?",
    "How has avg contract compliance changed over time?",
    "What is the monthly trend in highest quality score?",
    "How has avg quality score changed over time?",
    "What is the monthly trend in avg on-time delivery?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total spend usd?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(total_spend_usd) AS total_spend_usd",
        "FROM {fqn}.procurement_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ]
    },
    {
      "question": "How has avg contract compliance changed over time?",
      "sql_lines": [
        "SELECT transaction_date, MEASURE(avg_compliance_pct) AS avg_compliance_pct",
        "FROM {fqn}.procurement_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY transaction_date"
      ]
    },
    {
      "question": "What is the monthly trend in avg on-time delivery?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(avg_on_time_pct) AS avg_on_time_pct",
        "FROM {fqn}.supplier_snapshots_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "What is the trend of total transaction amount usd over time?",
      "sql_lines": [
        "SELECT transaction_date, SUM(amount_usd) AS total_amount_usd",
        "FROM {fqn}.procurement_transactions",
        "GROUP BY transaction_date ORDER BY transaction_date"
      ]
    },
    {
      "question": "What is the trend of total avg lead time days over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(avg_lead_time_days) AS total_avg_lead_time_days",
        "FROM {fqn}.supplier_snapshots",
