          "comment": "Transaction ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('PT-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.supplier_id) + 100000 AS STRING), 8, '0'))"
