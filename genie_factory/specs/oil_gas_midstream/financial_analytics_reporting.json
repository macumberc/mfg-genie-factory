        "alias": "revenue_variance_pct",
        "sql": "ROUND(100.0 * (budget_snapshots.actual_revenue_usd - budget_snapshots.planned_revenue_usd) / NULLIF(budget_snapshots.planned_revenue_usd, 0), 2)",
        "display_name": "revenue variance pct",
        "synonyms": [
