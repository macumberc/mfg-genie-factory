  "metric_views": [
    {
      "view_name": "simulation_runs_metrics",
      "source_table": "simulation_runs",
      "dimensions": [
        {
          "name": "run_date",
          "expr": "run_date"
        },
        {
          "name": "scenario_id",
          "expr": "scenario_id"
        },
        {
          "name": "scenario_type",
          "expr": "scenario_type"
        }
      ],
      "measures": [
        {
          "name": "avg_npv_mm",
          "expr": "AVG(npv_mm)",
          "comment": "Avg NPV millions"
        },
        {
          "name": "avg_revenue_impact_mm",
          "expr": "AVG(revenue_impact_mm)",
          "comment": "Avg revenue impact millions"
        },
        {
          "name": "total_runs",
          "expr": "COUNT(DISTINCT run_id)",
          "comment": "Total simulation runs"
        },
        {
          "name": "total_capex_mm",
          "expr": "SUM(capex_required_mm)",
          "comment": "Total capex millions"
        },
        {
          "name": "total_throughput_change_percent",
          "expr": "SUM(throughput_change_pct)",
          "comment": "Total throughput change pct"
        },
        {
          "name": "total_probability_weight",
          "expr": "SUM(probability_weight)",
          "comment": "Total probability weight"
        },
        {
          "name": "max_throughput_change_percent",
          "expr": "MAX(throughput_change_pct)",
          "comment": "Maximum throughput change pct"
        }
      ]
    },
    {
      "view_name": "outcome_snapshots_metrics",
      "source_table": "outcome_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "scenario_id",
          "expr": "scenario_id"
        },
        {
          "name": "scenario_type",
          "expr": "scenario_type"
        },
        {
          "name": "confidence_level",
          "expr": "confidence_level"
        }
      ],
      "measures": [
        {
          "name": "avg_ebitda_mm",
          "expr": "AVG(projected_ebitda_mm)",
          "comment": "Avg EBITDA millions"
        },
        {
          "name": "avg_throughput_mbpd",
          "expr": "AVG(projected_throughput_mbpd)",
          "comment": "Avg throughput MBPD"
        },
        {
          "name": "avg_regulatory_risk",
          "expr": "AVG(regulatory_risk_score)",
          "comment": "Avg regulatory risk score"
        },
        {
          "name": "max_projected_ebitda_mm",
          "expr": "MAX(projected_ebitda_mm)",
          "comment": "Maximum projected ebitda mm"
        }
      ]
    }
  ],
  "genie_instructions": "You are an oil & gas midstream analytics assistant for MidStream Dynamics. Answer questions about scenario planning and business simulation for midstream pipeline operations using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (scenario_name), query the base tables directly.\n- When joining tables, use the shared keys: scenario_id (shared across outcome_snapshots, scenario_kpi_monthly, simulation_runs).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique total runss?",
    "How has highest throughput change percent changed over time?",
    "What is the monthly trend in total capex millions?",
    "How has total throughput change pct changed over time?",
    "What is the monthly trend in highest projected ebitda mm?",
    "How has avg ebitda millions changed over time?",
    "What is the monthly trend in avg throughput mbpd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total capex millions?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_capex_mm) AS total_capex_mm",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
