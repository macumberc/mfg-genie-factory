        {
          "name": "event_type",
          "sql_type": "STRING",
          "comment": "Type: Violation, Inspection, Audit, Corrective Action, Self-Report, Near Miss",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Violation' WHEN {status_noise} < 0.35 THEN 'Inspection' WHEN {status_noise} < 0.50 THEN 'Audit' WHEN {status_noise} < 0.70 THEN 'Corrective Action' WHEN {status_noise} < 0.85 THEN 'Self-Report' ELSE 'Near Miss' END",
          "entity_values": [
            "Violation",
            "Inspection",
            "Audit",
            "Corrective Action",
            "Self-Report",
            "Near Miss"
          ]
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Severity: Low, Medium, High, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN 'Low' WHEN {status_noise} < 0.70 THEN 'Medium' WHEN {status_noise} < 0.90 THEN 'High' ELSE 'Critical' END",
          "entity_values": [
            "Low",
            "Medium",
            "High",
            "Critical"
          ]
        },
        {
          "name": "fine_amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Fine/penalty amount USD",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(0.0, {qty_noise} * 500000.0), 2)"
        },
        {
          "name": "resolution_days",
          "sql_type": "INT",
          "comment": "Days to resolution",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(1, FLOOR({qty_noise} * 180)) AS INT)"
        },
        {
          "name": "status",
          "sql_type": "STRING",
          "comment": "Status: Open, In Progress, Closed, Overdue",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'Open' WHEN {status_noise} < 0.45 THEN 'In Progress' WHEN {status_noise} < 0.85 THEN 'Closed' ELSE 'Overdue' END",
          "entity_values": [
            "Open",
            "In Progress",
            "Closed",
            "Overdue"
          ]
        }
      ],
