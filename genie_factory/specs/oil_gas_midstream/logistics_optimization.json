  "genie_instructions": "You are an oil & gas midstream analytics assistant for PipeRoute Midstream. Answer questions about pipeline logistics optimization and throughput management using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (segment_name), query the base tables directly.\n- When joining tables, use the shared keys: segment_id (shared across flow_readings, logistics_events, throughput_kpi_monthly).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.\n- Treat the `status` field as authoritative for lifecycle state.",
  "sample_questions": [
    "What is the monthly trend in unique total readingss?",
    "How has highest throughput bpd changed over time?",
    "What is the monthly trend in total pressure psi?",
    "How has avg throughput bpd changed over time?",
    "What is the monthly trend in unique total eventss?",
    "How has highest volume impact bbl changed over time?",
    "What is the monthly trend in total volume impact bbl?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total pressure psi?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_pressure_psi) AS total_pressure_psi",
        "FROM {fqn}.flow_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has avg throughput bpd changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_throughput_bpd) AS avg_throughput_bpd",
        "FROM {fqn}.flow_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the monthly trend in total volume impact bbl?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_volume_impact_bbl) AS total_volume_impact_bbl",
        "FROM {fqn}.logistics_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How does total throughput in bpd break down by pipeline segment id for 'Operating' records?",
      "sql_lines": [
        "SELECT segment_id, COUNT(*) AS record_count, SUM(throughput_bpd) AS total_throughput_bpd",
        "FROM {fqn}.flow_readings",
        "WHERE status = 'Operating' GROUP BY segment_id ORDER BY total_throughput_bpd DESC"
      ]
    },
    {
      "question": "What is the trend of total volume impact bbl over time?",
      "sql_lines": [
        "SELECT event_date, SUM(volume_impact_bbl) AS total_volume_impact_bbl",
        "FROM {fqn}.logistics_events",
        "GROUP BY event_date ORDER BY event_date"
      ]
    },
    {
      "question": "How has the average average utilization changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(avg_utilization_pct) AS avg_avg_utilization_pct",
        "FROM {fqn}.throughput_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ]
    },
    {
      "question": "How has avg tariff usd/bbl changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_tariff) AS avg_tariff",
        "FROM {fqn}.flow_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    }
  ],
