  "metric_views": [
    {
      "view_name": "trade_transactions_metrics",
      "source_table": "trade_transactions",
      "dimensions": [
        {
          "name": "trade_date",
          "expr": "trade_date"
        },
        {
          "name": "contract_id",
          "expr": "contract_id"
        },
        {
          "name": "commodity",
          "expr": "commodity"
        },
        {
          "name": "counterparty_type",
          "expr": "counterparty_type"
        },
        {
          "name": "trade_type",
          "expr": "trade_type"
        },
        {
          "name": "settlement_status",
          "expr": "settlement_status"
        }
      ],
      "measures": [
        {
          "name": "total_pnl_usd",
          "expr": "SUM(pnl_usd)",
          "comment": "Total P&L USD"
        },
        {
          "name": "total_volume_bbl",
          "expr": "SUM(volume_bbl)",
          "comment": "Total volume BBL"
        },
        {
          "name": "total_trades",
          "expr": "COUNT(DISTINCT trade_id)",
          "comment": "Total trades"
        },
        {
          "name": "avg_price_usd",
          "expr": "AVG(price_usd)",
          "comment": "Avg price USD"
        },
        {
          "name": "max_volume_bbl",
          "expr": "MAX(volume_bbl)",
          "comment": "Maximum volume bbl"
        }
      ]
    },
    {
      "view_name": "position_snapshots_metrics",
      "source_table": "position_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "contract_id",
          "expr": "contract_id"
        },
        {
          "name": "commodity",
          "expr": "commodity"
        },
        {
          "name": "counterparty_type",
          "expr": "counterparty_type"
        }
      ],
      "measures": [
        {
          "name": "total_mtm_usd",
          "expr": "SUM(mtm_value_usd)",
          "comment": "Total MTM USD"
        },
        {
          "name": "total_var_usd",
          "expr": "SUM(var_95_usd)",
          "comment": "Total VaR USD"
        },
        {
          "name": "avg_net_position_bbl",
          "expr": "AVG(net_position_bbl)",
          "comment": "Avg net position BBL"
        },
        {
          "name": "total_delta",
          "expr": "SUM(delta)",
          "comment": "Total delta"
        },
        {
          "name": "max_net_position_bbl",
          "expr": "MAX(net_position_bbl)",
          "comment": "Maximum net position bbl"
        }
      ]
