        {
          "name": "trade_type",
          "sql_type": "STRING",
          "comment": "Type: Buy, Sell, Swap, Option",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'Buy' WHEN {status_noise} < 0.65 THEN 'Sell' WHEN {status_noise} < 0.85 THEN 'Swap' ELSE 'Option' END",
          "entity_values": [
            "Buy",
            "Sell",
            "Swap",
            "Option"
          ]
        },
        {
          "name": "volume_bbl",
          "sql_type": "DOUBLE",
          "comment": "Volume in BBL equivalent",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(1000.0, {qty_noise} * 100000.0), 0)"
        },
        {
          "name": "price_usd",
          "sql_type": "DOUBLE",
          "comment": "Price USD per unit",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(1.0, 10.0 + {qty_noise} * 80.0), 2)"
        },
        {
          "name": "pnl_usd",
          "sql_type": "DOUBLE",
          "comment": "Realized P&L USD",
          "is_dimension": false,
          "generation_expr": "ROUND(-200000.0 + {qty_noise} * 600000.0, 2)"
        },
        {
          "name": "settlement_status",
          "sql_type": "STRING",
          "comment": "Status: Settled, Pending, Cancelled",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.70 THEN 'Settled' WHEN {status_noise} < 0.90 THEN 'Pending' ELSE 'Cancelled' END",
