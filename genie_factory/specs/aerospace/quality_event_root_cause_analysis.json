  "genie_instructions": "You are an aerospace analytics assistant for AeroQuality Corp. Answer questions about aerospace quality event tracking and root cause analysis using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (component_id, component_name), query the base tables directly.\n- When joining tables, use the shared keys: component_id (shared across inspection_records, quality_events, quality_kpi_monthly).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in critical event count?",
    "How has escape count changed over time?",
    "What is the monthly trend in unique total eventss?",
    "How has unique components changed over time?",
    "What is the monthly trend in fail count?",
    "How has unique total inspectionss changed over time?",
    "What is the monthly trend in unique components?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total eventss?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(total_events) AS total_events",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Monthly trend of total quality event counts over time; matches phrases like 'event volume trend' or 'how many quality events per month'."
    },
    {
      "question": "How has unique components changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(unique_component_count) AS unique_component_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Time-series trend of distinct components affected by quality events; matches 'unique components over time' using quality_events_metrics unique_component_count."
    },
    {
      "question": "What is the monthly trend in unique components?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', inspection_date) AS inspection_date_month, MEASURE(unique_component_count) AS unique_component_count",
        "FROM {fqn}.inspection_metrics",
        "GROUP BY ALL",
        "ORDER BY inspection_date_month"
      ],
      "usage_guidance": "Time-series trend of distinct components appearing in inspection records; matches 'unique components inspected over time' using inspection_metrics unique_component_count."
    },
    {
      "question": "What is the trend of total cost of quality (rework, scrap, warranty) in usd over time?",
      "sql_lines": [
        "SELECT event_date, SUM(cost_of_quality_usd) AS total_cost_of_quality_usd",
        "FROM {fqn}.quality_events",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Cumulative cost-of-quality trend (rework, scrap, warranty) over time; matches 'cost of quality trend' aggregating cost_of_quality_usd from quality_events."
    },
    {
      "question": "What is the trend of total number of units inspected over time?",
      "sql_lines": [
        "SELECT inspection_date, SUM(units_inspected) AS total_units_inspected",
        "FROM {fqn}.inspection_records",
        "GROUP BY inspection_date ORDER BY inspection_date"
      ],
      "usage_guidance": "Trend of total units inspected over time; matches 'inspection volume over time' or 'how many units inspected per period' from inspection_records."
    },
    {
      "question": "How has the average defect rate in parts per million changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(defect_rate_ppm) AS avg_defect_rate_ppm",
        "FROM {fqn}.quality_kpi_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ],
      "usage_guidance": "Time-series trend of average defect rate in PPM; matches 'defect rate trend' or 'parts per million over time' from quality_kpi_monthly."
    },
    {
      "question": "How does critical event count vary across component classes?",
      "sql_lines": [
        "SELECT component_class, MEASURE(critical_event_count) AS critical_event_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY critical_event_count DESC"
      ],
      "usage_guidance": "Cross-category comparison ranking component classes by critical event count; matches 'which component class has most critical events' or 'critical events by component class'."
    }
