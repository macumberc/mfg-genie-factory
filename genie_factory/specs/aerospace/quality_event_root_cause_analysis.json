          "is_dimension": true,
          "generation_expr": "",
          "entity_values": [
            "Structural",
            "Engine",
            "Avionics",
            "Landing Gear",
            "Interior",
            "Hydraulic"
          ],
          "synonyms": [
            "part category",
            "assembly type",
            "part family"
          ]
        },
        {
          "name": "process_area",
          "sql_type": "STRING",
          "comment": "Manufacturing process: Machining, Composites, Assembly, Heat Treatment, Surface Treatment, Testing",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.22 THEN 'Machining' WHEN {status_noise} < 0.40 THEN 'Composites' WHEN {status_noise} < 0.58 THEN 'Assembly' WHEN {status_noise} < 0.72 THEN 'Heat Treatment' WHEN {status_noise} < 0.86 THEN 'Surface Treatment' ELSE 'Testing' END",
          "entity_values": [
            "Machining",
            "Composites",
            "Assembly",
            "Heat Treatment",
            "Surface Treatment",
            "Testing"
          ]
        },
        {
          "name": "event_type",
          "sql_type": "STRING",
          "comment": "Event type: Non-Conformance, Escape, Customer Complaint, Audit Finding",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.50 THEN 'Non-Conformance' WHEN {status_noise} < 0.70 THEN 'Escape' WHEN {status_noise} < 0.88 THEN 'Customer Complaint' ELSE 'Audit Finding' END",
          "entity_values": [
            "Non-Conformance",
            "Escape",
            "Customer Complaint",
            "Audit Finding"
          ]
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Severity: Critical, Major, Minor, Observation",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.08 THEN 'Critical' WHEN {status_noise} < 0.30 THEN 'Major' WHEN {status_noise} < 0.70 THEN 'Minor' ELSE 'Observation' END",
          "entity_values": [
            "Critical",
            "Major",
            "Minor",
            "Observation"
          ]
        },
        {
          "name": "root_cause",
          "sql_type": "STRING",
          "comment": "Root cause: Tooling Wear, Operator Error, Material Defect, Process Drift, Design Gap, Supplier Quality, Environmental, Unknown",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Tooling Wear' WHEN {status_noise} < 0.28 THEN 'Operator Error' WHEN {status_noise} < 0.40 THEN 'Material Defect' WHEN {status_noise} < 0.52 THEN 'Process Drift' WHEN {status_noise} < 0.62 THEN 'Design Gap' WHEN {status_noise} < 0.75 THEN 'Supplier Quality' WHEN {status_noise} < 0.85 THEN 'Environmental' ELSE 'Unknown' END",
          "entity_values": [
            "Tooling Wear",
            "Operator Error",
            "Material Defect",
            "Process Drift",
            "Design Gap",
            "Supplier Quality",
            "Environmental",
            "Unknown"
          ]
        },
        {
          "name": "cost_of_quality_usd",
          "sql_type": "DOUBLE",
          "comment": "Cost of quality (rework, scrap, warranty) in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(500.0 + ({qty_noise} * 99500.0), 2)"
        },
        {
          "name": "days_to_closure",
          "sql_type": "INT",
          "comment": "Days from event to closure",
          "is_dimension": false,
          "generation_expr": "CAST(1 + FLOOR({qty_noise} * 89) AS INT)"
        }
      ],
      "seasonal_patterns": {
        "Structural": {
          "3,4,9,10": 0.05
