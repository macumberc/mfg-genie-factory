        {
          "name": "program_type",
          "sql_type": "STRING",
          "comment": "Program type: Production, Development, Aftermarket, Military, Space",
          "is_dimension": true,
          "generation_expr": "",
          "entity_values": [
            "Production",
            "Development",
            "Aftermarket",
            "Military",
            "Space"
          ]
        },
        {
          "name": "txn_type",
          "sql_type": "STRING",
          "comment": "Transaction type: Collection, Disbursement, Milestone Payment, Progress Payment, Advance",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Collection' WHEN {status_noise} < 0.55 THEN 'Disbursement' WHEN {status_noise} < 0.72 THEN 'Milestone Payment' WHEN {status_noise} < 0.88 THEN 'Progress Payment' ELSE 'Advance' END",
          "entity_values": [
            "Collection",
            "Disbursement",
            "Milestone Payment",
            "Progress Payment",
            "Advance"
          ]
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Transaction amount in USD (positive = inflow, negative = outflow)",
          "is_dimension": false,
          "generation_expr": "ROUND((CASE WHEN {status_noise} < 0.30 THEN 1.0 WHEN {status_noise} < 0.55 THEN -1.0 ELSE 1.0 END) * (50000.0 + ({qty_noise} * 4950000.0)), 2)"
        },
        {
          "name": "counterparty",
          "sql_type": "STRING",
          "comment": "Counterparty: Customer, Supplier, Government, Internal",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN 'Customer' WHEN {status_noise} < 0.65 THEN 'Supplier' WHEN {status_noise} < 0.82 THEN 'Government' ELSE 'Internal' END",
          "entity_values": [
            "Customer",
            "Supplier",
            "Government",
            "Internal"
          ]
        },
        {
          "name": "currency",
          "sql_type": "STRING",
          "comment": "Transaction currency: USD, EUR, GBP, JPY",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.60 THEN 'USD' WHEN {status_noise} < 0.80 THEN 'EUR' WHEN {status_noise} < 0.92 THEN 'GBP' ELSE 'JPY' END",
          "entity_values": [
            "USD",
            "EUR",
            "GBP",
            "JPY"
          ]
        },
        {
          "name": "payment_terms_days",
          "sql_type": "INT",
          "comment": "Payment terms in days",
          "is_dimension": false,
          "generation_expr": "CAST(CASE WHEN {status_noise} < 0.20 THEN 30 WHEN {status_noise} < 0.50 THEN 45 WHEN {status_noise} < 0.75 THEN 60 ELSE 90 END AS INT)"
        }
      ],
