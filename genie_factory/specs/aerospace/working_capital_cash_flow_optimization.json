  "metric_views": [
    {
      "view_name": "cash_txn_metrics",
      "source_table": "cash_transactions",
      "dimensions": [
        {
          "name": "txn_date",
          "expr": "txn_date"
        },
        {
          "name": "program_type",
          "expr": "program_type"
        },
        {
          "name": "txn_type",
          "expr": "txn_type"
        },
        {
          "name": "counterparty",
          "expr": "counterparty"
        }
      ],
      "measures": [
        {
          "name": "total_inflows",
          "expr": "SUM(CASE WHEN amount_usd > 0 THEN amount_usd ELSE 0 END)",
          "comment": "Total cash inflows USD"
        },
        {
          "name": "total_outflows",
          "expr": "SUM(CASE WHEN amount_usd < 0 THEN ABS(amount_usd) ELSE 0 END)",
          "comment": "Total cash outflows USD"
        },
        {
          "name": "net_cash_flow",
          "expr": "SUM(amount_usd)",
          "comment": "Net cash flow USD"
        },
        {
          "name": "txn_count",
          "expr": "COUNT(DISTINCT txn_id)",
          "comment": "Total transactions"
        },
        {
          "name": "avg_payment_terms",
          "expr": "AVG(payment_terms_days)",
          "comment": "Average payment terms in days"
        },
        {
          "name": "unique_program_count",
          "expr": "COUNT(DISTINCT program_id)",
          "comment": "Number of distinct programs"
        },
        {
          "name": "max_amount",
          "expr": "MAX(amount_usd)",
          "comment": "Maximum amount usd"
        }
      ]
    },
    {
      "view_name": "working_capital_metrics",
      "source_table": "working_capital_snapshots",
      "dimensions": [
        {
          "name": "snapshot_date",
          "expr": "snapshot_date"
        },
        {
          "name": "program_type",
          "expr": "program_type"
        }
      ],
      "measures": [
        {
          "name": "total_receivables",
          "expr": "SUM(accounts_receivable_usd)",
          "comment": "Total accounts receivable USD"
        },
        {
          "name": "total_payables",
          "expr": "SUM(accounts_payable_usd)",
          "comment": "Total accounts payable USD"
        },
        {
          "name": "avg_dso",
          "expr": "AVG(dso_days)",
          "comment": "Average days sales outstanding"
        },
        {
          "name": "avg_ccc",
          "expr": "AVG(cash_conversion_cycle_days)",
          "comment": "Average cash conversion cycle days"
        },
        {
          "name": "total_wip_inventory",
          "expr": "SUM(wip_inventory_usd)",
          "comment": "Total WIP inventory value USD"
        },
        {
          "name": "total_dpo_days",
          "expr": "SUM(dpo_days)",
          "comment": "Total dpo days"
