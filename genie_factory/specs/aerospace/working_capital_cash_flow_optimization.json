  "company_name": "AeroCapital Finance",
  "industry": "Aerospace",
  "use_case": "Aerospace working capital and cash flow optimization",
  "space_title": "AeroCapital Finance - Working Capital & Cash Flow 💰",
  "space_description": "Working capital analytics for AeroCapital Finance. Ask about cash transactions, receivables, payables, program-level working capital, cash conversion cycle, and free cash flow across 20 aerospace programs.",
  "schema_basename": "aerospace_working_capital",
  "tables": [
    {
      "table_name": "cash_transactions",
      "description": "Daily cash transaction records including collections, disbursements, milestone payments, and program-level cash flows.",
      "columns": [
        {
          "name": "txn_id",
          "sql_type": "STRING",
          "comment": "Unique transaction identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('CT-', LPAD(CAST(ROW_NUMBER() OVER (ORDER BY d.dt, e.program_id) + 10000 AS STRING), 7, '0'))"
        },
        {
          "name": "txn_date",
          "sql_type": "DATE",
          "comment": "Transaction date",
          "is_dimension": false,
          "generation_expr": "d.dt"
        },
        {
          "name": "program_id",
          "sql_type": "STRING",
