        {
          "name": "actual_units",
          "sql_type": "INT",
          "comment": "Actual units ordered",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(1, (5 + FLOOR({qty_noise} * 95)) * (0.75 + {status_noise} * 0.50)) AS INT)"
