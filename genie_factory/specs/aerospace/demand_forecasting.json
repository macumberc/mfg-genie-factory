        {
          "name": "forecast_error_pct",
          "sql_type": "DOUBLE",
          "comment": "Absolute forecast error percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(ABS(({qty_noise} * 0.40) - 0.10) * 100.0, 2)"
        },
        {
          "name": "model_version",
          "sql_type": "STRING",
          "comment": "Forecast model version",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'v4.0' WHEN {status_noise} < 0.55 THEN 'v4.1' ELSE 'v4.2' END",
