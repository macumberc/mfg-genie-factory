  "metric_views": [
    {
      "view_name": "order_metrics",
      "source_table": "aftermarket_orders",
      "dimensions": [
        {
          "name": "order_date",
          "expr": "order_date"
        },
        {
          "name": "part_category",
          "expr": "part_category"
        },
        {
          "name": "customer_segment",
          "expr": "customer_segment"
        },
        {
          "name": "order_status",
          "expr": "order_status"
        }
      ],
      "measures": [
        {
          "name": "total_order_revenue",
          "expr": "SUM(order_quantity * unit_price_usd)",
          "comment": "Total order revenue in USD"
        },
        {
          "name": "total_backlog_units",
          "expr": "SUM(order_quantity) FILTER (WHERE order_status = 'Backlog')",
          "comment": "Total units in backlog"
        },
        {
          "name": "total_order_count",
          "expr": "COUNT(DISTINCT order_id)",
          "comment": "Total orders placed"
        },
        {
          "name": "avg_lead_time_days",
          "expr": "AVG(lead_time_days)",
          "comment": "Average quoted lead time"
        },
        {
          "name": "shipped_order_count",
          "expr": "COUNT(DISTINCT CASE WHEN order_status = 'Shipped' THEN order_id END)",
          "comment": "Number of shipped orders"
        },
        {
          "name": "max_order_quantity",
          "expr": "MAX(order_quantity)",
          "comment": "Maximum order quantity"
        }
      ]
    },
