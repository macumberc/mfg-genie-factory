  "genie_instructions": "You are an aerospace analytics assistant for AeroChain Logistics. Answer questions about aerospace supply chain and long-lead materials planning using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (material_id, material_name), query the base tables directly.\n- When joining tables, use the shared keys: material_id (shared across procurement_orders, supply_kpi_monthly, supply_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in late delivery count?",
    "How has unique total pos changed over time?",
    "What is the monthly trend in unique materials?",
    "How has highest order quantity kg changed over time?",
    "What is the monthly trend in critical material count?",
    "How has unique snapshots changed over time?",
    "What is the monthly trend in highest on hand kg?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique materials?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', order_date) AS order_date_month, MEASURE(unique_material_count) AS unique_material_count",
        "FROM {fqn}.procurement_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date_month"
      ],
      "usage_guidance": "Monthly trend of distinct materials procured; matches phrases like 'how many unique materials ordered each month' using order_date and unique_material_count."
    },
    {
      "question": "How has highest order quantity kg changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(max_order_quantity_kg) AS max_order_quantity_kg",
        "FROM {fqn}.procurement_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Time-series trend of peak single-order volume in kg; matches 'largest order quantity over time' using order_date and max_order_quantity_kg."
    },
    {
      "question": "What is the monthly trend in highest on hand kg?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', snapshot_date) AS snapshot_date_month, MEASURE(max_on_hand_kg) AS max_on_hand_kg",
        "FROM {fqn}.supply_position_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date_month"
      ],
      "usage_guidance": "Time-series trend of peak on-hand inventory in kg; matches 'highest stock level over time' using snapshot_date and max_on_hand_kg."
    },
    {
      "question": "How does total order quantity in kilograms break down by material for 'On Time' records?",
      "sql_lines": [
        "SELECT material_id, COUNT(*) AS record_count, SUM(order_quantity_kg) AS total_order_quantity_kg",
        "FROM {fqn}.procurement_orders",
        "WHERE delivery_status = 'On Time' GROUP BY material_id ORDER BY total_order_quantity_kg DESC"
      ],
      "usage_guidance": "Filtered aggregate breaking down total order quantity by material for on-time deliveries only; matches 'which materials had the most kg delivered on time' filtering delivery_status = 'On Time'."
    },
    {
      "question": "What is the trend of total on-hand inventory in kg over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(on_hand_kg) AS total_on_hand_kg",
        "FROM {fqn}.supply_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Trend of total inventory on hand across all materials over time; matches 'how has our total stock changed' using supply_snapshots and on_hand_kg."
    },
    {
      "question": "How has the average supplier on-time delivery rate changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(on_time_delivery_pct) AS avg_on_time_delivery_pct",
        "FROM {fqn}.supply_kpi_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ],
      "usage_guidance": "Monthly trend of average supplier on-time delivery rate; matches 'is supplier delivery performance improving' using supply_kpi_monthly and on_time_delivery_pct."
    },
    {
      "question": "How has late delivery count changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(late_delivery_count) AS late_delivery_count",
        "FROM {fqn}.procurement_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Time-series trend of late delivery count; matches 'are late deliveries increasing or decreasing over time' using order_date and late_delivery_count."
    }
  ],
