        {
          "name": "health_score",
          "sql_type": "DOUBLE",
          "comment": "Computed engine health score 0-100 (higher is healthier)",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(15.0, 95.0 - ({qty_noise} * 45.0) - (CASE WHEN {status_noise} < 0.05 THEN 25.0 ELSE 0.0 END)), 2)"
        },
        {
          "name": "anomaly_flag",
          "sql_type": "STRING",
          "comment": "Anomaly detection flag: Normal, Watch, Alert, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.65 THEN 'Normal' WHEN {status_noise} < 0.82 THEN 'Watch' WHEN {status_noise} < 0.94 THEN 'Alert' ELSE 'Critical' END",
          "entity_values": [
            "Normal",
            "Watch",
            "Alert",
            "Critical"
          ]
        }
