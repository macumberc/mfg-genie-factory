        "display_name": "total maintenance cost",
        "synonyms": [
          "MRO spend",
          "repair cost"
        ]
      },
      {
        "alias": "total_downtime_hours",
        "sql": "SUM(maintenance_events.downtime_hours)",
        "display_name": "total downtime hours",
        "synonyms": [
          "AOG hours",
          "aircraft on ground"
        ]
      },
      {
