    "expressions": [
      {
        "alias": "reading_month",
        "sql": "DATE_TRUNC('month', sensor_readings.reading_date)",
        "display_name": "reading month",
        "synonyms": [
          "month of reading",
          "monthly"
        ]
      },
      {
        "alias": "egt_severity",
        "sql": "CASE WHEN sensor_readings.egt_celsius > 700 THEN 'High' WHEN sensor_readings.egt_celsius > 650 THEN 'Elevated' ELSE 'Normal' END",
        "display_name": "EGT severity level",
        "synonyms": [
          "temperature severity",
          "EGT category"
        ]
      },
      {
        "alias": "cost_category",
        "sql": "CASE WHEN maintenance_events.cost_usd > 1000000 THEN 'Major' WHEN maintenance_events.cost_usd > 200000 THEN 'Moderate' ELSE 'Minor' END",
        "display_name": "maintenance cost category",
        "synonyms": [
          "cost tier",
          "expense level"
        ]
      }
    ],
    "measures": [
