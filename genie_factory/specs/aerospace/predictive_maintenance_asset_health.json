  "genie_instructions": "You are an aerospace analytics assistant for AeroGuard Systems. Answer questions about aircraft engine predictive maintenance and asset health monitoring using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (engine_id, aircraft_type), query the base tables directly.\n- When joining tables, use the shared keys: engine_id (shared across health_monthly, maintenance_events, sensor_readings).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in critical alert count?",
    "How has unique readings changed over time?",
    "What is the monthly trend in unique engines?",
    "How has highest egt celsius changed over time?",
    "What is the monthly trend in unscheduled removal count?",
    "How has unique total eventss changed over time?",
    "What is the monthly trend in unique engines?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique engines?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(unique_engine_count) AS unique_engine_count",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has highest egt celsius changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_egt_celsius) AS max_egt_celsius",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has total parts replaced changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_parts_replaced) AS total_parts_replaced",
        "FROM {fqn}.maintenance_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "What is the trend of total exhaust gas temperature in celsius over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(egt_celsius) AS total_egt_celsius",
        "FROM {fqn}.sensor_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the trend of total aircraft downtime in hours over time?",
      "sql_lines": [
        "SELECT event_date, SUM(downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.maintenance_events",
        "GROUP BY event_date ORDER BY event_date"
      ]
    },
    {
      "question": "How has the average average health score for the month (0-100) changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(avg_health_score) AS avg_avg_health_score",
        "FROM {fqn}.health_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ]
    },
    {
      "question": "How has total fuel flow kg hr changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_fuel_flow_kg_hr) AS total_fuel_flow_kg_hr",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "sensor_readings.anomaly_flag = 'Critical'",
        "display_name": "critical anomalies",
