          "name": "fuel_flow_kg_hr",
          "sql_type": "DOUBLE",
          "comment": "Fuel flow rate in kg/hr",
          "is_dimension": false,
          "generation_expr": "ROUND(800.0 + ({qty_noise} * 1200.0), 2)"
