  "genie_instructions": "You are an aerospace analytics assistant for AeroSim Dynamics. Answer questions about design space simulation and optimization for aircraft fuel efficiency using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (config_id, config_name), query the base tables directly.\n- When joining tables, use the shared keys: config_id (shared across optimization_monthly, parameter_snapshots, simulation_runs).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in pareto run count?",
    "How has unique simulations changed over time?",
    "What is the monthly trend in unique configs?",
    "How has highest drag coefficient changed over time?",
    "What is the monthly trend in unique snapshots?",
    "How has unique configs changed over time?",
    "What is the monthly trend in highest wing span m?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique configs?",
      "sql_lines": [
        "SELECT run_date, MEASURE(unique_config_count) AS unique_config_count",
        "FROM {fqn}.simulation_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Monthly trend of unique design configurations tracked over time using simulation run dates from the simulation_metrics view."
    },
    {
      "question": "How has highest drag coefficient changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(max_drag_coefficient) AS max_drag_coefficient",
        "FROM {fqn}.simulation_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Time-series trend of peak drag coefficient values across simulation runs, useful for aerodynamic performance degradation analysis."
    },
    {
      "question": "What is the monthly trend in highest wing span m?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(max_wing_span_m) AS max_wing_span_m",
        "FROM {fqn}.parameter_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Monthly progression of maximum wing span measurements over time, sourced from parameter_metrics snapshot dates."
    },
    {
      "question": "How has total empty weight kg changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(total_empty_weight_kg) AS total_empty_weight_kg",
        "FROM {fqn}.parameter_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ],
      "usage_guidance": "Cumulative empty weight trajectory over time across parameter snapshots, relevant for structural weight budget monitoring."
    },
    {
      "question": "What is the trend of total total drag coefficient cd over time?",
      "sql_lines": [
        "SELECT run_date, SUM(drag_coefficient) AS total_drag_coefficient",
        "FROM {fqn}.simulation_runs",
        "GROUP BY run_date ORDER BY run_date"
      ],
      "usage_guidance": "Aggregate drag coefficient summed per simulation run date directly from simulation_runs, for raw aerodynamic load trending."
    },
    {
      "question": "What is the trend of total wing span in meters over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(wing_span_m) AS total_wing_span_m",
        "FROM {fqn}.parameter_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Total wing span summed across parameter snapshot dates from parameter_snapshots, for geometric design evolution tracking."
    },
    {
      "question": "How many distinct unique monthly record are there per engine type?",
      "sql_lines": [
        "SELECT engine_type, COUNT(DISTINCT record_id) AS distinct_count",
        "FROM {fqn}.optimization_monthly",
        "GROUP BY engine_type ORDER BY distinct_count DESC"
      ],
      "usage_guidance": "Count of distinct monthly optimization records broken down by engine type category, for engine configuration coverage analysis."
    }
  ],
