          "name": "gl_category",
          "sql_type": "STRING",
          "comment": "GL category: Revenue, COGS, Labor, Materials, Overhead, R&D, SGA",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'Revenue' WHEN {status_noise} < 0.38 THEN 'COGS' WHEN {status_noise} < 0.52 THEN 'Labor' WHEN {status_noise} < 0.65 THEN 'Materials' WHEN {status_noise} < 0.78 THEN 'Overhead' WHEN {status_noise} < 0.90 THEN 'R&D' ELSE 'SGA' END",
          "entity_values": [
            "Revenue",
            "COGS",
            "Labor",
            "Materials",
            "Overhead",
            "R&D",
            "SGA"
          ]
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Transaction amount in USD (revenue positive, expenses negative)",
          "is_dimension": false,
          "generation_expr": "ROUND((CASE WHEN {status_noise} < 0.20 THEN 1.0 ELSE -1.0 END) * (10000.0 + ({qty_noise} * 990000.0)), 2)"
        },
        {
          "name": "currency",
          "sql_type": "STRING",
          "comment": "Original currency: USD, EUR, GBP",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.65 THEN 'USD' WHEN {status_noise} < 0.85 THEN 'EUR' ELSE 'GBP' END",
          "entity_values": [
            "USD",
            "EUR",
            "GBP"
          ]
        },
        {
          "name": "project_code",
          "sql_type": "STRING",
          "comment": "Project code for cost allocation",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'PROD-NB' WHEN {status_noise} < 0.45 THEN 'PROD-WB' WHEN {status_noise} < 0.60 THEN 'DEF-FW' WHEN {status_noise} < 0.72 THEN 'SPC-SAT' WHEN {status_noise} < 0.82 THEN 'BJ-CABIN' WHEN {status_noise} < 0.92 THEN 'SVC-MRO' ELSE 'RD-NXT' END",
          "entity_values": [
            "PROD-NB",
            "PROD-WB",
            "DEF-FW",
            "SPC-SAT",
            "BJ-CABIN",
            "SVC-MRO",
            "RD-NXT"
          ]
        },
        {
          "name": "is_recurring",
          "sql_type": "STRING",
          "comment": "Recurring vs one-time: Recurring, One-Time",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.75 THEN 'Recurring' ELSE 'One-Time' END",
          "entity_values": [
