          "expr": "project_code"
        }
      ],
      "measures": [
        {
          "name": "total_revenue",
          "expr": "SUM(CASE WHEN gl_category = 'Revenue' THEN amount_usd ELSE 0 END)",
          "comment": "Total revenue in USD"
        },
        {
          "name": "total_cogs",
          "expr": "SUM(CASE WHEN gl_category = 'COGS' THEN ABS(amount_usd) ELSE 0 END)",
          "comment": "Total cost of goods sold USD"
        },
        {
          "name": "total_opex",
          "expr": "SUM(CASE WHEN gl_category IN ('Labor', 'Overhead', 'SGA') THEN ABS(amount_usd) ELSE 0 END)",
          "comment": "Total operating expenses USD"
