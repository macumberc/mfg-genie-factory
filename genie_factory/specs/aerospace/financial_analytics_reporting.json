    {
      "view_name": "financial_txn_metrics",
      "source_table": "financial_transactions",
      "dimensions": [
        {
          "name": "txn_date",
          "expr": "txn_date"
        },
        {
          "name": "business_segment",
          "expr": "business_segment"
