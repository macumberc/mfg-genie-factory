        {
          "name": "event_type",
          "sql_type": "STRING",
          "comment": "Event type: Manufacture, Installation, Removal, Shop Visit, Certification, Scrapped",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Manufacture' WHEN {status_noise} < 0.35 THEN 'Installation' WHEN {status_noise} < 0.50 THEN 'Removal' WHEN {status_noise} < 0.70 THEN 'Shop Visit' WHEN {status_noise} < 0.90 THEN 'Certification' ELSE 'Scrapped' END",
          "entity_values": [
            "Manufacture",
            "Installation",
            "Removal",
            "Shop Visit",
            "Certification",
            "Scrapped"
          ]
        },
        {
          "name": "facility_code",
          "sql_type": "STRING",
          "comment": "Facility where event occurred",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'OEM-SEA' WHEN {status_noise} < 0.40 THEN 'MRO-DFW' WHEN {status_noise} < 0.55 THEN 'MRO-SIN' WHEN {status_noise} < 0.70 THEN 'MRO-DUB' WHEN {status_noise} < 0.82 THEN 'OEM-TLS' WHEN {status_noise} < 0.92 THEN 'MRO-HKG' ELSE 'DEPOT-OKC' END",
          "entity_values": [
            "OEM-SEA",
            "MRO-DFW",
            "MRO-SIN",
            "MRO-DUB",
            "OEM-TLS",
            "MRO-HKG",
            "DEPOT-OKC"
          ]
        },
        {
          "name": "document_reference",
          "sql_type": "STRING",
          "comment": "Reference document: 8130-3, EASA Form 1, Work Order, Birth Certificate",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN '8130-3' WHEN {status_noise} < 0.55 THEN 'EASA Form 1' WHEN {status_noise} < 0.80 THEN 'Work Order' ELSE 'Birth Certificate' END",
          "entity_values": [
            "8130-3",
            "EASA Form 1",
            "Work Order",
            "Birth Certificate"
          ]
        },
        {
          "name": "counterfeit_risk_score",
          "sql_type": "DOUBLE",
          "comment": "AI-computed counterfeit risk score 0-100 (higher = riskier)",
          "is_dimension": false,
          "generation_expr": "ROUND(GREATEST(1.0, {qty_noise} * 100.0 * (CASE WHEN {status_noise} < 0.05 THEN 3.0 ELSE 1.0 END)), 2)"
        },
        {
          "name": "chain_of_custody_valid",
          "sql_type": "STRING",
          "comment": "Chain of custody validation: Valid, Gap Detected, Under Review",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.82 THEN 'Valid' WHEN {status_noise} < 0.94 THEN 'Gap Detected' ELSE 'Under Review' END",
          "entity_values": [
            "Valid",
            "Gap Detected",
            "Under Review"
          ]
        }
      ],
