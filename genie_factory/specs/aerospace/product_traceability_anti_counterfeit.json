  "example_sqls": [
    {
      "question": "What is the monthly trend in scrapped count?",
      "sql_lines": [
        "SELECT event_date, MEASURE(scrapped_count) AS scrapped_count",
        "FROM {fqn}.lifecycle_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How has unique total eventss changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_events) AS total_events",
        "FROM {fqn}.lifecycle_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "What is the monthly trend in unique snapshots?",
      "sql_lines": [
        "SELECT snapshot_date, MEASURE(snapshot_count) AS snapshot_count",
        "FROM {fqn}.certification_metrics",
        "GROUP BY ALL",
        "ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has the average ai-computed counterfeit risk score 0-100 (higher = riskier) changed over time?",
      "sql_lines": [
        "SELECT event_date, AVG(counterfeit_risk_score) AS avg_counterfeit_risk_score",
        "FROM {fqn}.lifecycle_events",
        "GROUP BY event_date ORDER BY event_date"
      ]
    },
    {
      "question": "What is the trend of total days until certification expires over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(days_until_cert_expiry) AS total_days_until_cert_expiry",
        "FROM {fqn}.certification_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has the average documentation completeness percentage changed over time?",
