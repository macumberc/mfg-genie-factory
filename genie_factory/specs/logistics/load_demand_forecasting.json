  "genie_instructions": "You are a logistics analytics assistant for CargoSight Analytics. Answer questions about load demand forecasting and shipment volume prediction using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (lane_id, lane_name), query the base tables directly.\n- When joining tables, use the shared keys: lane_id (shared across capacity_snapshots, demand_forecasts, shipment_orders).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in total freight revenue count?",
    "How has total weight delivered lbs count changed over time?",
    "What is the monthly trend in delivered order count?",
    "How has delayed order count changed over time?",
    "What is the monthly trend in unique forecast records?",
    "How has unique lanes changed over time?",
    "What is the monthly trend in highest forecasted shipments?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in delivered order count?",
      "sql_lines": [
        "SELECT order_date, MEASURE(delivered_order_count) AS delivered_order_count",
        "FROM {fqn}.shipment_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ]
    },
    {
      "question": "How has delayed order count changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(delayed_order_count) AS delayed_order_count",
        "FROM {fqn}.shipment_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest forecasted shipments?",
      "sql_lines": [
        "SELECT forecast_month, MEASURE(max_forecasted_shipments) AS max_forecasted_shipments",
        "FROM {fqn}.demand_forecasts_metrics",
        "GROUP BY ALL",
        "ORDER BY forecast_month"
      ]
    },
    {
      "question": "How has unique forecast records changed over time?",
      "sql_lines": [
        "SELECT forecast_month, MEASURE(forecast_record_count) AS forecast_record_count",
        "FROM {fqn}.demand_forecasts_metrics",
        "GROUP BY ALL",
        "ORDER BY forecast_month"
      ]
    },
    {
      "question": "How does total shipment weight in pounds break down by shipping lane for 'Delayed' records?",
      "sql_lines": [
        "SELECT lane_id, COUNT(*) AS record_count, SUM(weight_lbs) AS total_weight_lbs",
        "FROM {fqn}.shipment_orders",
        "WHERE order_status = 'Delayed' GROUP BY lane_id ORDER BY total_weight_lbs DESC"
      ]
    },
    {
      "question": "What is the trend of total predicted shipment count for month over time?",
      "sql_lines": [
        "SELECT forecast_month, SUM(forecasted_shipments) AS total_forecasted_shipments",
        "FROM {fqn}.demand_forecasts",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ]
    },
    {
      "question": "How has the average capacity utilization percentage changed over time?",
      "sql_lines": [
        "SELECT snapshot_date, AVG(capacity_utilization_pct) AS avg_capacity_utilization_pct",
        "FROM {fqn}.capacity_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    }
  ],
