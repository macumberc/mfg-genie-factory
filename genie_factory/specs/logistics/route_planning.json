        },
        {
          "name": "origin_location",
          "expr": "origin_location"
        },
        {
          "name": "destination_location",
          "expr": "destination_location"
        },
        {
          "name": "weather_condition",
          "expr": "weather_condition"
        }
      ],
      "measures": [
        {
          "name": "total_distance_km",
          "expr": "SUM(distance_km)",
          "comment": "Total distance driven across all segments in km"
        },
        {
          "name": "total_fuel_consumed_liters",
          "expr": "SUM(fuel_consumed_liters)",
          "comment": "Total fuel consumed across all segments in liters"
        },
        {
          "name": "total_fuel_cost_usd",
          "expr": "SUM(fuel_cost_usd)",
          "comment": "Total fuel cost across all segments in USD"
        },
        {
          "name": "avg_load_utilization_pct",
          "expr": "AVG(load_utilization_pct)",
          "comment": "Average load utilization percentage"
        },
        {
          "name": "avg_traffic_delay_minutes",
          "expr": "AVG(traffic_delay_minutes)",
          "comment": "Average traffic delay per segment in minutes"
        },
        {
          "name": "segment_count",
          "expr": "COUNT(DISTINCT segment_id)",
          "comment": "Total number of route segments"
        },
        {
          "name": "total_load_weight_kg",
          "expr": "SUM(load_weight_kg)",
          "comment": "Total load weight kg"
        },
        {
          "name": "unique_vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Number of distinct vehicles"
        },
        {
          "name": "unique_route_count",
          "expr": "COUNT(DISTINCT route_id)",
          "comment": "Number of distinct routes"
        },
        {
          "name": "max_distance_km",
          "expr": "MAX(distance_km)",
          "comment": "Maximum distance km"
        }
      ]
    },
