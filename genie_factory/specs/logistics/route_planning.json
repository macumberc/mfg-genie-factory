        {
          "name": "route_id",
          "sql_type": "STRING",
          "comment": "Route identifier grouping segments",
          "is_dimension": false,
          "generation_expr": "CONCAT('RT-', LPAD(CAST(FLOOR({qty_noise} * 500) AS STRING), 4, '0'))"
        },
        {
          "name": "origin_location",
          "sql_type": "STRING",
          "comment": "Segment origin city",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.1 THEN 'Chicago' WHEN {status_noise} < 0.2 THEN 'Dallas' WHEN {status_noise} < 0.3 THEN 'Atlanta' WHEN {status_noise} < 0.4 THEN 'Los Angeles' WHEN {status_noise} < 0.5 THEN 'New York' WHEN {status_noise} < 0.6 THEN 'Seattle' WHEN {status_noise} < 0.7 THEN 'Denver' WHEN {status_noise} < 0.8 THEN 'Miami' WHEN {status_noise} < 0.9 THEN 'Houston' ELSE 'Phoenix' END",
          "entity_values": [
            "Chicago",
            "Dallas",
            "Atlanta",
            "Los Angeles",
            "New York",
            "Seattle",
            "Denver",
            "Miami",
            "Houston",
            "Phoenix"
          ]
        },
        {
          "name": "destination_location",
          "sql_type": "STRING",
          "comment": "Segment destination city",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.1 THEN 'Denver' WHEN {status_noise} < 0.2 THEN 'Miami' WHEN {status_noise} < 0.3 THEN 'Chicago' WHEN {status_noise} < 0.4 THEN 'New York' WHEN {status_noise} < 0.5 THEN 'Dallas' WHEN {status_noise} < 0.6 THEN 'Atlanta' WHEN {status_noise} < 0.7 THEN 'Los Angeles' WHEN {status_noise} < 0.8 THEN 'Phoenix' WHEN {status_noise} < 0.9 THEN 'Seattle' ELSE 'Houston' END",
          "entity_values": [
            "Denver",
            "Miami",
            "Chicago",
            "New York",
            "Dallas",
            "Atlanta",
            "Los Angeles",
            "Phoenix",
            "Seattle",
            "Houston"
          ]
        },
        {
          "name": "distance_km",
          "sql_type": "DOUBLE",
          "comment": "Segment distance in kilometers",
          "is_dimension": false,
          "generation_expr": "ROUND(50 + {qty_noise} * 1450, 1)"
        },
        {
          "name": "fuel_consumed_liters",
          "sql_type": "DOUBLE",
          "comment": "Fuel consumed on this segment in liters",
          "is_dimension": false,
          "generation_expr": "ROUND((50 + {qty_noise} * 1450) / (3.0 + {qty_noise} * 5.0), 2)"
        },
        {
          "name": "fuel_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Fuel cost for this segment in USD",
          "is_dimension": false,
          "generation_expr": "ROUND((50 + {qty_noise} * 1450) / (3.0 + {qty_noise} * 5.0) * (1.10 + {qty_noise} * 0.50), 2)"
        },
        {
          "name": "load_weight_kg",
          "sql_type": "DOUBLE",
          "comment": "Cargo weight on this segment in kg",
          "is_dimension": false,
          "generation_expr": "ROUND(500 + {qty_noise} * 24500, 1)"
        },
        {
          "name": "load_utilization_pct",
          "sql_type": "DOUBLE",
          "comment": "Load weight as percent of vehicle capacity",
          "is_dimension": false,
          "generation_expr": "ROUND(30 + {qty_noise} * 65, 2)"
        },
        {
          "name": "traffic_delay_minutes",
          "sql_type": "DOUBLE",
          "comment": "Delay due to traffic in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 120, 1)"
        },
        {
          "name": "weather_condition",
          "sql_type": "STRING",
          "comment": "Weather during segment: Clear, Rain, Snow, Fog",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'Clear' WHEN {status_noise} < 0.80 THEN 'Rain' WHEN {status_noise} < 0.93 THEN 'Snow' ELSE 'Fog' END",
          "entity_values": [
            "Clear",
            "Rain",
            "Snow",
            "Fog"
          ]
        }
