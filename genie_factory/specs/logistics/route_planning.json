  "genie_instructions": "You are a logistics analytics assistant for TransRoute Logistics. Answer questions about route planning, fuel optimization, and delivery efficiency using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (vehicle_name, fuel_type, home_depot, status), query the base tables directly.\n- When joining tables, use the shared keys: vehicle_id (shared across route_efficiency_metrics, route_segments, vehicles).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.\n- Treat the `status` field as authoritative for lifecycle state.",
  "sample_questions": [
    "What is the monthly trend in unique segments?",
    "How has unique vehicles changed over time?",
    "What is the monthly trend in unique routes?",
    "How has highest distance km changed over time?",
    "What is the highest total distance km for each week start?",
    "What is the weekly distances in km for each week start?",
    "How does weekly fuel consumption in liters vary by week start?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique routes?",
      "sql_lines": [
        "SELECT segment_date, MEASURE(unique_route_count) AS unique_route_count",
        "FROM {fqn}.route_segments_metrics",
        "GROUP BY ALL",
        "ORDER BY segment_date"
      ]
    },
    {
      "question": "How has highest distance km changed over time?",
      "sql_lines": [
        "SELECT segment_date, MEASURE(max_distance_km) AS max_distance_km",
        "FROM {fqn}.route_segments_metrics",
        "GROUP BY ALL",
        "ORDER BY segment_date"
      ]
    },
    {
      "question": "How does weekly fuel consumption in liters vary by week start?",
      "sql_lines": [
        "SELECT week_start, MEASURE(total_weekly_fuel_liters) AS total_weekly_fuel_liters",
        "FROM {fqn}.route_efficiency_metrics_mv",
        "GROUP BY ALL",
        "ORDER BY total_weekly_fuel_liters DESC"
      ]
    },
    {
      "question": "Show the distribution of records by unique vehicle",
      "sql_lines": [
        "SELECT vehicle_id, COUNT(*) AS record_count",
        "FROM {fqn}.vehicles",
        "GROUP BY vehicle_id ORDER BY record_count DESC"
      ]
    },
    {
      "question": "What is the trend of total segment distance in kilometers over time?",
      "sql_lines": [
        "SELECT segment_date, SUM(distance_km) AS total_distance_km",
        "FROM {fqn}.route_segments",
        "GROUP BY segment_date ORDER BY segment_date"
      ]
    },
    {
      "question": "How has the average percentage of deliveries completed on time changed over time?",
      "sql_lines": [
        "SELECT week_start, AVG(on_time_delivery_pct) AS avg_on_time_delivery_pct",
        "FROM {fqn}.route_efficiency_metrics",
        "GROUP BY week_start ORDER BY week_start"
      ]
    },
    {
      "question": "Which vehicle types have the highest total load weight kg?",
      "sql_lines": [
        "SELECT vehicle_type, MEASURE(total_load_weight_kg) AS total_load_weight_kg",
        "FROM {fqn}.route_segments_metrics",
        "GROUP BY ALL",
        "ORDER BY total_load_weight_kg DESC"
      ]
    }
  ],
