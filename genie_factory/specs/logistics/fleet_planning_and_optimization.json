  "schema_basename": "fleet_planning",
  "tables": [
    {
      "table_name": "fleet_operations",
      "description": "Daily fleet dispatch and operation records including vehicle assignments, routes, cargo, mileage, fuel usage, and delivery outcomes.",
      "columns": [
        {
          "name": "operation_id",
          "sql_type": "STRING",
          "comment": "Unique fleet operation identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('FOP-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "operation_date",
          "sql_type": "DATE",
          "comment": "Date of the fleet operation",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "vehicle_id",
          "sql_type": "STRING",
          "comment": "Vehicle asset identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "vehicle_name",
          "sql_type": "STRING",
          "comment": "Human-readable vehicle name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "vehicle_class",
          "sql_type": "STRING",
          "comment": "Vehicle class: Heavy Duty, Medium Duty, Light Duty, Sprinter",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "depot_code",
          "sql_type": "STRING",
          "comment": "Depot/hub origin code",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.125 THEN 'DEP-NE' WHEN {status_noise} < 0.25 THEN 'DEP-SE' WHEN {status_noise} < 0.375 THEN 'DEP-MW' WHEN {status_noise} < 0.5 THEN 'DEP-SW' WHEN {status_noise} < 0.625 THEN 'DEP-NW' WHEN {status_noise} < 0.75 THEN 'DEP-SC' WHEN {status_noise} < 0.875 THEN 'DEP-WC' ELSE 'DEP-CE' END"
        },
        {
          "name": "route_distance_km",
          "sql_type": "DOUBLE",
          "comment": "Total route distance in kilometers",
          "is_dimension": false,
          "generation_expr": "ROUND(80 + {qty_noise} * 920, 1)"
        },
        {
          "name": "cargo_weight_kg",
          "sql_type": "DOUBLE",
          "comment": "Cargo weight in kilograms",
          "is_dimension": false,
          "generation_expr": "ROUND(200 + {qty_noise} * 19800, 1)"
        },
        {
          "name": "fuel_consumed_liters",
          "sql_type": "DOUBLE",
          "comment": "Fuel consumed in liters",
          "is_dimension": false,
          "generation_expr": "ROUND((80 + {qty_noise} * 920) / (3.5 + {qty_noise} * 6.5), 2)"
        },
        {
          "name": "delivery_status",
          "sql_type": "STRING",
          "comment": "Delivery outcome: On Time, Late, Partial, Failed",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.03 THEN 'Failed' WHEN {status_noise} < 0.08 THEN 'Partial' WHEN {status_noise} < 0.18 THEN 'Late' ELSE 'On Time' END"
        },
        {
          "name": "revenue_usd",
          "sql_type": "DOUBLE",
          "comment": "Revenue earned from this operation in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(150 + {qty_noise} * 2850, 2)"
        }
      ],
