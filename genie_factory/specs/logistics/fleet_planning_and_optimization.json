  "metric_views": [
    {
      "view_name": "fleet_operations_metrics",
      "source_table": "fleet_operations",
      "dimensions": [
        {
          "name": "operation_date",
          "expr": "operation_date"
        },
        {
          "name": "vehicle_class",
          "expr": "vehicle_class"
        },
        {
          "name": "depot_code",
          "expr": "depot_code"
        },
        {
          "name": "delivery_status",
          "expr": "delivery_status"
        }
      ],
      "measures": [
        {
          "name": "total_revenue_usd",
          "expr": "SUM(revenue_usd)",
          "comment": "Total revenue from fleet operations in USD"
        },
        {
          "name": "total_fuel_consumed_liters",
          "expr": "SUM(fuel_consumed_liters)",
          "comment": "Total fuel consumed in liters"
        },
        {
          "name": "total_distance_km",
          "expr": "SUM(route_distance_km)",
          "comment": "Total route distance in km"
        },
        {
          "name": "total_cargo_weight_kg",
          "expr": "SUM(cargo_weight_kg)",
          "comment": "Total cargo weight in kg"
        },
        {
          "name": "operation_count",
          "expr": "COUNT(DISTINCT operation_id)",
          "comment": "Number of fleet operations"
        },
        {
          "name": "on_time_operation_count",
          "expr": "COUNT(DISTINCT CASE WHEN delivery_status = 'On Time' THEN operation_id END)",
          "comment": "Number of on-time operations"
        },
        {
          "name": "unique_vehicle_count",
          "expr": "COUNT(DISTINCT vehicle_id)",
          "comment": "Number of distinct vehicles"
        },
        {
          "name": "max_route_distance_km",
          "expr": "MAX(route_distance_km)",
          "comment": "Maximum route distance km"
        }
      ]
    },
    {
      "view_name": "fleet_kpi_monthly_metrics",
      "source_table": "fleet_kpi_monthly",
      "dimensions": [
        {
          "name": "report_month",
          "expr": "report_month"
        },
        {
          "name": "vehicle_class",
          "expr": "vehicle_class"
        },
        {
          "name": "vehicle_id",
          "expr": "vehicle_id"
        }
      ],
      "measures": [
        {
          "name": "total_monthly_revenue",
          "expr": "SUM(monthly_revenue_usd)",
          "comment": "Total monthly revenue in USD"
        },
        {
          "name": "total_monthly_fuel_cost",
          "expr": "SUM(monthly_fuel_cost_usd)",
          "comment": "Total monthly fuel cost in USD"
        },
        {
          "name": "total_monthly_maintenance_cost",
          "expr": "SUM(monthly_maintenance_cost_usd)",
          "comment": "Total monthly maintenance cost in USD"
        },
        {
          "name": "avg_utilization_pct",
          "expr": "AVG(avg_utilization_pct)",
          "comment": "Average utilization rate"
        },
        {
          "name": "avg_on_time_delivery_pct",
          "expr": "AVG(on_time_delivery_pct)",
          "comment": "Average on-time delivery percentage"
        },
        {
          "name": "total_total_distance_km",
          "expr": "SUM(total_distance_km)",
          "comment": "Total total distance km"
        },
        {
          "name": "max_monthly_revenue",
          "expr": "MAX(monthly_revenue_usd)",
          "comment": "Maximum monthly revenue usd"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The fleet_operations_metrics view (source: fleet_operations) has dimensions: operation_date, vehicle_class, depot_code, delivery_status. Measures: total_revenue_usd, total_fuel_consumed_liters, total_distance_km, total_cargo_weight_kg, operation_count, on_time_operation_count. The fleet_kpi_monthly_metrics view (source: fleet_kpi_monthly) has dimensions: report_month, vehicle_class, vehicle_id. Measures: total_monthly_revenue, total_monthly_fuel_cost, total_monthly_maintenance_cost, avg_utilization_pct, avg_on_time_delivery_pct. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. vehicle_name).",
  "sample_questions": [
    "What is the monthly trend in on time operation count?",
    "How has unique operations changed over time?",
    "What is the monthly trend in unique vehicles?",
    "How has highest route distance km changed over time?",
    "What is the monthly trend in highest monthly revenue?",
    "How has total monthly revenue in usd changed over time?",
    "What is the monthly trend in total monthly fuel cost in usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique vehicles?",
      "sql_lines": [
        "SELECT operation_date, MEASURE(unique_vehicle_count) AS unique_vehicle_count",
        "FROM {fqn}.fleet_operations_metrics",
        "GROUP BY ALL",
        "ORDER BY operation_date"
      ]
    },
    {
      "question": "How has highest route distance km changed over time?",
      "sql_lines": [
        "SELECT operation_date, MEASURE(max_route_distance_km) AS max_route_distance_km",
        "FROM {fqn}.fleet_operations_metrics",
        "GROUP BY ALL",
        "ORDER BY operation_date"
      ]
    },
    {
      "question": "What is the monthly trend in total monthly fuel cost in usd?",
