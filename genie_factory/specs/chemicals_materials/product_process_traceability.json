          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'FAC-TX' WHEN {status_noise} < 0.40 THEN 'FAC-OH' WHEN {status_noise} < 0.60 THEN 'FAC-NJ' WHEN {status_noise} < 0.80 THEN 'FAC-CA' ELSE 'FAC-GA' END",
