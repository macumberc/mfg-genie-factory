          "name": "input_quantity_kg",
          "sql_type": "DOUBLE",
          "comment": "Input material quantity in kg",
          "is_dimension": false,
          "generation_expr": "ROUND(50 + {qty_noise} * 4950, 1)"
        },
        {
          "name": "output_quantity_kg",
          "sql_type": "DOUBLE",
          "comment": "Output product quantity in kg",
          "is_dimension": false,
          "generation_expr": "ROUND((50 + {qty_noise} * 4950) * (0.80 + {qty_noise} * 0.18), 1)"
        },
        {
          "name": "quality_check_result",
          "sql_type": "STRING",
          "comment": "Quality checkpoint result: Pass, Fail, Hold",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.05 THEN 'Fail' WHEN {status_noise} < 0.12 THEN 'Hold' ELSE 'Pass' END",
          "entity_values": [
            "Fail",
            "Hold",
            "Pass"
          ]
        }
