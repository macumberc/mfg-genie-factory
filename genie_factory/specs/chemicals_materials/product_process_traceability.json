  "metric_views": [
    {
      "view_name": "production_events_metrics",
      "source_table": "production_events",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "facility_id",
          "expr": "facility_id"
        },
        {
          "name": "process_step",
          "expr": "process_step"
        },
        {
          "name": "supplier_id",
          "expr": "supplier_id"
        },
        {
          "name": "quality_check_result",
          "expr": "quality_check_result"
        }
      ],
      "measures": [
        {
          "name": "total_production_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total production events"
        },
        {
          "name": "total_input_kg",
          "expr": "SUM(input_quantity_kg)",
          "comment": "Total input material in kg"
        },
        {
          "name": "total_output_kg",
          "expr": "SUM(output_quantity_kg)",
          "comment": "Total output product in kg"
        },
        {
          "name": "passed_quality_checks",
          "expr": "COUNT(DISTINCT CASE WHEN quality_check_result = 'Pass' THEN event_id END)",
          "comment": "Events passing quality checks"
        },
        {
          "name": "failed_quality_checks",
          "expr": "COUNT(DISTINCT CASE WHEN quality_check_result = 'Fail' THEN event_id END)",
          "comment": "Events failing quality checks"
        },
        {
          "name": "unique_lot_count",
          "expr": "COUNT(DISTINCT lot_number)",
          "comment": "Number of unique lots"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_input_quantity_kg",
          "expr": "MAX(input_quantity_kg)",
          "comment": "Maximum input quantity kg"
        }
      ]
    },
    {
      "view_name": "traceability_monthly_metrics",
      "source_table": "traceability_monthly",
      "dimensions": [
        {
          "name": "report_month",
          "expr": "report_month"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "product_id",
          "expr": "product_id"
        }
      ],
      "measures": [
        {
          "name": "total_lots_produced",
          "expr": "SUM(lots_produced)",
          "comment": "Total lots produced"
        },
        {
          "name": "total_lots_full_genealogy",
          "expr": "SUM(lots_with_full_genealogy)",
          "comment": "Lots with complete genealogy"
        },
        {
          "name": "avg_traceability_score",
          "expr": "AVG(traceability_score_pct)",
          "comment": "Average traceability score"
        },
        {
          "name": "avg_recall_readiness_hours",
          "expr": "AVG(recall_readiness_hours)",
          "comment": "Average mock recall time in hours"
        },
        {
          "name": "total_quality_holds",
          "expr": "SUM(quality_holds_count)",
          "comment": "Total lots on quality hold"
        },
        {
          "name": "max_lots_produced",
          "expr": "MAX(lots_produced)",
          "comment": "Maximum lots produced"
        },
        {
          "name": "total_supplier_audits_completed",
          "expr": "SUM(supplier_audits_completed)",
          "comment": "Total supplier audits completed"
        }
      ]
    }
  ],
  "genie_instructions": "You are a chemicals & materials analytics assistant for TraceCore Materials. Answer questions about product and process traceability for chemical manufacturing using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (product_name), query the base tables directly.\n- When joining tables, use the shared keys: product_id (shared across lot_tracking_snapshots, production_events, traceability_monthly); lot_number (joins lot_tracking_snapshots and production_events).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in passed quality checks count?",
    "How has failed quality checks count changed over time?",
    "What is the monthly trend in unique total production eventss?",
    "How has unique lots changed over time?",
    "What is the monthly trend in highest lots produced?",
    "How has total lots produced changed over time?",
    "What is the monthly trend in lots with complete genealogy?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total production eventss?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_production_events) AS total_production_events",
        "FROM {fqn}.production_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How has unique lots changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(unique_lot_count) AS unique_lot_count",
        "FROM {fqn}.production_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "What is the monthly trend in lots with complete genealogy?",
      "sql_lines": [
        "SELECT report_month, MEASURE(total_lots_full_genealogy) AS total_lots_full_genealogy",
        "FROM {fqn}.traceability_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month"
      ]
    },
    {
      "question": "What is the trend of total input material quantity in kg over time?",
      "sql_lines": [
        "SELECT event_date, SUM(input_quantity_kg) AS total_input_quantity_kg",
        "FROM {fqn}.production_events",
        "GROUP BY event_date ORDER BY event_date"
      ]
    },
    {
      "question": "What is the trend of total quantity remaining in lot in kg over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(quantity_on_hand_kg) AS total_quantity_on_hand_kg",
        "FROM {fqn}.lot_tracking_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How has the average traceability completeness score (0-100) changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(traceability_score_pct) AS avg_traceability_score_pct",
        "FROM {fqn}.traceability_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ]
    },
    {
      "question": "How does failed quality checks count vary across product categories?",
      "sql_lines": [
        "SELECT product_category, MEASURE(failed_quality_checks) AS failed_quality_checks",
        "FROM {fqn}.production_events_metrics",
        "GROUP BY ALL",
        "ORDER BY failed_quality_checks DESC"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "quality_check_result = 'Fail'",
        "display_name": "failed quality checks",
        "synonyms": [
          "quality failures",
          "failed inspections",
          "QC fails"
        ],
        "instruction": "Use when analyzing production events that failed quality checkpoints."
      },
      {
        "sql": "lot_status IN ('Quarantine', 'Recalled')",
        "display_name": "quarantined or recalled lots",
        "synonyms": [
          "problem lots",
          "held lots",
          "recalled products"
        ],
        "instruction": "Use when identifying lots that are under investigation or have been recalled."
      },
      {
        "sql": "process_step = 'Reaction'",
        "display_name": "reaction step events",
        "synonyms": [
          "chemical reaction",
          "synthesis step"
        ],
        "instruction": "Use when filtering to the reaction process step only."
      }
    ],
    "expressions": [
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', event_date)",
        "display_name": "event month",
        "synonyms": [
          "month",
          "production month"
        ]
      },
      {
        "alias": "process_yield_pct",
        "sql": "output_quantity_kg / NULLIF(input_quantity_kg, 0) * 100",
        "display_name": "process yield percentage",
        "synonyms": [
          "yield",
          "conversion rate",
          "step yield"
        ]
      },
      {
        "alias": "genealogy_completeness_pct",
        "sql": "lots_with_full_genealogy * 100.0 / NULLIF(lots_produced, 0)",
        "display_name": "genealogy completeness rate",
        "synonyms": [
          "genealogy rate",
          "traceability completeness"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_production_output",
        "sql": "SUM(output_quantity_kg)",
        "display_name": "total production output",
        "synonyms": [
          "output",
          "production volume",
          "total yield"
        ]
      },
      {
        "alias": "quality_pass_rate",
        "sql": "COUNT(DISTINCT CASE WHEN quality_check_result = 'Pass' THEN event_id END) * 1.0 / NULLIF(COUNT(DISTINCT event_id), 0)",
        "display_name": "quality pass rate",
        "synonyms": [
          "QC pass rate",
          "inspection pass rate"
        ]
      },
      {
        "alias": "avg_traceability_score",
        "sql": "AVG(traceability_score_pct)",
        "display_name": "average traceability score",
        "synonyms": [
          "trace score",
          "genealogy score"
        ]
      },
      {
        "alias": "avg_recall_readiness",
        "sql": "AVG(recall_readiness_hours)",
        "display_name": "average recall readiness time",
        "synonyms": [
          "recall time",
          "mock recall hours"
        ]
      }
    ]
  },
