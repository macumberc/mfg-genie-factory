            "FAC-OH",
            "FAC-NJ",
            "FAC-CA",
            "FAC-GA"
          ]
        },
        {
          "name": "process_step",
          "sql_type": "STRING",
          "comment": "Process step: Mixing, Reaction, Purification, Drying, Packaging",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.22 THEN 'Mixing' WHEN {status_noise} < 0.44 THEN 'Reaction' WHEN {status_noise} < 0.62 THEN 'Purification' WHEN {status_noise} < 0.80 THEN 'Drying' ELSE 'Packaging' END",
          "entity_values": [
            "Mixing",
            "Reaction",
            "Purification",
            "Drying",
            "Packaging"
          ]
        },
        {
          "name": "supplier_id",
          "sql_type": "STRING",
          "comment": "Raw material supplier",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'SUP-01' WHEN {status_noise} < 0.30 THEN 'SUP-02' WHEN {status_noise} < 0.45 THEN 'SUP-03' WHEN {status_noise} < 0.60 THEN 'SUP-04' WHEN {status_noise} < 0.75 THEN 'SUP-05' WHEN {status_noise} < 0.88 THEN 'SUP-06' ELSE 'SUP-07' END",
          "entity_values": [
            "SUP-01",
            "SUP-02",
            "SUP-03",
            "SUP-04",
            "SUP-05",
            "SUP-06",
            "SUP-07"
          ]
        },
