  "metric_views": [
    {
      "view_name": "chemical_orders_metrics",
      "source_table": "chemical_orders",
      "dimensions": [
        {
          "name": "order_date",
          "expr": "order_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "customer_segment",
          "expr": "customer_segment"
        },
        {
          "name": "plant_id",
          "expr": "plant_id"
        },
        {
          "name": "fulfillment_status",
          "expr": "fulfillment_status"
        }
      ],
      "measures": [
        {
          "name": "total_order_value_usd",
          "expr": "SUM(order_value_usd)",
          "comment": "Total order value in USD"
        },
        {
          "name": "total_order_quantity_kg",
          "expr": "SUM(order_quantity_kg)",
          "comment": "Total order quantity in kg"
        },
        {
          "name": "fulfilled_order_count",
          "expr": "COUNT(DISTINCT CASE WHEN fulfillment_status = 'Fulfilled' THEN order_id END)",
          "comment": "Count of fulfilled orders"
        },
        {
          "name": "total_order_count",
          "expr": "COUNT(DISTINCT order_id)",
          "comment": "Total orders placed"
        },
        {
          "name": "backorder_count",
          "expr": "COUNT(DISTINCT CASE WHEN fulfillment_status = 'Backorder' THEN order_id END)",
          "comment": "Count of backorders"
        },
        {
          "name": "avg_unit_price_usd",
          "expr": "AVG(unit_price_usd)",
          "comment": "Average price per kg in USD"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_order_quantity_kg",
          "expr": "MAX(order_quantity_kg)",
          "comment": "Maximum order quantity kg"
        }
      ]
    },
    {
      "view_name": "demand_forecasts_metrics",
      "source_table": "demand_forecasts",
      "dimensions": [
