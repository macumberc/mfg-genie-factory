  "schema_basename": "chem_demand_forecast",
  "tables": [
    {
      "table_name": "chemical_orders",
      "description": "Daily chemical product order records with quantities, pricing, customer segments, plant origins, and fulfillment status.",
      "columns": [
        {
          "name": "order_id",
          "sql_type": "STRING",
          "comment": "Unique order identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('ORD-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "order_date",
          "sql_type": "DATE",
          "comment": "Date order was placed",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "product_id",
          "sql_type": "STRING",
          "comment": "Chemical product identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_name",
          "sql_type": "STRING",
          "comment": "Chemical product name",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_category",
          "sql_type": "STRING",
          "comment": "Product category: Solvents, Polymers, Specialty Chemicals, Coatings, Adhesives",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "plant_id",
          "sql_type": "STRING",
          "comment": "Manufacturing plant identifier",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.17 THEN 'PLT-HOU' WHEN {status_noise} < 0.33 THEN 'PLT-CHI' WHEN {status_noise} < 0.50 THEN 'PLT-NJ' WHEN {status_noise} < 0.67 THEN 'PLT-LA' WHEN {status_noise} < 0.83 THEN 'PLT-ATL' ELSE 'PLT-SEA' END"
        },
        {
          "name": "customer_segment",
          "sql_type": "STRING",
          "comment": "Customer segment: Industrial, Automotive, Construction, Consumer, Pharmaceutical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'Industrial' WHEN {status_noise} < 0.45 THEN 'Automotive' WHEN {status_noise} < 0.65 THEN 'Construction' WHEN {status_noise} < 0.82 THEN 'Consumer' ELSE 'Pharmaceutical' END"
        },
        {
          "name": "order_quantity_kg",
          "sql_type": "DOUBLE",
          "comment": "Order quantity in kilograms",
          "is_dimension": false,
          "generation_expr": "ROUND(100 + {qty_noise} * 9900, 1)"
        },
        {
          "name": "unit_price_usd",
          "sql_type": "DOUBLE",
          "comment": "Price per kilogram in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(2.50 + {qty_noise} * 47.50, 2)"
        },
        {
          "name": "order_value_usd",
          "sql_type": "DOUBLE",
          "comment": "Total order value in USD",
          "is_dimension": false,
          "generation_expr": "ROUND((100 + {qty_noise} * 9900) * (2.50 + {qty_noise} * 47.50), 2)"
        },
        {
          "name": "fulfillment_status",
          "sql_type": "STRING",
          "comment": "Fulfillment status: Fulfilled, Partial, Backorder, Cancelled",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.02 THEN 'Cancelled' WHEN {status_noise} < 0.08 THEN 'Backorder' WHEN {status_noise} < 0.15 THEN 'Partial' ELSE 'Fulfilled' END"
        }
      ],
      "seasonal_patterns": {
