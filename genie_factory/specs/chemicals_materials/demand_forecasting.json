    {
      "table_name": "demand_forecasts",
      "description": "Monthly demand forecasts vs actuals by product and plant, including model version and accuracy metrics.",
      "columns": [
        {
          "name": "forecast_id",
          "sql_type": "STRING",
          "comment": "Unique forecast record ID",
          "is_dimension": false,
          "generation_expr": "CONCAT('FCST-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "forecast_month",
          "sql_type": "DATE",
          "comment": "Month being forecasted",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', dt)"
        },
        {
          "name": "product_id",
          "sql_type": "STRING",
          "comment": "Chemical product identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_category",
          "sql_type": "STRING",
          "comment": "Product category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "plant_id",
          "sql_type": "STRING",
          "comment": "Manufacturing plant",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.17 THEN 'PLT-HOU' WHEN {status_noise} < 0.33 THEN 'PLT-CHI' WHEN {status_noise} < 0.50 THEN 'PLT-NJ' WHEN {status_noise} < 0.67 THEN 'PLT-LA' WHEN {status_noise} < 0.83 THEN 'PLT-ATL' ELSE 'PLT-SEA' END"
        },
        {
          "name": "model_version",
          "sql_type": "STRING",
          "comment": "Forecast model version",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.33 THEN 'v4.0' WHEN {status_noise} < 0.66 THEN 'v4.1' ELSE 'v4.2' END"
        },
        {
          "name": "forecasted_quantity_kg",
          "sql_type": "DOUBLE",
          "comment": "Predicted demand quantity in kg",
          "is_dimension": false,
          "generation_expr": "ROUND(5000 + {qty_noise} * 95000, 1)"
        },
        {
          "name": "actual_quantity_kg",
          "sql_type": "DOUBLE",
          "comment": "Actual demand quantity in kg",
          "is_dimension": false,
          "generation_expr": "ROUND((5000 + {qty_noise} * 95000) * (0.85 + {qty_noise} * 0.30), 1)"
        },
        {
          "name": "forecasted_revenue_usd",
          "sql_type": "DOUBLE",
          "comment": "Predicted revenue in USD",
          "is_dimension": false,
          "generation_expr": "ROUND((5000 + {qty_noise} * 95000) * (5.0 + {qty_noise} * 25.0), 2)"
        },
        {
          "name": "actual_revenue_usd",
          "sql_type": "DOUBLE",
          "comment": "Actual revenue in USD",
          "is_dimension": false,
          "generation_expr": "ROUND((5000 + {qty_noise} * 95000) * (5.0 + {qty_noise} * 25.0) * (0.88 + {qty_noise} * 0.24), 2)"
        }
      ],
