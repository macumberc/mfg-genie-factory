  "genie_instructions": "You are a chemicals & materials analytics assistant for ChemFlow Industries. Answer questions about chemical product demand forecasting and inventory optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (product_id, product_name), query the base tables directly.\n- When joining tables, use the shared keys: product_id (shared across chemical_orders, demand_forecasts, inventory_positions); plant_id (shared across chemical_orders, demand_forecasts, inventory_positions).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in fulfilled order count?",
    "How has backorder count changed over time?",
    "What is the monthly trend in unique total orders?",
    "How has unique products changed over time?",
    "What is the monthly trend in unique forecast records?",
    "How has unique products changed over time?",
    "What is the monthly trend in highest forecasted quantity kg?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total orders?",
      "sql_lines": [
        "SELECT order_date, MEASURE(total_order_count) AS total_order_count",
        "FROM {fqn}.chemical_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Monthly trend of total order volume; matches phrases like 'order count over time' or 'how many orders per month' using order_date dimension."
    },
    {
      "question": "How has unique products changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(unique_product_count) AS unique_product_count",
        "FROM {fqn}.chemical_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Time-series trend of product variety; matches 'how many unique products ordered over time' using unique_product_count across order_date."
    },
    {
      "question": "How has average price per kg in usd changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(avg_unit_price_usd) AS avg_unit_price_usd",
        "FROM {fqn}.chemical_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ],
      "usage_guidance": "Trend of average chemical pricing per kg; matches 'price changes over time' or 'avg unit price trend' using avg_unit_price_usd by order_date."
    },
    {
      "question": "How does backorder count vary across product categories?",
      "sql_lines": [
        "SELECT product_category, MEASURE(backorder_count) AS backorder_count",
        "FROM {fqn}.chemical_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY backorder_count DESC"
      ],
      "usage_guidance": "Ranked breakdown of supply shortfalls by chemical category; matches 'which product categories have the most backorders' using backorder_count grouped by product_category."
    },
    {
      "question": "How does total order quantity in kilograms break down by chemical product for 'Backorder' records?",
      "sql_lines": [
        "SELECT product_id, COUNT(*) AS record_count, SUM(order_quantity_kg) AS total_order_quantity_kg",
        "FROM {fqn}.chemical_orders",
        "WHERE fulfillment_status = 'Backorder' GROUP BY product_id ORDER BY total_order_quantity_kg DESC"
      ],
      "usage_guidance": "Filtered aggregate of order quantity by product for backlogged demand; matches 'backorder volumes by product' filtering fulfillment_status = 'Backorder' on chemical_orders."
    },
    {
      "question": "What is the trend of total predicted demand quantity in kg over time?",
      "sql_lines": [
        "SELECT forecast_month, SUM(forecasted_quantity_kg) AS total_forecasted_quantity_kg",
        "FROM {fqn}.demand_forecasts",
        "GROUP BY forecast_month ORDER BY forecast_month"
      ],
      "usage_guidance": "Time-series of total forecasted demand in kg; matches 'predicted demand trend' or 'forecasted quantity over time' using demand_forecasts grouped by forecast_month."
    },
    {
      "question": "How many distinct unique inventory snapshot id are there per product category?",
      "sql_lines": [
        "SELECT product_category, COUNT(DISTINCT snapshot_id) AS distinct_count",
        "FROM {fqn}.inventory_positions",
        "GROUP BY product_category ORDER BY distinct_count DESC"
      ],
      "usage_guidance": "Count of distinct inventory snapshots per chemical category; matches 'how many inventory records exist by category' using snapshot_id on inventory_positions."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "fulfillment_status = 'Fulfilled'",
        "display_name": "fulfilled orders",
        "synonyms": [
          "completed orders",
          "shipped orders",
          "delivered orders"
        ],
        "instruction": "Use when calculating fulfillment rate or revenue from completed orders."
      },
      {
        "sql": "reorder_status IN ('Critical', 'Low')",
        "display_name": "low inventory",
        "synonyms": [
          "stockout risk",
          "below safety stock",
          "inventory alert"
        ],
        "instruction": "Use when identifying products at risk of stockout."
      },
      {
        "sql": "product_category = 'Polymers'",
        "display_name": "polymer products",
        "synonyms": [
          "resins",
          "plastics",
          "polymer resins"
        ],
        "instruction": "Use when filtering to polymer product category only."
      }
    ],
    "expressions": [
      {
        "alias": "order_month",
        "sql": "DATE_TRUNC('month', order_date)",
        "display_name": "order month",
        "synonyms": [
          "month",
          "booking month",
          "billing month"
        ]
      },
      {
        "alias": "forecast_error_kg",
        "sql": "actual_quantity_kg - forecasted_quantity_kg",
        "display_name": "forecast error (kg)",
        "synonyms": [
          "demand forecast miss",
          "prediction error",
          "volume variance"
        ]
      },
      {
        "alias": "inventory_coverage_ratio",
        "sql": "on_hand_qty_kg / NULLIF(safety_stock_kg, 0)",
        "display_name": "inventory coverage ratio",
        "synonyms": [
          "stock coverage",
          "safety stock ratio",
          "stock coverage ratio"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_order_value",
        "sql": "SUM(order_value_usd)",
        "display_name": "total order value",
        "synonyms": [
          "revenue",
          "order revenue",
          "total sales"
        ]
      },
      {
        "alias": "fulfillment_rate",
        "sql": "COUNT(DISTINCT CASE WHEN fulfillment_status = 'Fulfilled' THEN order_id END) * 1.0 / NULLIF(COUNT(DISTINCT order_id), 0)",
        "display_name": "fulfillment rate",
        "synonyms": [
          "fill rate",
          "order completion rate",
          "delivery rate"
        ]
      },
      {
        "alias": "avg_days_of_supply",
        "sql": "AVG(days_of_supply)",
        "display_name": "average days of supply",
        "synonyms": [
          "DOS",
          "inventory days",
          "supply coverage"
        ]
      },
      {
        "alias": "forecast_quantity_accuracy",
        "sql": "SUM(actual_quantity_kg) * 1.0 / NULLIF(SUM(forecasted_quantity_kg), 0)",
        "display_name": "forecast quantity accuracy",
        "synonyms": [
          "forecast accuracy",
          "demand accuracy",
          "volume accuracy"
        ]
      }
    ]
  },
