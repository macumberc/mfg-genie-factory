  "metric_views": [
    {
      "view_name": "experiment_runs_metrics",
      "source_table": "experiment_runs",
      "dimensions": [
        {
          "name": "run_date",
          "expr": "run_date"
        },
        {
          "name": "formulation_category",
          "expr": "formulation_category"
        },
        {
          "name": "lab_facility",
          "expr": "lab_facility"
        },
        {
          "name": "run_result",
          "expr": "run_result"
        }
      ],
      "measures": [
        {
          "name": "total_experiments",
          "expr": "COUNT(DISTINCT run_id)",
          "comment": "Total experiment runs"
        },
        {
          "name": "passed_experiments",
          "expr": "COUNT(DISTINCT CASE WHEN run_result = 'Pass' THEN run_id END)",
          "comment": "Experiments that passed"
        },
        {
          "name": "avg_yield_pct",
          "expr": "AVG(yield_pct)",
          "comment": "Average product yield percentage"
