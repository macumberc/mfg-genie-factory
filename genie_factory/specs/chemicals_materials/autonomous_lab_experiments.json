          "comment": "Total temperature c"
        },
        {
          "name": "total_pressure_bar",
          "expr": "SUM(pressure_bar)",
          "comment": "Total pressure bar"
        },
        {
          "name": "unique_formulation_count",
          "expr": "COUNT(DISTINCT formulation_id)",
          "comment": "Number of distinct formulations"
        },
        {
          "name": "max_temperature_c",
          "expr": "MAX(temperature_c)",
          "comment": "Maximum temperature c"
