  "benchmarks": [
    {
      "question": "What is the monthly trend in passed experiments count?",
      "sql_lines": [
        "SELECT run_date, MEASURE(passed_experiments) AS passed_experiments",
        "FROM {fqn}.experiment_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "How has unique total experimentss changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_experiments) AS total_experiments",
        "FROM {fqn}.experiment_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest experiments run?",
      "sql_lines": [
        "SELECT report_month, MEASURE(max_experiments_run) AS max_experiments_run",
        "FROM {fqn}.optimization_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month"
      ]
    },
    {
      "question": "How has total experiments conducted changed over time?",
      "sql_lines": [
        "SELECT report_month, MEASURE(total_experiments_run) AS total_experiments_run",
        "FROM {fqn}.optimization_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month"
      ]
    },
    {
      "question": "What are the top target formulation by total reaction temperature in celsius?",
      "sql_lines": [
        "SELECT formulation_id, SUM(temperature_c) AS total_temperature_c",
        "FROM {fqn}.experiment_runs",
        "GROUP BY formulation_id ORDER BY total_temperature_c DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average model-predicted yield percentage by human-readable formulation name?",
      "sql_lines": [
        "SELECT formulation_name, AVG(predicted_yield_pct) AS avg_predicted_yield_pct",
        "FROM {fqn}.parameter_snapshots",
        "GROUP BY formulation_name ORDER BY avg_predicted_yield_pct DESC"
      ]
    },
    {
      "question": "How many records are there per first day of reporting month?",
      "sql_lines": [
        "SELECT report_month, COUNT(*) AS record_count",
        "FROM {fqn}.optimization_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ]
