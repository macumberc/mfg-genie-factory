  "genie_instructions": "You are a chemicals & materials analytics assistant for LabAuto Sciences. Answer questions about autonomous lab experiment tracking and formulation optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (formulation_name), query the base tables directly.\n- When joining tables, use the shared keys: formulation_id (shared across experiment_runs, optimization_monthly, parameter_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in passed experiments count?",
    "How has unique total experimentss changed over time?",
    "What is the monthly trend in unique formulations?",
    "How has highest yield pct changed over time?",
    "What is the monthly trend in highest experiments run?",
    "How has total experiments conducted changed over time?",
    "What is the monthly trend in total best yield pct?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique formulations?",
      "sql_lines": [
        "SELECT run_date, MEASURE(unique_formulation_count) AS unique_formulation_count",
        "FROM {fqn}.experiment_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Monthly trend of distinct formulations tested; matches phrases like 'how many unique formulations per month' using unique_formulation_count from experiment_runs_metrics."
    },
    {
      "question": "How has highest yield pct changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(max_yield_pct) AS max_yield_pct",
        "FROM {fqn}.experiment_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Time-series trend of peak yield percentage achieved; matches phrases like 'best yield over time' using max_yield_pct from experiment_runs_metrics."
    },
    {
      "question": "What is the monthly trend in total best yield pct?",
      "sql_lines": [
        "SELECT report_month, MEASURE(total_best_yield_percent) AS total_best_yield_percent",
        "FROM {fqn}.optimization_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month"
      ],
      "usage_guidance": "Monthly cumulative best-yield trend across optimization cycles; matches phrases like 'total best yield per month' using total_best_yield_percent from optimization_monthly_metrics."
    },
    {
      "question": "How has average model prediction accuracy changed over time?",
      "sql_lines": [
        "SELECT report_month, MEASURE(avg_model_accuracy_pct) AS avg_model_accuracy_pct",
        "FROM {fqn}.optimization_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month"
      ],
      "usage_guidance": "Time-series trend of ML model prediction accuracy; matches phrases like 'how accurate are predictions over time' using avg_model_accuracy_pct from optimization_monthly_metrics."
    },
    {
      "question": "What is the trend of total reaction temperature in celsius over time?",
      "sql_lines": [
        "SELECT run_date, SUM(temperature_c) AS total_temperature_c",
        "FROM {fqn}.experiment_runs",
        "GROUP BY run_date ORDER BY run_date"
      ],
      "usage_guidance": "Daily trend of summed reaction temperatures across experiment runs; matches phrases like 'total temperature used in experiments over time' from experiment_runs table."
    },
    {
      "question": "What is the trend of total model-recommended optimal temperature in celsius over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(optimal_temp_c) AS total_optimal_temp_c",
        "FROM {fqn}.parameter_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of model-recommended optimal temperatures; matches phrases like 'how have suggested optimal temperatures changed' using optimal_temp_c from parameter_snapshots."
    },
    {
      "question": "How has the average percentage of experiments that passed changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(pass_rate_pct) AS avg_pass_rate_pct",
        "FROM {fqn}.optimization_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ],
      "usage_guidance": "Monthly trend of average experiment pass rate percentage; matches phrases like 'how often do experiments pass over time' using pass_rate_pct from optimization_monthly table."
    }
  ],
