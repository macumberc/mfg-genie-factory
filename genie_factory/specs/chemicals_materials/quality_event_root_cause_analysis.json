          "sql_type": "STRING",
          "comment": "Type: Deviation, Non-Conformance, Customer Complaint, Audit Finding",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN 'Deviation' WHEN {status_noise} < 0.65 THEN 'Non-Conformance' WHEN {status_noise} < 0.85 THEN 'Customer Complaint' ELSE 'Audit Finding' END",
          "entity_values": [
            "Deviation",
            "Non-Conformance",
            "Customer Complaint",
            "Audit Finding"
          ]
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Severity: Critical, Major, Minor",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.08 THEN 'Critical' WHEN {status_noise} < 0.35 THEN 'Major' ELSE 'Minor' END",
          "entity_values": [
            "Critical",
            "Major",
            "Minor"
          ]
        },
        {
          "name": "root_cause_category",
          "sql_type": "STRING",
          "comment": "Root cause: Equipment, Process, Material, Human Error, Environmental",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'Equipment' WHEN {status_noise} < 0.50 THEN 'Process' WHEN {status_noise} < 0.70 THEN 'Material' WHEN {status_noise} < 0.88 THEN 'Human Error' ELSE 'Environmental' END",
