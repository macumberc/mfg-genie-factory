            "Equipment",
            "Process",
            "Material",
            "Human Error",
            "Environmental"
          ]
        },
        {
          "name": "cost_of_quality_usd",
          "sql_type": "DOUBLE",
          "comment": "Estimated cost of the quality event in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(500 + {qty_noise} * 49500, 2)"
        },
