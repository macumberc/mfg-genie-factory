    {
      "question": "How has closed effective count changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(closed_effective_count) AS closed_effective_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest total events?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', report_month) AS report_month_month, MEASURE(max_total_events) AS max_total_events",
        "FROM {fqn}.quality_kpi_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month_month"
      ]
    },
    {
      "question": "How has total quality events per month changed over time?",
      "sql_lines": [
        "SELECT report_month, MEASURE(total_monthly_events) AS total_monthly_events",
        "FROM {fqn}.quality_kpi_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month"
      ]
    },
    {
      "question": "What are the top 10 chemical product by total estimated cost of the quality event in usd?",
      "sql_lines": [
        "SELECT product_id, SUM(cost_of_quality_usd) AS total_cost_of_quality_usd",
        "FROM {fqn}.quality_events",
        "GROUP BY product_id ORDER BY total_cost_of_quality_usd DESC LIMIT 10"
      ]
    },
    {
      "question": "What is the average batch yield percentage by chemical product name?",
      "sql_lines": [
        "SELECT product_name, AVG(yield_pct) AS avg_yield_pct",
        "FROM {fqn}.batch_records",
        "GROUP BY product_name ORDER BY avg_yield_pct DESC"
      ]
    },
    {
      "question": "How many records are there per first day of reporting month?",
      "sql_lines": [
        "SELECT report_month, COUNT(*) AS record_count",
        "FROM {fqn}.quality_kpi_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ]
    }
  ]
