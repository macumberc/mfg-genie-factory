  "metric_views": [
    {
      "view_name": "quality_events_metrics",
      "source_table": "quality_events",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "production_line",
          "expr": "production_line"
        },
        {
          "name": "event_type",
          "expr": "event_type"
        },
        {
          "name": "severity",
          "expr": "severity"
        },
        {
          "name": "root_cause_category",
          "expr": "root_cause_category"
        }
      ],
      "measures": [
        {
          "name": "total_quality_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total quality events"
        },
        {
          "name": "critical_event_count",
          "expr": "COUNT(DISTINCT CASE WHEN severity = 'Critical' THEN event_id END)",
          "comment": "Count of critical severity events"
        },
        {
          "name": "total_cost_of_quality_usd",
          "expr": "SUM(cost_of_quality_usd)",
          "comment": "Total cost of quality in USD"
        },
        {
          "name": "avg_resolution_days",
          "expr": "AVG(resolution_days)",
          "comment": "Average days to resolve events"
        },
        {
          "name": "closed_effective_count",
          "expr": "COUNT(DISTINCT CASE WHEN capa_status = 'Closed Effective' THEN event_id END)",
          "comment": "CAPAs closed effectively"
        },
        {
          "name": "open_event_count",
          "expr": "COUNT(DISTINCT CASE WHEN capa_status IN ('Open', 'In Progress') THEN event_id END)",
          "comment": "Events still open or in progress"
        },
        {
          "name": "unique_product_count",
          "expr": "COUNT(DISTINCT product_id)",
          "comment": "Number of distinct products"
        },
        {
          "name": "max_cost_of_quality",
          "expr": "MAX(cost_of_quality_usd)",
          "comment": "Maximum cost of quality usd"
        }
      ]
    },
    {
      "view_name": "quality_kpi_monthly_metrics",
      "source_table": "quality_kpi_monthly",
      "dimensions": [
        {
          "name": "report_month",
          "expr": "report_month"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "product_id",
          "expr": "product_id"
        }
      ],
      "measures": [
        {
          "name": "total_monthly_events",
          "expr": "SUM(total_events)",
          "comment": "Total quality events per month"
        },
        {
          "name": "total_critical_events",
          "expr": "SUM(critical_events)",
          "comment": "Total critical events per month"
        },
        {
          "name": "avg_capa_closure_rate",
          "expr": "AVG(capa_closure_rate_pct)",
          "comment": "Average CAPA closure rate"
        },
        {
          "name": "total_monthly_coq_usd",
          "expr": "SUM(cost_of_quality_usd)",
          "comment": "Total monthly cost of quality in USD"
        },
        {
          "name": "avg_batch_pass_rate",
          "expr": "AVG(batch_pass_rate_pct)",
          "comment": "Average batch pass rate"
        },
        {
          "name": "total_avg_resolution_days",
          "expr": "SUM(avg_resolution_days)",
          "comment": "Total avg resolution days"
        },
        {
          "name": "max_total_events",
          "expr": "MAX(total_events)",
          "comment": "Maximum total events"
        }
      ]
    }
  ],
  "genie_instructions": "You are a chemicals & materials analytics assistant for PureChem Analytics. Answer questions about quality event tracking and root cause analysis for chemical manufacturing using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (product_name), query the base tables directly.\n- When joining tables, use the shared keys: product_id (shared across batch_records, quality_events, quality_kpi_monthly).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in critical event count?",
    "How has closed effective count changed over time?",
    "What is the monthly trend in open event count?",
    "How has unique total quality eventss changed over time?",
    "What is the monthly trend in highest total events?",
    "How has total quality events per month changed over time?",
    "What is the monthly trend in total critical events per month?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in open event count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(open_event_count) AS open_event_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Route trend-over-time questions about unresolved or open quality events using the quality_events_metrics metric view with open_event_count measure."
    },
    {
      "question": "How has unique total quality eventss changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_quality_events) AS total_quality_events",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Route time-series questions about total volume of quality events across all types using the quality_events_metrics metric view with total_quality_events measure."
    },
    {
      "question": "What is the monthly trend in total critical events per month?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', report_month) AS report_month_month, MEASURE(total_critical_events) AS total_critical_events",
        "FROM {fqn}.quality_kpi_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY report_month_month"
      ],
      "usage_guidance": "Route monthly trend questions about critical-severity event counts using the quality_kpi_monthly_metrics metric view with total_critical_events measure."
    },
    {
      "question": "How does total estimated cost of the quality event in usd break down by chemical product for 'Open' records?",
      "sql_lines": [
        "SELECT product_id, COUNT(*) AS record_count, SUM(cost_of_quality_usd) AS total_cost_of_quality_usd",
        "FROM {fqn}.quality_events",
        "WHERE capa_status = 'Open' GROUP BY product_id ORDER BY total_cost_of_quality_usd DESC"
      ],
      "usage_guidance": "Route cost-breakdown-by-product questions filtered to Open CAPA status records, aggregating cost_of_quality_usd from the quality_events table."
    },
    {
      "question": "What is the trend of total batch size in kilograms over time?",
      "sql_lines": [
        "SELECT batch_date, SUM(batch_size_kg) AS total_batch_size_kg",
        "FROM {fqn}.batch_records",
        "GROUP BY batch_date ORDER BY batch_date"
      ],
      "usage_guidance": "Route trend questions about batch production volume in kilograms over time using batch_records with batch_size_kg summed by batch_date."
    },
    {
      "question": "How has the average capa closure rate for the month changed over time?",
      "sql_lines": [
        "SELECT report_month, AVG(capa_closure_rate_pct) AS avg_capa_closure_rate_pct",
        "FROM {fqn}.quality_kpi_monthly",
        "GROUP BY report_month ORDER BY report_month"
      ],
      "usage_guidance": "Route time-series questions about CAPA closure rate percentage trends using the quality_kpi_monthly table with avg_capa_closure_rate_pct by report_month."
    },
    {
      "question": "How has open event count changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(open_event_count) AS open_event_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Route questions about how open, unresolved quality event counts have changed over time using quality_events_metrics open_event_count measure."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "severity = 'Critical'",
        "display_name": "critical events",
        "synonyms": [
          "critical deviations",
          "high severity",
          "critical quality"
        ],
        "instruction": "Use when filtering to the most severe quality events only."
      },
      {
        "sql": "capa_status IN ('Open', 'In Progress')",
        "display_name": "open CAPAs",
        "synonyms": [
          "unresolved events",
          "pending CAPAs",
          "active events"
        ],
        "instruction": "Use when analyzing events that have not yet been resolved."
      },
      {
        "sql": "root_cause_category = 'Equipment'",
        "display_name": "equipment-related events",
        "synonyms": [
          "equipment failures",
          "machine issues",
          "hardware root cause"
        ],
        "instruction": "Use when filtering to equipment-related root causes."
      }
    ],
    "expressions": [
      {
        "alias": "event_month",
        "sql": "DATE_TRUNC('month', event_date)",
        "display_name": "event month",
        "synonyms": [
          "month",
          "reporting month",
          "incident month"
        ]
      },
      {
        "alias": "quality_cost_per_batch",
        "sql": "cost_of_quality_usd / NULLIF(total_events, 0)",
        "display_name": "quality cost per event",
        "synonyms": [
          "cost per deviation",
          "unit quality cost",
          "cost per incident"
        ]
      },
      {
        "alias": "temp_deviation_abs",
        "sql": "ABS(temperature_deviation_c)",
        "display_name": "absolute temperature deviation",
        "synonyms": [
          "temp offset",
          "deviation magnitude",
          "temperature variance"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_cost_of_quality",
        "sql": "SUM(cost_of_quality_usd)",
        "display_name": "total cost of quality",
        "synonyms": [
          "COQ",
          "quality cost",
          "total quality spend"
        ]
      },
      {
        "alias": "capa_effectiveness_rate",
        "sql": "COUNT(DISTINCT CASE WHEN capa_status = 'Closed Effective' THEN event_id END) * 1.0 / NULLIF(COUNT(DISTINCT event_id), 0)",
        "display_name": "CAPA effectiveness rate",
        "synonyms": [
          "closure rate",
          "resolution effectiveness",
          "corrective action rate"
        ]
      },
      {
        "alias": "batch_pass_rate",
        "sql": "COUNT(DISTINCT CASE WHEN quality_result = 'Pass' THEN batch_id END) * 1.0 / NULLIF(COUNT(DISTINCT batch_id), 0)",
        "display_name": "batch pass rate",
        "synonyms": [
          "quality rate",
          "first-pass yield",
          "lot acceptance rate"
        ]
      },
      {
        "alias": "avg_resolution_time",
        "sql": "AVG(resolution_days)",
        "display_name": "average resolution time",
        "synonyms": [
          "mean time to resolution",
          "MTTR",
          "avg days to close"
        ]
      }
    ]
  },
  "benchmarks": [
    {
      "question": "What is the monthly trend in critical event count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(critical_event_count) AS critical_event_count",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ]
