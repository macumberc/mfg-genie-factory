  "metric_views": [
    {
      "view_name": "customer_orders_metrics",
      "source_table": "customer_orders",
      "dimensions": [
        {
          "name": "order_date",
          "expr": "order_date"
        },
        {
          "name": "product_family",
          "expr": "product_family"
        },
        {
          "name": "customer_region",
          "expr": "customer_region"
        },
        {
          "name": "order_status",
          "expr": "order_status"
        }
      ],
      "measures": [
        {
          "name": "total_order_revenue",
          "expr": "SUM(order_quantity * unit_price_usd)",
          "comment": "Total order revenue in USD"
        },
        {
          "name": "total_order_quantity",
          "expr": "SUM(order_quantity)",
          "comment": "Total units ordered"
        },
        {
          "name": "total_orders",
          "expr": "COUNT(DISTINCT order_id)",
          "comment": "Total number of orders"
        },
        {
          "name": "avg_lead_time",
          "expr": "AVG(lead_time_days)",
          "comment": "Average lead time in days"
        },
        {
          "name": "total_discount_percent",
          "expr": "SUM(discount_pct)",
          "comment": "Total discount pct"
        },
        {
          "name": "max_order_quantity",
          "expr": "MAX(order_quantity)",
          "comment": "Maximum order quantity"
        }
      ]
    },
    {
      "view_name": "demand_kpi_metrics",
      "source_table": "demand_kpi_monthly",
      "dimensions": [
        {
          "name": "kpi_month",
          "expr": "kpi_month"
        },
        {
          "name": "product_family",
          "expr": "product_family"
        }
      ],
      "measures": [
        {
          "name": "avg_forecast_accuracy",
          "expr": "AVG(forecast_accuracy_pct)",
          "comment": "Average forecast accuracy"
        },
        {
          "name": "avg_fill_rate",
          "expr": "AVG(fill_rate_pct)",
          "comment": "Average order fill rate"
        },
        {
          "name": "total_backlog",
          "expr": "SUM(backlog_units)",
          "comment": "Total backlog units"
        },
        {
          "name": "total_revenue",
          "expr": "SUM(total_revenue_usd)",
          "comment": "Total monthly revenue"
        },
        {
          "name": "max_forecast_accuracy_percent",
          "expr": "MAX(forecast_accuracy_pct)",
          "comment": "Maximum forecast accuracy pct"
        },
        {
          "name": "total_new_orders",
          "expr": "SUM(new_orders)",
          "comment": "Total new orders"
        },
        {
          "name": "total_cancelled_orders",
          "expr": "SUM(cancelled_orders)",
          "comment": "Total cancelled orders"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The customer_orders_metrics view (source: customer_orders) has dimensions: order_date, product_family, customer_region, order_status. Measures: total_order_revenue, total_order_quantity, total_orders, avg_lead_time. The demand_kpi_metrics view (source: demand_kpi_monthly) has dimensions: kpi_month, product_family. Measures: avg_forecast_accuracy, avg_fill_rate, total_backlog, total_revenue. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. equipment_model).",
  "sample_questions": [
    "What is the monthly trend in unique total orderss?",
    "How has highest order quantity changed over time?",
    "What is the monthly trend in total order revenue in usd?",
    "How has total units ordered changed over time?",
    "What is the monthly trend in highest forecast accuracy percent?",
    "How has total backlog units changed over time?",
    "What is the monthly trend in total monthly revenue?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total order revenue in usd?",
      "sql_lines": [
        "SELECT order_date, MEASURE(total_order_revenue) AS total_order_revenue",
        "FROM {fqn}.customer_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ]
    },
    {
      "question": "How has total units ordered changed over time?",
      "sql_lines": [
        "SELECT order_date, MEASURE(total_order_quantity) AS total_order_quantity",
        "FROM {fqn}.customer_orders_metrics",
        "GROUP BY ALL",
        "ORDER BY order_date"
      ]
    },
    {
      "question": "What is the monthly trend in total monthly revenue?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(total_revenue) AS total_revenue",
        "FROM {fqn}.demand_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ]
    },
    {
