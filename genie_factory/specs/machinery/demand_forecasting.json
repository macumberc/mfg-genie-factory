        {
          "name": "unit_price_usd",
          "sql_type": "DOUBLE",
          "comment": "Price per unit in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(5000.0 + ({qty_noise} * 495000.0), 2)"
        },
        {
          "name": "customer_region",
          "sql_type": "STRING",
          "comment": "Customer region",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'Americas' WHEN {status_noise} < 0.50 THEN 'EMEA' WHEN {status_noise} < 0.75 THEN 'APAC' ELSE 'LATAM' END"
        },
        {
          "name": "order_status",
          "sql_type": "STRING",
          "comment": "Status: Confirmed, Shipped, Backlog, Cancelled",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.04 THEN 'Cancelled' WHEN {status_noise} < 0.20 THEN 'Backlog' WHEN {status_noise} < 0.35 THEN 'Confirmed' ELSE 'Shipped' END"
        },
        {
          "name": "lead_time_days",
          "sql_type": "INT",
          "comment": "Promised lead time in days",
          "is_dimension": false,
          "generation_expr": "CAST(14 + FLOOR({qty_noise} * 166) AS INT)"
