          "name": "forecasted_units",
          "sql_type": "INT",
          "comment": "Forecasted demand units",
          "is_dimension": false,
          "generation_expr": "CAST(5 + FLOOR({qty_noise} * 95) AS INT)"
        },
        {
          "name": "actual_units",
          "sql_type": "INT",
          "comment": "Actual units ordered",
          "is_dimension": false,
          "generation_expr": "CAST(GREATEST(0, (5 + FLOOR({qty_noise} * 95)) * (0.75 + {status_noise} * 0.50)) AS INT)"
        },
        {
          "name": "forecast_bias",
          "sql_type": "DOUBLE",
          "comment": "Forecast bias (positive = over-forecast)",
          "is_dimension": false,
          "generation_expr": "ROUND(-15.0 + ({qty_noise} * 30.0), 1)"
        },
        {
          "name": "mape_pct",
          "sql_type": "DOUBLE",
          "comment": "Mean absolute percentage error",
          "is_dimension": false,
          "generation_expr": "ROUND(2.0 + ({qty_noise} * 28.0), 2)"
        },
        {
          "name": "model_version",
          "sql_type": "STRING",
          "comment": "Forecast model version",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'v4.0' WHEN {status_noise} < 0.60 THEN 'v4.1' ELSE 'v4.2' END"
        },
        {
          "name": "confidence_interval_pct",
          "sql_type": "DOUBLE",
          "comment": "Forecast confidence interval width",
          "is_dimension": false,
          "generation_expr": "ROUND(5.0 + ({qty_noise} * 35.0), 1)"
        }
