  "use_case": "Machining process defect detection and tool wear monitoring",
  "space_title": "PrecisionEdge Corp - Machining Defect Detection ⚙️",
  "space_description": "Machining analytics for PrecisionEdge. Ask about defect rates, tool wear progression, surface finish quality, and defect KPIs across 20 CNC machines.",
  "schema_basename": "mach_machining_defect",
  "tables": [
    {
      "table_name": "machining_events",
      "description": "Individual machining operation records with part quality measurements, cycle times, and defect flags.",
      "columns": [
        {
          "name": "event_id",
          "sql_type": "STRING",
          "comment": "Unique machining event identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('ME-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "event_date",
          "sql_type": "DATE",
          "comment": "Date of machining operation",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "machine_id",
          "sql_type": "STRING",
          "comment": "CNC machine identifier",
          "is_dimension": true,
          "generation_expr": "",
          "entity_values": [
            "PE-5AX-001",
            "PE-5AX-002",
            "PE-5AX-003",
