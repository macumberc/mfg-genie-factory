  "metric_views": [
    {
      "view_name": "machining_events_metrics",
      "source_table": "machining_events",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "machine_model",
          "expr": "machine_model"
        },
        {
          "name": "operation_type",
          "expr": "operation_type"
        },
        {
          "name": "defect_type",
          "expr": "defect_type"
        }
      ],
      "measures": [
        {
          "name": "total_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total machining events"
        },
        {
          "name": "defect_count",
          "expr": "COUNT(DISTINCT CASE WHEN defect_detected = true THEN event_id END)",
          "comment": "Total defective parts detected"
        },
        {
          "name": "avg_surface_finish",
          "expr": "AVG(surface_finish_um)",
          "comment": "Average surface roughness Ra in um"
        },
