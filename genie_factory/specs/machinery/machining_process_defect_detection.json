  "example_sqls": [
    {
      "question": "What is the monthly trend in unique machines?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', event_date) AS event_date_month, MEASURE(unique_machine_count) AS unique_machine_count",
        "FROM {fqn}.machining_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date_month"
      ],
      "usage_guidance": "Monthly trend of unique active machines from machining_events_metrics; matches questions about machine count over time by event date."
    },
    {
      "question": "How has highest surface finish um changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(max_surface_finish_um) AS max_surface_finish_um",
        "FROM {fqn}.machining_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ],
      "usage_guidance": "Time-series trend of peak surface finish (µm) from machining_events_metrics; matches questions about worst or highest surface roughness over time."
    },
    {
      "question": "How has unique machines changed over time?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(unique_machine_count) AS unique_machine_count",
        "FROM {fqn}.defect_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly trend of unique active machines from defect_kpi_metrics; matches questions about machine count over time by KPI month."
    },
    {
      "question": "What is the trend of total surface roughness ra in micrometers over time?",
      "sql_lines": [
        "SELECT event_date, SUM(surface_finish_um) AS total_surface_finish_um",
        "FROM {fqn}.machining_events",
        "GROUP BY event_date ORDER BY event_date"
      ],
      "usage_guidance": "Cumulative surface roughness Ra (µm) trend over time from raw machining_events; matches questions about total surface finish values by event date."
    },
    {
      "question": "What is the trend of total flank wear measurement in mm over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(flank_wear_mm) AS total_flank_wear_mm",
        "FROM {fqn}.tool_wear_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of total flank wear (mm) from tool_wear_snapshots; matches questions about cumulative or total tool flank wear progression over time."
    },
    {
      "question": "How has the average defect rate percentage changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(defect_rate_pct) AS avg_defect_rate_pct",
