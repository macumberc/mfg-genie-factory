        {
          "name": "machine_model",
          "sql_type": "STRING",
          "comment": "CNC machine model",
          "is_dimension": true,
          "generation_expr": "",
          "entity_values": [
            "5-Axis CNC",
            "CNC Lathe",
            "CNC Mill",
            "Surface Grinder",
            "CNC Drill"
          ],
          "synonyms": [
            "equipment type",
            "cnc series",
            "machine type"
          ]
        },
        {
          "name": "operation_type",
          "sql_type": "STRING",
          "comment": "Machining operation: Milling, Turning, Drilling, Grinding, Boring",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'Milling' WHEN {status_noise} < 0.45 THEN 'Turning' WHEN {status_noise} < 0.65 THEN 'Drilling' WHEN {status_noise} < 0.82 THEN 'Grinding' ELSE 'Boring' END",
          "entity_values": [
            "Milling",
            "Turning",
            "Drilling",
            "Grinding",
            "Boring"
          ]
        },
        {
          "name": "surface_finish_um",
          "sql_type": "DOUBLE",
          "comment": "Surface roughness Ra in micrometers",
          "is_dimension": false,
          "generation_expr": "ROUND(0.2 + ({qty_noise} * 6.3), 2)"
        },
        {
          "name": "dimensional_deviation_mm",
          "sql_type": "DOUBLE",
          "comment": "Deviation from nominal dimension in mm",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 0.15, 4)"
        },
        {
          "name": "cycle_time_sec",
          "sql_type": "DOUBLE",
          "comment": "Machining cycle time in seconds",
          "is_dimension": false,
          "generation_expr": "ROUND(30.0 + ({qty_noise} * 270.0), 1)"
        },
        {
          "name": "defect_detected",
          "sql_type": "BOOLEAN",
          "comment": "Whether a defect was detected",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.08 THEN true ELSE false END"
        },
        {
          "name": "defect_type",
          "sql_type": "STRING",
          "comment": "Defect type: Surface Scratch, Burr, Chatter Mark, Dimensional OOT, Tool Mark, None",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.92 THEN 'None' WHEN {status_noise} < 0.935 THEN 'Surface Scratch' WHEN {status_noise} < 0.95 THEN 'Burr' WHEN {status_noise} < 0.965 THEN 'Chatter Mark' WHEN {status_noise} < 0.98 THEN 'Dimensional OOT' ELSE 'Tool Mark' END",
          "entity_values": [
            "None",
            "Surface Scratch",
            "Burr",
            "Chatter Mark",
            "Dimensional OOT",
            "Tool Mark"
          ]
        }
      ],
