  "metric_views": [
    {
      "view_name": "parts_transactions_metrics",
      "source_table": "parts_transactions",
      "dimensions": [
        {
          "name": "txn_date",
          "expr": "txn_date"
        },
        {
          "name": "part_category",
          "expr": "part_category"
        },
        {
          "name": "txn_type",
          "expr": "txn_type"
        },
        {
          "name": "warehouse",
          "expr": "warehouse"
        }
      ],
      "measures": [
        {
          "name": "total_issued_qty",
          "expr": "SUM(CASE WHEN txn_type = 'Issue' THEN quantity ELSE 0 END)",
          "comment": "Total parts issued"
        },
        {
          "name": "total_received_qty",
          "expr": "SUM(CASE WHEN txn_type = 'Receipt' THEN quantity ELSE 0 END)",
          "comment": "Total parts received"
        },
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT txn_id)",
          "comment": "Total transactions"
        },
        {
          "name": "emergency_issues",
          "expr": "COUNT(DISTINCT CASE WHEN urgency = 'Emergency' THEN txn_id END)",
          "comment": "Emergency issue transactions"
        },
        {
          "name": "total_unit_cost",
          "expr": "SUM(unit_cost_usd)",
          "comment": "Total unit cost usd"
        },
        {
          "name": "max_quantity",
          "expr": "MAX(quantity)",
          "comment": "Maximum quantity"
        }
      ]
    },
    {
      "view_name": "inventory_kpi_metrics",
      "source_table": "inventory_kpi_monthly",
      "dimensions": [
        {
          "name": "kpi_month",
          "expr": "kpi_month"
        },
        {
          "name": "part_category",
          "expr": "part_category"
        }
      ],
      "measures": [
        {
          "name": "avg_turnover",
          "expr": "AVG(turnover_ratio)",
          "comment": "Average inventory turnover ratio"
        },
        {
          "name": "avg_fill_rate",
          "expr": "AVG(fill_rate_pct)",
          "comment": "Average fill rate percentage"
        },
        {
          "name": "total_stockouts",
          "expr": "SUM(stockout_events)",
          "comment": "Total stockout events"
        },
        {
          "name": "total_carrying_cost",
          "expr": "SUM(carrying_cost_usd)",
          "comment": "Total carrying cost in USD"
        },
        {
          "name": "total_avg_lead_time_days",
          "expr": "SUM(avg_lead_time_days)",
          "comment": "Total avg lead time days"
        },
        {
          "name": "max_turnover_ratio",
          "expr": "MAX(turnover_ratio)",
          "comment": "Maximum turnover ratio"
        },
        {
          "name": "total_emergency_orders",
          "expr": "SUM(emergency_orders)",
          "comment": "Total emergency orders"
        }
      ]
    }
  ],
  "genie_instructions": "You are a machinery analytics assistant for PartsVault Industrial. Answer questions about spare parts inventory optimization and demand planning using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (part_number), query the base tables directly.\n- When joining tables, use the shared keys: part_number (shared across inventory_kpi_monthly, inventory_snapshots, parts_transactions).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in total issued qty count?",
    "How has total received qty count changed over time?",
    "What is the monthly trend in emergency issues count?",
    "How has unique total transactionss changed over time?",
    "What is the monthly trend in highest turnover ratio?",
    "How has total stockout events changed over time?",
    "What is the monthly trend in total carrying cost in usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in emergency issues count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', txn_date) AS txn_date_month, MEASURE(emergency_issues) AS emergency_issues",
        "FROM {fqn}.parts_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date_month"
      ],
      "usage_guidance": "Monthly trend analysis of emergency parts issues count; triggered by phrases like 'urgent issue spikes' or 'emergency demand over time' using emergency_issues measure."
    },
    {
      "question": "How has unique total transactionss changed over time?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.parts_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ],
      "usage_guidance": "Time-series trend of total transaction volume across all types; triggered by 'transaction activity over time' or 'how busy is parts movement' using total_transactions measure."
    },
    {
      "question": "What is the monthly trend in total carrying cost in usd?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', kpi_month) AS kpi_month_month, MEASURE(total_carrying_cost) AS total_carrying_cost",
        "FROM {fqn}.inventory_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month_month"
      ],
      "usage_guidance": "Monthly trend of inventory carrying cost in USD; triggered by 'storage cost trends' or 'how much are we spending to hold inventory' using total_carrying_cost measure."
    },
    {
      "question": "How has total avg lead time days changed over time?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(total_avg_lead_time_days) AS total_avg_lead_time_days",
        "FROM {fqn}.inventory_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ],
      "usage_guidance": "Time-series trend of average supplier lead times in days; triggered by 'lead time changes over time' or 'are suppliers getting faster' using total_avg_lead_time_days measure."
    },
    {
      "question": "What is the trend of total transaction quantity over time?",
      "sql_lines": [
        "SELECT txn_date, SUM(quantity) AS total_quantity",
        "FROM {fqn}.parts_transactions",
        "GROUP BY txn_date ORDER BY txn_date"
      ],
      "usage_guidance": "Time-series trend of raw transaction quantities from parts_transactions table; triggered by 'parts movement volume' or 'how many units were transacted each day'."
    },
    {
      "question": "What is the trend of total quantity on hand over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(on_hand_qty) AS total_on_hand_qty",
        "FROM {fqn}.inventory_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Time-series trend of total on-hand inventory quantity from snapshots; triggered by 'stock levels over time' or 'how has our physical inventory changed' using on_hand_qty."
    },
    {
      "question": "How has the average inventory turnover ratio changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(turnover_ratio) AS avg_turnover_ratio",
        "FROM {fqn}.inventory_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly trend of average inventory turnover ratio from KPI table; triggered by 'how efficiently are we cycling inventory' or 'turnover rate changes over time'."
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "inventory_snapshots.stockout_risk = 'High'",
        "display_name": "high stockout risk",
        "synonyms": [
          "at risk",
          "critical stock",
          "critical shortage"
        ],
        "instruction": "Use when identifying parts at risk of stockout."
      },
      {
        "sql": "parts_transactions.urgency = 'Emergency'",
        "display_name": "emergency transactions",
        "synonyms": [
          "emergency orders",
          "rush orders",
          "urgent issues"
        ],
        "instruction": "Use when analyzing emergency part requests."
      },
      {
        "sql": "parts_transactions.txn_type = 'Issue'",
        "display_name": "parts issued",
        "synonyms": [
          "consumption",
          "usage",
          "consumed parts"
        ],
        "instruction": "Use when analyzing parts consumed from inventory."
      }
    ],
    "expressions": [
      {
        "alias": "txn_month",
        "sql": "DATE_TRUNC('month', parts_transactions.txn_date)",
        "display_name": "transaction month",
        "synonyms": [
          "monthly",
          "issue month",
          "activity month"
        ]
      },
      {
        "alias": "stock_coverage",
        "sql": "inventory_snapshots.on_hand_qty - inventory_snapshots.reorder_point",
        "display_name": "stock above reorder point",
        "synonyms": [
          "buffer",
          "safety stock",
          "buffer above reorder"
        ]
      },
      {
        "alias": "txn_value",
        "sql": "parts_transactions.quantity * parts_transactions.unit_cost_usd",
        "display_name": "transaction value",
        "synonyms": [
          "cost",
          "value",
          "line value"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_issued",
        "sql": "SUM(CASE WHEN parts_transactions.txn_type = 'Issue' THEN parts_transactions.quantity ELSE 0 END)",
        "display_name": "total parts issued",
        "synonyms": [
          "consumption",
          "usage",
          "total consumed"
        ]
      },
      {
        "alias": "total_carrying_cost",
        "sql": "SUM(inventory_kpi_monthly.carrying_cost_usd)",
        "display_name": "total carrying cost",
        "synonyms": [
          "holding cost",
          "storage expense",
          "inventory overhead"
        ]
      },
      {
        "alias": "avg_fill_rate",
        "sql": "AVG(inventory_kpi_monthly.fill_rate_pct)",
        "display_name": "average fill rate",
        "synonyms": [
          "fill rate",
          "service level",
          "demand satisfaction"
        ]
      },
      {
        "alias": "total_stockouts",
        "sql": "SUM(inventory_kpi_monthly.stockout_events)",
        "display_name": "total stockouts",
        "synonyms": [
          "stockout count",
          "shortage events",
          "out-of-stock count"
        ]
      }
    ]
  },
  "benchmarks": [
    {
      "question": "What is the monthly trend in total issued qty count?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', txn_date) AS txn_date_month, MEASURE(total_issued_qty) AS total_issued_qty",
        "FROM {fqn}.parts_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date_month"
      ]
    },
    {
      "question": "How has total received qty count changed over time?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(total_received_qty) AS total_received_qty",
        "FROM {fqn}.parts_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ]
    },
    {
      "question": "What is the monthly trend in highest turnover ratio?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', kpi_month) AS kpi_month_month, MEASURE(max_turnover_ratio) AS max_turnover_ratio",
        "FROM {fqn}.inventory_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month_month"
      ]
    },
    {
      "question": "How has total stockout events changed over time?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(total_stockouts) AS total_stockouts",
        "FROM {fqn}.inventory_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ]
    },
    {
      "question": "What are the top 10 spare part number by total transaction quantity?",
      "sql_lines": [
        "SELECT part_number, SUM(quantity) AS total_quantity",
        "FROM {fqn}.parts_transactions",
        "GROUP BY part_number ORDER BY total_quantity DESC LIMIT 10"
      ]
    },
    {
      "question": "How many records are there per snapshot date?",
      "sql_lines": [
        "SELECT snapshot_date, COUNT(*) AS record_count",
        "FROM {fqn}.inventory_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ]
    },
    {
      "question": "How many records are there per month of kpi record?",
      "sql_lines": [
        "SELECT kpi_month, COUNT(*) AS record_count",
        "FROM {fqn}.inventory_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ]
    }
  ]
