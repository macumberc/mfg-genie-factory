      "table_name": "parts_transactions",
      "description": "Spare part consumption and replenishment transactions.",
      "columns": [
        {
          "name": "txn_id",
          "sql_type": "STRING",
          "comment": "Unique transaction identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('PT-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "txn_date",
          "sql_type": "DATE",
          "comment": "Transaction date",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "part_number",
          "sql_type": "STRING",
          "comment": "Spare part number",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "part_category",
          "sql_type": "STRING",
          "comment": "Part category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "txn_type",
          "sql_type": "STRING",
          "comment": "Transaction type: Issue, Receipt, Return, Scrap",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'Issue' WHEN {status_noise} < 0.85 THEN 'Receipt' WHEN {status_noise} < 0.95 THEN 'Return' ELSE 'Scrap' END"
        },
        {
          "name": "quantity",
          "sql_type": "INT",
          "comment": "Transaction quantity",
          "is_dimension": false,
          "generation_expr": "CAST(1 + FLOOR({qty_noise} * 49) AS INT)"
        },
        {
          "name": "unit_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Unit cost in USD",
          "is_dimension": false,
          "generation_expr": ""
        },
        {
          "name": "warehouse",
          "sql_type": "STRING",
          "comment": "Warehouse location",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'WH-Central' WHEN {status_noise} < 0.55 THEN 'WH-East' WHEN {status_noise} < 0.80 THEN 'WH-West' ELSE 'WH-South' END"
        },
        {
          "name": "work_order_ref",
          "sql_type": "STRING",
          "comment": "Reference work order if applicable",
          "is_dimension": false,
          "generation_expr": "CONCAT('WO-', LPAD(CAST(FLOOR({qty_noise} * 5000) AS STRING), 5, '0'))"
        },
        {
          "name": "urgency",
          "sql_type": "STRING",
          "comment": "Urgency: Normal, Urgent, Emergency",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.70 THEN 'Normal' WHEN {status_noise} < 0.90 THEN 'Urgent' ELSE 'Emergency' END"
        }
