  "metric_views": [
    {
      "view_name": "parts_transactions_metrics",
      "source_table": "parts_transactions",
      "dimensions": [
        {
          "name": "txn_date",
          "expr": "txn_date"
        },
        {
          "name": "part_category",
          "expr": "part_category"
        },
        {
          "name": "txn_type",
          "expr": "txn_type"
        },
        {
          "name": "warehouse",
          "expr": "warehouse"
        }
      ],
      "measures": [
        {
          "name": "total_issued_qty",
          "expr": "SUM(CASE WHEN txn_type = 'Issue' THEN quantity ELSE 0 END)",
          "comment": "Total parts issued"
        },
        {
          "name": "total_received_qty",
          "expr": "SUM(CASE WHEN txn_type = 'Receipt' THEN quantity ELSE 0 END)",
