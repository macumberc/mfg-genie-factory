  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The parts_transactions_metrics view (source: parts_transactions) has dimensions: txn_date, part_category, txn_type, warehouse. Measures: total_issued_qty, total_received_qty, total_transactions, emergency_issues. The inventory_kpi_metrics view (source: inventory_kpi_monthly) has dimensions: kpi_month, part_category. Measures: avg_turnover, avg_fill_rate, total_stockouts, total_carrying_cost. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. part_number).",
  "sample_questions": [
    "What is the monthly trend in total issued qty count?",
    "How has total received qty count changed over time?",
    "What is the monthly trend in emergency issues count?",
    "How has unique total transactionss changed over time?",
    "What is the monthly trend in highest turnover ratio?",
    "How has total stockout events changed over time?",
    "What is the monthly trend in total carrying cost in usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in emergency issues count?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(emergency_issues) AS emergency_issues",
        "FROM {fqn}.parts_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ]
    },
    {
      "question": "How has unique total transactionss changed over time?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.parts_transactions_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ]
    },
    {
      "question": "What is the monthly trend in total carrying cost in usd?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(total_carrying_cost) AS total_carrying_cost",
        "FROM {fqn}.inventory_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ]
    },
    {
      "question": "How has total avg lead time days changed over time?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(total_avg_lead_time_days) AS total_avg_lead_time_days",
        "FROM {fqn}.inventory_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ]
    },
    {
      "question": "What is the trend of total transaction quantity over time?",
      "sql_lines": [
        "SELECT txn_date, SUM(quantity) AS total_quantity",
        "FROM {fqn}.parts_transactions",
        "GROUP BY txn_date ORDER BY txn_date"
      ]
    },
    {
      "question": "What is the trend of total quantity on hand over time?",
      "sql_lines": [
