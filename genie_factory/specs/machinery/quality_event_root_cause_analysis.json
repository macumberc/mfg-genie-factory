  "tables": [
    {
      "table_name": "quality_events",
      "description": "Individual quality event records with defect type, root cause, and impact assessment.",
      "columns": [
        {
          "name": "event_id",
          "sql_type": "STRING",
          "comment": "Unique quality event identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('QE-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "event_date",
          "sql_type": "DATE",
          "comment": "Date of quality event",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "product_line",
          "sql_type": "STRING",
          "comment": "Product line identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "product_category",
          "sql_type": "STRING",
          "comment": "Product category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "defect_type",
          "sql_type": "STRING",
          "comment": "Defect classification",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'Dimensional' WHEN {status_noise} < 0.38 THEN 'Surface Finish' WHEN {status_noise} < 0.54 THEN 'Material' WHEN {status_noise} < 0.68 THEN 'Assembly' WHEN {status_noise} < 0.80 THEN 'Weld' WHEN {status_noise} < 0.90 THEN 'Coating' ELSE 'Functional' END"
        },
        {
          "name": "root_cause",
          "sql_type": "STRING",
          "comment": "Root cause category",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.18 THEN 'Operator Error' WHEN {status_noise} < 0.35 THEN 'Machine Drift' WHEN {status_noise} < 0.50 THEN 'Material Defect' WHEN {status_noise} < 0.64 THEN 'Process Parameter' WHEN {status_noise} < 0.76 THEN 'Tooling Wear' WHEN {status_noise} < 0.88 THEN 'Design Issue' ELSE 'Environmental' END"
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Severity: Minor, Major, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.50 THEN 'Minor' WHEN {status_noise} < 0.82 THEN 'Major' ELSE 'Critical' END"
        },
        {
          "name": "units_affected",
          "sql_type": "INT",
          "comment": "Number of units affected",
          "is_dimension": false,
          "generation_expr": "CAST(1 + FLOOR({qty_noise} * 499) AS INT)"
        },
        {
          "name": "cost_impact_usd",
          "sql_type": "DOUBLE",
          "comment": "Total cost impact in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(500.0 + ({qty_noise} * 49500.0), 2)"
        },
        {
          "name": "capa_status",
          "sql_type": "STRING",
          "comment": "CAPA status: Open, In Progress, Closed, Verified",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Open' WHEN {status_noise} < 0.40 THEN 'In Progress' WHEN {status_noise} < 0.75 THEN 'Closed' ELSE 'Verified' END"
        }
      ],
