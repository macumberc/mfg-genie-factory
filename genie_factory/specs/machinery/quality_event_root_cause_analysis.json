  "metric_views": [
    {
      "view_name": "quality_events_metrics",
      "source_table": "quality_events",
      "dimensions": [
        {
          "name": "event_date",
          "expr": "event_date"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        },
        {
          "name": "defect_type",
          "expr": "defect_type"
        },
        {
          "name": "root_cause",
          "expr": "root_cause"
        },
        {
          "name": "severity",
          "expr": "severity"
        }
      ],
      "measures": [
        {
          "name": "total_events",
          "expr": "COUNT(DISTINCT event_id)",
          "comment": "Total quality events"
        },
        {
          "name": "total_cost_impact",
          "expr": "SUM(cost_impact_usd)",
          "comment": "Total cost impact in USD"
        },
        {
          "name": "total_units_affected",
          "expr": "SUM(units_affected)",
          "comment": "Total units affected"
        },
        {
          "name": "critical_event_count",
          "expr": "COUNT(DISTINCT CASE WHEN severity = 'Critical' THEN event_id END)",
          "comment": "Critical quality events"
        },
        {
          "name": "open_quality_event_count",
          "expr": "COUNT(DISTINCT CASE WHEN capa_status = 'Open' THEN event_id END)",
          "comment": "Count where capa status is Open"
        },
        {
          "name": "max_units_affected",
          "expr": "MAX(units_affected)",
          "comment": "Maximum units affected"
        }
      ]
    },
    {
      "view_name": "quality_kpi_metrics",
      "source_table": "quality_kpi_monthly",
      "dimensions": [
        {
          "name": "kpi_month",
          "expr": "kpi_month"
        },
        {
          "name": "product_category",
          "expr": "product_category"
        }
      ],
      "measures": [
        {
          "name": "avg_defect_ppm",
          "expr": "AVG(defect_ppm)",
          "comment": "Average defect rate in PPM"
        },
        {
          "name": "total_copq",
          "expr": "SUM(copq_usd)",
          "comment": "Total cost of poor quality"
        },
        {
          "name": "avg_capa_closure",
          "expr": "AVG(capa_closure_rate_pct)",
          "comment": "Average CAPA closure rate"
        },
        {
          "name": "avg_fpy",
          "expr": "AVG(first_pass_yield_pct)",
          "comment": "Average first-pass yield"
        },
        {
          "name": "max_defect_ppm",
          "expr": "MAX(defect_ppm)",
          "comment": "Maximum defect ppm"
        },
        {
          "name": "total_customer_complaints",
          "expr": "SUM(customer_complaints)",
          "comment": "Total customer complaints"
        },
        {
          "name": "total_audit_findings",
          "expr": "SUM(audit_findings)",
          "comment": "Total audit findings"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The quality_events_metrics view (source: quality_events) has dimensions: event_date, product_category, defect_type, root_cause, severity. Measures: total_events, total_cost_impact, total_units_affected, critical_event_count. The quality_kpi_metrics view (source: quality_kpi_monthly) has dimensions: kpi_month, product_category. Measures: avg_defect_ppm, total_copq, avg_capa_closure, avg_fpy. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. product_line).",
  "sample_questions": [
    "What is the monthly trend in critical event count?",
    "How has open capa status count changed over time?",
    "What is the monthly trend in unique total eventss?",
    "How has highest units affected changed over time?",
    "What is the monthly trend in highest defect ppm?",
    "How has total cost of poor quality changed over time?",
    "What is the monthly trend in total customer complaints?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total eventss?",
      "sql_lines": [
        "SELECT event_date, MEASURE(total_events) AS total_events",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
    {
      "question": "How has highest units affected changed over time?",
      "sql_lines": [
        "SELECT event_date, MEASURE(max_units_affected) AS max_units_affected",
        "FROM {fqn}.quality_events_metrics",
        "GROUP BY ALL",
        "ORDER BY event_date"
      ]
    },
