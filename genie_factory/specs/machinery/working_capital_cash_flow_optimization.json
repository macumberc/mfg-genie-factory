        },
        {
          "name": "direction",
          "expr": "direction"
        }
      ],
      "measures": [
        {
          "name": "total_inflow",
          "expr": "SUM(CASE WHEN direction = 'Inflow' THEN amount_usd ELSE 0 END)",
          "comment": "Total cash inflows"
        },
        {
          "name": "total_outflow",
          "expr": "SUM(CASE WHEN direction = 'Outflow' THEN amount_usd ELSE 0 END)",
          "comment": "Total cash outflows"
        },
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT txn_id)",
          "comment": "Total transactions"
        },
        {
          "name": "avg_days_outstanding",
          "expr": "AVG(days_outstanding)",
          "comment": "Average days outstanding"
        },
        {
          "name": "unique_business_unit_count",
          "expr": "COUNT(DISTINCT business_unit_id)",
          "comment": "Number of distinct business units"
        },
        {
          "name": "max_amount",
          "expr": "MAX(amount_usd)",
          "comment": "Maximum amount usd"
        },
        {
          "name": "total_payment_terms_days",
          "expr": "SUM(payment_terms_days)",
          "comment": "Total payment terms days"
        }
      ]
    },
