  "metric_views": [
    {
      "view_name": "cash_flow_txn_metrics",
      "source_table": "cash_flow_transactions",
      "dimensions": [
        {
          "name": "txn_date",
          "expr": "txn_date"
        },
        {
          "name": "business_unit_type",
          "expr": "business_unit_type"
