          "sql_type": "STRING",
          "comment": "Type: AR Collection, AP Payment, Capex, Operating Expense, Revenue",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'AR Collection' WHEN {status_noise} < 0.45 THEN 'AP Payment' WHEN {status_noise} < 0.55 THEN 'Capex' WHEN {status_noise} < 0.75 THEN 'Operating Expense' ELSE 'Revenue' END",
          "entity_values": [
            "AR Collection",
            "AP Payment",
            "Capex",
            "Operating Expense",
            "Revenue"
          ]
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Transaction amount in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(1000.0 + ({qty_noise} * 499000.0), 2)"
        },
        {
          "name": "direction",
          "sql_type": "STRING",
          "comment": "Cash direction: Inflow or Outflow",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.45 THEN 'Inflow' ELSE 'Outflow' END",
          "entity_values": [
            "Inflow",
            "Outflow"
          ]
        },
        {
          "name": "payment_terms_days",
          "sql_type": "INT",
          "comment": "Payment terms in days",
          "is_dimension": false,
          "generation_expr": "CAST(CASE WHEN {status_noise} < 0.25 THEN 30 WHEN {status_noise} < 0.55 THEN 45 WHEN {status_noise} < 0.80 THEN 60 ELSE 90 END AS INT)"
        },
        {
          "name": "days_outstanding",
          "sql_type": "INT",
          "comment": "Days the amount was outstanding",
          "is_dimension": false,
          "generation_expr": "CAST(5 + FLOOR({qty_noise} * 85) AS INT)"
        },
        {
          "name": "currency",
          "sql_type": "STRING",
          "comment": "Transaction currency",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.60 THEN 'USD' WHEN {status_noise} < 0.80 THEN 'EUR' WHEN {status_noise} < 0.92 THEN 'GBP' ELSE 'JPY' END",
          "entity_values": [
            "USD",
            "EUR",
            "GBP",
            "JPY"
          ]
        }
