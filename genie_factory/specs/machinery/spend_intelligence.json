  "genie_instructions": "You are a machinery analytics assistant for SpendLens Manufacturing. Answer questions about procurement spend intelligence and supplier performance analytics using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (supplier_id), query the base tables directly.\n- When joining tables, use the shared keys: supplier_id (shared across procurement_transactions, spend_kpi_monthly, supplier_snapshots).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in maverick po count?",
    "How has late delivery count changed over time?",
    "What is the monthly trend in unique total pos?",
    "How has unique suppliers changed over time?",
    "What is the monthly trend in unique suppliers?",
    "How has highest total spend changed over time?",
    "What is the monthly trend in total procurement spend?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in unique total pos?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', po_date) AS po_date_month, MEASURE(total_po_count) AS total_po_count",
        "FROM {fqn}.procurement_metrics",
        "GROUP BY ALL",
        "ORDER BY po_date_month"
      ],
      "usage_guidance": "Monthly trend of purchase order volume; user asks about PO count, order frequency, or procurement activity over time using procurement_metrics."
    },
    {
      "question": "How has unique suppliers changed over time?",
      "sql_lines": [
        "SELECT po_date, MEASURE(unique_supplier_count) AS unique_supplier_count",
        "FROM {fqn}.procurement_metrics",
        "GROUP BY ALL",
        "ORDER BY po_date"
      ],
      "usage_guidance": "Time-series of supplier base size; user asks how supplier count or vendor diversity evolved over time using procurement_metrics."
    },
    {
      "question": "What is the monthly trend in total procurement spend?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', kpi_month) AS kpi_month_month, MEASURE(total_spend) AS total_spend",
        "FROM {fqn}.spend_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month_month"
      ],
      "usage_guidance": "Monthly procurement spend trend; user asks about total spend, expenditure over time, or budget consumption trends using spend_kpi_metrics."
    },
    {
      "question": "What is the monthly trend in total supplier diversity pct?",
      "sql_lines": [
        "SELECT DATE_TRUNC('month', kpi_month) AS kpi_month_month, MEASURE(total_supplier_diversity_percent) AS total_supplier_diversity_percent",
        "FROM {fqn}.spend_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month_month"
      ],
      "usage_guidance": "Monthly supplier diversity percentage trend; user asks how diverse or minority supplier spend share changed over time using spend_kpi_metrics."
    },
    {
      "question": "How does total purchase order amount in usd break down by supplier for 'On Time' records?",
      "sql_lines": [
        "SELECT supplier_id, COUNT(*) AS record_count, SUM(po_amount_usd) AS total_po_amount_usd",
        "FROM {fqn}.procurement_transactions",
        "WHERE delivery_status = 'On Time' GROUP BY supplier_id ORDER BY total_po_amount_usd DESC"
      ],
      "usage_guidance": "Filtered spend breakdown by supplier for on-time deliveries; user asks which suppliers received the most PO spend among punctual vendors."
    },
    {
      "question": "What is the trend of total average lead time in days over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(lead_time_days) AS total_lead_time_days",
        "FROM {fqn}.supplier_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Trend of average supplier lead time over snapshot dates; user asks how fulfillment speed or lead time days changed across suppliers over time."
    },
    {
      "question": "How has the average maverick (off-contract) spend percentage changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(maverick_spend_pct) AS avg_maverick_spend_pct",
        "FROM {fqn}.spend_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly maverick (off-contract) spend percentage trend; user asks how rogue or non-compliant purchasing behavior shifted over time using spend_kpi_monthly."
    }
  ],
