        {
          "name": "equipment_type",
          "sql_type": "STRING",
          "comment": "Equipment type category",
          "is_dimension": true,
          "generation_expr": "",
          "entity_values": [
            "Excavator",
            "Crane",
            "Generator",
            "Compressor",
            "Pump System"
          ]
        },
        {
          "name": "priority",
          "sql_type": "STRING",
          "comment": "Ticket priority: Low, Medium, High, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Low' WHEN {status_noise} < 0.65 THEN 'Medium' WHEN {status_noise} < 0.88 THEN 'High' ELSE 'Critical' END",
          "entity_values": [
            "Low",
            "Medium",
            "High",
            "Critical"
          ]
        },
        {
          "name": "issue_category",
          "sql_type": "STRING",
          "comment": "Issue category: Mechanical, Electrical, Hydraulic, Software, Preventive",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Mechanical' WHEN {status_noise} < 0.50 THEN 'Electrical' WHEN {status_noise} < 0.68 THEN 'Hydraulic' WHEN {status_noise} < 0.82 THEN 'Software' ELSE 'Preventive' END",
          "entity_values": [
            "Mechanical",
            "Electrical",
            "Hydraulic",
            "Software",
            "Preventive"
          ]
        },
        {
          "name": "resolution_hours",
          "sql_type": "DOUBLE",
          "comment": "Time to resolution in hours",
          "is_dimension": false,
          "generation_expr": "ROUND(1.0 + ({qty_noise} * 47.0), 1)"
        },
        {
          "name": "parts_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Parts cost for the service visit in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(50.0 + ({qty_noise} * 4950.0), 2)"
        },
        {
          "name": "labor_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Labor cost for the service visit in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(100.0 + ({qty_noise} * 2400.0), 2)"
        },
        {
          "name": "first_time_fix",
          "sql_type": "BOOLEAN",
          "comment": "Whether the issue was resolved on the first visit",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.72 THEN true ELSE false END"
        }
      ],
