    {
      "table_name": "service_tickets",
      "description": "Individual field service ticket records with issue details, resolution times, and parts used.",
      "columns": [
        {
          "name": "ticket_id",
          "sql_type": "STRING",
          "comment": "Unique service ticket identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('ST-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "ticket_date",
          "sql_type": "DATE",
          "comment": "Date ticket was created",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "equipment_model",
          "sql_type": "STRING",
          "comment": "Equipment model at customer site",
          "is_dimension": true,
          "generation_expr": "",
          "entity_values": [
            "FF-EXC-100",
            "FF-EXC-200",
            "FF-EXC-300",
            "FF-EXC-400",
            "FF-CRN-100",
            "FF-CRN-200",
