  "metric_views": [
    {
      "view_name": "service_tickets_metrics",
      "source_table": "service_tickets",
      "dimensions": [
        {
          "name": "ticket_date",
          "expr": "ticket_date"
        },
        {
          "name": "equipment_type",
          "expr": "equipment_type"
        },
        {
          "name": "priority",
          "expr": "priority"
        },
        {
          "name": "issue_category",
          "expr": "issue_category"
        }
      ],
      "measures": [
        {
          "name": "total_tickets",
          "expr": "COUNT(DISTINCT ticket_id)",
          "comment": "Total service tickets"
        },
        {
          "name": "avg_resolution_hours",
          "expr": "AVG(resolution_hours)",
          "comment": "Average time to resolution in hours"
        },
        {
          "name": "total_service_cost",
          "expr": "SUM(parts_cost_usd + labor_cost_usd)",
          "comment": "Total service cost (parts + labor)"
        },
        {
          "name": "first_time_fix_count",
          "expr": "COUNT(DISTINCT CASE WHEN first_time_fix = true THEN ticket_id END)",
          "comment": "Tickets resolved on first visit"
        },
        {
          "name": "max_resolution_hours",
          "expr": "MAX(resolution_hours)",
          "comment": "Maximum resolution hours"
        }
      ]
    },
    {
      "view_name": "service_kpi_metrics",
      "source_table": "service_kpi_monthly",
      "dimensions": [
        {
          "name": "kpi_month",
          "expr": "kpi_month"
        },
        {
          "name": "equipment_type",
          "expr": "equipment_type"
        }
      ],
      "measures": [
        {
          "name": "avg_ftf_rate",
          "expr": "AVG(first_time_fix_rate_pct)",
          "comment": "Average first-time fix rate"
        },
        {
          "name": "avg_sla_compliance",
          "expr": "AVG(sla_compliance_pct)",
          "comment": "Average SLA compliance percentage"
        },
        {
          "name": "avg_cost_per_ticket",
          "expr": "AVG(avg_cost_per_ticket_usd)",
          "comment": "Average cost per service ticket"
        },
        {
          "name": "total_tickets_monthly",
          "expr": "SUM(total_tickets)",
          "comment": "Total tickets across all models"
        },
        {
          "name": "total_repeat_visit_percent",
          "expr": "SUM(repeat_visit_pct)",
          "comment": "Total repeat visit pct"
        },
