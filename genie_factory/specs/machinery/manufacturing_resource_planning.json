  "metric_views": [
    {
      "view_name": "work_orders_metrics",
      "source_table": "work_orders",
      "dimensions": [
        {
          "name": "wo_date",
          "expr": "wo_date"
        },
        {
          "name": "work_center_type",
          "expr": "work_center_type"
        },
        {
          "name": "wo_status",
          "expr": "wo_status"
        },
        {
          "name": "priority",
          "expr": "priority"
        }
      ],
      "measures": [
        {
          "name": "total_work_orders",
          "expr": "COUNT(DISTINCT wo_id)",
          "comment": "Total work orders"
        },
        {
          "name": "total_planned_hours",
          "expr": "SUM(planned_hours)",
          "comment": "Total planned hours"
        },
        {
          "name": "total_actual_hours",
          "expr": "SUM(actual_hours)",
          "comment": "Total actual hours consumed"
        },
        {
          "name": "total_completed_qty",
          "expr": "SUM(completed_qty)",
          "comment": "Total completed quantity"
        },
        {
          "name": "unique_work_center_count",
          "expr": "COUNT(DISTINCT work_center_id)",
          "comment": "Number of distinct work centers"
        },
        {
          "name": "max_planned_qty",
          "expr": "MAX(planned_qty)",
          "comment": "Maximum planned qty"
        },
        {
          "name": "total_planned_qty",
          "expr": "SUM(planned_qty)",
          "comment": "Total planned qty"
        }
      ]
    },
    {
      "view_name": "planning_kpi_metrics",
      "source_table": "planning_kpi_monthly",
      "dimensions": [
        {
          "name": "kpi_month",
          "expr": "kpi_month"
        },
        {
          "name": "work_center_type",
          "expr": "work_center_type"
        }
      ],
      "measures": [
        {
          "name": "avg_schedule_adherence",
          "expr": "AVG(schedule_adherence_pct)",
          "comment": "Average schedule adherence"
        },
        {
          "name": "total_throughput",
          "expr": "SUM(throughput_units)",
          "comment": "Total throughput units"
        },
        {
          "name": "avg_efficiency",
          "expr": "AVG(efficiency_pct)",
          "comment": "Average efficiency percentage"
        },
        {
          "name": "avg_on_time_completion",
          "expr": "AVG(on_time_completion_pct)",
          "comment": "Average on-time completion rate"
        },
        {
          "name": "total_scrap_rate_percent",
          "expr": "SUM(scrap_rate_pct)",
          "comment": "Total scrap rate pct"
        },
        {
          "name": "total_changeover_hours",
          "expr": "SUM(changeover_hours)",
          "comment": "Total changeover hours"
        },
        {
          "name": "unique_work_center_count",
          "expr": "COUNT(DISTINCT work_center_id)",
          "comment": "Number of distinct work centers"
        },
        {
          "name": "max_schedule_adherence_percent",
          "expr": "MAX(schedule_adherence_pct)",
          "comment": "Maximum schedule adherence pct"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The work_orders_metrics view (source: work_orders) has dimensions: wo_date, work_center_type, wo_status, priority. Measures: total_work_orders, total_planned_hours, total_actual_hours, total_completed_qty. The planning_kpi_metrics view (source: planning_kpi_monthly) has dimensions: kpi_month, work_center_type. Measures: avg_schedule_adherence, total_throughput, avg_efficiency, avg_on_time_completion. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. work_center_id).",
  "sample_questions": [
    "What is the monthly trend in unique total work orderss?",
    "How has unique work centers changed over time?",
    "What is the monthly trend in highest planned qty?",
    "How has total planned hours changed over time?",
    "What is the monthly trend in unique work centers?",
    "How has highest schedule adherence percent changed over time?",
    "What is the monthly trend in total throughput units?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest planned qty?",
      "sql_lines": [
        "SELECT wo_date, MEASURE(max_planned_qty) AS max_planned_qty",
