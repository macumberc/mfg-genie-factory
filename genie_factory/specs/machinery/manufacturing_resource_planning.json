      "table_name": "work_orders",
      "description": "Work order records with routing, quantities, and completion status.",
      "columns": [
        {
          "name": "wo_id",
          "sql_type": "STRING",
          "comment": "Unique work order identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('WO-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "wo_date",
          "sql_type": "DATE",
          "comment": "Work order creation date",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "work_center_id",
          "sql_type": "STRING",
          "comment": "Work center identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "work_center_type",
          "sql_type": "STRING",
          "comment": "Work center type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "wo_status",
          "sql_type": "STRING",
          "comment": "Status: Released, In Progress, Complete, On Hold",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.15 THEN 'Released' WHEN {status_noise} < 0.40 THEN 'In Progress' WHEN {status_noise} < 0.90 THEN 'Complete' ELSE 'On Hold' END"
        },
        {
          "name": "planned_qty",
          "sql_type": "INT",
          "comment": "Planned production quantity",
          "is_dimension": false,
          "generation_expr": "CAST(10 + FLOOR({qty_noise} * 490) AS INT)"
        },
        {
          "name": "completed_qty",
          "sql_type": "INT",
          "comment": "Completed quantity",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 500) AS INT)"
        },
        {
          "name": "planned_hours",
          "sql_type": "DOUBLE",
          "comment": "Planned labor/machine hours",
          "is_dimension": false,
          "generation_expr": "ROUND(2.0 + ({qty_noise} * 38.0), 1)"
        },
        {
          "name": "actual_hours",
          "sql_type": "DOUBLE",
          "comment": "Actual hours consumed",
          "is_dimension": false,
          "generation_expr": "ROUND(2.0 + ({qty_noise} * 46.0), 1)"
        },
        {
          "name": "priority",
          "sql_type": "STRING",
          "comment": "Priority: Low, Medium, High, Rush",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN 'Low' WHEN {status_noise} < 0.65 THEN 'Medium' WHEN {status_noise} < 0.90 THEN 'High' ELSE 'Rush' END"
        }
      ],
