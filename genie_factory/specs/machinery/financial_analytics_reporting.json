  "metric_views": [
    {
      "view_name": "financial_txn_metrics",
      "source_table": "financial_transactions",
      "dimensions": [
        {
          "name": "txn_date",
          "expr": "txn_date"
        },
        {
          "name": "cost_center_type",
          "expr": "cost_center_type"
        },
        {
          "name": "account_category",
          "expr": "account_category"
        }
      ],
      "measures": [
        {
          "name": "total_amount",
          "expr": "SUM(amount_usd)",
          "comment": "Total transaction amount"
        },
        {
          "name": "total_transactions",
          "expr": "COUNT(DISTINCT txn_id)",
          "comment": "Total transaction count"
        },
        {
          "name": "total_revenue",
          "expr": "SUM(CASE WHEN account_category = 'Revenue' THEN amount_usd ELSE 0 END)",
          "comment": "Total revenue"
        },
        {
          "name": "total_opex",
          "expr": "SUM(CASE WHEN account_category = 'Opex' THEN amount_usd ELSE 0 END)",
          "comment": "Total operating expenses"
        },
        {
          "name": "unique_cost_center_count",
          "expr": "COUNT(DISTINCT cost_center_id)",
          "comment": "Number of distinct cost centers"
        },
        {
          "name": "open_financial_transaction_count",
          "expr": "COUNT(DISTINCT CASE WHEN posting_status = 'Open' THEN txn_id END)",
          "comment": "Count where posting status is Open"
        },
        {
          "name": "max_amount",
          "expr": "MAX(amount_usd)",
          "comment": "Maximum amount usd"
        }
      ]
    },
    {
      "view_name": "financial_kpi_metrics",
      "source_table": "financial_kpi_monthly",
      "dimensions": [
        {
          "name": "kpi_month",
          "expr": "kpi_month"
        },
        {
          "name": "cost_center_type",
          "expr": "cost_center_type"
        }
      ],
      "measures": [
        {
          "name": "avg_gross_margin",
          "expr": "AVG(gross_margin_pct)",
          "comment": "Average gross margin percentage"
        },
        {
          "name": "avg_operating_margin",
          "expr": "AVG(operating_margin_pct)",
          "comment": "Average operating margin percentage"
        },
        {
          "name": "total_revenue",
          "expr": "SUM(revenue_usd)",
          "comment": "Total monthly revenue"
        },
        {
          "name": "total_expenses",
          "expr": "SUM(total_expense_usd)",
          "comment": "Total expenses"
        },
        {
          "name": "total_cost_per_headcount",
          "expr": "SUM(cost_per_headcount_usd)",
          "comment": "Total cost per headcount usd"
        },
        {
          "name": "total_budget_utilization_percent",
          "expr": "SUM(budget_utilization_pct)",
          "comment": "Total budget utilization pct"
        },
        {
          "name": "unique_cost_center_count",
          "expr": "COUNT(DISTINCT cost_center_id)",
          "comment": "Number of distinct cost centers"
        },
        {
          "name": "max_gross_margin_percent",
          "expr": "MAX(gross_margin_pct)",
          "comment": "Maximum gross margin pct"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The financial_txn_metrics view (source: financial_transactions) has dimensions: txn_date, cost_center_type, account_category. Measures: total_amount, total_transactions, total_revenue, total_opex. The financial_kpi_metrics view (source: financial_kpi_monthly) has dimensions: kpi_month, cost_center_type. Measures: avg_gross_margin, avg_operating_margin, total_revenue, total_expenses. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. cost_center_id).",
  "sample_questions": [
    "What is the monthly trend in total monthly revenue?",
    "How has total opex count changed over time?",
    "What is the monthly trend in open posting status count?",
    "How has unique total transactionss changed over time?",
    "What is the monthly trend in unique cost centers?",
    "How has highest gross margin percent changed over time?",
    "What is the monthly trend in total monthly revenue?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in open posting status count?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(open_financial_transaction_count) AS open_financial_transaction_count",
        "FROM {fqn}.financial_txn_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ]
    },
    {
      "question": "How has unique total transactionss changed over time?",
      "sql_lines": [
        "SELECT txn_date, MEASURE(total_transactions) AS total_transactions",
        "FROM {fqn}.financial_txn_metrics",
        "GROUP BY ALL",
        "ORDER BY txn_date"
      ]
    },
    {
      "question": "What is the monthly trend in total budget utilization pct?",
