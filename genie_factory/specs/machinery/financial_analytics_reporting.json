          "comment": "Unique transaction identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('FT-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "txn_date",
          "sql_type": "DATE",
          "comment": "Transaction posting date",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "cost_center_id",
          "sql_type": "STRING",
          "comment": "Cost center identifier",
          "is_dimension": true,
          "generation_expr": ""
