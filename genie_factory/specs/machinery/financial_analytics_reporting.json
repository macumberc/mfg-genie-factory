        {
          "name": "cost_center_type",
          "sql_type": "STRING",
          "comment": "Cost center type",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "account_category",
          "sql_type": "STRING",
          "comment": "Account: Revenue, COGS, Opex, Capex, Other",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.25 THEN 'Revenue' WHEN {status_noise} < 0.45 THEN 'COGS' WHEN {status_noise} < 0.72 THEN 'Opex' WHEN {status_noise} < 0.88 THEN 'Capex' ELSE 'Other' END"
        },
        {
          "name": "amount_usd",
          "sql_type": "DOUBLE",
          "comment": "Transaction amount in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(500.0 + ({qty_noise} * 99500.0), 2)"
        },
        {
          "name": "debit_credit",
          "sql_type": "STRING",
          "comment": "Debit or Credit",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.50 THEN 'Debit' ELSE 'Credit' END"
        },
        {
          "name": "fiscal_period",
          "sql_type": "STRING",
          "comment": "Fiscal period",
          "is_dimension": false,
          "generation_expr": "CONCAT('FY26-P', LPAD(CAST(MONTH(dt) AS STRING), 2, '0'))"
        },
        {
          "name": "gl_account",
          "sql_type": "STRING",
          "comment": "GL account code",
          "is_dimension": false,
          "generation_expr": "CONCAT(CAST(4000 + FLOOR({qty_noise} * 4000) AS STRING))"
        },
        {
          "name": "posting_status",
          "sql_type": "STRING",
          "comment": "Status: Posted, Pending, Reversed",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.88 THEN 'Posted' WHEN {status_noise} < 0.96 THEN 'Pending' ELSE 'Reversed' END"
        }
