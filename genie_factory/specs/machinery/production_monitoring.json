          "name": "shift",
          "sql_type": "STRING",
          "comment": "Shift: Day, Swing, Night",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN 'Day' WHEN {status_noise} < 0.72 THEN 'Swing' ELSE 'Night' END",
          "entity_values": [
            "Day",
            "Swing",
            "Night"
          ]
        },
