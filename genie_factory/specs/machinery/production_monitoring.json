          "name": "planned_qty",
          "sql_type": "INT",
          "comment": "Planned production quantity",
          "is_dimension": false,
          "generation_expr": "CAST(500 + FLOOR({qty_noise} * 4500) AS INT)"
        },
        {
          "name": "actual_qty",
          "sql_type": "INT",
          "comment": "Actual good units produced",
          "is_dimension": false,
          "generation_expr": "CAST(400 + FLOOR({qty_noise} * 4100) AS INT)"
        },
        {
          "name": "reject_qty",
          "sql_type": "INT",
          "comment": "Rejected units",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 120) AS INT)"
        },
        {
          "name": "cycle_time_sec",
          "sql_type": "DOUBLE",
          "comment": "Average cycle time per unit in seconds",
          "is_dimension": false,
          "generation_expr": "ROUND(15.0 + ({qty_noise} * 45.0), 1)"
        },
        {
          "name": "downtime_minutes",
          "sql_type": "DOUBLE",
          "comment": "Unplanned downtime in minutes",
          "is_dimension": false,
          "generation_expr": "ROUND({qty_noise} * 120.0, 1)"
        }
