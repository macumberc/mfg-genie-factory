  "metric_views": [
    {
      "view_name": "production_runs_metrics",
      "source_table": "production_runs",
      "dimensions": [
        {
          "name": "run_date",
          "expr": "run_date"
        },
        {
          "name": "line_type",
          "expr": "line_type"
        },
        {
          "name": "shift",
          "expr": "shift"
        }
      ],
      "measures": [
        {
          "name": "total_actual_qty",
          "expr": "SUM(actual_qty)",
          "comment": "Total good units produced"
        },
        {
          "name": "total_reject_qty",
          "expr": "SUM(reject_qty)",
          "comment": "Total rejected units"
        },
        {
          "name": "avg_cycle_time",
          "expr": "AVG(cycle_time_sec)",
          "comment": "Average cycle time in seconds"
        },
        {
          "name": "total_downtime_min",
          "expr": "SUM(downtime_minutes)",
          "comment": "Total unplanned downtime in minutes"
        },
        {
          "name": "unique_line_count",
          "expr": "COUNT(DISTINCT line_id)",
          "comment": "Number of distinct lines"
        },
        {
          "name": "max_planned_qty",
          "expr": "MAX(planned_qty)",
          "comment": "Maximum planned qty"
        },
        {
          "name": "total_planned_qty",
          "expr": "SUM(planned_qty)",
          "comment": "Total planned qty"
        }
      ]
    },
    {
      "view_name": "oee_metrics",
      "source_table": "oee_monthly",
      "dimensions": [
        {
          "name": "oee_month",
          "expr": "oee_month"
        },
        {
          "name": "line_type",
          "expr": "line_type"
        }
      ],
      "measures": [
        {
          "name": "avg_oee",
          "expr": "AVG(oee_pct)",
          "comment": "Average OEE percentage"
        },
        {
          "name": "avg_availability",
          "expr": "AVG(availability_pct)",
          "comment": "Average availability percentage"
        },
        {
          "name": "avg_quality",
          "expr": "AVG(quality_pct)",
          "comment": "Average quality percentage"
        },
        {
          "name": "total_output",
          "expr": "SUM(total_output_units)",
          "comment": "Total output units"
        },
