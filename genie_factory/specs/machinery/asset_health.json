  "genie_instructions": "You are a machinery analytics assistant for IronPulse Manufacturing. Answer questions about industrial asset health monitoring and predictive maintenance using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (asset_id), query the base tables directly.\n- When joining tables, use the shared keys: asset_id (shared across asset_health_monthly, condition_readings, failure_events).\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in unique assets?",
    "How has highest vibration velocity mm s changed over time?",
    "What is the monthly trend in total oil temperature c?",
    "How has average vibration velocity in mm/s changed over time?",
    "What is the monthly trend in unique assets?",
    "How has highest avg health index changed over time?",
    "What is the monthly trend in total maintenance cost in usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in total oil temperature c?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_oil_temperature_c) AS total_oil_temperature_c",
        "FROM {fqn}.condition_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "How has average vibration velocity in mm/s changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(avg_vibration_velocity) AS avg_vibration_velocity",
        "FROM {fqn}.condition_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the monthly trend in total avg health index?",
      "sql_lines": [
        "SELECT summary_month, MEASURE(total_avg_health_index) AS total_avg_health_index",
        "FROM {fqn}.asset_health_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY summary_month"
      ]
    },
    {
      "question": "Rank asset types by total unplanned downtime hours",
      "sql_lines": [
        "SELECT asset_type, MEASURE(total_unplanned_downtime) AS total_unplanned_downtime",
        "FROM {fqn}.asset_health_monthly_metrics",
        "GROUP BY ALL",
        "ORDER BY total_unplanned_downtime DESC"
      ]
    },
    {
      "question": "What is the trend of total bearing temperature in celsius over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(bearing_temperature_c) AS total_bearing_temperature_c",
        "FROM {fqn}.condition_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ]
    },
    {
      "question": "What is the trend of total downtime caused by failure in hours over time?",
      "sql_lines": [
        "SELECT failure_date, SUM(downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.failure_events",
        "GROUP BY failure_date ORDER BY failure_date"
      ]
    },
    {
      "question": "How has the average average health index for the month 0-100 changed over time?",
      "sql_lines": [
        "SELECT summary_month, AVG(avg_health_index) AS avg_avg_health_index",
        "FROM {fqn}.asset_health_monthly",
        "GROUP BY summary_month ORDER BY summary_month"
      ]
    }
  ],
  "sql_snippets": {
    "filters": [
      {
        "sql": "failure_events.severity = 'Critical'",
        "display_name": "critical failures",
        "synonyms": [
          "critical events",
          "critical severity"
        ],
        "instruction": "Use when filtering for the most severe failure events."
      },
      {
        "sql": "failure_events.was_predicted = true",
        "display_name": "predicted failures",
        "synonyms": [
          "ML predicted",
          "anticipated failures"
        ],
        "instruction": "Use when analyzing the effectiveness of predictive maintenance."
      },
      {
        "sql": "failure_events.detection_method = 'Breakdown'",
        "display_name": "breakdown failures",
        "synonyms": [
          "undetected failures",
          "surprise failures"
        ],
        "instruction": "Use when analyzing failures that were not caught by sensors or inspection."
      }
    ],
    "expressions": [
      {
        "alias": "reading_month",
        "sql": "DATE_TRUNC('month', condition_readings.reading_date)",
        "display_name": "reading month",
        "synonyms": [
          "month of reading",
          "monthly"
        ]
      },
      {
        "alias": "vibration_zone",
        "sql": "CASE WHEN condition_readings.vibration_velocity_mm_s < 4.5 THEN 'Good' WHEN condition_readings.vibration_velocity_mm_s < 11.2 THEN 'Alert' ELSE 'Danger' END",
        "display_name": "vibration zone (ISO 10816)",
        "synonyms": [
          "vibration severity",
          "vibration classification"
        ]
      },
      {
        "alias": "health_category",
        "sql": "CASE WHEN condition_readings.health_index >= 80 THEN 'Healthy' WHEN condition_readings.health_index >= 50 THEN 'Watch' ELSE 'Critical' END",
        "display_name": "health category",
        "synonyms": [
          "asset condition",
          "health status"
        ]
      }
    ],
    "measures": [
      {
        "alias": "total_repair_cost",
        "sql": "SUM(failure_events.repair_cost_usd)",
        "display_name": "total repair cost",
        "synonyms": [
          "repair spend",
          "failure cost"
        ]
      },
      {
        "alias": "total_downtime_hours",
        "sql": "SUM(failure_events.downtime_hours)",
        "display_name": "total downtime hours",
        "synonyms": [
          "downtime",
          "hours lost"
        ]
      },
      {
        "alias": "avg_health_index",
        "sql": "AVG(condition_readings.health_index)",
        "display_name": "average health index",
        "synonyms": [
          "health score",
          "asset health"
        ]
      },
      {
        "alias": "avg_availability",
        "sql": "AVG(asset_health_monthly.availability_pct)",
        "display_name": "average availability",
        "synonyms": [
          "uptime",
          "availability rate"
        ]
      }
    ]
  },
