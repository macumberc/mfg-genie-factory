        {
          "name": "failure_mode",
          "sql_type": "STRING",
          "comment": "Root cause failure mode",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.08 THEN 'Bearing Failure' WHEN {status_noise} < 0.16 THEN 'Seal Leak' WHEN {status_noise} < 0.24 THEN 'Impeller Erosion' WHEN {status_noise} < 0.32 THEN 'Shaft Misalignment' WHEN {status_noise} < 0.40 THEN 'Blade Fatigue' WHEN {status_noise} < 0.48 THEN 'Gear Tooth Wear' WHEN {status_noise} < 0.54 THEN 'Lubrication Failure' WHEN {status_noise} < 0.60 THEN 'Overheating' WHEN {status_noise} < 0.66 THEN 'Cavitation Damage' WHEN {status_noise} < 0.72 THEN 'Electrical Fault' WHEN {status_noise} < 0.78 THEN 'Corrosion' WHEN {status_noise} < 0.84 THEN 'Vibration Fatigue' ELSE 'Fouling' END",
          "entity_values": [
            "Bearing Failure",
            "Seal Leak",
            "Impeller Erosion",
            "Shaft Misalignment",
            "Blade Fatigue",
            "Gear Tooth Wear",
            "Lubrication Failure",
            "Overheating",
            "Cavitation Damage",
            "Electrical Fault",
            "Corrosion",
            "Vibration Fatigue",
            "Fouling"
          ]
        },
        {
          "name": "detection_method",
          "sql_type": "STRING",
          "comment": "How the failure was detected: Sensor, Inspection, Breakdown",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.45 THEN 'Sensor' WHEN {status_noise} < 0.75 THEN 'Inspection' ELSE 'Breakdown' END",
          "entity_values": [
            "Sensor",
            "Inspection",
            "Breakdown"
          ]
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Failure severity: Minor, Major, Critical",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.45 THEN 'Minor' WHEN {status_noise} < 0.80 THEN 'Major' ELSE 'Critical' END",
          "entity_values": [
            "Minor",
            "Major",
            "Critical"
          ]
        },
        {
          "name": "downtime_hours",
          "sql_type": "DOUBLE",
          "comment": "Downtime caused by failure in hours",
          "is_dimension": false,
          "generation_expr": "ROUND(1.0 + ({qty_noise} * 71.0), 1)"
        },
        {
          "name": "repair_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Cost to repair the failure in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(500.0 + ({qty_noise} * 49500.0), 2)"
        },
        {
          "name": "was_predicted",
          "sql_type": "BOOLEAN",
          "comment": "Whether the failure was predicted by the ML model",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN true ELSE false END"
        }
