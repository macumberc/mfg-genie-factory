  "genie_instructions": "You are a computer & electronic analytics assistant for VisionTech Electronics. Answer questions about visual defect detection and classification in electronics manufacturing using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (component_model), query the base tables directly.\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in total defects found count?",
    "How has unique total inspectionss changed over time?",
    "What is the monthly trend in highest confidence score?",
    "How has average detection model confidence score changed over time?",
    "What is the monthly trend in highest target pass rate percent?",
    "How has total scrap cost in usd changed over time?",
    "What is the monthly trend in total rework cost in usd?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest confidence score?",
      "sql_lines": [
        "SELECT inspection_date, MEASURE(max_confidence_score) AS max_confidence_score",
        "FROM {fqn}.inspection_events_metrics",
        "GROUP BY ALL",
        "ORDER BY inspection_date"
      ],
      "usage_guidance": "Monthly trend of peak/highest confidence score from the visual inspection model, when users ask about maximum detection confidence over time."
    },
    {
      "question": "How has average detection model confidence score changed over time?",
      "sql_lines": [
        "SELECT inspection_date, MEASURE(avg_confidence_score) AS avg_confidence_score",
        "FROM {fqn}.inspection_events_metrics",
        "GROUP BY ALL",
        "ORDER BY inspection_date"
      ],
      "usage_guidance": "Time-series trend of average AI model confidence score across all inspections, distinguishing average from maximum confidence metrics."
    },
    {
      "question": "What is the monthly trend in total rework cost in usd?",
      "sql_lines": [
        "SELECT kpi_month, MEASURE(total_rework_cost) AS total_rework_cost",
        "FROM {fqn}.detection_kpi_metrics",
        "GROUP BY ALL",
        "ORDER BY kpi_month"
      ],
      "usage_guidance": "Monthly rework cost trend in USD from detection_kpi_metrics, when users ask how rework expenses have changed over time by product line."
    },
    {
      "question": "What is the trend of total time to complete inspection in seconds over time?",
      "sql_lines": [
        "SELECT inspection_date, SUM(inspection_time_sec) AS total_inspection_time_sec",
        "FROM {fqn}.inspection_events",
        "GROUP BY inspection_date ORDER BY inspection_date"
      ],
      "usage_guidance": "Cumulative inspection throughput trend over time in seconds, when users ask about total inspection duration or time spent on inspections daily."
    },
    {
      "question": "What is the trend of total total inspections in snapshot period over time?",
      "sql_lines": [
        "SELECT snapshot_date, SUM(total_inspections) AS total_total_inspections",
        "FROM {fqn}.defect_classification_snapshots",
        "GROUP BY snapshot_date ORDER BY snapshot_date"
      ],
      "usage_guidance": "Trend of total inspections logged in classification snapshots over snapshot periods, for questions about historical inspection volume from snapshot data."
    },
    {
      "question": "How has the average target first-pass yield percentage changed over time?",
      "sql_lines": [
        "SELECT kpi_month, AVG(target_pass_rate_pct) AS avg_target_pass_rate_pct",
        "FROM {fqn}.detection_kpi_monthly",
        "GROUP BY kpi_month ORDER BY kpi_month"
      ],
      "usage_guidance": "Time-series of average target first-pass yield percentage from KPI table, when users ask how pass rate targets have shifted month over month."
    },
    {
      "question": "How does total defects found count vary across product lines?",
      "sql_lines": [
        "SELECT product_line, MEASURE(total_defects_found) AS total_defects_found",
        "FROM {fqn}.inspection_events_metrics",
        "GROUP BY ALL",
        "ORDER BY total_defects_found DESC"
      ],
      "usage_guidance": "Ranked breakdown of total defects found by product line, when users ask which product lines have the highest defect counts or detection volume."
    }
  ],
