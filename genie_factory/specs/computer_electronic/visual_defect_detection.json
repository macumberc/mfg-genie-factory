          "name": "inspection_station",
          "sql_type": "STRING",
          "comment": "Inspection station identifier",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN 'AOI-01' WHEN {status_noise} < 0.40 THEN 'AOI-02' WHEN {status_noise} < 0.60 THEN 'AOI-03' WHEN {status_noise} < 0.80 THEN 'XRAY-01' ELSE 'XRAY-02' END",
          "entity_values": [
            "AOI-01",
            "AOI-02",
            "AOI-03",
            "XRAY-01",
            "XRAY-02"
          ]
        },
        {
          "name": "defect_type",
          "sql_type": "STRING",
          "comment": "Detected defect classification: Solder Bridge, Missing Component, Misalignment, Tombstone, Scratch, Crack, None",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'None' WHEN {status_noise} < 0.65 THEN 'Solder Bridge' WHEN {status_noise} < 0.74 THEN 'Missing Component' WHEN {status_noise} < 0.82 THEN 'Misalignment' WHEN {status_noise} < 0.88 THEN 'Tombstone' WHEN {status_noise} < 0.94 THEN 'Scratch' ELSE 'Crack' END",
          "entity_values": [
            "None",
            "Solder Bridge",
            "Missing Component",
            "Misalignment",
            "Tombstone",
            "Scratch",
            "Crack"
          ]
        },
        {
          "name": "severity",
          "sql_type": "STRING",
          "comment": "Defect severity: Critical, Major, Minor, None",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'None' WHEN {status_noise} < 0.70 THEN 'Minor' WHEN {status_noise} < 0.88 THEN 'Major' ELSE 'Critical' END",
          "entity_values": [
            "None",
            "Minor",
            "Major",
            "Critical"
          ]
        },
        {
          "name": "confidence_score",
          "sql_type": "DOUBLE",
          "comment": "Model detection confidence score 0-1",
          "is_dimension": false,
          "generation_expr": "ROUND(0.70 + ({qty_noise} * 0.30), 4)"
        },
        {
          "name": "inspection_time_sec",
          "sql_type": "DOUBLE",
          "comment": "Time to complete inspection in seconds",
          "is_dimension": false,
          "generation_expr": "ROUND(1.5 + ({qty_noise} * 8.5), 2)"
        },
        {
          "name": "result",
          "sql_type": "STRING",
          "comment": "Inspection result: Pass or Fail",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.55 THEN 'Pass' ELSE 'Fail' END",
          "entity_values": [
            "Pass",
            "Fail"
          ]
        }
      ],
