    {
      "table_name": "parameter_sweeps",
      "description": "Parameter sweep snapshot records showing design space exploration results across voltage, frequency, and configuration variants.",
      "columns": [
        {
          "name": "sweep_id",
          "sql_type": "STRING",
          "comment": "Unique parameter sweep identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('PSW-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "sweep_date",
          "sql_type": "DATE",
          "comment": "Date of the parameter sweep",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "soc_design",
          "sql_type": "STRING",
          "comment": "SoC design identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "design_family",
          "sql_type": "STRING",
          "comment": "Design family category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "voltage_v",
          "sql_type": "DOUBLE",
          "comment": "Supply voltage in volts",
          "is_dimension": false,
          "generation_expr": "ROUND(0.6 + ({qty_noise} * 0.6), 3)"
        },
        {
          "name": "frequency_ghz",
          "sql_type": "DOUBLE",
          "comment": "Target frequency in GHz",
          "is_dimension": false,
          "generation_expr": "ROUND(0.8 + ({qty_noise} * 4.2), 2)"
        },
        {
          "name": "leakage_power_mw",
          "sql_type": "DOUBLE",
          "comment": "Leakage power in milliwatts",
          "is_dimension": false,
          "generation_expr": "ROUND(50.0 + ({qty_noise} * 950.0), 1)"
        },
        {
          "name": "throughput_gops",
          "sql_type": "DOUBLE",
          "comment": "Throughput in giga-operations per second",
          "is_dimension": false,
          "generation_expr": "ROUND(10.0 + ({qty_noise} * 990.0), 1)"
        },
        {
          "name": "thermal_margin_c",
          "sql_type": "DOUBLE",
          "comment": "Thermal margin in degrees Celsius (distance to Tjmax)",
          "is_dimension": false,
          "generation_expr": "ROUND(5.0 + ({qty_noise} * 45.0), 1)"
        },
        {
          "name": "pareto_optimal",
          "sql_type": "BOOLEAN",
          "comment": "Whether this point is on the Pareto frontier",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.20 THEN true ELSE false END"
        },
        {
          "name": "sweep_status",
          "sql_type": "STRING",
          "comment": "Sweep status: Complete, In Progress, Cancelled",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.80 THEN 'Complete' WHEN {status_noise} < 0.95 THEN 'In Progress' ELSE 'Cancelled' END"
        }
      ],
