{
  "company_name": "ChipArchitect Labs",
  "industry": "Computer & Electronic",
  "use_case": "System-on-chip design space simulation and optimization",
  "space_title": "ChipArchitect Labs - SoC Design Space Simulation 🧪",
  "space_description": "SoC design analytics for ChipArchitect Labs. Ask about simulation convergence, parameter sweep results, power-performance tradeoffs, and optimization KPIs across 20 SoC designs.",
  "schema_basename": "ce_design_sim_soc",
  "tables": [
    {
      "table_name": "simulation_runs",
      "description": "Individual SoC simulation run records with performance, power, and area results.",
      "columns": [
        {
          "name": "run_id",
          "sql_type": "STRING",
          "comment": "Unique simulation run identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('SIM-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "run_date",
          "sql_type": "DATE",
          "comment": "Date the simulation was executed",
          "is_dimension": false,
          "generation_expr": "dt"
        },
        {
          "name": "soc_design",
          "sql_type": "STRING",
          "comment": "SoC design identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "design_family",
          "sql_type": "STRING",
          "comment": "Design family category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "process_node",
          "sql_type": "STRING",
          "comment": "Fabrication process node: 3nm, 5nm, 7nm, 14nm",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.30 THEN '3nm' WHEN {status_noise} < 0.60 THEN '5nm' WHEN {status_noise} < 0.85 THEN '7nm' ELSE '14nm' END"
        },
        {
          "name": "clock_freq_ghz",
          "sql_type": "DOUBLE",
          "comment": "Simulated clock frequency in GHz",
          "is_dimension": false,
          "generation_expr": "ROUND(1.0 + ({qty_noise} * 4.0), 2)"
        },
        {
          "name": "power_mw",
          "sql_type": "DOUBLE",
          "comment": "Dynamic power consumption in milliwatts",
          "is_dimension": false,
          "generation_expr": "ROUND(200.0 + ({qty_noise} * 4800.0), 1)"
        },
        {
          "name": "area_mm2",
          "sql_type": "DOUBLE",
          "comment": "Die area in square millimeters",
          "is_dimension": false,
          "generation_expr": "ROUND(10.0 + ({qty_noise} * 190.0), 2)"
        },
        {
          "name": "timing_slack_ns",
          "sql_type": "DOUBLE",
          "comment": "Timing slack in nanoseconds (positive = met, negative = violated)",
          "is_dimension": false,
          "generation_expr": "ROUND(-2.0 + ({qty_noise} * 5.0), 3)"
        },
        {
          "name": "convergence_status",
          "sql_type": "STRING",
          "comment": "Simulation convergence: Converged, Partial, Failed",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.72 THEN 'Converged' WHEN {status_noise} < 0.90 THEN 'Partial' ELSE 'Failed' END"
        }
      ],
      "seasonal_patterns": {
        "Mobile SoC": {
          "1,2,3": 0.06,
          "9,10": 0.055
        },
        "Server SoC": {
          "4,5": 0.05,
          "10,11": 0.06
        },
        "IoT SoC": {
          "3,4": 0.045,
          "7,8": 0.05
        },
        "Automotive SoC": {
          "6,7": 0.055,
          "11,12": 0.06
        }
      },
