    {
      "table_name": "optimization_monthly",
      "description": "Monthly optimization KPIs tracking design convergence rates, PPA improvements, and simulation throughput.",
      "columns": [
        {
          "name": "opt_id",
          "sql_type": "STRING",
          "comment": "Unique optimization record identifier",
          "is_dimension": false,
          "generation_expr": "CONCAT('OPT-', LPAD(CAST({id_seq} AS STRING), 5, '0'))"
        },
        {
          "name": "opt_month",
          "sql_type": "DATE",
          "comment": "Month of the optimization record",
          "is_dimension": false,
          "generation_expr": "DATE_TRUNC('month', dt)"
        },
        {
          "name": "soc_design",
          "sql_type": "STRING",
          "comment": "SoC design identifier",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "design_family",
          "sql_type": "STRING",
          "comment": "Design family category",
          "is_dimension": true,
          "generation_expr": ""
        },
        {
          "name": "convergence_rate_pct",
          "sql_type": "DOUBLE",
          "comment": "Percentage of simulations that converged",
          "is_dimension": false,
          "generation_expr": "ROUND(60.0 + ({qty_noise} * 38.0), 2)"
        },
        {
          "name": "best_power_mw",
          "sql_type": "DOUBLE",
          "comment": "Best achieved dynamic power in milliwatts",
          "is_dimension": false,
          "generation_expr": "ROUND(150.0 + ({qty_noise} * 3850.0), 1)"
        },
        {
          "name": "best_frequency_ghz",
          "sql_type": "DOUBLE",
          "comment": "Best achieved clock frequency in GHz",
          "is_dimension": false,
          "generation_expr": "ROUND(1.5 + ({qty_noise} * 3.5), 2)"
        },
        {
          "name": "pareto_points_found",
          "sql_type": "INT",
          "comment": "Number of Pareto-optimal points discovered",
          "is_dimension": false,
          "generation_expr": "CAST(2 + FLOOR({qty_noise} * 48) AS INT)"
        },
        {
          "name": "total_sim_hours",
          "sql_type": "DOUBLE",
          "comment": "Total simulation compute hours consumed",
          "is_dimension": false,
          "generation_expr": "ROUND(100.0 + ({qty_noise} * 4900.0), 1)"
        },
        {
          "name": "target_met",
          "sql_type": "BOOLEAN",
          "comment": "Whether PPA targets were met this month",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.45 THEN true ELSE false END"
        },
        {
          "name": "ppa_improvement_pct",
          "sql_type": "DOUBLE",
          "comment": "Month-over-month PPA improvement percentage",
          "is_dimension": false,
          "generation_expr": "ROUND(-2.0 + ({qty_noise} * 12.0), 2)"
        }
      ],
