  "metric_views": [
    {
      "view_name": "simulation_runs_metrics",
      "source_table": "simulation_runs",
      "dimensions": [
        {
          "name": "run_date",
          "expr": "run_date"
        },
        {
          "name": "design_family",
          "expr": "design_family"
        },
        {
          "name": "process_node",
          "expr": "process_node"
        },
        {
          "name": "convergence_status",
          "expr": "convergence_status"
        }
      ],
      "measures": [
        {
          "name": "total_simulations",
          "expr": "COUNT(DISTINCT run_id)",
          "comment": "Total number of simulation runs"
        },
        {
          "name": "avg_clock_freq_ghz",
          "expr": "AVG(clock_freq_ghz)",
          "comment": "Average simulated clock frequency in GHz"
        },
        {
          "name": "avg_power_mw",
          "expr": "AVG(power_mw)",
          "comment": "Average dynamic power in milliwatts"
        },
        {
          "name": "converged_count",
          "expr": "COUNT(DISTINCT CASE WHEN convergence_status = 'Converged' THEN run_id END)",
          "comment": "Number of converged simulations"
        },
        {
          "name": "total_area_mm2",
          "expr": "SUM(area_mm2)",
          "comment": "Total area mm2"
        },
        {
          "name": "total_timing_slack_ns",
          "expr": "SUM(timing_slack_ns)",
          "comment": "Total timing slack ns"
        },
        {
          "name": "max_clock_freq_ghz",
          "expr": "MAX(clock_freq_ghz)",
          "comment": "Maximum clock freq ghz"
        }
      ]
    },
    {
      "view_name": "optimization_metrics",
      "source_table": "optimization_monthly",
      "dimensions": [
        {
          "name": "opt_month",
          "expr": "opt_month"
        },
        {
          "name": "design_family",
          "expr": "design_family"
        }
      ],
      "measures": [
        {
          "name": "avg_convergence_rate",
          "expr": "AVG(convergence_rate_pct)",
          "comment": "Average convergence rate percentage"
        },
        {
          "name": "total_pareto_points",
          "expr": "SUM(pareto_points_found)",
          "comment": "Total Pareto-optimal points discovered"
        },
        {
          "name": "total_sim_hours",
          "expr": "SUM(total_sim_hours)",
          "comment": "Total simulation compute hours"
        },
        {
          "name": "avg_ppa_improvement",
          "expr": "AVG(ppa_improvement_pct)",
          "comment": "Average PPA improvement percentage"
        },
        {
          "name": "total_best_power_mw",
          "expr": "SUM(best_power_mw)",
          "comment": "Total best power mw"
        },
        {
          "name": "total_best_frequency_ghz",
          "expr": "SUM(best_frequency_ghz)",
          "comment": "Total best frequency ghz"
        },
        {
          "name": "max_convergence_rate_percent",
          "expr": "MAX(convergence_rate_pct)",
          "comment": "Maximum convergence rate pct"
        }
      ]
    }
  ],
  "genie_instructions": "ALWAYS prefer metric views with MEASURE() syntax for aggregation questions. The simulation_runs_metrics view (source: simulation_runs) has dimensions: run_date, design_family, process_node, convergence_status. Measures: total_simulations, avg_clock_freq_ghz, avg_power_mw, converged_count. The optimization_metrics view (source: optimization_monthly) has dimensions: opt_month, design_family. Measures: avg_convergence_rate, total_pareto_points, total_sim_hours, avg_ppa_improvement. Use GROUP BY ALL with MEASURE() queries. Only query base tables directly when the question requires columns not available as metric view dimensions (e.g. soc_design).",
  "sample_questions": [
