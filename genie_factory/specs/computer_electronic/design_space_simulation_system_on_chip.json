  "genie_instructions": "You are a computer & electronic analytics assistant for ChipArchitect Labs. Answer questions about system-on-chip design space simulation and optimization using the tables and metric views below.\n\n- When a question aggregates a measure (totals, counts, averages, rates), use the metric views with MEASURE() and GROUP BY ALL.\n- When a question needs a base-table column (soc_design), query the base tables directly.\n- When the user's phrasing matches a SQL snippet display name (filters, expressions, or measures), prefer that snippet.",
  "sample_questions": [
    "What is the monthly trend in converged count?",
    "How has unique total simulationss changed over time?",
    "What is the monthly trend in highest clock freq ghz?",
    "How has total area mm2 changed over time?",
    "What is the monthly trend in highest convergence rate percent?",
    "How has total pareto-optimal points discovered changed over time?",
    "What is the monthly trend in total simulation compute hours?"
  ],
  "example_sqls": [
    {
      "question": "What is the monthly trend in highest clock freq ghz?",
      "sql_lines": [
        "SELECT run_date, MEASURE(max_clock_freq_ghz) AS max_clock_freq_ghz",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Monthly trend of peak clock frequency (GHz) across simulation runs, matching phrases like 'highest clock speed over time' using max_clock_freq_ghz from simulation_runs_metrics."
    },
    {
      "question": "How has total area mm2 changed over time?",
      "sql_lines": [
        "SELECT run_date, MEASURE(total_area_mm2) AS total_area_mm2",
        "FROM {fqn}.simulation_runs_metrics",
        "GROUP BY ALL",
        "ORDER BY run_date"
      ],
      "usage_guidance": "Time-series trend of cumulative silicon area (mm²) across simulation runs, matching phrases like 'how area footprint evolved' using total_area_mm2 from simulation_runs_metrics."
    },
    {
      "question": "What is the monthly trend in total simulation compute hours?",
      "sql_lines": [
        "SELECT opt_month, MEASURE(total_sim_hours) AS total_sim_hours",
        "FROM {fqn}.optimization_metrics",
        "GROUP BY ALL",
        "ORDER BY opt_month"
      ],
      "usage_guidance": "Monthly trend of total compute hours consumed by optimization jobs, matching phrases like 'simulation compute cost over time' using total_sim_hours from optimization_metrics."
    },
    {
      "question": "How has total best power mw changed over time?",
      "sql_lines": [
        "SELECT opt_month, MEASURE(total_best_power_mw) AS total_best_power_mw",
        "FROM {fqn}.optimization_metrics",
        "GROUP BY ALL",
        "ORDER BY opt_month"
      ],
      "usage_guidance": "Time-series trend of best-achieved power (mW) from optimization runs, matching phrases like 'lowest power results over time' using total_best_power_mw from optimization_metrics."
    },
    {
      "question": "How does total simulated clock frequency in ghz break down by soc design for 'Converged' records?",
      "sql_lines": [
        "SELECT soc_design, COUNT(*) AS record_count, SUM(clock_freq_ghz) AS total_clock_freq_ghz",
        "FROM {fqn}.simulation_runs",
        "WHERE convergence_status = 'Converged' GROUP BY soc_design ORDER BY total_clock_freq_ghz DESC"
      ],
      "usage_guidance": "Per-SoC-design breakdown of summed clock frequency filtered to Converged status only, matching phrases like 'frequency distribution by design for converged runs' from simulation_runs."
    },
    {
      "question": "What is the trend of total supply voltage in volts over time?",
      "sql_lines": [
        "SELECT sweep_date, SUM(voltage_v) AS total_voltage_v",
        "FROM {fqn}.parameter_sweeps",
        "GROUP BY sweep_date ORDER BY sweep_date"
      ],
      "usage_guidance": "Time-series trend of total supply voltage across parameter sweep experiments, matching phrases like 'voltage levels over sweep dates' using voltage_v from parameter_sweeps."
    },
    {
      "question": "How has the average percentage of simulations that converged changed over time?",
      "sql_lines": [
        "SELECT opt_month, AVG(convergence_rate_pct) AS avg_convergence_rate_pct",
        "FROM {fqn}.optimization_monthly",
        "GROUP BY opt_month ORDER BY opt_month"
      ],
      "usage_guidance": "Monthly trend of average convergence rate percentage across optimization cycles, matching phrases like 'how often simulations converge over time' using convergence_rate_pct from optimization_monthly."
    }
  ],
