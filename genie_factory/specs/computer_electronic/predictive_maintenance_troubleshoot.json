        {
          "name": "maintenance_type",
          "sql_type": "STRING",
          "comment": "Type: Scheduled, Corrective, Predictive",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN 'Scheduled' WHEN {status_noise} < 0.70 THEN 'Corrective' ELSE 'Predictive' END",
          "entity_values": [
            "Scheduled",
            "Corrective",
            "Predictive"
          ]
        },
        {
          "name": "failure_mode",
          "sql_type": "STRING",
          "comment": "Failure mode identified: Belt Wear, Motor Burnout, Nozzle Clog, Thermal Drift, Solder Contamination, Calibration Drift, None",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.40 THEN 'None' WHEN {status_noise} < 0.52 THEN 'Belt Wear' WHEN {status_noise} < 0.62 THEN 'Motor Burnout' WHEN {status_noise} < 0.72 THEN 'Nozzle Clog' WHEN {status_noise} < 0.82 THEN 'Thermal Drift' WHEN {status_noise} < 0.92 THEN 'Solder Contamination' ELSE 'Calibration Drift' END",
          "entity_values": [
            "None",
            "Belt Wear",
            "Motor Burnout",
            "Nozzle Clog",
            "Thermal Drift",
            "Solder Contamination",
            "Calibration Drift"
          ]
        },
        {
          "name": "downtime_hours",
          "sql_type": "DOUBLE",
          "comment": "Total downtime in hours for this event",
          "is_dimension": false,
          "generation_expr": "ROUND(0.5 + ({qty_noise} * 23.5), 1)"
        },
        {
          "name": "repair_cost_usd",
          "sql_type": "DOUBLE",
          "comment": "Cost of maintenance or repair in USD",
          "is_dimension": false,
          "generation_expr": "ROUND(200.0 + ({qty_noise} * 9800.0), 2)"
        },
        {
          "name": "parts_replaced",
          "sql_type": "INT",
          "comment": "Number of parts replaced",
          "is_dimension": false,
          "generation_expr": "CAST(FLOOR({qty_noise} * 8) AS INT)"
        },
        {
          "name": "was_predicted",
          "sql_type": "BOOLEAN",
          "comment": "Whether the failure was predicted by ML model",
          "is_dimension": false,
          "generation_expr": "CASE WHEN {status_noise} < 0.35 THEN true ELSE false END"
        }
      ],
