  "example_sqls": [
    {
      "question": "What is the monthly trend in unique machines?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(unique_machine_count) AS unique_machine_count",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route trend-over-time questions about active machine counts or fleet size across sensor reading dates on assembly lines."
    },
    {
      "question": "How has highest vibration mm s changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(max_vibration_mm_s) AS max_vibration_mm_s",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route peak-vibration trend questions tracking highest vibration mm/s spikes over time to catch mechanical wear escalation."
    },
    {
      "question": "How has total prediction accuracy pct changed over time?",
      "sql_lines": [
        "SELECT health_month, MEASURE(total_prediction_accuracy_percent) AS total_prediction_accuracy_percent",
        "FROM {fqn}.equipment_health_metrics",
        "GROUP BY ALL",
        "ORDER BY health_month"
      ],
      "usage_guidance": "Route time-series questions about predictive model accuracy percentage or how well failure predictions have improved month-over-month."
    },
    {
      "question": "What is the trend of total operating temperature in celsius over time?",
      "sql_lines": [
        "SELECT reading_date, SUM(temperature_c) AS total_temperature_c",
        "FROM {fqn}.sensor_readings",
        "GROUP BY reading_date ORDER BY reading_date"
      ],
      "usage_guidance": "Route cumulative or total operating temperature trend questions across sensor reading dates for thermal load analysis on assembly lines."
    },
    {
      "question": "What is the trend of total total downtime in hours for this event over time?",
      "sql_lines": [
        "SELECT maintenance_date, SUM(downtime_hours) AS total_downtime_hours",
        "FROM {fqn}.maintenance_records",
        "GROUP BY maintenance_date ORDER BY maintenance_date"
      ],
      "usage_guidance": "Route downtime accumulation trend questions tracking total unplanned or maintenance-related downtime hours per maintenance event date."
    },
    {
      "question": "How has the average equipment availability percentage 0-100 changed over time?",
      "sql_lines": [
        "SELECT health_month, AVG(availability_pct) AS avg_availability_pct",
        "FROM {fqn}.equipment_health_monthly",
        "GROUP BY health_month ORDER BY health_month"
      ],
      "usage_guidance": "Route average equipment availability percentage trend questions month-over-month from equipment_health_monthly for uptime performance monitoring."
    },
    {
      "question": "How has total anomaly score changed over time?",
      "sql_lines": [
        "SELECT reading_date, MEASURE(total_anomaly_score) AS total_anomaly_score",
        "FROM {fqn}.sensor_readings_metrics",
        "GROUP BY ALL",
        "ORDER BY reading_date"
      ],
      "usage_guidance": "Route anomaly score trend questions tracking cumulative sensor anomaly signals over time to identify deteriorating equipment health patterns."
    }
